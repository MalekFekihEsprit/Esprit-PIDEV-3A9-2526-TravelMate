# Configuration des APIs pour le système de réservation TravelMate
# Copiez ce fichier vers .env et remplissez vos vraies clés API

# PayPal (mode test/sandbox - gratuit)
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret_here
PAYPAL_SANDBOX=true

# Gmail avec mots de passe d'application (GRATUIT)
# Gmail avec mots de passe d'application (GRATUIT)
GMAIL_EMAIL=marsaoui.hajer2005@gmail.com
GMAIL_APP_PASSWORD=hajer2005

# MyMemory Translation API (GRATUIT)
MYMEMORY_EMAIL=marsaoui.hajer2005@gmail.com

# OpenWeatherMap API (GRATUIT pour les prévisions météo)
OPENWEATHER_API_KEY=5b5ca3a8c69476ef14a06b74d819455f

# WhatsApp Business API (GRATUIT pour commencer)
WHATSAPP_ACCESS_TOKEN=votre_access_token_whatsapp
WHATSAPP_PHONE_NUMBER_ID=votre_phone_number_id_whatsapp
WHATSAPP_API_VERSION=v18.0

# SMS-API.com (alternative gratuite à Twilio)
SMS_API_KEY=votre_cle_api_sms_api_com_ici

# Twilio (optionnel, si vous préférez)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Configuration générale
APP_ENV=dev
APP_SECRET=your_app_secret_here
