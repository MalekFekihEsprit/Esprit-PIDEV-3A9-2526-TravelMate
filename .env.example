# Configuration des APIs pour le système de réservation

# PayPal (mode test/sandbox - gratuit)
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret_here
PAYPAL_SANDBOX=true

# Gmail avec mots de passe d'application (GRATUIT)
GMAIL_EMAIL=votre_email_gmail@gmail.com
GMAIL_APP_PASSWORD=votre_mot_de_passe_application_ici

# SMS-API.com (alternative gratuite à Twilio)
SMS_API_KEY=votre_cle_api_sms_api_com_ici

# Twilio (optionnel, si vous préférez)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Configuration générale
APP_ENV=dev
APP_SECRET=your_app_secret_here
