{% extends 'base_admin.html.twig' %}

{% block title %}Voyages Admin | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-voyages-page {
            display: grid;
            gap: 1rem;
        }

        .admin-voyages-form-card {
            padding: 1.35rem;
            border-radius: 28px;
            border: 1px solid rgba(196, 111, 75, 0.18);
            background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.9));
            box-shadow: var(--admin-shadow-soft);
        }

        .admin-voyages-form-card__header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .admin-voyages-form-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem;
            color: var(--admin-text);
        }

        .admin-voyages-form-card__desc {
            color: var(--admin-text-muted);
            max-width: 60ch;
        }

        .admin-voyages-form {
            display: grid;
            gap: 1rem;
        }

        .admin-voyages-form__grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem 1.2rem;
        }

        .admin-voyages-field {
            display: grid;
            gap: 0.42rem;
        }

        .admin-voyages-field--readonly {
            align-content: end;
        }

        .admin-voyages-label {
            font-size: 0.86rem;
            font-weight: 600;
            color: var(--admin-text-muted);
        }

        .admin-voyages-input,
        .admin-voyages-select {
            width: 100%;
            min-height: 48px;
            padding: 0.82rem 0.95rem;
            border-radius: 14px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.96);
            color: var(--admin-text);
            outline: none;
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
        }

        .admin-voyages-input:focus,
        .admin-voyages-select:focus {
            border-color: rgba(196, 111, 75, 0.32);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.1);
            background: #fff;
        }

        .admin-voyages-input[readonly] {
            background: rgba(244, 235, 223, 0.72);
            color: var(--admin-text-muted);
        }

        .admin-voyages-form__actions {
            display: flex;
            justify-content: flex-end;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .admin-action-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.8rem 1rem;
            border: 1px solid transparent;
            border-radius: 999px;
            cursor: pointer;
            transition: transform var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
        }

        .admin-action-btn:hover {
            transform: translateY(-1px);
        }

        .admin-action-btn.is-submitting,
        .admin-voyages-icon.is-submitting {
            opacity: 0.6;
            pointer-events: none;
            cursor: wait;
            transform: none;
        }

        .admin-action-btn--primary {
            background: var(--admin-primary);
            color: #fff;
        }

        .admin-action-btn--primary:hover {
            background: var(--admin-primary-dark);
        }

        .admin-action-btn--secondary {
            background: var(--admin-secondary);
            color: #fff;
        }

        .admin-action-btn--secondary:hover {
            background: #276b66;
        }

        .admin-action-btn--ghost {
            background: rgba(255, 253, 249, 0.92);
            color: var(--admin-text-muted);
            border-color: var(--admin-border);
        }

        .admin-action-btn--ghost:hover {
            color: var(--admin-primary);
            border-color: rgba(196, 111, 75, 0.28);
            background: rgba(196, 111, 75, 0.06);
        }

        .admin-action-btn--refresh {
            background: rgba(47, 127, 121, 0.1);
            color: var(--admin-secondary);
            border-color: rgba(47, 127, 121, 0.2);
        }

        .admin-action-btn--refresh:hover {
            background: rgba(47, 127, 121, 0.18);
        }

        .admin-voyages-errors {
            display: grid;
            gap: 0.65rem;
            margin-bottom: 1rem;
        }

        .admin-voyages-error {
            padding: 0.85rem 1rem;
            border-radius: 14px;
            background: var(--admin-danger-soft);
            border: 1px solid rgba(191, 91, 91, 0.14);
            color: var(--admin-danger);
            font-size: 0.92rem;
        }

        .admin-voyages-toasts {
            position: fixed;
            top: calc(var(--topbar-height) + 1rem);
            right: 1.25rem;
            z-index: 1200;
            display: grid;
            gap: 0.85rem;
            width: min(360px, calc(100vw - 2rem));
        }

        .admin-voyages-toast {
            position: relative;
            padding: 1rem 3rem 1rem 1.1rem;
            border-radius: 22px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.96);
            box-shadow: var(--admin-shadow);
            animation: admin-voyages-toast-in 240ms ease;
        }

        .admin-voyages-toast--success {
            border-left: 4px solid var(--admin-success);
        }

        .admin-voyages-toast--error,
        .admin-voyages-toast--warning {
            border-left: 4px solid var(--admin-primary);
        }

        .admin-voyages-toast.is-hiding {
            animation: admin-voyages-toast-out 220ms ease forwards;
        }

        .admin-voyages-toast__title {
            display: block;
            margin-bottom: 0.16rem;
            font-size: 0.9rem;
            font-weight: 700;
        }

        .admin-voyages-toast__message {
            color: var(--admin-text-muted);
        }

        .admin-voyages-toast__close {
            position: absolute;
            top: 0.8rem;
            right: 0.8rem;
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 999px;
            background: rgba(31, 26, 23, 0.06);
            color: var(--admin-text-muted);
            cursor: pointer;
        }

        .admin-voyages-toast__close:hover {
            background: rgba(196, 111, 75, 0.12);
            color: var(--admin-primary);
        }

        .admin-voyages-list-card {
            padding: 1rem;
        }

        .admin-voyages-stats-card {
            padding: 1.2rem;
        }

        .admin-voyages-stats-card__header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .admin-voyages-stats-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.35rem;
            color: var(--admin-text);
        }

        .admin-voyages-stats-card__text {
            color: var(--admin-text-muted);
            max-width: 60ch;
        }

        .admin-voyages-stats-layout {
            display: grid;
            grid-template-columns: minmax(260px, 0.85fr) minmax(0, 1.15fr);
            gap: 1.2rem;
            align-items: center;
        }

        .admin-voyages-chart-wrap {
            display: grid;
            place-items: center;
            gap: 0.9rem;
            padding: 1rem;
            border-radius: 24px;
            background: linear-gradient(135deg, rgba(255,253,249,0.92), rgba(244,235,223,0.72));
            border: 1px solid rgba(231, 220, 205, 0.88);
        }

        .admin-voyages-chart {
            position: relative;
            width: min(240px, 100%);
            aspect-ratio: 1;
            border-radius: 50%;
            background: var(--chart-background);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
        }

        .admin-voyages-chart::after {
            content: '';
            position: absolute;
            inset: 18%;
            border-radius: 50%;
            background: rgba(255, 253, 249, 0.94);
            box-shadow: inset 0 0 0 1px rgba(231, 220, 205, 0.8);
        }

        .admin-voyages-chart__center {
            position: absolute;
            inset: 0;
            z-index: 1;
            display: grid;
            place-items: center;
            text-align: center;
            gap: 0.2rem;
            padding: 0 2.25rem;
        }

        .admin-voyages-chart__center strong {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            line-height: 1;
            color: var(--admin-text);
        }

        .admin-voyages-chart__center span {
            color: var(--admin-text-muted);
            font-size: 0.88rem;
        }

        .admin-voyages-stats-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.9rem;
        }

        .admin-voyages-stat-item {
            display: grid;
            gap: 0.5rem;
            padding: 1rem;
            border-radius: 18px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.92);
        }

        .admin-voyages-stat-item__top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
        }

        .admin-voyages-stat-item__label {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            min-width: 0;
            font-weight: 600;
            color: var(--admin-text);
        }

        .admin-voyages-stat-item__dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .admin-voyages-stat-item__percentage {
            font-family: 'Fraunces', serif;
            font-size: 1.25rem;
            color: var(--admin-text);
            white-space: nowrap;
        }

        .admin-voyages-stat-item__meta {
            color: var(--admin-text-muted);
            font-size: 0.9rem;
        }

        .admin-voyages-list-card__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .admin-voyages-list-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem;
        }

        .admin-voyages-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 34px;
            padding: 0 0.75rem;
            border-radius: 999px;
            background: rgba(196, 111, 75, 0.12);
            color: var(--admin-primary);
            font-weight: 700;
        }

        .admin-voyages-table-wrap {
            overflow-x: auto;
            border-radius: 22px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.9);
        }

        .admin-voyages-table {
            width: 100%;
            min-width: 980px;
            border-collapse: collapse;
        }

        .admin-voyages-table th,
        .admin-voyages-table td {
            padding: 0.95rem 0.9rem;
            border-bottom: 1px solid rgba(231, 220, 205, 0.78);
            text-align: left;
            vertical-align: middle;
        }

        .admin-voyages-table th {
            background: rgba(244, 235, 223, 0.72);
            color: var(--admin-text-muted);
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .admin-voyages-table tbody tr:hover {
            background: rgba(196, 111, 75, 0.04);
        }

        .admin-voyages-destination {
            display: grid;
            gap: 0.2rem;
        }

        .admin-voyages-destination small {
            color: var(--admin-text-muted);
        }

        .admin-voyages-actions {
            display: flex;
            gap: 0.55rem;
            align-items: center;
        }

        .admin-voyages-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            border: 1px solid transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform var(--transition-fast), filter var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
        }

        .admin-voyages-icon:hover {
            transform: translateY(-1px);
            filter: brightness(0.98);
        }

        .admin-voyages-icon--edit {
            background: rgba(47, 127, 121, 0.12);
            color: var(--admin-secondary);
            border-color: rgba(47, 127, 121, 0.22);
        }

        .admin-voyages-icon--delete {
            background: rgba(191, 91, 91, 0.12);
            color: var(--admin-danger);
            border-color: rgba(191, 91, 91, 0.18);
        }

        .admin-voyages-icon--participants {
            background: rgba(221, 191, 140, 0.22);
            color: var(--admin-primary-dark);
            border-color: rgba(196, 111, 75, 0.2);
        }

        .admin-voyages-empty {
            padding: 2rem 1rem;
            text-align: center;
            color: var(--admin-text-muted);
        }

        @keyframes admin-voyages-toast-in {
            from {
                opacity: 0;
                transform: translate3d(18px, -12px, 0);
            }
            to {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
        }

        @keyframes admin-voyages-toast-out {
            from {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
            to {
                opacity: 0;
                transform: translate3d(24px, -10px, 0);
            }
        }

        @media (max-width: 980px) {
            .admin-voyages-stats-layout,
            .admin-voyages-form__grid {
                grid-template-columns: 1fr;
            }

            .admin-voyages-stats-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .admin-voyages-form-card__header,
            .admin-voyages-list-card__header,
            .admin-voyages-form__actions {
                flex-direction: column;
                align-items: stretch;
            }

            .admin-voyages-toasts {
                right: 1rem;
                left: 1rem;
                width: auto;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="admin-voyages-page">
        {% set successFlashes = app.flashes('success') %}
        {% set warningFlashes = app.flashes('warning') %}
        {% set errorFlashes = app.flashes('error') %}

        {% if successFlashes is not empty or warningFlashes is not empty or errorFlashes is not empty %}
            <div class="admin-voyages-toasts" aria-live="polite" aria-atomic="true">
                {% for message in successFlashes %}
                    <div class="admin-voyages-toast admin-voyages-toast--success" data-admin-voyages-toast>
                        <strong class="admin-voyages-toast__title">Operation reussie</strong>
                        <div class="admin-voyages-toast__message">{{ message }}</div>
                        <button type="button" class="admin-voyages-toast__close" data-admin-voyages-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
                {% for message in warningFlashes %}
                    <div class="admin-voyages-toast admin-voyages-toast--warning" data-admin-voyages-toast>
                        <strong class="admin-voyages-toast__title">Attention</strong>
                        <div class="admin-voyages-toast__message">{{ message }}</div>
                        <button type="button" class="admin-voyages-toast__close" data-admin-voyages-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
                {% for message in errorFlashes %}
                    <div class="admin-voyages-toast admin-voyages-toast--error" data-admin-voyages-toast>
                        <strong class="admin-voyages-toast__title">Action impossible</strong>
                        <div class="admin-voyages-toast__message">{{ message }}</div>
                        <button type="button" class="admin-voyages-toast__close" data-admin-voyages-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <section class="admin-card admin-voyages-stats-card">
            <div class="admin-voyages-stats-card__header">
                <div>
                    <span class="admin-card__eyebrow">Statistiques</span>
                    <h2 class="admin-voyages-stats-card__title">Repartition des statuts</h2>
                    <p class="admin-voyages-stats-card__text">
                        Visualisez la part de chaque statut sur les voyages actuellement affiches{% if app.request.query.get('search') %}, filtres par la recherche "{{ app.request.query.get('search') }}"{% endif %}.
                    </p>
                </div>
                <span class="admin-voyages-count">{{ status_stats.total }}</span>
            </div>

            <div class="admin-voyages-stats-layout">
                <div class="admin-voyages-chart-wrap">
                    <div class="admin-voyages-chart" style="--chart-background: {{ status_stats.chart_background }};">
                        <div class="admin-voyages-chart__center">
                            <strong>{{ status_stats.total }}</strong>
                            <span>voyage{% if status_stats.total > 1 %}s{% endif %}</span>
                        </div>
                    </div>
                </div>

                <div class="admin-voyages-stats-grid">
                    {% if status_stats.items is not empty %}
                        {% for item in status_stats.items %}
                            <article class="admin-voyages-stat-item">
                                <div class="admin-voyages-stat-item__top">
                                    <span class="admin-voyages-stat-item__label">
                                        <span class="admin-voyages-stat-item__dot" style="background: {{ item.color }};"></span>
                                        <span>{{ item.label }}</span>
                                    </span>
                                    <span class="admin-voyages-stat-item__percentage">{{ item.percentage|number_format(1, ',', ' ') }}%</span>
                                </div>
                                <div class="admin-voyages-stat-item__meta">{{ item.count }} voyage{% if item.count > 1 %}s{% endif %}</div>
                            </article>
                        {% endfor %}
                    {% else %}
                        <div class="admin-voyages-empty">Aucune statistique disponible pour le moment.</div>
                    {% endif %}
                </div>
            </div>
        </section>

        <section class="admin-voyages-form-card">
            <div class="admin-voyages-form-card__header">
                <div>
                    <h2 class="admin-voyages-form-card__title">{{ editing_voyage ? 'Modifier le voyage' : 'Ajouter un voyage' }}</h2>
                    <p class="admin-voyages-form-card__desc">
                        {{ editing_voyage ? 'Mettez a jour les informations du voyage selectionne.' : 'Renseignez les details principaux puis ajoutez le voyage dans la base.' }}
                    </p>
                </div>
                {% if editing_voyage %}
                    <span class="status-pill status-pill--warning">Edition #{{ editing_voyage.idVoyage }}</span>
                {% else %}
                    <span class="status-pill status-pill--success">Nouveau voyage</span>
                {% endif %}
            </div>

            {% if form_errors is not empty %}
                <div class="admin-voyages-errors">
                    {% for error in form_errors %}
                        <div class="admin-voyages-error">{{ error }}</div>
                    {% endfor %}
                </div>
            {% endif %}

            <form
                method="post"
                action="{{ editing_voyage ? path('app_admin_voyages_update', {'id_voyage': editing_voyage.idVoyage}) : path('app_admin_voyages_create') }}"
                class="admin-voyages-form"
            >
                <input type="hidden" name="_token" value="{{ editing_voyage ? csrf_token('admin_voyage_update_' ~ editing_voyage.idVoyage) : csrf_token('admin_voyage_create') }}">
                <input type="hidden" name="_submission_nonce" value="{{ form_nonce }}">
                <input type="hidden" name="current_search" value="{{ app.request.query.get('search', '') }}">

                <div class="admin-voyages-form__grid">
                    <div class="admin-voyages-field">
                        <label class="admin-voyages-label" for="admin-voyage-title">Titre</label>
                        <input id="admin-voyage-title" class="admin-voyages-input" type="text" name="titre_voyage" value="{{ voyage_form.titreVoyage ?? '' }}" placeholder="Titre du voyage" required>
                    </div>

                    <div class="admin-voyages-field">
                        <label class="admin-voyages-label" for="admin-voyage-status">Statut</label>
                        <select id="admin-voyage-status" class="admin-voyages-select" name="statut" required>
                            <option value="">Choisir un statut</option>
                            {% for status in status_options %}
                                <option value="{{ status }}" {{ voyage_form.statut == status ? 'selected' : '' }}>{{ status }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="admin-voyages-field">
                        <label class="admin-voyages-label" for="admin-voyage-start">Debut</label>
                        <input id="admin-voyage-start" class="admin-voyages-input" type="date" name="date_debut" value="{{ voyage_form.dateDebut ? voyage_form.dateDebut|date('Y-m-d') : '' }}" required>
                    </div>

                    <div class="admin-voyages-field">
                        <label class="admin-voyages-label" for="admin-voyage-end">Fin</label>
                        <input id="admin-voyage-end" class="admin-voyages-input" type="date" name="date_fin" value="{{ voyage_form.dateFin ? voyage_form.dateFin|date('Y-m-d') : '' }}" required>
                    </div>

                    <div class="admin-voyages-field admin-voyages-field--readonly">
                        <label class="admin-voyages-label" for="admin-voyage-destination-id">ID destination</label>
                        <input id="admin-voyage-destination-id" class="admin-voyages-input" type="text" value="{{ voyage_form.destination ? voyage_form.destination.idDestination : '' }}" readonly>
                    </div>

                    <div class="admin-voyages-field">
                        <label class="admin-voyages-label" for="admin-voyage-destination">Destination</label>
                        <select id="admin-voyage-destination" class="admin-voyages-select" name="destination_id" required>
                            <option value="">Choisir une destination</option>
                            {% for destination in destinations %}
                                <option
                                    value="{{ destination.idDestination }}"
                                    data-destination-id="{{ destination.idDestination }}"
                                    {{ voyage_form.destination and voyage_form.destination.idDestination == destination.idDestination ? 'selected' : '' }}
                                >
                                    {{ destination.nomDestination }}{% if destination.paysDestination %} - {{ destination.paysDestination }}{% endif %}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="admin-voyages-form__actions">
                    <button type="submit" class="admin-action-btn {{ editing_voyage ? 'admin-action-btn--secondary' : 'admin-action-btn--primary' }}" data-admin-primary-submit>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            {% if editing_voyage %}
                                <path d="M4 20H8L18.5 9.5C19.3284 8.67157 19.3284 7.32843 18.5 6.5C17.6716 5.67157 16.3284 5.67157 15.5 6.5L5 17V20Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M13.5 8.5L16.5 11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            {% else %}
                                <path d="M12 5V19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <path d="M5 12H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            {% endif %}
                        </svg>
                        <span>{{ editing_voyage ? 'Mettre a jour' : 'Ajouter' }}</span>
                    </button>

                    {% if editing_voyage %}
                        <a href="{{ path('app_admin_voyages') }}" class="admin-action-btn admin-action-btn--ghost">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span>Annuler</span>
                        </a>
                    {% endif %}

                    <a href="{{ path('app_admin_voyages') }}" class="admin-action-btn admin-action-btn--refresh">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M20 11C20 15.4183 16.4183 19 12 19C8.99795 19 6.38267 17.3445 5 14.9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            <path d="M4 13V18H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M4 13C4 8.58172 7.58172 5 12 5C15.002 5 17.6173 6.6555 19 9.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            <path d="M20 11V6H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>Refresh</span>
                    </a>
                </div>
            </form>
        </section>

        <section class="admin-card admin-voyages-list-card">
            <div class="admin-voyages-list-card__header">
                <div>
                    <span class="admin-card__eyebrow">Liste</span>
                    <h2 class="admin-voyages-list-card__title">Liste des voyages</h2>
                </div>
                <span class="admin-voyages-count">{{ voyages|length }}</span>
            </div>

            <div class="admin-voyages-table-wrap">
                {% if voyages is not empty %}
                    <table class="admin-voyages-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Titre</th>
                                <th>Debut</th>
                                <th>Fin</th>
                                <th>Statut</th>
                                <th>ID Dest</th>
                                <th>Destination</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for voyage in voyages %}
                                <tr>
                                    <td>{{ voyage.idVoyage }}</td>
                                    <td>{{ voyage.titreVoyage }}</td>
                                    <td>{{ voyage.dateDebut ? voyage.dateDebut|date('Y-m-d') : '-' }}</td>
                                    <td>{{ voyage.dateFin ? voyage.dateFin|date('Y-m-d') : '-' }}</td>
                                    <td>{{ voyage.statut }}</td>
                                    <td>{{ voyage.destination ? voyage.destination.idDestination : '-' }}</td>
                                    <td>
                                        <div class="admin-voyages-destination">
                                            <span>{{ voyage.destination ? voyage.destination.nomDestination : 'Non definie' }}</span>
                                            {% if voyage.destination and voyage.destination.paysDestination %}
                                                <small>{{ voyage.destination.paysDestination }}</small>
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="admin-voyages-actions">
                                            <a href="{{ path('app_admin_participations', {'id_voyage': voyage.idVoyage}) }}" class="admin-voyages-icon admin-voyages-icon--participants" title="Participations" aria-label="Gerer les participations du voyage {{ voyage.titreVoyage }}">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                    <path d="M16 21V19.5C16 18.1193 14.8807 17 13.5 17H7.5C6.11929 17 5 18.1193 5 19.5V21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                                    <path d="M10.5 13C12.433 13 14 11.433 14 9.5C14 7.567 12.433 6 10.5 6C8.567 6 7 7.567 7 9.5C7 11.433 8.567 13 10.5 13Z" stroke="currentColor" stroke-width="1.8"/>
                                                    <path d="M18 8.5C19.1046 8.5 20 9.39543 20 10.5C20 11.6046 19.1046 12.5 18 12.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                    <path d="M18.5 17C19.8807 17 21 18.1193 21 19.5V21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                </svg>
                                            </a>

                                            <a href="{{ path('app_admin_voyages', {'edit': voyage.idVoyage}) }}" class="admin-voyages-icon admin-voyages-icon--edit" title="Modifier" aria-label="Modifier le voyage {{ voyage.titreVoyage }}">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                    <path d="M4 20H8L18.5 9.5C19.3284 8.67157 19.3284 7.32843 18.5 6.5C17.6716 5.67157 16.3284 5.67157 15.5 6.5L5 17V20Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                                    <path d="M13.5 8.5L16.5 11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </a>

                                            <form method="post" action="{{ path('app_admin_voyages_delete', {'id_voyage': voyage.idVoyage}) }}" onsubmit="return confirm('Supprimer ce voyage ?');" data-admin-delete-form>
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_voyage_delete_' ~ voyage.idVoyage) }}">
                                                <input type="hidden" name="_submission_nonce" value="{{ delete_nonces[voyage.idVoyage] ?? '' }}">
                                                <input type="hidden" name="current_search" value="{{ app.request.query.get('search', '') }}">
                                                <button type="submit" class="admin-voyages-icon admin-voyages-icon--delete" title="Supprimer" aria-label="Supprimer le voyage {{ voyage.titreVoyage }}" data-admin-delete-submit>
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                        <path d="M4 7H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M9 7V5.5C9 4.67157 9.67157 4 10.5 4H13.5C14.3284 4 15 4.67157 15 5.5V7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M7 7L7.8 18.2C7.87717 19.2804 8.77596 20.1191 9.85909 20.1191H14.1409C15.224 20.1191 16.1228 19.2804 16.2 18.2L17 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M10 11V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M14 11V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="admin-voyages-empty">Aucun voyage n'est encore disponible.</div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var destinationSelect = document.getElementById('admin-voyage-destination');
            var destinationIdField = document.getElementById('admin-voyage-destination-id');
            var toasts = document.querySelectorAll('[data-admin-voyages-toast]');
            var mainForm = document.querySelector('.admin-voyages-form');
            var deleteForms = document.querySelectorAll('[data-admin-delete-form]');

            function syncDestinationId() {
                if (!destinationSelect || !destinationIdField) {
                    return;
                }

                var selectedOption = destinationSelect.options[destinationSelect.selectedIndex];
                destinationIdField.value = selectedOption ? (selectedOption.getAttribute('data-destination-id') || '') : '';
            }

            function hideToast(toast) {
                if (!toast || toast.classList.contains('is-hiding')) {
                    return;
                }

                toast.classList.add('is-hiding');
                window.setTimeout(function () {
                    toast.remove();
                }, 220);
            }

            if (destinationSelect) {
                destinationSelect.addEventListener('change', syncDestinationId);
                syncDestinationId();
            }

            toasts.forEach(function (toast) {
                var closeButton = toast.querySelector('[data-admin-voyages-toast-close]');

                if (closeButton) {
                    closeButton.addEventListener('click', function () {
                        hideToast(toast);
                    });
                }

                window.setTimeout(function () {
                    hideToast(toast);
                }, 4200);
            });

            if (mainForm) {
                mainForm.addEventListener('submit', function (event) {
                    var submitButton = mainForm.querySelector('[data-admin-primary-submit]');

                    if (mainForm.dataset.submitting === 'true') {
                        event.preventDefault();
                        return;
                    }

                    mainForm.dataset.submitting = 'true';

                    if (submitButton) {
                        submitButton.disabled = true;
                        submitButton.classList.add('is-submitting');
                    }
                });
            }

            deleteForms.forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    var submitButton = form.querySelector('[data-admin-delete-submit]');

                    if (form.dataset.submitting === 'true') {
                        event.preventDefault();
                        return;
                    }

                    form.dataset.submitting = 'true';

                    if (submitButton) {
                        submitButton.disabled = true;
                        submitButton.classList.add('is-submitting');
                    }
                });
            });
        });
    </script>
{% endblock %}