{% extends 'base_admin.html.twig' %}

{% block title %}Modifier {{ categorie.nom }} | Administration TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-form-card {
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
            border-radius: var(--radius-xl);
            padding: 2rem 2.25rem;
            max-width: 680px;
        }
        .admin-form-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--admin-text);
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--admin-border);
        }

        .form-group { margin-bottom: 1.25rem; }
        .form-group label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--admin-text-muted);
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-bottom: 0.45rem;
        }
        .form-group input[type="text"],
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 0.7rem 0.95rem;
            border: 1px solid var(--admin-border);
            border-radius: var(--radius-md);
            background: var(--admin-bg-soft);
            font-size: 0.9rem;
            color: var(--admin-text);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
            outline: none;
        }
        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            border-color: var(--admin-primary);
            box-shadow: 0 0 0 3px rgba(196,111,75,.12);
            background: var(--admin-surface);
        }
        .form-group textarea { min-height: 100px; resize: vertical; }

        .admin-form-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 1.75rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--admin-border);
        }

        .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65rem 1.4rem; border-radius: var(--radius-md); font-size: 0.88rem; font-weight: 600; cursor: pointer; border: 1px solid transparent; transition: background var(--transition-fast); }
        .btn--primary { background: var(--admin-primary); color: #fff; }
        .btn--primary:hover { background: var(--admin-primary-dark); }
        .btn--ghost { background: transparent; border-color: var(--admin-border); color: var(--admin-text-muted); }
        .btn--ghost:hover { background: var(--admin-surface-alt); }
        .btn--danger { background: var(--admin-danger-soft); color: var(--admin-danger); border-color: rgba(191,91,91,.2); }
        .btn--danger:hover { background: rgba(191,91,91,.18); }

        .admin-danger-zone {
            margin-top: 2rem;
            background: var(--admin-danger-soft);
            border: 1px solid rgba(191,91,91,.2);
            border-radius: var(--radius-lg);
            padding: 1.25rem 1.5rem;
            max-width: 680px;
        }
        .admin-danger-zone__title {
            font-size: 0.82rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--admin-danger);
            margin-bottom: 0.35rem;
        }
        .admin-danger-zone__desc {
            font-size: 0.85rem;
            color: var(--admin-text-muted);
            margin-bottom: 0.9rem;
        }
    </style>
{% endblock %}

{% block body %}
<section class="admin-page-header">
    <div>
        <span class="admin-page-header__eyebrow">Catégories</span>
        <h1 class="admin-page-header__title">Modifier « {{ categorie.nom }} »</h1>
        <p class="admin-page-header__desc">Mettez à jour les informations de cette catégorie.</p>
    </div>
    <div class="admin-page-header__actions">
        <a href="{{ path('app_categorie_index') }}" class="btn btn--ghost">← Retour à la liste</a>
    </div>
</section>

<div class="admin-form-card">
    <p class="admin-form-card__title"> Modifier la catégorie</p>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="form-group">
            {{ form_label(form.nom) }}
            {{ form_widget(form.nom) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="form-group">
                {{ form_label(form.type) }}
                {{ form_widget(form.type) }}
                {{ form_errors(form.type) }}
            </div>
            <div class="form-group">
                {{ form_label(form.saison) }}
                {{ form_widget(form.saison) }}
                {{ form_errors(form.saison) }}
            </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="form-group">
                {{ form_label(form.niveauintensite) }}
                {{ form_widget(form.niveauintensite) }}
                {{ form_errors(form.niveauintensite) }}
            </div>
            <div class="form-group">
                {{ form_label(form.publiccible) }}
                {{ form_widget(form.publiccible) }}
                {{ form_errors(form.publiccible) }}
            </div>
        </div>

        <div class="admin-form-actions">
            <button type="submit" class="btn btn--primary">Enregistrer</button>
            <a href="{{ path('app_categorie_index') }}" class="btn btn--ghost">Annuler</a>
        </div>

    {{ form_end(form) }}
</div>

{# Zone de suppression #}
<div class="admin-danger-zone">
    <p class="admin-danger-zone__title">⚠️ Zone dangereuse</p>
    <p class="admin-danger-zone__desc">
        La suppression de cette catégorie est irréversible. Les activités liées pourraient être affectées.
    </p>
    <form method="post"
          action="{{ path('app_categorie_delete', {'id': categorie.id}) }}"
          onsubmit="return confirm('Supprimer définitivement « {{ categorie.nom }} » ?');"
          style="margin:0;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ categorie.id) }}">
        <button type="submit" class="btn btn--danger">🗑 Supprimer cette catégorie</button>
    </form>
</div>
{% endblock %}
