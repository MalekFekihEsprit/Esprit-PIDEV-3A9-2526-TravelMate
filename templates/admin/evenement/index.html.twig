{% extends 'base_admin.html.twig' %}

{% block title %}Gestion des Événements — Admin TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-header {
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;
        }
        .page-header__title { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 600; color: var(--admin-text); }
        .page-header__sub { font-size: 0.88rem; color: var(--admin-text-muted); margin-top: 0.2rem; }

        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { background: var(--admin-surface); border: 1px solid var(--admin-border); border-radius: var(--radius-lg); padding: 1.25rem; text-align: center; }
        .stat-card__num { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700; color: var(--admin-secondary); line-height: 1; }
        .stat-card__label { font-size: 0.8rem; color: var(--admin-text-muted); margin-top: 0.35rem; text-transform: uppercase; letter-spacing: 0.05em; }

        .admin-card { background: var(--admin-surface); border: 1px solid var(--admin-border); border-radius: var(--radius-xl); overflow: hidden; }
        .admin-card__header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--admin-border); display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
        .admin-card__title { font-weight: 600; font-size: 1rem; color: var(--admin-text); }

        .search-wrap { position: relative; min-width: 220px; }
        .search-wrap__icon { position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); color: var(--admin-text-muted); pointer-events: none; }
        .search-input { width: 100%; padding: 0.65rem 1rem 0.65rem 2.5rem; border: 1px solid var(--admin-border); border-radius: 999px; background: var(--admin-bg); font: inherit; font-size: 0.88rem; color: var(--admin-text); outline: none; transition: border-color var(--transition-fast); }
        .search-input:focus { border-color: var(--admin-secondary); }

        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th { text-align: left; padding: 0 1.5rem 0.85rem; border-bottom: 1px solid var(--admin-border); color: var(--admin-text-muted); font-size: 0.73rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; }
        .admin-table td { padding: 1rem 1.5rem; border-bottom: 1px solid rgba(231,220,205,0.6); font-size: 0.92rem; vertical-align: middle; }
        .admin-table tr:last-child td { border-bottom: none; }
        .admin-table tr:hover td { background: rgba(47,127,121,0.03); }

        .ev-date { display: flex; flex-direction: column; }
        .ev-date__day { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 700; color: var(--admin-secondary); line-height: 1; }
        .ev-date__month { font-size: 0.75rem; text-transform: uppercase; color: var(--admin-text-muted); letter-spacing: 0.05em; }

        .pill { display: inline-flex; align-items: center; padding: 0.25rem 0.65rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
        .pill--ok     { background: var(--admin-success-soft); color: var(--admin-success); }
        .pill--few    { background: var(--admin-warning-soft); color: var(--admin-warning); }
        .pill--full   { background: var(--admin-danger-soft);  color: var(--admin-danger); }

        .progress-mini { width: 80px; height: 5px; background: var(--admin-border); border-radius: 999px; overflow: hidden; }
        .progress-mini__fill { height: 100%; border-radius: 999px; background: var(--admin-secondary); }

        .actions-cell { display: flex; align-items: center; gap: 0.5rem; }
        .btn-icon { width: 34px; height: 34px; border-radius: var(--radius-sm); border: 1px solid var(--admin-border); background: var(--admin-surface); display: inline-flex; align-items: center; justify-content: center; color: var(--admin-text-muted); transition: all var(--transition-fast); cursor: pointer; text-decoration: none; }
        .btn-icon:hover { background: var(--admin-bg); color: var(--admin-primary); border-color: var(--admin-primary); }
        .btn-icon--danger:hover { color: var(--admin-danger); border-color: var(--admin-danger); background: var(--admin-danger-soft); }

        .flash-success { background: var(--admin-success-soft); border: 1px solid rgba(60,139,114,0.25); color: var(--admin-success); border-radius: var(--radius-md); padding: 0.85rem 1.25rem; margin-bottom: 1.25rem; font-size: 0.9rem; }
    </style>
{% endblock %}

{% block body %}

{% for msg in app.flashes('success') %}
    <div class="flash-success">✅ {{ msg }}</div>
{% endfor %}

<div class="page-header">
    <div>
        <div class="page-header__title">📅 Gestion des Événements</div>
        <div class="page-header__sub">Planifiez et gérez les événements collaboratifs de la plateforme</div>
    </div>
    <a href="{{ path('app_evenement_new') }}" class="btn btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Nouvel événement
    </a>
</div>

{% set nbComplet = evenements|filter(e => e.isComplet)|length %}
{% set nbDispo   = evenements|length - nbComplet %}
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-card__num">{{ evenements|length }}</div>
        <div class="stat-card__label">Total</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__num" style="color:var(--admin-success)">{{ nbDispo }}</div>
        <div class="stat-card__label">Places dispo</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__num" style="color:var(--admin-danger)">{{ nbComplet }}</div>
        <div class="stat-card__label">Complets</div>
    </div>
    <div class="stat-card">
        {% set totalPart = 0 %}{% for e in evenements %}{% set totalPart = totalPart + e.participations|length %}{% endfor %}
        <div class="stat-card__num">{{ totalPart }}</div>
        <div class="stat-card__label">Participants</div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card__header">
        <div class="admin-card__title">Liste des événements</div>
        <div class="search-wrap">
            <span class="search-wrap__icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </span>
            <input type="search" class="search-input" id="searchAdmin" placeholder="Rechercher…">
        </div>
    </div>

    <div style="overflow-x:auto">
        <table class="admin-table" id="adminTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Titre</th>
                    <th>Lieu</th>
                    <th>Heure</th>
                    <th>Places</th>
                    <th>Participants</th>
                    <th>Groupe</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if evenements is empty %}
                    <tr><td colspan="9">
                        <div style="padding:3rem;text-align:center;color:var(--admin-text-muted)">
                            <div style="font-size:3rem;margin-bottom:.75rem">📅</div>
                            <div style="font-weight:600;color:var(--admin-text);margin-bottom:.3rem">Aucun événement</div>
                            <p>Créez votre premier événement collaboratif.</p>
                        </div>
                    </td></tr>
                {% else %}
                    {% for ev in evenements %}
                        {% set nbPart = ev.participations|length %}
                        {% set pct = ev.nbPlaces > 0 ? ((nbPart / ev.nbPlaces) * 100)|round : 0 %}
                        <tr data-search="{{ ev.titre|lower }} {{ ev.lieu|lower }}">
                            <td style="color:var(--admin-text-muted);font-size:0.8rem">{{ ev.id }}</td>
                            <td>
                                <div class="ev-date">
                                    <span class="ev-date__day">{{ ev.date|date('d') }}</span>
                                    <span class="ev-date__month">{{ ev.date|date('M Y') }}</span>
                                </div>
                            </td>
                            <td><strong>{{ ev.titre }}</strong></td>
                            <td style="color:var(--admin-text-muted)">📍 {{ ev.lieu|slice(0,30) }}{{ ev.lieu|length > 30 ? '…' : '' }}</td>
                            <td>{{ ev.heure|date('H:i') }}</td>
                            <td>
                                <span class="pill {{ ev.isComplet ? 'pill--full' : (ev.placesRestantes <= 5 ? 'pill--few' : 'pill--ok') }}">
                                    {{ ev.placesRestantes }}/{{ ev.nbPlaces }}
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:.5rem">
                                    <div class="progress-mini">
                                        <div class="progress-mini__fill" style="width:{{ pct }}%"></div>
                                    </div>
                                    <span style="font-size:0.82rem;color:var(--admin-text-muted)">{{ nbPart }}</span>
                                </div>
                            </td>
                            <td>
                                {% if ev.lienGroupe %}
                                    <a href="{{ ev.lienGroupe }}" target="_blank" style="color:var(--admin-secondary);font-size:0.82rem">
                                        🔗 Lien
                                    </a>
                                {% else %}
                                    <span style="color:var(--admin-text-muted);font-size:0.82rem">—</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="actions-cell">
                                    <a href="{{ path('app_evenement_show', {id: ev.id}) }}" class="btn-icon" title="Voir" target="_blank">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/></svg>
                                    </a>
                                    <a href="{{ path('app_evenement_edit', {id: ev.id}) }}" class="btn-icon" title="Modifier">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                                    </a>
                                    <form method="post" action="{{ path('app_evenement_delete', {id: ev.id}) }}"
                                          onsubmit="return confirm('Supprimer « {{ ev.titre }} » ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ev.id) }}">
                                        <button type="submit" class="btn-icon btn-icon--danger" title="Supprimer">
                                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><polyline points="3 6 5 6 21 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M10 11v6M14 11v6M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.getElementById('searchAdmin').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#adminTable tbody tr[data-search]').forEach(row => {
            row.style.display = row.dataset.search.includes(q) ? '' : 'none';
        });
    });
</script>
{% endblock %}
