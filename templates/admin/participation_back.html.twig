{% extends 'base_admin.html.twig' %}

{% block title %}Participations Admin | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-participations-page {
            display: grid;
            gap: 1rem;
        }

        .admin-participations-card {
            padding: 1.2rem;
        }

        .admin-participations-card--highlight {
            border: 1px solid rgba(196, 111, 75, 0.18);
            background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.9));
        }

        .admin-participations-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .admin-participations-header__title {
            font-family: 'Fraunces', serif;
            font-size: 1.45rem;
            color: var(--admin-text);
        }

        .admin-participations-header__text {
            color: var(--admin-text-muted);
            max-width: 64ch;
        }

        .admin-participations-grid,
        .admin-participations-filters {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem 1.1rem;
        }

        .admin-participations-toolbar {
            display: grid;
            grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.6fr) auto;
            gap: 1rem;
            align-items: end;
        }

        .admin-participations-search-wrap {
            position: relative;
        }

        .admin-participations-search-icon {
            position: absolute;
            top: 50%;
            left: 1rem;
            transform: translateY(-50%);
            color: var(--admin-text-muted);
            pointer-events: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 20px;
            height: 20px;
            line-height: 0;
        }

        .admin-participations-input.admin-participations-search-input {
            padding-left: 3.25rem;
            border-radius: 999px;
            appearance: none;
            -webkit-appearance: none;
        }

        .admin-participations-search-input::-webkit-search-decoration,
        .admin-participations-search-input::-webkit-search-cancel-button,
        .admin-participations-search-input::-webkit-search-results-button,
        .admin-participations-search-input::-webkit-search-results-decoration {
            -webkit-appearance: none;
            appearance: none;
            display: none;
        }

        .admin-participations-field {
            display: grid;
            gap: 0.42rem;
        }

        .admin-participations-label {
            font-size: 0.86rem;
            font-weight: 600;
            color: var(--admin-text-muted);
        }

        .admin-participations-input,
        .admin-participations-select {
            width: 100%;
            min-height: 48px;
            padding: 0.82rem 0.95rem;
            border-radius: 14px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.96);
            color: var(--admin-text);
            outline: none;
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
        }

        .admin-participations-input:focus,
        .admin-participations-select:focus {
            border-color: rgba(196, 111, 75, 0.32);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.1);
            background: #fff;
        }

        .admin-participations-actions,
        .admin-participations-filter-actions,
        .admin-participations-row-actions {
            display: flex;
            gap: 0.75rem;
            align-items: center;
            flex-wrap: nowrap;
        }

        .admin-participations-role-cell {
            display: block;
        }

        .admin-participations-role-cell .admin-participations-select {
            min-width: 180px;
            width: 100%;
        }

        .admin-participations-update-form {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .admin-participations-delete-form {
            margin: 0;
        }

        .admin-participations-actions {
            justify-content: flex-end;
            margin-top: 1rem;
        }

        .admin-participations-inline {
            display: flex;
            align-items: end;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .admin-participations-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.82rem 1rem;
            border-radius: 999px;
            border: 1px solid transparent;
            cursor: pointer;
            transition: transform var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
        }

        .admin-participations-btn:hover {
            transform: translateY(-1px);
        }

        .admin-participations-btn.is-submitting,
        .admin-participations-icon.is-submitting {
            opacity: 0.6;
            pointer-events: none;
            cursor: wait;
            transform: none;
        }

        .admin-participations-btn--primary {
            background: var(--admin-primary);
            color: #fff;
        }

        .admin-participations-btn--primary:hover {
            background: var(--admin-primary-dark);
        }

        .admin-participations-btn--secondary {
            background: rgba(47, 127, 121, 0.1);
            color: var(--admin-secondary);
            border-color: rgba(47, 127, 121, 0.2);
        }

        .admin-participations-btn--secondary:hover {
            background: rgba(47, 127, 121, 0.18);
        }

        .admin-participations-btn--ghost {
            background: rgba(255, 253, 249, 0.92);
            color: var(--admin-text-muted);
            border-color: var(--admin-border);
        }

        .admin-participations-btn--ghost:hover {
            color: var(--admin-primary);
            border-color: rgba(196, 111, 75, 0.28);
            background: rgba(196, 111, 75, 0.06);
        }

        .admin-participations-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 34px;
            padding: 0 0.75rem;
            border-radius: 999px;
            background: rgba(196, 111, 75, 0.12);
            color: var(--admin-primary);
            font-weight: 700;
        }

        .admin-participations-note {
            color: var(--admin-text-muted);
            font-size: 0.9rem;
        }

        .admin-participations-table-wrap {
            overflow-x: auto;
            border-radius: 22px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.9);
        }

        .admin-participations-table {
            width: 100%;
            min-width: 1000px;
            border-collapse: collapse;
        }

        .admin-participations-table th,
        .admin-participations-table td {
            padding: 0.95rem 0.9rem;
            border-bottom: 1px solid rgba(231, 220, 205, 0.78);
            text-align: left;
            vertical-align: middle;
        }

        .admin-participations-table th {
            background: rgba(244, 235, 223, 0.72);
            color: var(--admin-text-muted);
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .admin-participations-table tbody tr:hover {
            background: rgba(196, 111, 75, 0.04);
        }

        .admin-participations-sort {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            color: inherit;
        }

        .admin-participations-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            border: 1px solid transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform var(--transition-fast), filter var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
        }

        .admin-participations-icon:hover {
            transform: translateY(-1px);
            filter: brightness(0.98);
        }

        .admin-participations-icon--save {
            background: rgba(47, 127, 121, 0.12);
            color: var(--admin-secondary);
            border-color: rgba(47, 127, 121, 0.22);
        }

        .admin-participations-icon--delete {
            background: rgba(191, 91, 91, 0.12);
            color: var(--admin-danger);
            border-color: rgba(191, 91, 91, 0.18);
        }

        .admin-participations-toasts {
            position: fixed;
            top: calc(var(--topbar-height) + 1rem);
            right: 1.25rem;
            z-index: 1200;
            display: grid;
            gap: 0.85rem;
            width: min(360px, calc(100vw - 2rem));
        }

        .admin-participations-toast {
            position: relative;
            padding: 1rem 3rem 1rem 1.1rem;
            border-radius: 22px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.96);
            box-shadow: var(--admin-shadow);
            animation: admin-participations-toast-in 240ms ease;
        }

        .admin-participations-toast--success {
            border-left: 4px solid var(--admin-success);
        }

        .admin-participations-toast--error,
        .admin-participations-toast--warning {
            border-left: 4px solid var(--admin-primary);
        }

        .admin-participations-toast.is-hiding {
            animation: admin-participations-toast-out 220ms ease forwards;
        }

        .admin-participations-toast__title {
            display: block;
            margin-bottom: 0.16rem;
            font-size: 0.9rem;
            font-weight: 700;
        }

        .admin-participations-toast__message {
            color: var(--admin-text-muted);
        }

        .admin-participations-toast__close {
            position: absolute;
            top: 0.8rem;
            right: 0.8rem;
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 999px;
            background: rgba(31, 26, 23, 0.06);
            color: var(--admin-text-muted);
            cursor: pointer;
        }

        .admin-participations-toast__close:hover {
            background: rgba(196, 111, 75, 0.12);
            color: var(--admin-primary);
        }

        .admin-participations-empty {
            padding: 2rem 1rem;
            text-align: center;
            color: var(--admin-text-muted);
        }

        @keyframes admin-participations-toast-in {
            from {
                opacity: 0;
                transform: translate3d(18px, -12px, 0);
            }
            to {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
        }

        @keyframes admin-participations-toast-out {
            from {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
            to {
                opacity: 0;
                transform: translate3d(24px, -10px, 0);
            }
        }

        @media (max-width: 980px) {
            .admin-participations-toolbar,
            .admin-participations-grid,
            .admin-participations-filters {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .admin-participations-header,
            .admin-participations-actions,
            .admin-participations-filter-actions,
            .admin-participations-inline,
            .admin-participations-row-actions {
                flex-direction: column;
                align-items: stretch;
            }

            .admin-participations-toasts {
                right: 1rem;
                left: 1rem;
                width: auto;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="admin-participations-page">
        {% set successFlashes = app.flashes('success') %}
        {% set warningFlashes = app.flashes('warning') %}
        {% set errorFlashes = app.flashes('error') %}

        {% if successFlashes is not empty or warningFlashes is not empty or errorFlashes is not empty %}
            <div class="admin-participations-toasts" aria-live="polite" aria-atomic="true">
                {% for message in successFlashes %}
                    <div class="admin-participations-toast admin-participations-toast--success" data-admin-participations-toast>
                        <strong class="admin-participations-toast__title">Operation reussie</strong>
                        <div class="admin-participations-toast__message">{{ message }}</div>
                        <button type="button" class="admin-participations-toast__close" data-admin-participations-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
                {% for message in warningFlashes %}
                    <div class="admin-participations-toast admin-participations-toast--warning" data-admin-participations-toast>
                        <strong class="admin-participations-toast__title">Attention</strong>
                        <div class="admin-participations-toast__message">{{ message }}</div>
                        <button type="button" class="admin-participations-toast__close" data-admin-participations-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
                {% for message in errorFlashes %}
                    <div class="admin-participations-toast admin-participations-toast--error" data-admin-participations-toast>
                        <strong class="admin-participations-toast__title">Action impossible</strong>
                        <div class="admin-participations-toast__message">{{ message }}</div>
                        <button type="button" class="admin-participations-toast__close" data-admin-participations-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <section class="admin-card admin-participations-card admin-participations-card--highlight">
            <div class="admin-participations-header">
                <div>
                    <span class="admin-card__eyebrow">Participations</span>
                    <h1 class="admin-participations-header__title">Ajouter un participant au voyage {{ voyage.titreVoyage }}</h1>
                </div>

                <div class="admin-participations-actions">
                    <span class="admin-participations-count">{{ participations|length }}</span>
                    <a href="{{ path('app_admin_voyages') }}" class="admin-participations-btn admin-participations-btn--ghost">Retour aux voyages</a>
                </div>
            </div>

            <form method="post" action="{{ path('app_admin_participations', {'id_voyage': voyage.idVoyage} + filters) }}" class="admin-participations-form" data-admin-participation-add-form>
                <input type="hidden" name="_token" value="{{ csrf_token('admin_participation_add_' ~ voyage.idVoyage) }}">
                <input type="hidden" name="_submission_nonce" value="{{ add_nonce }}">

                <div class="admin-participations-grid">
                    <div class="admin-participations-field">
                        <label class="admin-participations-label" for="participation-email">Email</label>
                        <input id="participation-email" name="email" type="email" class="admin-participations-input" value="{{ last_email }}" placeholder="email@exemple.com" required>
                    </div>

                    <div class="admin-participations-field">
                        <label class="admin-participations-label" for="participation-role">Role</label>
                        <select id="participation-role" name="role_participation" class="admin-participations-select">
                            {% for role in role_options %}
                                <option value="{{ role }}" {{ last_role == role ? 'selected' : '' }}>{{ role }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="admin-participations-actions">
                    <button type="submit" class="admin-participations-btn admin-participations-btn--primary" data-admin-participation-add-submit>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M12 5V19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            <path d="M5 12H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                        <span>Ajouter</span>
                    </button>
                </div>
            </form>
        </section>

        <section class="admin-card admin-participations-card">
            <form method="get" action="{{ path('app_admin_participations', {'id_voyage': voyage.idVoyage}) }}">
                <div class="admin-participations-toolbar">
                    <div class="admin-participations-field">
                        <label class="admin-participations-label" for="participation-filter-name">Nom</label>
                        <div class="admin-participations-search-wrap">
                            <input id="participation-filter-name" name="name" type="search" class="admin-participations-input admin-participations-search-input" value="{{ filters.name }}" placeholder="Rechercher par nom...">
                            <span class="admin-participations-search-icon" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path d="M21 21L16.65 16.65M18 10.5C18 14.6421 14.6421 18 10.5 18C6.35786 18 3 14.6421 3 10.5C3 6.35786 6.35786 3 10.5 3C14.6421 3 18 6.35786 18 10.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <div class="admin-participations-field">
                        <label class="admin-participations-label" for="participation-filter-sort">Tri</label>
                        <select id="participation-filter-sort" name="sort" class="admin-participations-select">
                            <option value="name_asc" {{ filters.sort == 'name_asc' ? 'selected' : '' }}>Nom A a Z</option>
                            <option value="name_desc" {{ filters.sort == 'name_desc' ? 'selected' : '' }}>Nom Z a A</option>
                            <option value="role_asc" {{ filters.sort == 'role_asc' ? 'selected' : '' }}>Role A a Z</option>
                            <option value="role_desc" {{ filters.sort == 'role_desc' ? 'selected' : '' }}>Role Z a A</option>
                        </select>
                    </div>

                    <div class="admin-participations-filter-actions">
                        <button type="submit" class="admin-participations-btn admin-participations-btn--primary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M21 21L16.65 16.65M18 10.5C18 14.6421 14.6421 18 10.5 18C6.35786 18 3 14.6421 3 10.5C3 6.35786 6.35786 3 10.5 3C14.6421 3 18 6.35786 18 10.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                            <span>Rechercher</span>
                        </button>
                        <a href="{{ path('app_admin_participations', {'id_voyage': voyage.idVoyage}) }}" class="admin-participations-btn admin-participations-btn--secondary">Reinitialiser</a>
                    </div>
                </div>
            </form>
        </section>

        <section class="admin-card admin-participations-card">
            <div class="admin-participations-header">
                <div>
                    <span class="admin-card__eyebrow">Liste</span>
                    <h2 class="admin-participations-header__title">Liste des participants</h2>
                </div>
                <span class="admin-participations-count">{{ participations|length }}</span>
            </div>

            <div class="admin-participations-table-wrap">
                {% if participations is not empty %}
                    <table class="admin-participations-table">
                        <thead>
                            <tr>
                                <th>User ID</th>
                                <th>Email</th>
                                <th>Nom</th>
                                <th>Prenom</th>
                                <th>Role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for participation in participations %}
                                {% set user = participation.user %}
                                <tr>
                                    <td>{{ user.id }}</td>
                                    <td>{{ user.email }}</td>
                                    <td>{{ user.nom }}</td>
                                    <td>{{ user.prenom }}</td>
                                    <td>
                                        <div class="admin-participations-role-cell">
                                            <select name="role_participation_display" class="admin-participations-select" style="min-width: 180px;" data-admin-role-select>
                                                {% for role in role_options %}
                                                    <option value="{{ role }}" {{ participation.roleParticipation == role ? 'selected' : '' }}>{{ role }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="admin-participations-row-actions">
                                            <form method="post" action="{{ path('app_admin_participations_update', {'id_voyage': voyage.idVoyage, 'userId': user.id}) }}" class="admin-participations-update-form" data-admin-participation-update-form>
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_participation_update_' ~ voyage.idVoyage ~ '_' ~ user.id) }}">
                                                <input type="hidden" name="_submission_nonce" value="{{ update_nonces[user.id] ?? '' }}">
                                                <input type="hidden" name="name" value="{{ filters.name }}">
                                                <input type="hidden" name="sort" value="{{ filters.sort }}">
                                                <input type="hidden" name="role_participation" value="{{ participation.roleParticipation }}" data-admin-role-hidden>
                                                <button type="submit" class="admin-participations-icon admin-participations-icon--save" aria-label="Mettre a jour le role de {{ user.prenom }} {{ user.nom }}" title="Mettre a jour" data-admin-participation-update-submit>
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                        <path d="M5 20H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M7 4H16L19 7V20H7V4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                                        <path d="M9 4V9H15V4" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                                        <path d="M9 15H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                    </svg>
                                                </button>
                                            </form>

                                            <form method="post" action="{{ path('app_admin_participations_delete', {'id_voyage': voyage.idVoyage, 'userId': user.id}) }}" onsubmit="return confirm('Supprimer ce participant ?');" data-admin-participation-delete-form class="admin-participations-delete-form">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_participation_delete_' ~ voyage.idVoyage ~ '_' ~ user.id) }}">
                                                <input type="hidden" name="_submission_nonce" value="{{ delete_nonces[user.id] ?? '' }}">
                                                <input type="hidden" name="name" value="{{ filters.name }}">
                                                <input type="hidden" name="sort" value="{{ filters.sort }}">
                                                <button type="submit" class="admin-participations-icon admin-participations-icon--delete" aria-label="Supprimer {{ user.prenom }} {{ user.nom }}" title="Supprimer" data-admin-participation-delete-submit>
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                        <path d="M4 7H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M9 7V5.5C9 4.67157 9.67157 4 10.5 4H13.5C14.3284 4 15 4.67157 15 5.5V7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M7 7L7.8 18.2C7.87717 19.2804 8.77596 20.1191 9.85909 20.1191H14.1409C15.224 20.1191 16.1228 19.2804 16.2 18.2L17 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M10 11V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                        <path d="M14 11V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="admin-participations-empty">Aucun participant ne correspond a votre recherche.</div>
                {% endif %}
            </div>
        </section>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toasts = document.querySelectorAll('[data-admin-participations-toast]');
            var addForm = document.querySelector('[data-admin-participation-add-form]');
            var updateForms = document.querySelectorAll('[data-admin-participation-update-form]');
            var deleteForms = document.querySelectorAll('[data-admin-participation-delete-form]');
            var roleSelects = document.querySelectorAll('[data-admin-role-select]');

            function hideToast(toast) {
                if (!toast || toast.classList.contains('is-hiding')) {
                    return;
                }

                toast.classList.add('is-hiding');
                window.setTimeout(function () {
                    toast.remove();
                }, 220);
            }

            function lockFormOnSubmit(form, buttonSelector) {
                if (!form) {
                    return;
                }

                form.addEventListener('submit', function (event) {
                    var submitButton = form.querySelector(buttonSelector);

                    if (form.dataset.submitting === 'true') {
                        event.preventDefault();
                        return;
                    }

                    form.dataset.submitting = 'true';

                    if (submitButton) {
                        submitButton.disabled = true;
                        submitButton.classList.add('is-submitting');
                    }
                });
            }

            roleSelects.forEach(function (select) {
                select.addEventListener('change', function () {
                    var row = select.closest('tr');

                    if (!row) {
                        return;
                    }

                    var hiddenInput = row.querySelector('[data-admin-role-hidden]');

                    if (hiddenInput) {
                        hiddenInput.value = select.value;
                    }
                });
            });

            toasts.forEach(function (toast) {
                var closeButton = toast.querySelector('[data-admin-participations-toast-close]');

                if (closeButton) {
                    closeButton.addEventListener('click', function () {
                        hideToast(toast);
                    });
                }

                window.setTimeout(function () {
                    hideToast(toast);
                }, 4200);
            });

            lockFormOnSubmit(addForm, '[data-admin-participation-add-submit]');
            updateForms.forEach(function (form) {
                lockFormOnSubmit(form, '[data-admin-participation-update-submit]');
            });
            deleteForms.forEach(function (form) {
                lockFormOnSubmit(form, '[data-admin-participation-delete-submit]');
            });
        });
    </script>
{% endblock %}