{% extends 'base_admin.html.twig' %}

{% block title %}{{ title }} | Administration TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .etape-form {
            max-width: 700px;
        }

        .etape-form__card {
            border-radius: 26px;
            border: 1px solid var(--admin-border);
            background: rgba(255, 253, 249, 0.96);
            box-shadow: var(--admin-shadow-soft);
            overflow: hidden;
        }

        .etape-form__head {
            padding: 1.1rem 1.35rem;
            border-bottom: 1px solid var(--admin-border);
            font-family: 'Fraunces', serif;
            font-size: 1.15rem;
            color: var(--admin-text);
        }

        .etape-form__body {
            padding: 1.5rem;
        }

        .etape-form__group {
            margin-bottom: 1.25rem;
        }

        .etape-form__label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--admin-text-muted);
            margin-bottom: 0.5rem;
        }

        .etape-form__label span {
            color: var(--admin-danger);
        }

        .etape-form__input,
        .etape-form__textarea,
        .etape-form__select {
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 14px;
            border: 1px solid var(--admin-border);
            background: var(--admin-surface);
            font-size: 0.95rem;
            transition: all 0.15s ease;
        }

        .etape-form__input:focus,
        .etape-form__textarea:focus,
        .etape-form__select:focus {
            outline: none;
            border-color: var(--admin-primary);
            box-shadow: 0 0 0 3px rgba(196, 111, 75, 0.1);
        }

        .etape-form__textarea {
            resize: vertical;
            min-height: 100px;
        }

        .etape-form__info {
            font-size: 0.75rem;
            color: var(--admin-text-muted);
            margin-top: 0.35rem;
        }

        .etape-form__actions {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid var(--admin-border);
        }

        .etape-form__btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.7rem 1.3rem;
            border-radius: 999px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s ease;
            border: 1px solid transparent;
        }

        .etape-form__btn--primary {
            background: var(--admin-primary);
            color: white;
        }

        .etape-form__btn--primary:hover {
            background: var(--admin-primary-dark);
            transform: translateY(-1px);
        }

        .etape-form__btn--secondary {
            background: transparent;
            color: var(--admin-text-muted);
            border-color: var(--admin-border);
        }

        .etape-form__btn--secondary:hover {
            background: rgba(196, 111, 75, 0.08);
            color: var(--admin-primary);
            border-color: rgba(196, 111, 75, 0.3);
            transform: translateY(-1px);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="etape-form">
        <div class="etape-form__card">
            <div class="etape-form__head">
                {{ title }}
                <span style="font-size: 0.85rem; font-weight: normal; margin-left: 0.75rem;">
                    pour l'itinéraire "{{ itineraire.nom_itineraire }}"
                </span>
            </div>

            <form method="post" class="etape-form__body">
                <div class="etape-form__group">
                    <label for="description_etape" class="etape-form__label">
                        Description <span>*</span>
                    </label>
                    <textarea id="description_etape" name="description_etape" class="etape-form__textarea" required minlength="10">{{ etape ? etape.description_etape : '' }}</textarea>
                    <div class="etape-form__info">Minimum 10 caractères. Décrivez l'étape, les activités prévues, etc.</div>
                </div>

                <div class="etape-form__group">
                    <label for="numero_jour" class="etape-form__label">
                        Jour <span>*</span>
                    </label>
                    <input type="number" id="numero_jour" name="numero_jour" class="etape-form__input" 
                           value="{{ etape ? etape.numero_jour : (jour is defined ? jour : 1) }}" 
                           min="1" {% if nbJours %}max="{{ nbJours }}"{% endif %} required>
                    {% if nbJours %}
                        <div class="etape-form__info">Le voyage dure {{ nbJours }} jour{{ nbJours > 1 ? 's' : '' }} (du jour 1 au jour {{ nbJours }})</div>
                    {% endif %}
                </div>

                <div class="etape-form__group">
                    <label for="heure" class="etape-form__label">
                        Heure <span>*</span>
                    </label>
                    <input type="time" id="heure" name="heure" class="etape-form__input" 
                           value="{{ etape and etape.heure ? etape.heure|date('H:i') : '' }}" required>
                    <div class="etape-form__info">Format HH:MM (ex: 14:30)</div>
                </div>

                <div class="etape-form__actions">
                    <button type="submit" class="etape-form__btn etape-form__btn--primary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        {{ etape ? 'Mettre à jour' : 'Créer l\'étape' }}
                    </button>
                    <a href="{{ path('app_admin_etapes_index', { itineraireId: itineraire.id_itineraire }) }}" class="etape-form__btn etape-form__btn--secondary">
                        Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}