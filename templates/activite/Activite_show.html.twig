{% extends 'base.html.twig' %}

{% block title %}{{ activite.nom }} — TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Layout principal ── */
        .show-layout {
            display: grid;
            grid-template-columns: 1fr 360px;
            gap: 2rem;
            align-items: start;
        }
        @media (max-width: 1024px) {
            .show-layout { grid-template-columns: 1fr; }
        }

        /* ── Breadcrumb ── */
        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: var(--color-text-muted);
            margin-bottom: 1.5rem;
        }
        .breadcrumb a { color: var(--color-primary); }
        .breadcrumb a:hover { text-decoration: underline; }

        /* ── Image hero ── */
        .show-img-wrap {
            position: relative;
            height: 380px;
            border-radius: var(--radius-xl);
            overflow: hidden;
            background: var(--color-surface-soft);
            margin-bottom: 1.5rem;
        }
        .show-img {
            width: 100%; height: 100%;
            object-fit: cover;
        }
        .show-img-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            font-size: 5rem; color: var(--color-text-muted);
        }
        .show-badges {
            position: absolute; top: 1rem; left: 1rem;
            display: flex; gap: 0.5rem; flex-wrap: wrap;
        }
        .badge {
            padding: 0.3rem 0.75rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 600;
        }
        .badge--fire { background: rgba(220,50,30,0.88); color:#fff; }
        .badge--cat  { background: rgba(255,253,249,0.92); color:var(--color-primary); border:1px solid rgba(196,111,75,0.25); }
        .badge--statut-active   { background:rgba(47,127,121,0.88); color:#fff; }
        .badge--statut-inactive { background:rgba(150,150,150,0.85);color:#fff; }
        .badge--statut-attente  { background:rgba(200,160,50,0.88); color:#fff; }

        /* ── Header infos ── */
        .show-header { margin-bottom: 1.5rem; }
        .show-title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--color-text);
            line-height: 1.2;
            margin-bottom: 0.75rem;
        }
        .show-meta-row {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 0.75rem;
        }
        .meta-item {
            display: flex; align-items: center; gap: 0.4rem;
            font-size: 0.88rem; color: var(--color-text-muted);
        }
        .meta-item strong { color: var(--color-text); }

        /* Rating header */
        .show-rating-row {
            display: flex; align-items: center; gap: 0.5rem;
            font-size: 0.92rem; color: var(--color-text-muted);
        }
        .stars-lg { color: #f59e0b; font-size: 1.1rem; }

        /* ── Onglets ── */
        .tabs {
            display: flex;
            border-bottom: 2px solid var(--color-border);
            margin-bottom: 1.5rem;
            gap: 0.25rem;
        }
        .tab-btn {
            padding: 0.75rem 1.25rem;
            border: none;
            background: transparent;
            font: inherit;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--color-text-muted);
            cursor: pointer;
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            transition: color var(--transition-fast), border-color var(--transition-fast);
        }
        .tab-btn:hover { color: var(--color-primary); }
        .tab-btn.is-active {
            color: var(--color-primary);
            border-bottom-color: var(--color-primary);
        }
        .tab-panel { display: none; }
        .tab-panel.is-active { display: block; }

        /* ── Onglet Détails ── */
        .detail-section {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1rem;
        }
        .detail-section__title {
            font-weight: 600;
            color: var(--color-text);
            margin-bottom: 0.75rem;
            font-size: 1rem;
        }
        .detail-section p { color: var(--color-text-muted); line-height: 1.7; }
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }
        .info-item {
            display: flex; flex-direction: column; gap: 0.2rem;
        }
        .info-item__label { font-size: 0.78rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
        .info-item__value { font-weight: 600; color: var(--color-text); font-size: 0.95rem; }

        /* ── Onglet Tarifs ── */
        .tarif-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.25rem;
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 0.75rem;
        }
        .tarif-card__name { font-weight: 600; color: var(--color-text); }
        .tarif-card__desc { font-size: 0.83rem; color: var(--color-text-muted); margin-top: 0.15rem; }
        .tarif-card__price {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--color-primary);
            white-space: nowrap;
        }
        .tarif-card__unit { font-size: 0.78rem; color: var(--color-text-muted); }

        /* ── Onglet Avis ── */
        .avis-summary {
            display: flex; align-items: center; gap: 2rem;
            background: linear-gradient(135deg, rgba(196,111,75,0.06), rgba(47,127,121,0.04));
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .avis-score {
            text-align: center;
        }
        .avis-score__num {
            font-family: 'Fraunces', serif;
            font-size: 3rem;
            font-weight: 600;
            color: var(--color-primary);
            line-height: 1;
        }
        .avis-score__stars { color: #f59e0b; font-size: 1.2rem; margin: 0.25rem 0; }
        .avis-score__count { font-size: 0.82rem; color: var(--color-text-muted); }

        .avis-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.25rem;
            margin-bottom: 1rem;
        }
        .avis-card__header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 0.75rem;
        }
        .avis-card__user {
            display: flex; align-items: center; gap: 0.65rem;
        }
        .avis-card__avatar {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: var(--color-surface-soft);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; color: var(--color-primary);
            font-size: 0.95rem;
            border: 1px solid var(--color-border);
        }
        .avis-card__name { font-weight: 600; font-size: 0.92rem; }
        .avis-card__date { font-size: 0.78rem; color: var(--color-text-muted); }
        .avis-card__stars { color: #f59e0b; }
        .avis-card__comment { color: var(--color-text-muted); line-height: 1.65; font-size: 0.92rem; }

        /* Formulaire avis */
        .avis-form-wrap {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-top: 1.5rem;
        }
        .avis-form-wrap h3 {
            font-weight: 600; margin-bottom: 1rem; font-size: 1rem;
        }
        .form-group { margin-bottom: 1rem; }
        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--color-text-muted);
            margin-bottom: 0.4rem;
        }
        .form-control {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            font: inherit;
            font-size: 0.92rem;
            color: var(--color-text);
            outline: none;
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }
        .form-control:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196,111,75,0.1);
        }
        textarea.form-control { resize: vertical; min-height: 100px; }

        /* Étoiles cliquables */
        .star-rating { display: flex; gap: 0.4rem; margin-bottom: 0.5rem; }
        .star-rating input { display: none; }
        .star-rating label {
            font-size: 2rem;
            color: var(--color-border);
            cursor: pointer;
            transition: color var(--transition-fast), transform var(--transition-fast);
        }
        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input:checked ~ label { color: #f59e0b; }
        .star-rating label:hover { transform: scale(1.2); }

        /* ── Sidebar : Box réservation ── */
        .resa-box {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            padding: 1.5rem;
            position: sticky;
            top: calc(var(--navbar-height) + 1rem);
        }
        .resa-box__title {
            font-family: 'Fraunces', serif;
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--color-text);
            margin-bottom: 0.25rem;
        }
        .resa-box__price {
            font-family: 'Fraunces', serif;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--color-primary);
            margin-bottom: 1.25rem;
        }
        .resa-box__price span { font-size: 0.9rem; color: var(--color-text-muted); font-weight: 400; font-family: 'Outfit', sans-serif; }
        .resa-field { margin-bottom: 0.85rem; }
        .resa-field label {
            display: block;
            font-size: 0.82rem;
            font-weight: 500;
            color: var(--color-text-muted);
            margin-bottom: 0.35rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .resa-input {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            font: inherit;
            font-size: 0.92rem;
            color: var(--color-text);
            outline: none;
            transition: border-color var(--transition-fast);
        }
        .resa-input:focus { border-color: var(--color-primary); }
        .resa-persons { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; }
        .resa-total {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.85rem 0;
            border-top: 1px solid var(--color-border);
            border-bottom: 1px solid var(--color-border);
            margin-bottom: 1rem;
            font-weight: 600;
        }
        .resa-total__amount { color: var(--color-primary); font-family: 'Fraunces', serif; font-size: 1.1rem; }
        .resa-btn-group { display: flex; flex-direction: column; gap: 0.6rem; }
        .resa-btn-help {
            display: flex; align-items: center; justify-content: center; gap: 0.4rem;
            padding: 0.8rem;
            border: 1px solid var(--color-border);
            border-radius: 999px;
            background: transparent;
            font: inherit;
            font-size: 0.9rem;
            color: var(--color-text-muted);
            cursor: pointer;
            transition: background var(--transition-fast), border-color var(--transition-fast);
        }
        .resa-btn-help:hover {
            background: var(--color-hover);
            border-color: rgba(196,111,75,0.3);
            color: var(--color-primary);
        }
        .resa-features {
            margin-top: 1.25rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--color-border);
        }
        .resa-feature {
            display: flex; align-items: center; gap: 0.6rem;
            font-size: 0.85rem; color: var(--color-text-muted);
            margin-bottom: 0.5rem;
        }
        .resa-feature .check { color: var(--color-secondary); }
    </style>
{% endblock %}

{% block body %}
{# Breadcrumb #}
<nav class="breadcrumb">
    <a href="{{ path('app_home') }}">Accueil</a>
    <span>›</span>
    <a href="{{ path('app_activites') }}">Activités</a>
    <span>›</span>
    <span>{{ activite.nom }}</span>
</nav>

<div class="show-layout">
    {# ── Colonne principale ── #}
    <div>
        {# Image #}
        <div class="show-img-wrap">
            {% if activite.imagePath %}
                <img src="{{ asset(activite.imagePath|replace({'\\\\': '/'})) }}"
                     alt="{{ activite.nom }}" class="show-img"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="show-img-placeholder" style="display:none">🌄</div>
            {% else %}
                <div class="show-img-placeholder">🌄</div>
            {% endif %}

            <div class="show-badges">
                {% if activite.avis|length >= 3 and activite.moyenneAvis >= 4 %}
                    <span class="badge badge--fire">🔥 Trending</span>
                {% endif %}
                {% if activite.categorie %}
                    <span class="badge badge--cat">{{ activite.categorie.nom }}</span>
                {% endif %}
            </div>
        </div>

        {# Header #}
        <div class="show-header">
            <h1 class="show-title">{{ activite.nom }}</h1>

            <div class="show-meta-row">
                {% if activite.lieu %}
                    <span class="meta-item">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="currentColor"/></svg>
                        <strong>{{ activite.lieu|slice(0,60) }}</strong>
                    </span>
                {% endif %}
                <span class="meta-item">⏱ <strong>{{ activite.duree }}h</strong> de durée</span>
                <span class="meta-item">👤 Dès <strong>{{ activite.agemin }} ans</strong></span>
                <span class="meta-item">
                    {% set diff = activite.niveaudifficulte|lower %}
                    {% if diff == 'facile' %}🟢{% elseif diff == 'moyen' %}🟡{% elseif diff == 'difficile' %}🟠{% else %}🔴{% endif %}
                    <strong>{{ activite.niveaudifficulte }}</strong>
                </span>
            </div>

            {% if activite.avis|length > 0 %}
                <div class="show-rating-row">
                    <span class="stars-lg">
                        {% for i in 1..5 %}{{ i <= activite.moyenneAvis ? '★' : '☆' }}{% endfor %}
                    </span>
                    <strong>{{ activite.moyenneAvis }}</strong>
                    <span>({{ activite.avis|length }} avis)</span>
                </div>
            {% else %}
                <div class="show-rating-row">
                    <span style="color:var(--color-text-muted)">Pas encore d'avis</span>
                </div>
            {% endif %}
        </div>

        {# ── Onglets ── #}
        <div class="tabs">
            <button class="tab-btn is-active" data-tab="details">Détails</button>
            <button class="tab-btn" data-tab="tarifs">Tarifs</button>
            <button class="tab-btn" data-tab="avis">
                Avis
                {% if activite.avis|length > 0 %}
                    <span style="background:var(--color-primary);color:#fff;border-radius:999px;padding:0.1rem 0.5rem;font-size:0.72rem;margin-left:0.3rem">{{ activite.avis|length }}</span>
                {% endif %}
            </button>
        </div>

        {# ── Panel Détails ── #}
        <div class="tab-panel is-active" id="tab-details">
            <div class="detail-section">
                <div class="detail-section__title">À propos de cette activité</div>
                <p>{{ activite.description }}</p>
            </div>

            <div class="detail-section">
                <div class="detail-section__title">Informations pratiques</div>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-item__label">Catégorie</span>
                        <span class="info-item__value">{{ activite.categorie ? activite.categorie.nom : '—' }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">Durée</span>
                        <span class="info-item__value">{{ activite.duree }} heure{{ activite.duree > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">Niveau</span>
                        <span class="info-item__value">{{ activite.niveaudifficulte }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">Âge minimum</span>
                        <span class="info-item__value">{{ activite.agemin }} ans</span>
                    </div>
                    <div class="info-item">
                        <span class="info-item__label">Statut</span>
                        <span class="info-item__value">{{ activite.statut }}</span>
                    </div>
                    {% if activite.categorie %}
                        <div class="info-item">
                            <span class="info-item__label">Type</span>
                            <span class="info-item__value">{{ activite.categorie.type }}</span>
                        </div>
                        <div class="info-item">
                            <span class="info-item__label">Saison</span>
                            <span class="info-item__value">{{ activite.categorie.saison }}</span>
                        </div>
                        <div class="info-item">
                            <span class="info-item__label">Public cible</span>
                            <span class="info-item__value">{{ activite.categorie.publiccible }}</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ── Panel Tarifs ── #}
        <div class="tab-panel" id="tab-tarifs">
            <div class="tarif-card">
                <div>
                    <div class="tarif-card__name">Tarif standard</div>
                    <div class="tarif-card__desc">Prix par personne, toutes taxes comprises</div>
                </div>
                <div style="text-align:right">
                    <div class="tarif-card__price">{{ activite.budget }} <span class="tarif-card__unit">TND</span></div>
                    <div class="tarif-card__unit">/ personne</div>
                </div>
            </div>

            <div class="tarif-card">
                <div>
                    <div class="tarif-card__name">Groupe (2+ personnes)</div>
                    <div class="tarif-card__desc">Réduction de 10% par personne supplémentaire</div>
                </div>
                <div style="text-align:right">
                    <div class="tarif-card__price">{{ (activite.budget * 0.9)|round }} <span class="tarif-card__unit">TND</span></div>
                    <div class="tarif-card__unit">/ personne</div>
                </div>
            </div>

            <div style="background:var(--color-secondary-soft);border:1px solid rgba(47,127,121,0.2);border-radius:var(--radius-md);padding:1rem;margin-top:1rem;color:var(--color-secondary);font-size:0.88rem">
                ℹ️ Les prix incluent toutes les taxes. Le paiement se fait lors de la réservation.
            </div>
        </div>

        {# ── Panel Avis ── #}
        <div class="tab-panel" id="tab-avis">

            {# Résumé rating #}
            {% if activite.avis|length > 0 %}
                <div class="avis-summary">
                    <div class="avis-score">
                        <div class="avis-score__num">{{ activite.moyenneAvis }}</div>
                        <div class="avis-score__stars">
                            {% for i in 1..5 %}{{ i <= activite.moyenneAvis ? '★' : '☆' }}{% endfor %}
                        </div>
                        <div class="avis-score__count">{{ activite.avis|length }} avis</div>
                    </div>
                    <div style="flex:1;color:var(--color-text-muted);font-size:0.9rem">
                        Note moyenne basée sur {{ activite.avis|length }} avis de voyageurs ayant participé à cette activité.
                    </div>
                </div>

                {# Liste des avis #}
                {% for avi in activite.avis %}
                    <div class="avis-card">
                        <div class="avis-card__header">
                            <div class="avis-card__user">
                                <div class="avis-card__avatar">
                                    {{ avi.user.prenom|slice(0,1)|upper }}{{ avi.user.nom|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <div class="avis-card__name">{{ avi.user.prenom }} {{ avi.user.nom }}</div>
                                    <div class="avis-card__date">{{ avi.createdAt|date('d/m/Y') }}</div>
                                </div>
                            </div>
                            <div class="avis-card__stars">
                                {% for i in 1..5 %}{{ i <= avi.note ? '★' : '☆' }}{% endfor %}
                                <span style="font-size:0.82rem;color:var(--color-text-muted);margin-left:0.3rem">{{ avi.note }}/5</span>
                            </div>
                        </div>
                        {% if avi.commentaire %}
                            <div class="avis-card__comment">{{ avi.commentaire }}</div>
                        {% endif %}
                    </div>
                {% endfor %}
            {% else %}
                <div style="text-align:center;padding:2.5rem;color:var(--color-text-muted)">
                    <div style="font-size:2.5rem;margin-bottom:0.75rem">💬</div>
                    <div style="font-weight:600;color:var(--color-text);margin-bottom:0.3rem">Aucun avis pour l'instant</div>
                    <div>Soyez le premier à partager votre expérience !</div>
                </div>
            {% endif %}

            {# Formulaire avis #}
            <div class="avis-form-wrap">
                <h3>✍️ Laisser un avis</h3>
                <form action="{{ path('app_avis_new', {id: activite.id}) }}" method="POST">
                    <div class="form-group">
                        <label>Votre note</label>
                        <div class="star-rating">
                            {% for i in [5,4,3,2,1] %}
                                <input type="radio" name="note" id="star{{ i }}" value="{{ i }}" {{ i == 5 ? 'checked' : '' }}>
                                <label for="star{{ i }}" title="{{ i }} étoile{{ i > 1 ? 's' : '' }}">★</label>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="commentaire">Votre commentaire (optionnel)</label>
                        <textarea class="form-control" id="commentaire" name="commentaire"
                                  placeholder="Partagez votre expérience…" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn--primary" style="width:100%">
                        Publier mon avis
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ── Sidebar : Box réservation ── #}
    <aside>
        <div class="resa-box">
            <div class="resa-box__title">Réserver maintenant</div>
            <div class="resa-box__price">{{ activite.budget }} TND <span>/ personne</span></div>

            <form id="resaForm">
                <div class="resa-field">
                    <label>Date souhaitée</label>
                    <input type="date" class="resa-input" id="resaDate"
                           min="{{ "now"|date("Y-m-d") }}">
                </div>

                <div class="resa-field">
                    <label>Nombre de participants</label>
                    <div class="resa-persons">
                        <div>
                            <label style="font-size:0.78rem;color:var(--color-text-muted);display:block;margin-bottom:0.25rem">Adultes</label>
                            <input type="number" class="resa-input" id="nbAdultes" min="1" value="1">
                        </div>
                        <div>
                            <label style="font-size:0.78rem;color:var(--color-text-muted);display:block;margin-bottom:0.25rem">Enfants</label>
                            <input type="number" class="resa-input" id="nbEnfants" min="0" value="0">
                        </div>
                    </div>
                </div>

                <div class="resa-total">
                    <span>Total estimé</span>
                    <span class="resa-total__amount" id="resaTotal">{{ activite.budget }} TND</span>
                </div>

                <div class="resa-btn-group">
                    <button type="button" class="btn btn--primary" onclick="alert('Fonctionnalité de réservation à venir !')">
                        ✅ Confirmer la réservation
                    </button>
                    <button type="button" class="resa-btn-help">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.7"/><path d="M9 9C9 7.34315 10.3431 6 12 6C13.6569 6 15 7.34315 15 9C15 10.6569 13.6569 12 12 12V14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="12" cy="17" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="1.5"/></svg>
                        Besoin d'aide ?
                    </button>
                </div>
            </form>

            <div class="resa-features">
                <div class="resa-feature"><span class="check">✓</span> Annulation gratuite sous 24h</div>
                <div class="resa-feature"><span class="check">✓</span> Confirmation immédiate</div>
                <div class="resa-feature"><span class="check">✓</span> Paiement sécurisé</div>
                {% if activite.agemin > 0 %}
                    <div class="resa-feature"><span style="color:var(--color-primary-dark)">⚠</span> Âge minimum : {{ activite.agemin }} ans</div>
                {% endif %}
            </div>
        </div>
    </aside>
</div>
{% endblock %}

{% block javascripts %}
<script>
    // ── Onglets ──────────────────────────────────────────────────────────────
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('is-active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('is-active'));
            btn.classList.add('is-active');
            document.getElementById('tab-' + btn.dataset.tab).classList.add('is-active');
        });
    });

    // ── Calcul total réservation ─────────────────────────────────────────────
    const prix      = {{ activite.budget }};
    const adultes   = document.getElementById('nbAdultes');
    const enfants   = document.getElementById('nbEnfants');
    const totalEl   = document.getElementById('resaTotal');

    function updateTotal() {
        const nb    = parseInt(adultes.value || 1) + parseInt(enfants.value || 0);
        const total = nb * prix;
        totalEl.textContent = total + ' TND';
    }

    adultes.addEventListener('input', updateTotal);
    enfants.addEventListener('input', updateTotal);

    // ── Étoiles interactives (RTL trick) ────────────────────────────────────
    // Les étoiles sont dans l'ordre 5→1 pour le trick CSS pur
    // On s'assure que la valeur sélectionnée s'affiche correctement
    document.querySelectorAll('.star-rating label').forEach(label => {
        label.addEventListener('mouseenter', () => {
            const val = parseInt(label.getAttribute('for').replace('star', ''));
            document.querySelectorAll('.star-rating label').forEach(l => {
                const lVal = parseInt(l.getAttribute('for').replace('star', ''));
                l.style.color = lVal >= val ? '#f59e0b' : 'var(--color-border)';
            });
        });
    });
    document.querySelector('.star-rating').addEventListener('mouseleave', () => {
        document.querySelectorAll('.star-rating label').forEach(l => {
            l.style.color = '';
        });
    });
</script>
{% endblock %}
