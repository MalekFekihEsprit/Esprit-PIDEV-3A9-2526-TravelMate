{% extends 'base.html.twig' %}

{% block title %}Activités — TravelMate{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<style>

/* ═══════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════ */
.act-hero {
    position: relative;
    height: 480px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 3rem;
    display: flex;
    align-items: flex-end;
}
.act-hero__bg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to top, rgba(20,14,10,0.72) 0%, rgba(20,14,10,0.18) 55%, transparent 100%),
        url('/uploads/activites/rand.jpg') center/cover no-repeat;
    transform: scale(1.04);
    transition: transform 8s ease;
}
.act-hero:hover .act-hero__bg { transform: scale(1); }
.act-hero__content {
    position: relative;
    padding: 2.5rem 3rem;
    max-width: 640px;
}
.act-hero__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
}
.act-hero__title {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
}
.act-hero__desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 1.75rem;
}
.act-hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }
.btn-hero-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.5rem; border-radius: 999px;
    background: var(--color-primary); color: #fff;
    font: inherit; font-size: 0.92rem; font-weight: 600;
    border: none; cursor: pointer; text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-primary:hover { background: var(--color-primary-dark); transform: translateY(-1px); }
.btn-hero-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.5rem; border-radius: 999px;
    background: rgba(255,255,255,0.12); color: #fff;
    font: inherit; font-size: 0.92rem; font-weight: 500;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer; text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-ghost:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }

/* Stats hero */
.act-hero__stats {
    position: absolute; bottom: 2.5rem; right: 3rem;
    display: flex; gap: 1.5rem;
}
.hero-stat { text-align: center; color: #fff; }
.hero-stat__num { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 600; line-height: 1; }
.hero-stat__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }

/* ═══════════════════════════════════════════════════
   BANNIÈRE IA — section vedettes
═══════════════════════════════════════════════════ */
.ai-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, rgba(124,58,237,0.07) 0%, rgba(196,111,75,0.07) 100%);
    border: 1px solid rgba(124,58,237,0.2);
    border-radius: var(--radius-xl);
    padding: 0.9rem 1.4rem;
    margin-bottom: 1.5rem;
    font-size: 0.88rem;
    color: var(--color-text);
}
.ai-banner__icon {
    font-size: 1.3rem;
    flex-shrink: 0;
}
.ai-banner__text strong { color: #7c3aed; font-weight: 600; }
.ai-banner__text span   { color: var(--color-text-muted); }

/* ═══════════════════════════════════════════════════
   DESTINATION PICKER
═══════════════════════════════════════════════════ */
.dest-strip {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.75rem;
    box-shadow: 0 4px 20px var(--color-shadow);
    flex-wrap: wrap;
    gap: 1rem;
}
.dest-strip__label-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-shrink: 0;
    padding-right: 1.5rem;
    border-right: 1px solid var(--color-border);
    min-width: 0;
}
@media (max-width: 700px) {
    .dest-strip__label-col { border-right: none; padding-right: 0; border-bottom: 1px solid var(--color-border); padding-bottom: 1rem; width: 100%; }
}
.dest-strip__eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
}
.dest-strip__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
}

.dest-strip__input-col {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 1.5rem;
    min-width: 0;
}
@media (max-width: 700px) {
    .dest-strip__input-col { padding-left: 0; }
}

.dest-input-wrap {
    flex: 1;
    position: relative;
    min-width: 0;
}
.dest-input-wrap__icon {
    position: absolute;
    left: 1rem; top: 50%; transform: translateY(-50%);
    color: var(--color-primary);
    pointer-events: none;
}
.dest-input {
    width: 100%;
    padding: 0.85rem 1rem 0.85rem 2.75rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    font: inherit;
    font-size: 0.97rem;
    color: var(--color-text);
    background: var(--color-surface);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.dest-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(196,111,75,0.1);
}
.dest-input::placeholder { color: var(--color-text-muted); }

/* Suggestions autocomplete */
.dest-suggestions {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0; right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 12px 40px rgba(71,48,35,0.12);
    z-index: 200;
    overflow: hidden;
    display: none;
}
.dest-suggestions.is-open { display: block; }
.dest-suggestion {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text);
    transition: background var(--transition-fast);
}
.dest-suggestion:hover { background: var(--color-hover); }
.dest-suggestion svg { color: var(--color-text-muted); flex-shrink: 0; }
.dest-suggestion__main { font-weight: 500; }
.dest-suggestion__sub { font-size: 0.78rem; color: var(--color-text-muted); }

.dest-map-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--color-border);
    background: var(--color-surface-soft);
    font-size: 1.25rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
}
.dest-map-toggle:hover {
    border-color: var(--color-primary);
    background: rgba(196,111,75,0.08);
    transform: translateY(-1px);
}

/* Panneau carte */
.dest-map-panel {
    display: none;
    margin-top: -0.5rem;
    margin-bottom: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-surface);
    box-shadow: 0 8px 28px rgba(71,48,35,0.08);
}
.dest-map-panel.is-open { display: block; }
.dest-map-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface-soft);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.88rem;
    color: var(--color-text-muted);
}
.dest-map-panel__head strong { color: var(--color-text); font-weight: 600; }
.dest-map-panel__close {
    border: none;
    background: transparent;
    color: var(--color-primary);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    padding: 0.35rem 0.6rem;
    border-radius: 8px;
}
.dest-map-panel__close:hover { background: rgba(196,111,75,0.1); }
.dest-map-panel__map {
    height: min(52vh, 380px);
    width: 100%;
    background: var(--color-surface-soft);
}
.dest-map-panel__hint {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    padding: 0.5rem 1rem 0.65rem;
    margin: 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
}

/* Chip destination active */
.dest-active-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem 0.4rem 0.75rem;
    border-radius: 999px;
    background: rgba(196,111,75,0.1);
    border: 1px solid rgba(196,111,75,0.25);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-left: 0.5rem;
}
.dest-active-chip__clear {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
}
.dest-active-chip__clear:hover { opacity: 1; }

/* Banner résultats destination */
.dest-banner {
    display: none;
    align-items: center;
    gap: 0.75rem;
    background: rgba(196,111,75,0.06);
    border: 1px solid rgba(196,111,75,0.18);
    border-radius: var(--radius-lg);
    padding: 0.85rem 1.25rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text);
}
.dest-banner.is-visible { display: flex; }
.dest-banner svg { color: var(--color-primary); flex-shrink: 0; }
.dest-banner__text strong { color: var(--color-primary); }
.dest-banner__clear {
    margin-left: auto;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    white-space: nowrap;
}
.dest-banner__clear:hover { color: var(--color-primary); border-color: rgba(196,111,75,0.3); }

/* ═══════════════════════════════════════════════════
   BARRE FILTRES
═══════════════════════════════════════════════════ */
.filters-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
}
.filters-bar__left { flex: 1; display: flex; gap: 0.65rem; flex-wrap: wrap; align-items: center; }

.search-field { position: relative; min-width: 220px; flex: 1; max-width: 300px; }
.search-field__icon {
    position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
    color: var(--color-text-muted); pointer-events: none;
}
.search-field__input {
    width: 100%; padding: 0.72rem 1rem 0.72rem 2.6rem;
    border: 1px solid var(--color-border); border-radius: 999px;
    background: var(--color-surface); font: inherit; font-size: 0.9rem; color: var(--color-text);
    outline: none; transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.search-field__input:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(196,111,75,0.1); }

.filter-pill-select {
    padding: 0.72rem 1rem;
    border: 1px solid var(--color-border); border-radius: 999px;
    background: var(--color-surface); font: inherit; font-size: 0.9rem; color: var(--color-text-muted);
    outline: none; cursor: pointer;
    transition: border-color var(--transition-fast); min-width: 160px;
}
.filter-pill-select:focus { border-color: var(--color-primary); }

/* Chips catégories */
.cat-chips { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
.cat-chip {
    padding: 0.45rem 1rem; border-radius: 999px;
    border: 1px solid var(--color-border); background: var(--color-surface);
    font: inherit; font-size: 0.85rem; color: var(--color-text-muted);
    cursor: pointer; transition: all var(--transition-fast); white-space: nowrap;
}
.cat-chip:hover, .cat-chip.is-active {
    background: var(--color-primary); border-color: var(--color-primary); color: #fff;
}

/* Compteur */
.results-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
.results-count { font-size: 0.88rem; color: var(--color-text-muted); }
.results-count strong { color: var(--color-text); font-weight: 600; }

/* ═══════════════════════════════════════════════════
   GRILLE CARTES
═══════════════════════════════════════════════════ */
.act-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
}
.act-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-xl); overflow: hidden;
    display: flex; flex-direction: column; text-decoration: none; color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    position: relative;
}
.act-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(71,48,35,0.11);
    border-color: rgba(196,111,75,0.25);
}

/* Carte vedette IA : bordure violette subtile */
.act-card--vedette {
    border-color: rgba(124,58,237,0.3);
    box-shadow: 0 0 0 1px rgba(124,58,237,0.12), 0 4px 20px rgba(124,58,237,0.08);
}
.act-card--vedette:hover {
    border-color: rgba(124,58,237,0.5);
    box-shadow: 0 20px 48px rgba(124,58,237,0.15);
}

.act-card__img-wrap { position: relative; height: 210px; overflow: hidden; background: var(--color-surface-soft); }
.act-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.act-card:hover .act-card__img { transform: scale(1.06); }
.act-card__img-placeholder {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--color-surface-soft), var(--color-border));
    color: var(--color-text-muted);
}
.act-card__img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(20,14,10,0.55) 0%, transparent 45%);
    pointer-events: none;
}
.act-card__badges { position: absolute; top: 0.85rem; left: 0.85rem; display: flex; gap: 0.35rem; flex-wrap: wrap; }
.badge { padding: 0.28rem 0.65rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em; backdrop-filter: blur(8px); }
.badge--trending { background: rgba(196,111,75,0.9); color: #fff; }
.badge--cat { background: rgba(255,253,249,0.92); color: var(--color-primary); border: 1px solid rgba(196,111,75,0.2); }

/* Badge vedette IA */
.badge--vedette {
    background: rgba(124,58,237,0.88);
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.3rem;
}

.act-card__rating {
    position: absolute; bottom: 0.75rem; left: 0.85rem;
    display: flex; align-items: center; gap: 0.3rem;
    color: #fff; font-size: 0.82rem; font-weight: 600;
}
.act-card__rating .star { color: #f59e0b; }

.act-card__body { padding: 1.1rem 1.25rem 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
.act-card__name { font-family: 'Fraunces', serif; font-size: 1.05rem; font-weight: 600; color: var(--color-text); line-height: 1.25; }
.act-card__location { display: flex; align-items: center; gap: 0.35rem; font-size: 0.82rem; color: var(--color-text-muted); }

.act-card__location mark {
    background: rgba(196,111,75,0.15);
    color: var(--color-primary);
    border-radius: 3px;
    padding: 0 2px;
}

/* Résumé IA sous le nom */
.act-card__ai-summary {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: #7c3aed;
    background: rgba(124,58,237,0.06);
    border: 1px solid rgba(124,58,237,0.12);
    border-radius: 8px;
    padding: 0.45rem 0.7rem;
    line-height: 1.4;
}
.act-card__ai-summary-icon { flex-shrink: 0; font-size: 0.9rem; margin-top: 0.05rem; }

/* Score IA discret */
.act-card__ai-score {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.74rem;
    color: var(--color-text-muted);
}
.act-card__ai-score-bar {
    flex: 1;
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
}
.act-card__ai-score-fill {
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(90deg, #7c3aed, #c46f4b);
    transition: width 0.6s ease;
}

.act-card__tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
.tag {
    padding: 0.22rem 0.65rem; border-radius: 999px;
    border: 1px solid var(--color-border);
    font-size: 0.72rem; font-weight: 500; color: var(--color-text-muted);
    background: var(--color-surface-soft);
}
.tag--facile        { border-color: rgba(47,127,121,0.3); color: var(--color-secondary); background: rgba(47,127,121,0.06); }
.tag--intermediaire { border-color: rgba(180,140,40,0.3); color: #7a5e08; background: rgba(180,140,40,0.07); }
.tag--difficile     { border-color: rgba(196,111,75,0.3); color: var(--color-primary-dark); background: rgba(196,111,75,0.07); }
.tag--expert        { border-color: rgba(160,50,50,0.3); color: #8b1a1a; background: rgba(160,50,50,0.07); }

.act-card__footer {
    display: flex; align-items: flex-end; justify-content: space-between; margin-top: auto; padding-top: 0.5rem;
}
.act-price-label { font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.1rem; }
.act-price-value { font-family: 'Fraunces', serif; font-size: 1.25rem; font-weight: 600; color: var(--color-primary); }
.act-price-unit  { font-family: 'Outfit', sans-serif; font-size: 0.78rem; font-weight: 400; color: var(--color-text-muted); }
.act-card__arrow {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--color-surface-soft); border: 1px solid var(--color-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--color-primary);
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.act-card:hover .act-card__arrow {
    background: var(--color-primary); color: #fff; transform: translateX(3px);
}

/* Vide */
.act-empty { grid-column: 1/-1; padding: 4rem 2rem; text-align: center; color: var(--color-text-muted); }
.act-empty__title { font-size: 1.15rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.4rem; margin-top: 0.75rem; }

</style>
{% endblock %}

{% block body %}

{% include '_travelmate_mymemory_translate.html.twig' %}

{# ════════════════════════════════════════
   HERO
════════════════════════════════════════ #}
<section class="act-hero">
    <div class="act-hero__bg"></div>
    <div class="act-hero__content">
        <span class="act-hero__eyebrow" data-translate="true">Explorez & Découvrez</span>
        <h1 class="act-hero__title" data-translate="true">Des activités pour chaque voyageur</h1>
        <p class="act-hero__desc" data-translate="true">
            Randonnées, sorties nautiques, ateliers culturels —
            réservez des expériences uniques adaptées à votre rythme et vos envies.
        </p>
        <div class="act-hero__actions">
            <a href="#activites" class="btn-hero-primary">
                <span data-translate="true">Explorer les activités</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="{{ path('app_evenements') }}" class="btn-hero-ghost" data-translate="true">Voir les événements</a>
        </div>
    </div>
    <div class="act-hero__stats">
        <div class="hero-stat">
            <div class="hero-stat__num">{{ activites|length }}</div>
            <div class="hero-stat__label" data-translate="true">Activités</div>
        </div>
        <div class="hero-stat">
            <div class="hero-stat__num">{{ categories|length }}</div>
            <div class="hero-stat__label" data-translate="true">Catégories</div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════
   SECTION ACTIVITÉS
════════════════════════════════════════ #}
<div id="activites">

    {# ── Bannière IA (uniquement si scoreMap disponible) ── #}
    {% if scoreMap is defined and scoreMap|length > 0 %}
        {% set nbVedettes = 0 %}
        {% for s in scoreMap %}{% if s.recommended %}{% set nbVedettes = nbVedettes + 1 %}{% endif %}{% endfor %}
        <div class="ai-banner">
            <span class="ai-banner__icon">✨</span>
            <div class="ai-banner__text">
                <strong data-translate="true">Recommandé par l'IA</strong>
                <span data-translate="true"> — Les activités sont triées par score IA basé sur l'analyse de vos avis.</span>
                {% if nbVedettes > 0 %}
                    <span style="color:var(--color-text-muted)"> · <strong style="color:#7c3aed">{{ nbVedettes }} vedette{{ nbVedettes > 1 ? 's' : '' }}</strong> mise{{ nbVedettes > 1 ? 's' : '' }} en avant.</span>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {# ── Destination Picker ── #}
    <div class="dest-strip">
        <div class="dest-strip__label-col">
            <div class="dest-strip__eyebrow" data-translate="true">Destination</div>
            <div class="dest-strip__title" data-translate="true">Choisissez votre destination</div>
        </div>
        <div class="dest-strip__input-col">
            <div class="dest-input-wrap">
                <span class="dest-input-wrap__icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/></svg>
                </span>
                <input
                    type="text"
                    class="dest-input"
                    id="destInput"
                    placeholder="Vous partez où ?"
                    autocomplete="off"
                    data-translate="true"
                >
                <div class="dest-suggestions" id="destSuggestions"></div>
            </div>
            <button type="button" class="dest-map-toggle" id="destMapToggle" title="Ouvrir ou fermer la carte" aria-expanded="false" aria-controls="destMapPanel">🗺️</button>
        </div>
    </div>

    {# Carte interactive #}
    <div id="destMapPanel" class="dest-map-panel" aria-hidden="true" role="region" aria-label="Carte destination">
        <div class="dest-map-panel__head">
            <span><strong>Carte</strong> — cliquez sur un point pour filtrer les activités à proximité</span>
            <button type="button" class="dest-map-panel__close" id="destMapClose">Fermer</button>
        </div>
        <div id="destMapContainer" class="dest-map-panel__map"></div>
        <p class="dest-map-panel__hint">Fonds de carte © OpenStreetMap · Adresse via Nominatim</p>
    </div>

    {# ── Banner résultat destination ── #}
    <div class="dest-banner" id="destBanner">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="currentColor"/></svg>
        <span class="dest-banner__text" id="destBannerText"></span>
        <button class="dest-banner__clear" id="destBannerClear" data-translate="true">Voir toutes les activités</button>
    </div>

    {# ── Chips catégories ── #}
    <div class="cat-chips">
        <button class="cat-chip is-active" data-cat="" data-translate="true">Toutes</button>
        {% for cat in categories %}
            <button class="cat-chip" data-cat="{{ cat.id }}" data-translate="true" data-original="{{ cat.nom }}">{{ cat.nom }}</button>
        {% endfor %}
    </div>

    {# ── Barre de filtres ── #}
    <div class="filters-bar">
        <div class="filters-bar__left">
            <div class="search-field">
                <span class="search-field__icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <input type="search" class="search-field__input" id="searchInput" placeholder="Rechercher une activité…" data-translate="true">
            </div>
            <select class="filter-pill-select" id="diffFilter">
                <option value="" data-translate="true">Toute difficulté</option>
                <option value="facile" data-translate="true">Facile</option>
                <option value="intermediaire" data-translate="true">Intermédiaire</option>
                <option value="difficile" data-translate="true">Difficile</option>
                <option value="expert" data-translate="true">Expert</option>
            </select>
            <select class="filter-pill-select" id="budgetFilter">
                <option value="" data-translate="true">Tout budget</option>
                <option value="0-50" data-translate="true">Moins de 50 TND</option>
                <option value="50-150" data-translate="true">50 – 150 TND</option>
                <option value="150+" data-translate="true">Plus de 150 TND</option>
            </select>
        </div>
    </div>

    {# ── Compteur ── #}
    <div class="results-row">
        <p class="results-count">
            <strong id="countNum">{{ activites|length }}</strong>
            <span data-translate="true">activité{% if activites|length != 1 %}s{% endif %} disponible{% if activites|length != 1 %}s{% endif %}</span>
        </p>
    </div>

    {# ── Grille ── #}
    <div class="act-grid" id="actGrid">
        {% if activites is empty %}
            <div class="act-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" style="margin:0 auto;color:var(--color-border)"><path d="M3 7h18M3 12h18M3 17h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <div class="act-empty__title" data-translate="true">Aucune activité disponible</div>
                <p data-translate="true">Revenez bientôt, de nouvelles expériences arrivent.</p>
            </div>
        {% else %}
            {% for activite in activites %}
                {# Récupérer les infos IA pour cette activité (null si IA indisponible) #}
                {% set aiInfo  = (scoreMap is defined and scoreMap[activite.id] is defined) ? scoreMap[activite.id] : null %}
                {% set vedette = aiInfo and aiInfo.recommended %}

                {% set moyenne = activite.moyenneAvis %}
                {% set nbAvis  = activite.avis|length %}
                {% set diff    = activite.niveaudifficulte|lower %}

                <a href="{{ path('app_activite_show', {id: activite.id}) }}"
                   class="act-card{% if vedette %} act-card--vedette{% endif %}"
                   data-nom="{{ activite.nom|lower }}"
                   data-cat="{{ activite.categorie ? activite.categorie.id : '' }}"
                   data-diff="{{ activite.niveaudifficulte|lower }}"
                   data-budget="{{ activite.budget }}"
                   data-lieu="{{ activite.lieu|default('')|lower }}"
                   data-lat="{{ activite.latitude is not null ? activite.latitude : '' }}"
                   data-lng="{{ activite.longitude is not null ? activite.longitude : '' }}">

                    <div class="act-card__img-wrap">
                        {% if activite.imagePath %}
                            <img src="{{ asset(activite.imagePath) }}"
                                 alt="{{ activite.nom }}" class="act-card__img"
                                 onerror="this.style.display='none';this.parentElement.querySelector('.act-card__img-placeholder').style.display='flex'">
                        {% endif %}
                        <div class="act-card__img-placeholder" style="{{ activite.imagePath ? 'display:none' : '' }}">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <div class="act-card__img-overlay"></div>

                        <div class="act-card__badges">
                            {# Badge vedette IA — priorité maximale, affiché en premier #}
                            {% if vedette %}
                                <span class="badge badge--vedette">✨ Vedette IA</span>
                            {% elseif nbAvis >= 3 and moyenne >= 4 %}
                                <span class="badge badge--trending" data-translate="true">Populaire</span>
                            {% endif %}
                            {% if activite.categorie %}
                                <span class="badge badge--cat" data-translate="true" data-original="{{ activite.categorie.nom }}">{{ activite.categorie.nom }}</span>
                            {% endif %}
                        </div>

                        {% if nbAvis > 0 %}
                            <div class="act-card__rating">
                                <span class="star">&#9733;</span>
                                <span>{{ moyenne }}</span>
                                <span style="opacity:.7">({{ nbAvis }})</span>
                            </div>
                        {% endif %}
                    </div>

                    <div class="act-card__body">
                        <div class="act-card__name" data-translate="true" data-original="{{ activite.nom }}">{{ activite.nom }}</div>

                        {% if activite.lieu %}
                            <div class="act-card__location" data-location="{{ activite.lieu|lower }}">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                                <span class="location-text" data-translate="true" data-original="{{ activite.lieu|slice(0,42) }}{{ activite.lieu|length > 42 ? '…' : '' }}">{{ activite.lieu|slice(0,42) }}{{ activite.lieu|length > 42 ? '…' : '' }}</span>
                            </div>
                        {% endif %}

                        {# Résumé IA — affiché uniquement si l'IA a retourné un résumé #}
                        {% if aiInfo and aiInfo.ai_summary is defined and aiInfo.ai_summary %}
                            <div class="act-card__ai-summary">
                                <span class="act-card__ai-summary-icon">🤖</span>
                                <span>{{ aiInfo.ai_summary }}</span>
                            </div>
                        {% endif %}

                        {# Barre de score IA #}
                        {% if aiInfo and aiInfo.ai_score is defined %}
                            {% set scorePct = ((aiInfo.ai_score / 10) * 100)|round %}
                            <div class="act-card__ai-score">
                                <span style="white-space:nowrap;font-size:0.7rem">Score IA</span>
                                <div class="act-card__ai-score-bar">
                                    <div class="act-card__ai-score-fill" style="width:{{ scorePct }}%"></div>
                                </div>
                                <span>{{ aiInfo.ai_score }}/10</span>
                            </div>
                        {% endif %}

                        <div class="act-card__tags">
                            <span class="tag tag--{{ diff }}" data-translate="true" data-original="{{ activite.niveaudifficulte }}">{{ activite.niveaudifficulte }}</span>
                            <span class="tag">{{ activite.duree }}h</span>
                            <span class="tag">+{{ activite.agemin }} <span data-translate="true">ans</span></span>
                        </div>

                        <div class="act-card__footer">
                            <div>
                                <div class="act-price-label" data-translate="true">À partir de</div>
                                <div class="act-price-value">{{ activite.budget }} <span class="act-price-unit">TND</span></div>
                            </div>
                            <div class="act-card__arrow">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        {% endif %}
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/travelmate-mymemory-translate.js') }}"></script>
<script>
(function () {
    function bootTranslate() {
        if (window.TravelMateTranslate) {
            TravelMateTranslate.init({ sourceLang: 'fr' });
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootTranslate);
    } else {
        bootTranslate();
    }
})();
</script>
<script>window.TRAVELMATE_NOMINATIM_EMAIL = '';</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script src="{{ asset('js/activite-list-filters.js') }}"></script>
{% endblock %}
