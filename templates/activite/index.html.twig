{% extends 'base.html.twig' %}

{% block title %}Activités — TravelMate{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

/* ═══════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════ */
.act-hero {
    position: relative;
    height: 480px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 3rem;
    display: flex;
    align-items: flex-end;
}

.act-hero__bg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to top, rgba(20,14,10,0.72) 0%, rgba(20,14,10,0.18) 55%, transparent 100%),
        url('/uploads/activites/rand.jpg') center/cover no-repeat;
    transform: scale(1.04);
    transition: transform 8s ease;
}
.act-hero:hover .act-hero__bg { transform: scale(1); }

.act-hero__content {
    position: relative;
    padding: 2.5rem 3rem;
    max-width: 640px;
}

.act-hero__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
}

.act-hero__title {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
}

.act-hero__desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 1.75rem;
}

.act-hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
}

.btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-primary:hover { background: var(--color-primary-dark); transform: translateY(-1px); }

.btn-hero-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: #fff;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-ghost:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }

/* Stats dans le hero */
.act-hero__stats {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    display: flex;
    gap: 1.5rem;
}
.hero-stat {
    text-align: center;
    color: #fff;
}
.hero-stat__num {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1;
}
.hero-stat__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
    margin-top: 0.2rem;
}

/* ═══════════════════════════════════════════════════
   BARRE FILTRES
═══════════════════════════════════════════════════ */
.filters-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
}

.filters-bar__left {
    flex: 1;
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    align-items: center;
}

.search-field {
    position: relative;
    min-width: 220px;
    flex: 1;
    max-width: 300px;
}
.search-field__icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
}
.search-field__input {
    width: 100%;
    padding: 0.72rem 1rem 0.72rem 2.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    font: inherit;
    font-size: 0.9rem;
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.search-field__input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(196,111,75,0.1);
}

.filter-pill-select {
    padding: 0.72rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    font: inherit;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    outline: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
    min-width: 160px;
}
.filter-pill-select:focus { border-color: var(--color-primary); }

/* Chips catégories */
.cat-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
}
.cat-chip {
    padding: 0.45rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    font: inherit;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
}
.cat-chip:hover,
.cat-chip.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
}

/* Compteur + vue toggle */
.results-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
}
.results-count {
    font-size: 0.88rem;
    color: var(--color-text-muted);
}
.results-count strong { color: var(--color-text); font-weight: 600; }

/* ═══════════════════════════════════════════════════
   GRILLE CARTES
═══════════════════════════════════════════════════ */
.act-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
}

/* Carte */
.act-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
}
.act-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(71,48,35,0.11);
    border-color: rgba(196,111,75,0.25);
}

/* Image */
.act-card__img-wrap {
    position: relative;
    height: 210px;
    overflow: hidden;
    background: var(--color-surface-soft);
}
.act-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}
.act-card:hover .act-card__img { transform: scale(1.06); }
.act-card__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-surface-soft), var(--color-border));
    color: var(--color-text-muted);
    font-size: 2.5rem;
}

/* Overlay gradient sur l'image */
.act-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,14,10,0.55) 0%, transparent 45%);
    pointer-events: none;
}

/* Badges */
.act-card__badges {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
}
.badge {
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
}
.badge--trending { background: rgba(196,111,75,0.9); color: #fff; }
.badge--cat { background: rgba(255,253,249,0.92); color: var(--color-primary); border: 1px solid rgba(196,111,75,0.2); }
.badge--active   { background: rgba(47,127,121,0.88);  color: #fff; }
.badge--inactive { background: rgba(100,100,100,0.75); color: #fff; }
.badge--attente  { background: rgba(180,140,40,0.85);  color: #fff; }

/* Rating (en bas de l'image) */
.act-card__rating {
    position: absolute;
    bottom: 0.75rem;
    left: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
}
.act-card__rating .star { color: #f59e0b; }

/* Corps */
.act-card__body {
    padding: 1.1rem 1.25rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}
.act-card__name {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.25;
}
.act-card__location {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
}
.act-card__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.15rem;
}
.tag {
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    background: var(--color-surface-soft);
}
.tag--facile   { border-color: rgba(47,127,121,0.3); color: var(--color-secondary); }
.tag--moyen    { border-color: rgba(180,140,40,0.3);  color: #8a6b0a; }
.tag--difficile{ border-color: rgba(196,111,75,0.3);  color: var(--color-primary); }
.tag--expert   { border-color: rgba(160,50,50,0.3);   color: #8b1a1a; }

/* Footer carte */
.act-card__footer {
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.act-price-label { font-size: 0.72rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.act-price-value {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-primary);
}
.act-price-unit { font-size: 0.78rem; font-weight: 400; color: var(--color-text-muted); font-family: 'Outfit', sans-serif; }
.act-card__arrow {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--color-text-muted);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
    flex-shrink: 0;
}
.act-card:hover .act-card__arrow {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
}

/* Vide */
.act-empty {
    grid-column: 1/-1;
    padding: 4rem 2rem;
    text-align: center;
    color: var(--color-text-muted);
}
.act-empty__title { font-size: 1.15rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.4rem; margin-top: 0.75rem; }

</style>
{% endblock %}

{% block body %}

{# ════════════════════════════════════════
   HERO
════════════════════════════════════════ #}
<section class="act-hero">
    <div class="act-hero__bg"></div>

    <div class="act-hero__content">
        <span class="act-hero__eyebrow">Explorez & Découvrez</span>
        <h1 class="act-hero__title">
            Des activités pour chaque voyageur
        </h1>
        <p class="act-hero__desc">
            Randonnées, sorties nautiques, ateliers culturels —
            réservez des expériences uniques adaptées à votre rythme et vos envies.
        </p>
        <div class="act-hero__actions">
            <a href="#activites" class="btn-hero-primary">
                Explorer les activités
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="{{ path('app_evenements') }}" class="btn-hero-ghost">
                Voir les événements
            </a>
        </div>
    </div>

    <div class="act-hero__stats">
        <div class="hero-stat">
            <div class="hero-stat__num">{{ activites|length }}</div>
            <div class="hero-stat__label">Activités</div>
        </div>
        <div class="hero-stat">
            <div class="hero-stat__num">{{ categories|length }}</div>
            <div class="hero-stat__label">Catégories</div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════
   SECTION ACTIVITÉS
════════════════════════════════════════ #}
<div id="activites">

    {# Chips catégories #}
    <div class="cat-chips">
        <button class="cat-chip is-active" data-cat="">Toutes</button>
        {% for cat in categories %}
            <button class="cat-chip" data-cat="{{ cat.id }}">{{ cat.nom }}</button>
        {% endfor %}
    </div>

    {# Barre de filtres #}
    <div class="filters-bar">
        <div class="filters-bar__left">
            <div class="search-field">
                <span class="search-field__icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <input type="search" class="search-field__input" id="searchInput" placeholder="Rechercher une activité…">
            </div>

            <select class="filter-pill-select" id="diffFilter">
                <option value="">Toute difficulté</option>
                <option value="Facile">Facile</option>
                <option value="Moyen">Moyen</option>
                <option value="Difficile">Difficile</option>
                <option value="Expert">Expert</option>
            </select>

            <select class="filter-pill-select" id="budgetFilter">
                <option value="">Tout budget</option>
                <option value="0-50">Moins de 50 TND</option>
                <option value="50-150">50 – 150 TND</option>
                <option value="150+">Plus de 150 TND</option>
            </select>
        </div>
    </div>

    {# Compteur #}
    <div class="results-row">
        <p class="results-count">
            <strong id="countNum">{{ activites|length }}</strong>
            activité{% if activites|length != 1 %}s{% endif %} disponible{% if activites|length != 1 %}s{% endif %}
        </p>
    </div>

    {# Grille #}
    <div class="act-grid" id="actGrid">
        {% if activites is empty %}
            <div class="act-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" style="margin:0 auto;color:var(--color-border)"><path d="M3 7h18M3 12h18M3 17h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <div class="act-empty__title">Aucune activité disponible</div>
                <p>Revenez bientôt, de nouvelles expériences arrivent.</p>
            </div>
        {% else %}
            {% for activite in activites %}
                {% set moyenne = activite.moyenneAvis %}
                {% set nbAvis  = activite.avis|length %}
                {% set diff    = activite.niveaudifficulte|lower %}
                {% set statut  = activite.statut|lower %}

                <a href="{{ path('app_activite_show', {id: activite.id}) }}"
                   class="act-card"
                   data-nom="{{ activite.nom|lower }}"
                   data-cat="{{ activite.categorie ? activite.categorie.id : '' }}"
                   data-diff="{{ activite.niveaudifficulte }}"
                   data-budget="{{ activite.budget }}">

                    {# Image #}
                    <div class="act-card__img-wrap">
                        {% if activite.imagePath %}
                            <img src="{{ asset('uploads/activites/' ~ activite.imagePath) }}"
                                 alt="{{ activite.nom }}"
                                 class="act-card__img"
                                 onerror="this.style.display='none';this.parentElement.querySelector('.act-card__img-placeholder').style.display='flex'">
                        {% endif %}
                        <div class="act-card__img-placeholder" style="{{ activite.imagePath ? 'display:none' : '' }}">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <div class="act-card__img-overlay"></div>

                        {# Badges #}
                        <div class="act-card__badges">
                            {% if nbAvis >= 3 and moyenne >= 4 %}
                                <span class="badge badge--trending">Populaire</span>
                            {% endif %}
                            {% if activite.categorie %}
                                <span class="badge badge--cat">{{ activite.categorie.nom }}</span>
                            {% endif %}
                        </div>

                        {# Rating #}
                        {% if nbAvis > 0 %}
                            <div class="act-card__rating">
                                <span class="star">★</span>
                                <span>{{ moyenne }}</span>
                                <span style="opacity:.7">({{ nbAvis }})</span>
                            </div>
                        {% endif %}
                    </div>

                    {# Corps #}
                    <div class="act-card__body">
                        <div class="act-card__name">{{ activite.nom }}</div>

                        {% if activite.lieu %}
                            <div class="act-card__location">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                                {{ activite.lieu|slice(0,42) }}{{ activite.lieu|length > 42 ? '…' : '' }}
                            </div>
                        {% endif %}

                        <div class="act-card__tags">
                            <span class="tag tag--{{ diff }}">{{ activite.niveaudifficulte }}</span>
                            <span class="tag">{{ activite.duree }}h</span>
                            <span class="tag">+{{ activite.agemin }} ans</span>
                        </div>

                        <div class="act-card__footer">
                            <div>
                                <div class="act-price-label">À partir de</div>
                                <div class="act-price-value">
                                    {{ activite.budget }}
                                    <span class="act-price-unit">TND</span>
                                </div>
                            </div>
                            <div class="act-card__arrow">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        {% endif %}
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
(function() {
    const searchInput  = document.getElementById('searchInput');
    const diffFilter   = document.getElementById('diffFilter');
    const budgetFilter = document.getElementById('budgetFilter');
    const catChips     = document.querySelectorAll('.cat-chip');
    const cards        = document.querySelectorAll('.act-card[data-nom]');
    const countEl      = document.getElementById('countNum');

    let activeCat = '';

    function filter() {
        const q      = searchInput.value.toLowerCase().trim();
        const diff   = diffFilter.value.toLowerCase();
        const budget = budgetFilter.value;
        let visible  = 0;

        cards.forEach(card => {
            const matchNom    = card.dataset.nom.includes(q);
            const matchCat    = !activeCat || card.dataset.cat === activeCat;
            const matchDiff   = !diff || card.dataset.diff.toLowerCase() === diff;
            const b           = parseInt(card.dataset.budget) || 0;
            const matchBudget = !budget ||
                (budget === '0-50'   && b <= 50)  ||
                (budget === '50-150' && b > 50 && b <= 150) ||
                (budget === '150+'   && b > 150);

            const show = matchNom && matchCat && matchDiff && matchBudget;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        if (countEl) countEl.textContent = visible;
    }

    // Events filtres
    searchInput.addEventListener('input', filter);
    diffFilter.addEventListener('change', filter);
    budgetFilter.addEventListener('change', filter);

    // Chips catégories
    catChips.forEach(chip => {
        chip.addEventListener('click', () => {
            catChips.forEach(c => c.classList.remove('is-active'));
            chip.classList.add('is-active');
            activeCat = chip.dataset.cat;
            filter();
        });
    });

    // Scroll doux vers la section
    document.querySelector('a[href="#activites"]')?.addEventListener('click', e => {
        e.preventDefault();
        document.getElementById('activites').scrollIntoView({ behavior: 'smooth' });
    });
})();
</script>
{% endblock %}
