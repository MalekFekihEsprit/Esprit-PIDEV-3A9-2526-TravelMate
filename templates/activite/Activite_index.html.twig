{% extends 'base.html.twig' %}

{% block title %}Activités — TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Hero ── */
        .act-hero {
            background: linear-gradient(135deg, rgba(196,111,75,0.12) 0%, rgba(47,127,121,0.08) 100%);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            padding: 2.5rem 2rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            flex-wrap: wrap;
        }
        .act-hero__title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--color-text);
            line-height: 1.15;
        }
        .act-hero__title span { color: var(--color-primary); }
        .act-hero__sub {
            color: var(--color-text-muted);
            font-size: 1rem;
            margin-top: 0.4rem;
        }

        /* ── Filtres & Recherche ── */
        .act-filters {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 1.75rem;
        }
        .act-search {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 340px;
        }
        .act-search__icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-text-muted);
            pointer-events: none;
        }
        .act-search__input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.75rem;
            border: 1px solid var(--color-border);
            border-radius: 999px;
            background: var(--color-surface);
            font: inherit;
            font-size: 0.92rem;
            color: var(--color-text);
            outline: none;
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }
        .act-search__input:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196,111,75,0.12);
        }
        .filter-select {
            padding: 0.75rem 1.1rem;
            border: 1px solid var(--color-border);
            border-radius: 999px;
            background: var(--color-surface);
            font: inherit;
            font-size: 0.92rem;
            color: var(--color-text-muted);
            outline: none;
            cursor: pointer;
            transition: border-color var(--transition-fast);
        }
        .filter-select:focus { border-color: var(--color-primary); }

        /* ── Compteur ── */
        .act-count {
            font-size: 0.88rem;
            color: var(--color-text-muted);
            margin-bottom: 1.25rem;
        }
        .act-count strong { color: var(--color-primary); }

        /* ── Grille ── */
        .act-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        /* ── Carte ── */
        .act-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
        }
        .act-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 40px rgba(71,48,35,0.10);
            border-color: rgba(196,111,75,0.3);
        }

        /* Image */
        .act-card__img-wrap {
            position: relative;
            height: 200px;
            overflow: hidden;
            background: var(--color-surface-soft);
        }
        .act-card__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }
        .act-card:hover .act-card__img { transform: scale(1.05); }
        .act-card__img-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-text-muted);
            font-size: 3rem;
        }

        /* Badges sur l'image */
        .act-card__badges {
            position: absolute;
            top: 0.75rem;
            left: 0.75rem;
            display: flex;
            gap: 0.4rem;
            flex-wrap: wrap;
        }
        .badge {
            padding: 0.3rem 0.7rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.02em;
        }
        .badge--fire {
            background: rgba(220,50,30,0.88);
            color: #fff;
            backdrop-filter: blur(6px);
        }
        .badge--cat {
            background: rgba(255,253,249,0.9);
            color: var(--color-primary);
            border: 1px solid rgba(196,111,75,0.25);
            backdrop-filter: blur(6px);
        }
        .badge--statut-active   { background: rgba(47,127,121,0.9);  color:#fff; }
        .badge--statut-inactive { background: rgba(150,150,150,0.85); color:#fff; }
        .badge--statut-attente  { background: rgba(200,160,50,0.88);  color:#fff; }

        /* Étoiles */
        .act-card__rating {
            position: absolute;
            bottom: 0.75rem;
            right: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            background: rgba(255,253,249,0.92);
            border: 1px solid rgba(231,220,205,0.8);
            border-radius: 999px;
            padding: 0.3rem 0.65rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--color-text);
            backdrop-filter: blur(6px);
        }
        .stars { color: #f59e0b; letter-spacing: -1px; }

        /* Corps de la carte */
        .act-card__body {
            padding: 1.25rem;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }
        .act-card__name {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-text);
            line-height: 1.2;
        }
        .act-card__meta {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.83rem;
            color: var(--color-text-muted);
        }
        .act-card__price {
            margin-top: auto;
            padding-top: 0.75rem;
            border-top: 1px solid var(--color-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .price-label { font-size: 0.78rem; color: var(--color-text-muted); }
        .price-value {
            font-family: 'Fraunces', serif;
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--color-primary);
        }
        .price-unit { font-size: 0.8rem; color: var(--color-text-muted); }
        .act-card__cta {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--color-secondary);
        }

        /* ── Vide ── */
        .act-empty {
            grid-column: 1/-1;
            text-align: center;
            padding: 4rem 2rem;
            color: var(--color-text-muted);
        }
        .act-empty__icon { font-size: 3.5rem; margin-bottom: 1rem; }
        .act-empty__title { font-size: 1.2rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.4rem; }

        /* ── Difficile pill ── */
        .diff-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.2rem 0.55rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 500;
        }
        .diff-pill--facile  { background: rgba(47,127,121,0.1);  color: var(--color-secondary); }
        .diff-pill--moyen   { background: rgba(200,160,50,0.12); color: #9a7a10; }
        .diff-pill--difficile { background: rgba(196,111,75,0.12); color: var(--color-primary-dark); }
        .diff-pill--expert  { background: rgba(150,30,30,0.1);   color: #8b1a1a; }
    </style>
{% endblock %}

{% block body %}
{# ── Hero ── #}
<div class="act-hero">
    <div>
        <h1 class="act-hero__title">Nos <span>Activités</span></h1>
        <p class="act-hero__sub">Découvrez des expériences uniques dans chaque destination</p>
    </div>
    <a href="{{ path('app_evenements') }}" class="btn btn--secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M8 7V3m8 4V3M3 11h18M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Voir les Événements
    </a>
</div>

{# ── Filtres ── #}
<div class="act-filters">
    <div class="act-search">
        <span class="act-search__icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </span>
        <input
            type="search"
            class="act-search__input"
            id="searchInput"
            placeholder="Rechercher une activité…"
            value="{{ searchQuery ?? '' }}"
        >
    </div>

    <select class="filter-select" id="catFilter">
        <option value="">Toutes les catégories</option>
        {% for cat in categories %}
            <option value="{{ cat.id }}" {{ (selectedCat ?? '') == cat.id ? 'selected' : '' }}>
                {{ cat.nom }}
            </option>
        {% endfor %}
    </select>

    <select class="filter-select" id="diffFilter">
        <option value="">Toute difficulté</option>
        <option value="Facile"    {{ (selectedDiff ?? '') == 'Facile'    ? 'selected' : '' }}>Facile</option>
        <option value="Moyen"     {{ (selectedDiff ?? '') == 'Moyen'     ? 'selected' : '' }}>Moyen</option>
        <option value="Difficile" {{ (selectedDiff ?? '') == 'Difficile' ? 'selected' : '' }}>Difficile</option>
        <option value="Expert"    {{ (selectedDiff ?? '') == 'Expert'    ? 'selected' : '' }}>Expert</option>
    </select>
</div>

<p class="act-count">
    <strong>{{ activites|length }}</strong> activité{{ activites|length != 1 ? 's' : '' }} trouvée{{ activites|length != 1 ? 's' : '' }}
</p>

{# ── Grille ── #}
<div class="act-grid" id="actGrid">
    {% if activites is empty %}
        <div class="act-empty">
            <div class="act-empty__icon">🏖️</div>
            <div class="act-empty__title">Aucune activité disponible</div>
            <p>Revenez bientôt, de nouvelles aventures arrivent !</p>
        </div>
    {% else %}
        {% for activite in activites %}
            {% set moyenneAvis = activite.moyenneAvis %}
            {% set nbAvis = activite.avis|length %}
            {% set isTrending = nbAvis >= 3 and moyenneAvis >= 4 %}

            <a href="{{ path('app_activite_show', {id: activite.id}) }}" class="act-card"
               data-nom="{{ activite.nom|lower }}"
               data-cat="{{ activite.categorie ? activite.categorie.id : '' }}"
               data-diff="{{ activite.niveaudifficulte }}">

                {# Image #}
                <div class="act-card__img-wrap">
                    {% if activite.imagePath %}
                        <img
                            src="{{ asset(activite.imagePath|replace({'\\\\': '/'})) }}"
                            alt="{{ activite.nom }}"
                            class="act-card__img"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                        >
                        <div class="act-card__img-placeholder" style="display:none">🌄</div>
                    {% else %}
                        <div class="act-card__img-placeholder">🌄</div>
                    {% endif %}

                    {# Badges #}
                    <div class="act-card__badges">
                        {% if isTrending %}
                            <span class="badge badge--fire">🔥 Trending</span>
                        {% endif %}
                        {% if activite.categorie %}
                            <span class="badge badge--cat">{{ activite.categorie.nom }}</span>
                        {% endif %}
                        <span class="badge badge--statut-{{ activite.statut|lower|replace({' ': '-', 'en attente': 'attente'}) }}">
                            {{ activite.statut }}
                        </span>
                    </div>

                    {# Rating #}
                    {% if nbAvis > 0 %}
                        <div class="act-card__rating">
                            <span class="stars">★</span>
                            <span>{{ moyenneAvis }}</span>
                            <span style="color:var(--color-text-muted)">({{ nbAvis }})</span>
                        </div>
                    {% endif %}
                </div>

                {# Corps #}
                <div class="act-card__body">
                    <div class="act-card__name">{{ activite.nom }}</div>

                    {% if activite.lieu %}
                        <div class="act-card__meta">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/></svg>
                            {{ activite.lieu|slice(0, 40) }}{{ activite.lieu|length > 40 ? '…' : '' }}
                        </div>
                    {% endif %}

                    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                        {# Difficulté #}
                        {% set diff = activite.niveaudifficulte|lower %}
                        <span class="diff-pill diff-pill--{{ diff }}">
                            {% if diff == 'facile' %}🟢{% elseif diff == 'moyen' %}🟡{% elseif diff == 'difficile' %}🟠{% else %}🔴{% endif %}
                            {{ activite.niveaudifficulte }}
                        </span>

                        {# Durée #}
                        <span style="font-size:0.8rem;color:var(--color-text-muted)">
                            ⏱ {{ activite.duree }}h
                        </span>

                        {# Âge min #}
                        <span style="font-size:0.8rem;color:var(--color-text-muted)">
                            👤 +{{ activite.agemin }} ans
                        </span>
                    </div>

                    {# Prix + CTA #}
                    <div class="act-card__price">
                        <div>
                            <div class="price-label">À partir de</div>
                            <div class="price-value">
                                {{ activite.budget }} <span class="price-unit">TND</span>
                            </div>
                        </div>
                        <span class="act-card__cta">
                            Voir les détails
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                    </div>
                </div>
            </a>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script>
    // ── Filtrage côté client (instantané) ──────────────────────────────────
    const searchInput = document.getElementById('searchInput');
    const catFilter   = document.getElementById('catFilter');
    const diffFilter  = document.getElementById('diffFilter');
    const cards       = document.querySelectorAll('.act-card[data-nom]');
    const countEl     = document.querySelector('.act-count strong');

    function filterCards() {
        const search = searchInput.value.toLowerCase().trim();
        const cat    = catFilter.value;
        const diff   = diffFilter.value.toLowerCase();
        let visible  = 0;

        cards.forEach(card => {
            const matchNom  = card.dataset.nom.includes(search);
            const matchCat  = !cat  || card.dataset.cat  === cat;
            const matchDiff = !diff || card.dataset.diff.toLowerCase() === diff;
            const show = matchNom && matchCat && matchDiff;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        if (countEl) countEl.textContent = visible;
    }

    searchInput.addEventListener('input', filterCards);
    catFilter.addEventListener('change', filterCards);
    diffFilter.addEventListener('change', filterCards);
</script>
{% endblock %}
