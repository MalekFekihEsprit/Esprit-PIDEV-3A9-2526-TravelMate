{% extends 'base.html.twig' %}

{% block title %}{{ activite.nom }} — TravelMate{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<style>
.tm-geo-map { margin-top: 0.85rem; }
.tm-geo-map-btn {
    appearance: none;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast);
}
.tm-geo-map-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
.tm-geo-map-panel { margin-top: 0.65rem; }
.tm-geo-map-canvas { height: 240px; border-radius: var(--radius-lg); border: 1px solid var(--color-border); overflow: hidden; }

/* ══════════════════════════════════════════════════════
   BREADCRUMB
══════════════════════════════════════════════════════ */
.breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
}
.breadcrumb a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
}
.breadcrumb a:hover { color: var(--color-primary); }
.breadcrumb__sep {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
}
.breadcrumb__current { color: var(--color-text); font-weight: 500; }

/* ══════════════════════════════════════════════════════
   GALERIE MULTI-IMAGES (style Booking / Bali Best Of)
══════════════════════════════════════════════════════ */
.gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 280px 190px;
    gap: 0.5rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 2rem;
    position: relative;
}
/* Mode image unique — pleine largeur */
.gallery.gallery--single {
    grid-template-columns: 1fr;
    grid-template-rows: 420px;
}
@media (max-width: 768px) {
    .gallery {
        grid-template-columns: 1fr;
        grid-template-rows: 260px;
    }
    .gallery__item:not(:first-child) { display: none; }
    .gallery.gallery--single {
        grid-template-rows: 260px;
    }
}

.gallery__item {
    overflow: hidden;
    background: var(--color-surface-soft);
    cursor: pointer;
    position: relative;
}
.gallery__item:first-child {
    grid-row: span 2;
}
.gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
}
.gallery__item:hover img { transform: scale(1.04); }

/* Placeholder si pas d'image */
.gallery__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface-soft), var(--color-border));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
}

/* Badge "Voir tout" */
.gallery__btn-all {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    background: rgba(255,253,249,0.95);
    border: 1px solid rgba(231,220,205,0.9);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    z-index: 4;
}
.gallery__btn-all:hover {
    background: #fff;
    box-shadow: 0 4px 16px rgba(71,48,35,0.12);
}

/* Overlay darkener sur last item quand il y a plus de 4 images */
.gallery__item--more::after {
    content: attr(data-more);
    position: absolute;
    inset: 0;
    background: rgba(20,14,10,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 600;
}

/* Lightbox */
.lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(10,8,6,0.96);
    align-items: center;
    justify-content: center;
    flex-direction: column;
}
.lightbox.is-open { display: flex; }
.lightbox__img {
    max-width: 90vw;
    max-height: 80vh;
    border-radius: var(--radius-lg);
    object-fit: contain;
}
.lightbox__close {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    width: 42px; height: 42px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
}
.lightbox__close:hover { background: rgba(255,255,255,0.2); }
.lightbox__nav {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    width: 46px; height: 46px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
}
.lightbox__nav:hover { background: rgba(255,255,255,0.2); }
.lightbox__prev { left: 1.5rem; }
.lightbox__next { right: 1.5rem; }
.lightbox__counter {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.08em;
}

/* ══════════════════════════════════════════════════════
   LAYOUT PRINCIPAL
══════════════════════════════════════════════════════ */
.show-layout {
    display: grid;
    grid-template-columns: 1fr 370px;
    gap: 2.25rem;
    align-items: start;
}
@media (max-width: 1024px) {
    .show-layout { grid-template-columns: 1fr; }
}

/* ══════════════════════════════════════════════════════
   EN-TÊTE : NOM, RATING, META
══════════════════════════════════════════════════════ */
.show-header { margin-bottom: 1.75rem; }

.show-header__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
}
.show-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.15;
}

.show-badge-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
}
.sbadge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
}
.sbadge--cat  { background: rgba(196,111,75,0.1); color: var(--color-primary); border: 1px solid rgba(196,111,75,0.2); }
.sbadge--diff-facile       { background: rgba(47,127,121,0.09); color: var(--color-secondary); border: 1px solid rgba(47,127,121,0.2); }
.sbadge--diff-intermediaire { background: rgba(180,140,40,0.1); color: #7a5e08; border: 1px solid rgba(180,140,40,0.25); }
.sbadge--diff-difficile    { background: rgba(196,111,75,0.12); color: var(--color-primary-dark); border: 1px solid rgba(196,111,75,0.25); }
.sbadge--diff-expert       { background: rgba(160,50,50,0.1); color: #8b1a1a; border: 1px solid rgba(160,50,50,0.2); }
.sbadge--statut-active   { background: rgba(47,127,121,0.1); color: var(--color-secondary); border: 1px solid rgba(47,127,121,0.2); }
.sbadge--statut-inactive { background: rgba(130,130,130,0.1); color: #666; border: 1px solid rgba(130,130,130,0.2); }

.show-rating-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
}
.stars-display {
    display: flex;
    gap: 0.12rem;
}
.stars-display svg { flex-shrink: 0; }
.rating-score { font-weight: 700; font-size: 1rem; color: var(--color-text); }
.rating-count { font-size: 0.85rem; color: var(--color-text-muted); }

/* Meta pills sous le titre */
.show-meta-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0;
}
.mpill {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
}
.mpill svg { flex-shrink: 0; color: var(--color-text-muted); }
.mpill strong { color: var(--color-text); font-weight: 600; }

/* ══════════════════════════════════════════════════════
   ONGLETS 100% CSS — zéro JS requis
══════════════════════════════════════════════════════ */
.tab-radio { display: none; }
.tabs {
    display: flex;
    border-bottom: 1.5px solid var(--color-border);
    margin-bottom: 1.75rem;
    gap: 0;
}
.tab-label {
    padding: 0.8rem 1.35rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1.5px;
    transition: color 180ms ease, border-color 180ms ease;
    white-space: nowrap;
    user-select: none;
    display: inline-block;
}
.tab-label:hover { color: var(--color-text); }
.tab-panel { display: none; }
#tab-radio-details:checked ~ .tabs label[for="tab-radio-details"],
#tab-radio-tarifs:checked  ~ .tabs label[for="tab-radio-tarifs"],
#tab-radio-avis:checked    ~ .tabs label[for="tab-radio-avis"] {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    font-weight: 600;
}
#tab-radio-details:checked ~ .tab-content #tab-details,
#tab-radio-tarifs:checked  ~ .tab-content #tab-tarifs,
#tab-radio-avis:checked    ~ .tab-content #tab-avis { display: block; }
.tab-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: #fff;
    border-radius: 999px;
    padding: 0.05rem 0.48rem;
    font-size: 0.68rem;
    font-weight: 700;
    margin-left: 0.4rem;
    vertical-align: middle;
}

/* ══════════════════════════════════════════════════════
   PANNEAU DÉTAILS
══════════════════════════════════════════════════════ */
.detail-block {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    margin-bottom: 1.25rem;
}
.detail-block__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.85rem;
}
.detail-block p {
    color: var(--color-text);
    line-height: 1.75;
    font-size: 0.97rem;
}
.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 1rem;
}
.info-item__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-text-muted);
    margin-bottom: 0.2rem;
}
.info-item__value {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
}

/* ══════════════════════════════════════════════════════
   PANNEAU TARIFS
══════════════════════════════════════════════════════ */
.tarif-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: 0.75rem;
    gap: 1rem;
}
.tarif-row__name { font-weight: 600; font-size: 0.97rem; }
.tarif-row__desc { font-size: 0.82rem; color: var(--color-text-muted); margin-top: 0.15rem; }
.tarif-row__price {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    white-space: nowrap;
    text-align: right;
}
.tarif-row__unit { font-size: 0.75rem; color: var(--color-text-muted); font-family: 'Outfit', sans-serif; font-weight: 400; }
.tarif-note {
    background: rgba(47,127,121,0.06);
    border: 1px solid rgba(47,127,121,0.15);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    font-size: 0.86rem;
    color: var(--color-secondary);
    line-height: 1.6;
    margin-top: 0.5rem;
}

/* ══════════════════════════════════════════════════════
   PANNEAU AVIS
══════════════════════════════════════════════════════ */
/* Summary bloc style image 2 */
.rating-summary {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2rem 2.25rem;
    margin-bottom: 2rem;
}
@media (max-width: 640px) {
    .rating-summary { flex-direction: column; gap: 1.5rem; }
}
.rating-circle {
    flex-shrink: 0;
    width: 90px; height: 90px;
    border-radius: 50%;
    border: 3px solid var(--color-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
}
.rating-circle__num {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1;
}
.rating-circle__denom {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1;
}
.rating-circle__label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
}

.rating-bars { flex: 1; display: flex; flex-direction: column; gap: 0.55rem; }
.rbar-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 0.82rem;
}
.rbar-label { width: 52px; color: var(--color-text-muted); flex-shrink: 0; }
.rbar-track {
    flex: 1;
    height: 6px;
    background: var(--color-border);
    border-radius: 999px;
    overflow: hidden;
}
.rbar-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 999px;
    transition: width 0.6s ease;
}
.rbar-fill--primary { background: var(--color-primary); }
.rbar-pct { width: 32px; text-align: right; color: var(--color-text-muted); flex-shrink: 0; }

/* Séparateur section Avis */
.avis-section-sep {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}
.avis-section-sep__line { flex: 1; height: 1px; background: var(--color-border); }
.avis-section-sep__label { font-size: 0.8rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.1em; text-transform: uppercase; }

/* Carte avis */
.avis-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
}
.avis-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.85rem;
}
.avis-card__user { display: flex; align-items: center; gap: 0.75rem; }
.avis-card__avatar {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-primary);
    flex-shrink: 0;
}
.avis-card__name { font-weight: 600; font-size: 0.93rem; color: var(--color-text); }
.avis-card__date { font-size: 0.76rem; color: var(--color-text-muted); margin-top: 0.1rem; }
.avis-card__act  { font-size: 0.78rem; color: var(--color-text-muted); font-style: italic; }
.avis-stars { display: flex; gap: 0.15rem; }
.avis-stars svg { flex-shrink: 0; }
.avis-card__comment {
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.7;
}

/* Empty avis */
.avis-empty {
    text-align: center;
    padding: 3rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
}
.avis-empty__icon { margin-bottom: 0.75rem; color: var(--color-border); }
.avis-empty__title { font-weight: 600; color: var(--color-text); margin-bottom: 0.3rem; font-size: 1rem; }

/* Formulaire avis */
.avis-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    margin-top: 1.75rem;
}
.avis-form__title {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 1.25rem;
}
.form-group { margin-bottom: 1rem; }
.form-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.45rem;
}
.form-control {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    font: inherit;
    font-size: 0.92rem;
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.form-control:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(196,111,75,0.08);
}
textarea.form-control { resize: vertical; min-height: 100px; }

/* Étoiles interactives */
.star-picker { display: flex; gap: 0.35rem; flex-direction: row-reverse; justify-content: flex-end; }
.star-picker input { display: none; }
.star-picker label {
    font-size: 2rem;
    color: var(--color-border);
    cursor: pointer;
    transition: color var(--transition-fast), transform var(--transition-fast);
    line-height: 1;
}
.star-picker input:checked ~ label,
.star-picker label:hover,
.star-picker label:hover ~ label { color: #f59e0b; }
.star-picker label:hover { transform: scale(1.15); }

/* ══════════════════════════════════════════════════════
   SIDEBAR : BOX RÉSERVATION
══════════════════════════════════════════════════════ */
.resa-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: sticky;
    top: calc(var(--navbar-height) + 1rem);
    box-shadow: 0 8px 40px rgba(71,48,35,0.07);
}
.resa-box__head {
    background: #3b2a20;
    padding: 1.5rem 1.75rem 1.25rem;
    color: #fff;
}
.resa-box__head-title {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
}
.resa-box__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-top: 0.5rem;
}
.resa-box__price-num {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 600;
}
.resa-box__price-unit { font-size: 0.88rem; opacity: 0.7; }

.resa-box__body { padding: 1.5rem 1.75rem; }

.resa-field { margin-bottom: 1rem; }
.resa-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.4rem;
}
.resa-input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    font: inherit;
    font-size: 0.92rem;
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.resa-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(196,111,75,0.08);
}
.resa-persons { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; }
.resa-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1rem 0;
}
.resa-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-weight: 600;
}
.resa-total-amount { font-family: 'Fraunces', serif; font-size: 1.15rem; color: var(--color-primary); }

.btn-resa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
    margin-bottom: 0.75rem;
}
.btn-resa:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(196,111,75,0.3);
}
.btn-help {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    width: 100%;
    padding: 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font: inherit;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
}
.btn-help:hover {
    background: var(--color-hover);
    border-color: rgba(196,111,75,0.25);
    color: var(--color-primary);
}

/* Garanties */
.resa-guarantees {
    padding: 1.25rem 1.75rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}
.resa-guarantee {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.83rem;
    color: var(--color-text-muted);
}
.resa-guarantee svg { flex-shrink: 0; color: var(--color-secondary); }

/* ══════════════════════════════════════════════════════
   BOUTON MESSAGERIE FLOTTANT
══════════════════════════════════════════════════════ */
.chat-fab {
    position: fixed;
    bottom: 2rem;
    left: 2rem;
    z-index: 500;
    display: flex;
    align-items: center;
    gap: 0;
    cursor: pointer;
}
.chat-fab__btn {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: #3b2a20;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
    box-shadow: 0 6px 24px rgba(0,0,0,0.2);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    position: relative;
}
.chat-fab__btn:hover {
    transform: scale(1.07);
    box-shadow: 0 10px 32px rgba(0,0,0,0.25);
}
.chat-fab__dot {
    position: absolute;
    top: 2px; right: 2px;
    width: 12px; height: 12px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid #3b2a20;
}
.chat-fab__tooltip {
    position: absolute;
    left: 66px;
    top: 50%;
    transform: translateY(-50%);
    background: #3b2a20;
    color: #fff;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-md);
    font-size: 0.82rem;
    font-weight: 500;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-fast);
}
.chat-fab:hover .chat-fab__tooltip { opacity: 1; }

/* ══════════════════════════════════════════════════════
   BLOC MÉTÉO DANS LA SIDEBAR
══════════════════════════════════════════════════════ */
.weather-widget {
    margin-top: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
}
.weather-widget__title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
}
.weather-widget__placeholder {
    text-align: center;
    padding: 1.25rem 0.5rem;
    background: var(--color-surface-soft);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
}
.weather-widget__placeholder span { font-size: 1.5rem; display: block; margin-bottom: 0.35rem; }

/* Résultat météo */
.wcard {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
}
.wcard__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    background: linear-gradient(135deg, rgba(47,127,121,0.08), rgba(196,111,75,0.06));
    border-bottom: 1px solid var(--color-border);
}
.wcard__icon { font-size: 2.2rem; line-height: 1; flex-shrink: 0; }
.wcard__main { flex: 1; min-width: 0; }
.wcard__temp { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 600; color: var(--color-text); line-height: 1; }
.wcard__desc { font-size: 0.82rem; color: var(--color-text-muted); margin-top: 0.15rem; text-transform: capitalize; }
.wcard__minmax { font-size: 0.78rem; color: var(--color-text-muted); margin-top: 0.1rem; }

.wcard__details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
}
.wcard__detail {
    display: flex;
    flex-direction: column;
    padding: 0.6rem 0.9rem;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
}
.wcard__detail:nth-child(even) { border-right: none; }
.wcard__detail:nth-last-child(-n+2) { border-bottom: none; }
.wcard__detail-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-text-muted); margin-bottom: 0.15rem; }
.wcard__detail-value { font-size: 0.9rem; font-weight: 600; color: var(--color-text); }

/* Barre pluie */
.wcard__rain-bar {
    height: 4px;
    background: var(--color-border);
    border-radius: 999px;
    margin-top: 0.25rem;
    overflow: hidden;
}
.wcard__rain-fill {
    height: 100%;
    background: #3b82f6;
    border-radius: 999px;
    transition: width 0.5s ease;
}

/* Alerte météo */
.wcard__alert {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    line-height: 1.45;
}
.wcard__alert--good { color: var(--color-secondary); background: rgba(47,127,121,0.06); }
.wcard__alert--warn { color: #b45309; background: rgba(180,83,9,0.06); }
.wcard__alert--bad  { color: #dc2626; background: rgba(220,38,38,0.06); }

/* Loading */
.weather-loading {
    text-align: center;
    padding: 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
}
.weather-spinner {
    width: 28px; height: 28px;
    border: 2.5px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: wspin 0.8s linear infinite;
    margin: 0 auto 0.5rem;
}
@keyframes wspin { to { transform: rotate(360deg); } }

/* Erreur */
.weather-error-msg {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0.9rem;
    background: rgba(220,38,38,0.06);
    border: 1px solid rgba(220,38,38,0.2);
    border-radius: var(--radius-md);
    font-size: 0.82rem;
    color: #dc2626;
}

</style>
{% endblock %}

{% block body %}

{% include '_travelmate_mymemory_translate.html.twig' %}

{# ── Breadcrumb ─────────────────────────────────────────────────────────── #}
<nav class="breadcrumb" aria-label="Fil d'Ariane">
    <a href="{{ path('app_home') }}" data-translate="true">Accueil</a>
    <span class="breadcrumb__sep"></span>
    <a href="{{ path('app_activites') }}" data-translate="true">Activités</a>
    {% if activite.categorie %}
        <span class="breadcrumb__sep"></span>
        <a href="{{ path('app_categorie_show', {id: activite.categorie.id}) }}" data-translate="true" data-original="{{ activite.categorie.nom|e('html_attr') }}">{{ activite.categorie.nom }}</a>
    {% endif %}
    <span class="breadcrumb__sep"></span>
    <span class="breadcrumb__current" data-translate="true" data-original="{{ activite.nom|e('html_attr') }}">{{ activite.nom }}</span>
</nav>

{# ── Image hero (une seule image depuis imagePath) ────────────────────────── #}
<div class="gallery gallery--single" id="gallery">

    {# Slot unique — grande image pleine largeur #}
    <div class="gallery__item" onclick="openLightbox(0)">
        {% if activite.imagePath %}
            {# imagePath est déjà "uploads/activites/fichier.ext" (voir ActiviteController) #}
            <img src="{{ asset(activite.imagePath) }}" alt="{{ activite.nom }}" loading="eager">
        {% else %}
            <div class="gallery__placeholder">
                <svg width="52" height="52" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
        {% endif %}
    </div>

    {# Bouton "Agrandir" #}
    {% if activite.imagePath %}
        <button type="button" class="gallery__btn-all" onclick="openLightbox(0)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span data-translate="true">Agrandir</span>
        </button>
    {% endif %}
</div>

{# Lightbox #}
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <button class="lightbox__close" onclick="closeLightbox()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>
    <button class="lightbox__nav lightbox__prev" onclick="event.stopPropagation();shiftLightbox(-1)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <img class="lightbox__img" id="lightboxImg" src="" alt="">
    <button class="lightbox__nav lightbox__next" onclick="event.stopPropagation();shiftLightbox(1)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="lightbox__counter" id="lightboxCounter"></div>
</div>

{# ── Layout principal ────────────────────────────────────────────────────── #}
<div class="show-layout">

    {# ═══════════════════════════════════════
       COLONNE PRINCIPALE
    ═══════════════════════════════════════ #}
    <div>

        {# En-tête #}
        <div class="show-header">
            <div class="show-badge-row">
                {% if activite.categorie %}
                    <span class="sbadge sbadge--cat" data-translate="true" data-original="{{ activite.categorie.nom|e('html_attr') }}">{{ activite.categorie.nom }}</span>
                {% endif %}
                {% set diff = activite.niveaudifficulte|lower %}
                <span class="sbadge sbadge--diff-{{ diff }}" data-translate="true" data-original="{{ activite.niveaudifficulte|e('html_attr') }}">{{ activite.niveaudifficulte }}</span>
                <span class="sbadge sbadge--statut-{{ activite.statut|lower }}" data-translate="true" data-original="{{ activite.statut|capitalize|e('html_attr') }}">{{ activite.statut|capitalize }}</span>
            </div>

            <div class="show-header__top">
                <h1 class="show-title" data-translate="true" data-original="{{ activite.nom|e('html_attr') }}">{{ activite.nom }}</h1>
            </div>

            {# Rating #}
            {% set moyenne = activite.moyenneAvis %}
            {% set nbAvis  = activite.avis|length %}
            <div class="show-rating-row">
                <div class="stars-display">
                    {% for i in 1..5 %}
                        {% if i <= moyenne %}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {% elseif i - 0.5 <= moyenne %}
                            <svg width="16" height="16" viewBox="0 0 24 24"><defs><linearGradient id="hg{{ i }}"><stop offset="50%" stop-color="#f59e0b"/><stop offset="50%" stop-color="#e7dccd"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#hg{{ i }})"/></svg>
                        {% else %}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#e7dccd"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {% endif %}
                    {% endfor %}
                </div>
                {% if nbAvis > 0 %}
                    <span class="rating-score">{{ moyenne }}</span>
                    <span class="rating-count" data-translate="true" data-original="{{ ('(' ~ nbAvis ~ ' avis)')|e('html_attr') }}">({{ nbAvis }} avis)</span>
                {% else %}
                    <span class="rating-count" data-translate="true">Pas encore d'avis</span>
                {% endif %}
            </div>

            {# Meta pills #}
            <div class="show-meta-pills">
                {% if activite.lieu %}
                    <span class="mpill">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="currentColor"/></svg>
                        <strong data-translate="true" data-original="{{ activite.lieu|e('html_attr') }}">{{ activite.lieu }}</strong>
                    </span>
                {% endif %}
                <span class="mpill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.7"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                    <span data-translate="true" data-original="{{ (activite.duree ~ 'h de durée')|e('html_attr') }}"><strong>{{ activite.duree }}h</strong> de durée</span>
                </span>
                <span class="mpill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.7"/></svg>
                    <span data-translate="true" data-original="{{ ('Dès ' ~ activite.agemin ~ ' ans')|e('html_attr') }}">Dès <strong>{{ activite.agemin }} ans</strong></span>
                </span>
            </div>

            {% if activite.lieu %}
                <div class="tm-geo-map js-tm-geo-map" 
                     data-lat="{{ activite.latitude ?: '' }}" 
                     data-lng="{{ activite.longitude ?: '' }}" 
                     data-address="{{ activite.lieu|e('html_attr') }}"
                     data-label="{{ activite.lieu|e('html_attr') }}">
                    <button type="button" class="tm-geo-map-btn js-tm-geo-map-toggle" aria-expanded="false" data-label-show="Voir sur la carte" data-label-hide="Masquer la carte">Voir sur la carte</button>
                    <div class="js-tm-geo-map-panel tm-geo-map-panel" hidden>
                        <div class="js-tm-geo-map-canvas tm-geo-map-canvas" role="application" aria-label="Carte du lieu"></div>
                    </div>
                </div>
            {% endif %}
        </div>

        {# ── Onglets 100% CSS ── #}
        {# Les radios DOIVENT être AVANT .tabs et .tab-content pour que ~ fonctionne #}
        <input class="tab-radio" type="radio" name="activite-tab" id="tab-radio-details" checked>
        <input class="tab-radio" type="radio" name="activite-tab" id="tab-radio-tarifs">
        <input class="tab-radio" type="radio" name="activite-tab" id="tab-radio-avis">

        <div class="tabs">
            <label class="tab-label" for="tab-radio-details"><span data-translate="true">Détails</span></label>
            <label class="tab-label" for="tab-radio-tarifs"><span data-translate="true">Tarifs</span></label>
            <label class="tab-label" for="tab-radio-avis">
                <span data-translate="true">Avis</span>{% if nbAvis > 0 %}<span class="tab-badge">{{ nbAvis }}</span>{% endif %}
            </label>
        </div>

        <div class="tab-content">

        {# ══ Panel Détails ══ #}
        <div class="tab-panel" id="tab-details">

            <div class="detail-block">
                <div class="detail-block__label" data-translate="true">À propos de cette activité</div>
                <p data-translate="true" data-original="{{ activite.description|e('html_attr') }}">{{ activite.description }}</p>
            </div>

            <div class="detail-block">
                <div class="detail-block__label" data-translate="true">Informations pratiques</div>
                <div class="info-grid">
                    <div>
                        <div class="info-item__label" data-translate="true">Catégorie</div>
                        <div class="info-item__value" data-translate="true" data-original="{{ (activite.categorie ? activite.categorie.nom : '—')|e('html_attr') }}">{{ activite.categorie ? activite.categorie.nom : '—' }}</div>
                    </div>
                    <div>
                        <div class="info-item__label" data-translate="true">Durée</div>
                        <div class="info-item__value" data-translate="true" data-original="{{ (activite.duree ~ ' heure' ~ (activite.duree > 1 ? 's' : ''))|e('html_attr') }}">{{ activite.duree }} heure{{ activite.duree > 1 ? 's' : '' }}</div>
                    </div>
                    <div>
                        <div class="info-item__label" data-translate="true">Niveau</div>
                        <div class="info-item__value" data-translate="true" data-original="{{ activite.niveaudifficulte|e('html_attr') }}">{{ activite.niveaudifficulte }}</div>
                    </div>
                    <div>
                        <div class="info-item__label" data-translate="true">Âge minimum</div>
                        <div class="info-item__value" data-translate="true" data-original="{{ (activite.agemin ~ ' ans')|e('html_attr') }}">{{ activite.agemin }} ans</div>
                    </div>
                    <div>
                        <div class="info-item__label" data-translate="true">Statut</div>
                        <div class="info-item__value" data-translate="true" data-original="{{ activite.statut|capitalize|e('html_attr') }}">{{ activite.statut|capitalize }}</div>
                    </div>
                    {% if activite.categorie %}
                        <div>
                            <div class="info-item__label" data-translate="true">Type</div>
                            <div class="info-item__value" data-translate="true" data-original="{{ activite.categorie.type|e('html_attr') }}">{{ activite.categorie.type }}</div>
                        </div>
                        <div>
                            <div class="info-item__label" data-translate="true">Saison idéale</div>
                            <div class="info-item__value" data-translate="true" data-original="{{ activite.categorie.saison|e('html_attr') }}">{{ activite.categorie.saison }}</div>
                        </div>
                        <div>
                            <div class="info-item__label" data-translate="true">Public cible</div>
                            <div class="info-item__value" data-translate="true" data-original="{{ activite.categorie.publiccible|e('html_attr') }}">{{ activite.categorie.publiccible }}</div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ══ Panel Tarifs ══ #}
        <div class="tab-panel" id="tab-tarifs">
            <div class="tarif-row">
                <div>
                    <div class="tarif-row__name" data-translate="true">Tarif standard</div>
                    <div class="tarif-row__desc" data-translate="true">Prix par personne, toutes taxes comprises</div>
                </div>
                <div style="text-align:right">
                    <div class="tarif-row__price">{{ activite.budget }} <span class="tarif-row__unit">TND</span></div>
                    <div class="tarif-row__unit" data-translate="true">par personne</div>
                </div>
            </div>

            <div class="tarif-row">
                <div>
                    <div class="tarif-row__name" data-translate="true">Groupe (2+ personnes)</div>
                    <div class="tarif-row__desc" data-translate="true">Réduction de 10 % par personne supplémentaire</div>
                </div>
                <div style="text-align:right">
                    <div class="tarif-row__price">{{ (activite.budget * 0.9)|round }} <span class="tarif-row__unit">TND</span></div>
                    <div class="tarif-row__unit" data-translate="true">par personne</div>
                </div>
            </div>

            <div class="tarif-note" data-translate="true">
                Les prix incluent toutes les taxes applicables. Le paiement s'effectue lors de la confirmation de réservation.
            </div>
        </div>

        {# ══ Panel Avis ══ #}
        <div class="tab-panel" id="tab-avis">

            {% if nbAvis > 0 %}
                {# Calcul des distributions par note #}
                {% set dist = {5:0, 4:0, 3:0, 2:0, 1:0} %}
                {% for avi in activite.avis %}
                    {% set n = avi.note %}
                    {% set dist = dist|merge({(n): dist[n] + 1}) %}
                {% endfor %}

                <div class="rating-summary">
                    <div class="rating-circle">
                        <span class="rating-circle__num">{{ moyenne }}</span>
                        <span class="rating-circle__denom">/5</span>
                        <span class="rating-circle__label" data-translate="true" data-original="{{ (moyenne >= 4.5 ? 'Excellent' : (moyenne >= 3.5 ? 'Très bien' : 'Bien'))|e('html_attr') }}">{{ moyenne >= 4.5 ? 'Excellent' : (moyenne >= 3.5 ? 'Très bien' : 'Bien') }}</span>
                    </div>
                    <div class="rating-bars">
                        {% for star in [5,4,3,2,1] %}
                            {% set pct = nbAvis > 0 ? ((dist[star] / nbAvis) * 100)|round : 0 %}
                            <div class="rbar-row">
                                <span class="rbar-label" data-translate="true" data-original="{{ (star ~ ' étoile' ~ (star > 1 ? 's' : ''))|e('html_attr') }}">{{ star }} étoile{{ star > 1 ? 's' : '' }}</span>
                                <div class="rbar-track">
                                    <div class="rbar-fill{{ star == 5 ? ' rbar-fill--primary' : '' }}" style="width:{{ pct }}%"></div>
                                </div>
                                <span class="rbar-pct">{{ pct }}%</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="avis-section-sep">
                    <div class="avis-section-sep__line"></div>
                    <span class="avis-section-sep__label" data-translate="true">Avis</span>
                    <div class="avis-section-sep__line"></div>
                </div>

                {% for avi in activite.avis %}
                    <div class="avis-card">
                        <div class="avis-card__header">
                            <div class="avis-card__user">
                                <div class="avis-card__avatar">
                                    {{ avi.user.prenom|slice(0,1)|upper }}{{ avi.user.nom|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <div class="avis-card__name">{{ avi.user.prenom }} {{ avi.user.nom }}</div>
                                    <div class="avis-card__date">{{ avi.createdAt|date('d M Y') }}</div>
                                </div>
                            </div>
                            <div class="avis-stars">
                                {% for i in 1..5 %}
