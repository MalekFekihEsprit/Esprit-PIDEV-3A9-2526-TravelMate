{# Le script météo est injecté directement ici pour garantir l'exécution après le DOM #}

<script>
// Calcul total réservation
(function () {
    var prix    = {{ activite.budget }};
    var adultes = document.getElementById('nbAdultes');
    var enfants = document.getElementById('nbEnfants');
    var totalEl = document.getElementById('resaTotal');
    if (!adultes || !enfants || !totalEl) return;
    function updateTotal() {
        var nb = parseInt(adultes.value || 1) + parseInt(enfants.value || 0);
        totalEl.textContent = (nb * prix) + ' TND';
    }
    adultes.addEventListener('input', updateTotal);
    enfants.addEventListener('input', updateTotal);
})();

// Lightbox
var galleryImages = {{ activite.imagePath ? '["' ~ asset(activite.imagePath)|e('js') ~ '"]' : '[]' }};
var currentIdx = 0;
function openLightbox(idx) {
    if (!galleryImages.length) return;
    currentIdx = Math.min(idx, galleryImages.length - 1);
    _updateLightbox();
    document.getElementById('lightbox').classList.add('is-open');
    document.body.style.overflow = 'hidden';
}
function closeLightbox() {
    document.getElementById('lightbox').classList.remove('is-open');
    document.body.style.overflow = '';
}
function shiftLightbox(dir) {
    currentIdx = (currentIdx + dir + galleryImages.length) % galleryImages.length;
    _updateLightbox();
}
function _updateLightbox() {
    document.getElementById('lightboxImg').src = galleryImages[currentIdx];
    document.getElementById('lightboxCounter').textContent = (currentIdx + 1) + ' / ' + galleryImages.length;
}
document.addEventListener('keydown', function (e) {
    if (!document.getElementById('lightbox').classList.contains('is-open')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowLeft')  shiftLightbox(-1);
    if (e.key === 'ArrowRight') shiftLightbox(1);
}); 
</script>

{# ══════════════════════════════════════════════════════
   MÉTÉO — placé ici (fin de block body, DOM garanti prêt)
   pour éviter tout problème de timing avec les assets JS
══════════════════════════════════════════════════════ #}
<script>
(function () {
    var activiteLocation = '{{ activite.lieu ? activite.lieu|e("js") : "Tunis" }}';

    function initWeather() {
        var resaDate       = document.getElementById('resaDate');
        var weatherContent = document.getElementById('weatherContent');

        if (!resaDate || !weatherContent) {
            // Retry si le DOM n'est pas encore complet (edge case)
            setTimeout(initWeather, 100);
            return;
        }

        function onDateChange() {
            var date = resaDate.value;
            if (!date) {
                weatherContent.innerHTML =
                    '<div class="weather-widget__placeholder"><span>🌤️</span>' +
                    '<span>Choisissez une date pour voir la météo prévue</span></div>';
                return;
            }
            fetchWeather(date);
        }

        // Écouter 'change' ET 'input' pour compatibilité tous navigateurs + mobile
        resaDate.addEventListener('change', onDateChange);
        resaDate.addEventListener('input',  onDateChange);

        // ✅ FIX PRINCIPAL : déclencher immédiatement si une date est déjà présente
        if (resaDate.value) {
            fetchWeather(resaDate.value);
        }

        function fetchWeather(date) {
            weatherContent.innerHTML =
                '<div style="display:flex;align-items:center;gap:0.6rem;padding:1rem;color:var(--color-text-muted);font-size:0.88rem">' +
                    '<div style="width:18px;height:18px;border:2px solid var(--color-border);border-top-color:var(--color-primary);border-radius:50%;animation:wmSpin .7s linear infinite;flex-shrink:0"></div>' +
                    '<span>Chargement de la météo…</span>' +
                '</div>' +
                '<style>@keyframes wmSpin{to{transform:rotate(360deg)}}</style>';

            var url = '/weather/forecast?date=' + encodeURIComponent(date) +
                      '&location=' + encodeURIComponent(activiteLocation);

            fetch(url)
                .then(function(r) {
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    return r.json();
                })
                .then(function(data) {
                    if (data.error) throw new Error(data.error);
                    renderWeather(data);
                })
                .catch(function(err) {
                    weatherContent.innerHTML =
                        '<div style="padding:0.9rem;background:rgba(220,38,38,0.05);border:1px solid rgba(220,38,38,0.15);border-radius:8px;font-size:0.83rem;color:#dc2626">' +
                            '⚠️ Météo indisponible : ' + err.message +
                        '</div>';
                });
        }

        function renderWeather(data) {
            var forecasts = data.forecasts || [];
            if (!forecasts.length) {
                weatherContent.innerHTML =
                    '<div class="weather-widget__placeholder" style="background:rgba(196,111,75,0.06);border:1px solid rgba(196,111,75,0.2);border-radius:12px;padding:1.2rem;text-align:center">' +
                        '<span style="font-size:1.8rem;display:block">📅</span>' +
                        '<span style="display:block;margin-top:0.5rem;font-size:0.88rem;color:var(--color-text-muted)">' +
                            'Prévisions indisponibles pour cette date.<br>' +
                            '<small>L\'API météo couvre uniquement les 5 prochains jours.</small>' +
                        '</span>' +
                    '</div>';
                return;
            }

            var temps   = forecasts.map(function(f){ return f.temperature; });
            var minT    = Math.min.apply(null, temps);
            var maxT    = Math.max.apply(null, temps);
            var avgT    = Math.round(temps.reduce(function(a,b){return a+b;},0) / temps.length);
            var maxRain = Math.max.apply(null, forecasts.map(function(f){ return f.rain_probability || 0; }));
            var mid     = forecasts[Math.floor(forecasts.length / 2)] || forecasts[0];
            var humidity  = mid.humidity || 0;
            var windSpeed = mid.wind_speed || 0;
            var icon      = getWeatherEmoji(mid.icon, mid.description);

            var alertClass, alertText;
            if (maxRain > 70) {
                alertClass = 'wcard__alert--bad';
                alertText  = '🌧️ Fortes pluies prévues. Pensez à reporter ou emporter un équipement imperméable.';
            } else if (maxRain > 40) {
                alertClass = 'wcard__alert--warn';
                alertText  = '☔ Risque de pluie. Un parapluie est recommandé.';
            } else if (maxT > 35) {
                alertClass = 'wcard__alert--warn';
                alertText  = '☀️ Températures élevées. Hydratez-vous bien.';
            } else {
                alertClass = 'wcard__alert--good';
                alertText  = ' Bonnes conditions météo prévues pour votre activité.';
            }

            var mockBadge = (data.mock || data.out_of_range)
                ? '<span style="font-size:0.7rem;opacity:0.5;margin-left:0.5rem">' +
                  (data.out_of_range ? '(estimé)' : '(démo)') + '</span>'
                : '';

            weatherContent.innerHTML =
                '<div class="wcard">' +
                    '<div class="wcard__top">' +
                        '<div class="wcard__icon">' + icon + '</div>' +
                        '<div class="wcard__main">' +
                            '<div class="wcard__temp">' + avgT + '°C' + mockBadge + '</div>' +
                            '<div class="wcard__desc">' + mid.description + '</div>' +
                            '<div class="wcard__minmax">' + minT + '° / ' + maxT + '°</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="wcard__details">' +
                        '<div class="wcard__detail">' +
                            '<span class="wcard__detail-label">Pluie</span>' +
                            '<span class="wcard__detail-value">' + Math.round(maxRain) + '%</span>' +
                            '<div class="wcard__rain-bar"><div class="wcard__rain-fill" style="width:' + Math.round(maxRain) + '%"></div></div>' +
                        '</div>' +
                        '<div class="wcard__detail">' +
                            '<span class="wcard__detail-label">Humidité</span>' +
                            '<span class="wcard__detail-value">' + humidity + '%</span>' +
                        '</div>' +
                        '<div class="wcard__detail">' +
                            '<span class="wcard__detail-label">Vent</span>' +
                            '<span class="wcard__detail-value">' + windSpeed + ' km/h</span>' +
                        '</div>' +
                        '<div class="wcard__detail">' +
                            '<span class="wcard__detail-label">Prévisions</span>' +
                            '<span class="wcard__detail-value">' + forecasts.length + ' tranches</span>' +
                        '</div>' +
                    '</div>' +
                    '<div class="wcard__alert ' + alertClass + '">' + alertText + '</div>' +
                '</div>';
        }

        function getWeatherEmoji(icon, desc) {
            if (!icon) return '🌡️';
            var code = icon.replace('d','').replace('n','');
            var map = {'01':'☀️','02':'⛅','03':'☁️','04':'☁️','09':'🌧️','10':'🌦️','11':'⛈️','13':'❄️','50':'🌫️'};
            return map[code] || '🌡️';
        }
    }

    // DOM est déjà prêt ici (script en fin de body), mais on garde le guard
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWeather);
    } else {
        initWeather();
    }
})();
</script>

