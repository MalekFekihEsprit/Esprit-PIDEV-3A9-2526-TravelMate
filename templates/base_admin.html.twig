<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Administration | TravelMate{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Fraunces:wght@500;600&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <style>
            :root {
                --admin-bg: #f8f4ed;
                --admin-bg-soft: #fcfaf6;
                --admin-surface: #fffdf9;
                --admin-surface-alt: #f4ebdf;
                --admin-border: #e7dccd;

                --admin-text: #1f1a17;
                --admin-text-muted: #71665c;

                --admin-primary: #c46f4b;      /* terracotta */
                --admin-primary-dark: #a85a39;
                --admin-secondary: #2f7f79;    /* teal */
                --admin-secondary-soft: #e3f0ee;
                --admin-accent: #ddbf8c;       /* sable */
                --admin-danger: #bf5b5b;
                --admin-danger-soft: #f8e7e7;
                --admin-success: #3c8b72;
                --admin-success-soft: #e5f2ed;
                --admin-warning: #b9872f;
                --admin-warning-soft: #f8efd9;

                --admin-shadow: 0 16px 36px rgba(71, 48, 35, 0.06);
                --admin-shadow-soft: 0 8px 24px rgba(71, 48, 35, 0.04);

                --radius-sm: 10px;
                --radius-md: 14px;
                --radius-lg: 18px;
                --radius-xl: 24px;
                --radius-2xl: 30px;

                --topbar-height: 78px;
                --sidebar-width: 290px;

                --transition-fast: 180ms ease;
                --transition-base: 260ms ease;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                min-height: 100vh;
                font-family: 'Outfit', sans-serif;
                color: var(--admin-text);
                background:
                    radial-gradient(circle at top right, rgba(221, 191, 140, 0.16), transparent 24%),
                    linear-gradient(180deg, #fbf8f2 0%, var(--admin-bg) 100%);
                line-height: 1.5;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img {
                display: block;
                max-width: 100%;
            }

            button,
            input,
            textarea,
            select {
                font: inherit;
            }

            /* =========================
               LAYOUT
            ========================== */
            .admin-shell {
                min-height: 100vh;
            }

            .admin-topbar {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1100;
                height: var(--topbar-height);
                background: rgba(255, 253, 249, 0.88);
                backdrop-filter: blur(14px);
                -webkit-backdrop-filter: blur(14px);
                border-bottom: 1px solid rgba(231, 220, 205, 0.92);
            }

            .admin-topbar__inner {
                height: 100%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                padding: 0 1.25rem;
            }

            .admin-body {
                display: grid;
                grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
                min-height: 100vh;
                padding-top: var(--topbar-height);
            }

            .admin-sidebar {
                position: sticky;
                top: var(--topbar-height);
                height: calc(100vh - var(--topbar-height));
                padding: 1.2rem;
                overflow-y: auto;
                border-right: 1px solid rgba(231, 220, 205, 0.7);
                background: rgba(255, 253, 249, 0.72);
            }

            .admin-main {
                min-width: 0;
                padding: 1.5rem;
            }

            .admin-main__inner {
                min-width: 0;
            }

            /* =========================
               BRAND
            ========================== */
            .admin-brand {
                display: inline-flex;
                align-items: center;
                gap: 0.8rem;
                flex-shrink: 0;
            }

            
            .brand__mark {
                width: 76px;
                height: 7px;
                border-radius: 14px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(255, 253, 249, 0.86);
            }
            .admin-brand__text {
                display: flex;
                flex-direction: column;
                line-height: 1.05;
            }

            .admin-brand__title {
                font-family: 'Fraunces', serif;
                font-size: 1.2rem;
                color: var(--admin-primary);
                font-weight: 600;
                letter-spacing: -0.02em;
            }

            .admin-brand__subtitle {
                font-size: 0.68rem;
                text-transform: uppercase;
                letter-spacing: 0.14em;
                color: var(--admin-text-muted);
            }

            .admin-topbar__center {
                flex: 1;
                min-width: 0;
                display: flex;
                justify-content: center;
            }

            .admin-search {
                position: relative;
                width: min(100%, 460px);
            }

            .admin-search__input {
                width: 100%;
                height: 46px;
                padding: 0 1rem 0 2.8rem;
                border-radius: 999px;
                border: 1px solid var(--admin-border);
                background: rgba(244, 235, 223, 0.58);
                color: var(--admin-text);
                outline: none;
                transition:
                    border-color var(--transition-fast),
                    background var(--transition-fast);
            }

            .admin-search__input:focus {
                border-color: rgba(196, 111, 75, 0.35);
                background: #fff;
            }

            .admin-search__icon {
                position: absolute;
                top: 50%;
                left: 1rem;
                transform: translateY(-50%);
                color: var(--admin-text-muted);
                pointer-events: none;
            }

            .admin-topbar__actions {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                flex-shrink: 0;
            }

            .icon-btn {
                position: relative;
                width: 44px;
                height: 44px;
                border-radius: 14px;
                border: 1px solid var(--admin-border);
                background: var(--admin-surface);
                color: var(--admin-text-muted);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition:
                    color var(--transition-fast),
                    border-color var(--transition-fast),
                    background var(--transition-fast),
                    transform var(--transition-fast);
            }

            .icon-btn:hover {
                color: var(--admin-primary);
                border-color: rgba(196, 111, 75, 0.28);
                background: rgba(196, 111, 75, 0.06);
                transform: translateY(-1px);
            }

            .icon-btn__badge {
                position: absolute;
                top: 7px;
                right: 7px;
                min-width: 18px;
                height: 18px;
                padding: 0 5px;
                border-radius: 999px;
                background: var(--admin-primary);
                color: #fff;
                font-size: 0.67rem;
                font-weight: 700;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border: 2px solid var(--admin-surface);
            }

            /* =========================
               ADMIN USER MENU
            ========================== */
            .admin-user {
                position: relative;
            }

            .admin-user__trigger {
                display: inline-flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.35rem 0.45rem 0.35rem 0.35rem;
                border-radius: 999px;
                border: 1px solid var(--admin-border);
                background: var(--admin-surface);
                cursor: pointer;
                transition:
                    background var(--transition-fast),
                    border-color var(--transition-fast),
                    transform var(--transition-fast);
            }

            .admin-user__trigger:hover {
                background: rgba(196, 111, 75, 0.06);
                border-color: rgba(196, 111, 75, 0.28);
                transform: translateY(-1px);
            }

            .admin-user__avatar {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                object-fit: contain;
                padding: 0.28rem;
                background: #fff;
                border: 2px solid rgba(196, 111, 75, 0.14);
            }

            .admin-user__meta {
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                line-height: 1.1;
            }

            .admin-user__name {
                font-weight: 600;
                font-size: 0.92rem;
                color: var(--admin-text);
            }

            .admin-user__role {
                font-size: 0.76rem;
                color: var(--admin-text-muted);
            }

            .admin-user__dropdown {
                position: absolute;
                top: calc(100% + 0.7rem);
                right: 0;
                width: 260px;
                padding: 0.85rem;
                border-radius: 20px;
                border: 1px solid var(--admin-border);
                background: rgba(255, 253, 249, 0.98);
                box-shadow: var(--admin-shadow);
                opacity: 0;
                visibility: hidden;
                transform: translateY(8px);
                transition:
                    opacity var(--transition-base),
                    visibility var(--transition-base),
                    transform var(--transition-base);
            }

            .admin-user:hover .admin-user__dropdown,
            .admin-user:focus-within .admin-user__dropdown {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

            .admin-user__dropdown-header {
                padding: 0.2rem 0.2rem 0.85rem;
                margin-bottom: 0.55rem;
                border-bottom: 1px solid var(--admin-border);
            }

            .admin-user__dropdown-title {
                font-weight: 700;
                color: var(--admin-text);
                font-size: 0.94rem;
            }

            .admin-user__dropdown-text {
                color: var(--admin-text-muted);
                font-size: 0.82rem;
                margin-top: 0.15rem;
            }

            .admin-user__dropdown-link,
            .admin-user__logout {
                display: flex;
                align-items: center;
                gap: 0.7rem;
                padding: 0.8rem 0.85rem;
                border-radius: 12px;
                transition:
                    background var(--transition-fast),
                    color var(--transition-fast);
            }

            .admin-user__dropdown-link {
                color: var(--admin-text-muted);
            }

            .admin-user__dropdown-link:hover {
                background: rgba(196, 111, 75, 0.08);
                color: var(--admin-primary);
            }

            .admin-user__dropdown-footer {
                margin-top: 0.6rem;
                padding-top: 0.6rem;
                border-top: 1px solid var(--admin-border);
            }

            .admin-user__logout {
                width: 100%;
                border: 0;
                background: rgba(196, 111, 75, 0.08);
                color: var(--admin-primary-dark);
                font-weight: 600;
                cursor: pointer;
            }

            .admin-user__logout:hover {
                background: rgba(196, 111, 75, 0.14);
            }

            /* =========================
               SIDEBAR
            ========================== */
            .admin-sidebar__card {
                padding: 1.1rem;
                border-radius: 22px;
                border: 1px solid var(--admin-border);
                background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.9));
                margin-bottom: 1rem;
                text-align: center;
            }

            .admin-sidebar__eyebrow {
                display: inline-block;
                margin-bottom: 0.55rem;
                padding: 0.4rem 0.75rem;
                border-radius: 999px;
                background: rgba(196, 111, 75, 0.1);
                color: var(--admin-primary);
                font-size: 0.76rem;
                font-weight: 700;
            }

            .admin-sidebar__title {
                font-weight: 700;
                font-size: 1.4rem;
                line-height: 1.08;
                color: var(--admin-text);
                font-family: 'Fraunces', serif;
            }

            .admin-sidebar__text {
                font-size: 0.92rem;
                color: var(--admin-text-muted);
            }

            .admin-nav {
                display: grid;
                gap: 0.35rem;
                margin-bottom: 1rem;
            }

            .admin-nav__section {
                margin: 0.8rem 0 0.2rem;
                padding: 0 0.45rem;
                color: var(--admin-text-muted);
                text-transform: uppercase;
                letter-spacing: 0.08em;
                font-size: 0.72rem;
                font-weight: 700;
            }

            .admin-nav__item {
                display: flex;
                align-items: center;
                gap: 0.8rem;
                padding: 0.88rem 0.95rem;
                border-radius: 16px;
                color: var(--admin-text-muted);
                transition:
                    background var(--transition-fast),
                    color var(--transition-fast),
                    transform var(--transition-fast);
            }

            .admin-nav__item:hover {
                background: rgba(196, 111, 75, 0.08);
                color: var(--admin-primary);
                transform: translateX(2px);
            }

            .admin-nav__item.is-active {
                background: var(--admin-primary);
                color: #fff;
            }

            .admin-nav__icon {
                width: 22px;
                text-align: center;
                font-size: 1rem;
                flex-shrink: 0;
            }

            .admin-nav__badge {
                margin-left: auto;
                min-width: 22px;
                height: 22px;
                padding: 0 6px;
                border-radius: 999px;
                font-size: 0.7rem;
                font-weight: 700;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(196, 111, 75, 0.12);
                color: var(--admin-primary);
            }

            .admin-nav__item.is-active .admin-nav__badge {
                background: rgba(255,255,255,0.18);
                color: #fff;
            }

            .admin-sidebar__footer {
                margin-top: 1rem;
                padding: 1rem;
                border-radius: 20px;
                background: linear-gradient(135deg, rgba(47,127,121,0.08), rgba(196,111,75,0.08));
                border: 1px solid var(--admin-border);
                color: var(--admin-text-muted);
                font-size: 0.88rem;
            }

            .admin-sidebar__footer strong {
                display: block;
                margin-bottom: 0.25rem;
                color: var(--admin-text);
            }

            /* =========================
               REUSABLE ADMIN UI
            ========================== */
            .admin-page-header {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 1rem;
                margin-bottom: 1.5rem;
                padding: 1.6rem;
                border-radius: 28px;
                border: 1px solid var(--admin-border);
                background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.9));
            }

            .admin-page-header__eyebrow {
                display: inline-block;
                margin-bottom: 0.45rem;
                color: var(--admin-secondary);
                font-size: 0.8rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.08em;
            }

            .admin-page-header__title {
                font-family: 'Fraunces', serif;
                font-size: 1.9rem;
                line-height: 1.08;
                color: var(--admin-text);
                margin-bottom: 0.45rem;
            }

            .admin-page-header__desc {
                max-width: 60ch;
                color: var(--admin-text-muted);
            }

            .admin-page-header__actions {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                justify-content: flex-end;
            }

            .admin-card {
                background: rgba(255, 253, 249, 0.94);
                border: 1px solid var(--admin-border);
                border-radius: 26px;
                padding: 1.25rem;
                box-shadow: var(--admin-shadow-soft);
            }

            .admin-card + .admin-card {
                margin-top: 1rem;
            }

            .admin-card__header {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 1rem;
                margin-bottom: 1rem;
            }

            .admin-card__eyebrow {
                display: inline-block;
                margin-bottom: 0.3rem;
                color: var(--admin-text-muted);
                font-size: 0.76rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                font-weight: 700;
            }

            .admin-card__title {
                font-size: 1.08rem;
                color: var(--admin-text);
            }

            .admin-card__link {
                color: var(--admin-primary);
                font-weight: 600;
                font-size: 0.9rem;
            }

            .admin-grid {
                display: grid;
                gap: 1rem;
            }

            .admin-grid--2 {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .admin-grid--3 {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }

            .admin-grid--4 {
                grid-template-columns: repeat(4, minmax(0, 1fr));
            }

            .admin-kpi {
                display: flex;
                align-items: flex-start;
                gap: 1rem;
                padding: 1.15rem;
                border-radius: 22px;
                border: 1px solid var(--admin-border);
                background: var(--admin-surface);
            }

            .admin-kpi__icon {
                width: 50px;
                height: 50px;
                border-radius: 16px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 1.2rem;
                flex-shrink: 0;
                background: rgba(196, 111, 75, 0.1);
            }

            .admin-kpi__label {
                display: block;
                font-size: 0.82rem;
                color: var(--admin-text-muted);
                margin-bottom: 0.2rem;
            }

            .admin-kpi__value {
                display: block;
                font-size: 1.6rem;
                font-weight: 700;
                color: var(--admin-text);
                line-height: 1;
            }

            .admin-kpi__meta {
                display: block;
                margin-top: 0.25rem;
                font-size: 0.8rem;
                color: var(--admin-text-muted);
            }

            .status-pill {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0.38rem 0.75rem;
                border-radius: 999px;
                font-size: 0.74rem;
                font-weight: 700;
                white-space: nowrap;
            }

            .status-pill--success {
                background: var(--admin-success-soft);
                color: var(--admin-success);
            }

            .status-pill--warning {
                background: var(--admin-warning-soft);
                color: var(--admin-warning);
            }

            .status-pill--danger {
                background: var(--admin-danger-soft);
                color: var(--admin-danger);
            }

            .btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                padding: 0.82rem 1.1rem;
                border-radius: 999px;
                border: 1px solid transparent;
                cursor: pointer;
                transition:
                    background var(--transition-fast),
                    color var(--transition-fast),
                    border-color var(--transition-fast),
                    transform var(--transition-fast);
            }

            .btn:hover {
                transform: translateY(-1px);
            }

            .btn--primary {
                background: var(--admin-primary);
                color: #fff;
            }

            .btn--primary:hover {
                background: var(--admin-primary-dark);
            }

            .btn--secondary {
                background: var(--admin-secondary-soft);
                color: var(--admin-secondary);
                border-color: rgba(47, 127, 121, 0.18);
            }

            .btn--ghost {
                background: transparent;
                color: var(--admin-text-muted);
                border-color: var(--admin-border);
            }

            .btn--ghost:hover {
                background: rgba(196, 111, 75, 0.08);
                color: var(--admin-primary);
                border-color: rgba(196, 111, 75, 0.28);
            }

            .admin-table-wrap {
                overflow-x: auto;
            }

            .admin-table {
                width: 100%;
                min-width: 700px;
                border-collapse: collapse;
            }

            .admin-table th {
                text-align: left;
                padding: 0 0 0.85rem;
                border-bottom: 1px solid var(--admin-border);
                color: var(--admin-text-muted);
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                font-weight: 700;
            }

            .admin-table td {
                padding: 1rem 0;
                border-bottom: 1px solid rgba(231, 220, 205, 0.7);
                color: var(--admin-text);
                font-size: 0.94rem;
                vertical-align: middle;
            }

            .admin-empty {
                padding: 2rem 1rem;
                text-align: center;
                color: var(--admin-text-muted);
            }

            /* =========================
               RESPONSIVE
            ========================== */
            .admin-mobile-toggle {
                display: none;
            }

            @media (max-width: 1180px) {
                .admin-grid--4 {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .admin-grid--3 {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }
            }

            @media (max-width: 980px) {
                .admin-topbar__center {
                    display: none;
                }

                .admin-body {
                    grid-template-columns: 1fr;
                }

                .admin-sidebar {
                    position: static;
                    top: unset;
                    height: auto;
                    border-right: 0;
                    border-bottom: 1px solid rgba(231, 220, 205, 0.7);
                    padding-top: 1rem;
                    padding-bottom: 1rem;
                }

                .admin-main {
                    padding: 1rem;
                }

                .admin-user__meta {
                    display: none;
                }

                .admin-mobile-toggle {
                    display: inline-flex;
                }
            }

            @media (max-width: 640px) {
                :root {
                    --topbar-height: 72px;
                }

                .admin-topbar__inner {
                    padding-left: 1rem;
                    padding-right: 1rem;
                }

                .admin-sidebar,
                .admin-main {
                    padding-left: 1rem;
                    padding-right: 1rem;
                }

                .admin-brand__subtitle {
                    display: none;
                }

                .admin-page-header {
                    padding: 1.2rem;
                }

                .admin-page-header__title {
                    font-size: 1.5rem;
                }

                .admin-page-header__actions {
                    width: 100%;
                    justify-content: flex-start;
                }

                .admin-grid--2,
                .admin-grid--3,
                .admin-grid--4 {
                    grid-template-columns: 1fr;
                }

                .admin-user__dropdown {
                    width: min(88vw, 260px);
                }
            }
        </style>
    {% endblock %}
</head>
<body>
<div class="admin-shell">
    {% set currentRoute = app.request.attributes.get('_route') %}

    <header class="admin-topbar">
        <div class="admin-topbar__inner">
            <div style="display:flex; align-items:center; gap:.75rem;">
                <button class="icon-btn admin-mobile-toggle" type="button" aria-label="Menu">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 7H20M4 12H20M4 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </button>

                <a href="{{ path('app_admin_users_stats') }}" class="admin-brand" aria-label="Administration TravelMate">
                    
                    <span class="brand__mark" aria-hidden="true">
                        {# Image located in travelmate_web/assets/images/logo.png #}
                        <img src="{{ asset('images/logo.png') }}" alt="Logo">        
                    </span>

                    <span class="admin-brand__text">
                        <span class="admin-brand__title">TravelMate</span>
                        <span class="admin-brand__subtitle">administration</span>
                    </span>
                </a>
            </div>

            <div class="admin-topbar__center">
                <form class="admin-search" method="get" action="{{ app.request.pathInfo }}">
                    <span class="admin-search__icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                            <path d="M21 21L16.65 16.65M18 10.5C18 14.6421 14.6421 18 10.5 18C6.35786 18 3 14.6421 3 10.5C3 6.35786 6.35786 3 10.5 3C14.6421 3 18 6.35786 18 10.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <input
                        type="text"
                        name="search"
                        class="admin-search__input"
                        value="{{ app.request.query.get('search', '') }}"
                        placeholder="Rechercher un utilisateur, un voyage, une destination..."
                    >
                </form>
            </div>

            <div class="admin-topbar__actions">
                <button class="icon-btn" type="button" aria-label="Notifications">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 18H9M17 8C17 5.23858 14.7614 3 12 3C9.23858 3 7 5.23858 7 8V10.7639C7 11.4233 6.87041 12.0763 6.61803 12.6851L5.16568 16.1894C4.75614 17.1774 5.48244 18.25 6.55104 18.25H17.449C18.5176 18.25 19.2439 17.1774 18.8343 16.1894L17.382 12.6851C17.1296 12.0763 17 11.4233 17 10.7639V8Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="icon-btn__badge">5</span>
                </button>

                <a href="{{ path('app_home') }}" class="icon-btn" aria-label="Retour au site">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M14 5L7 12L14 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M7 12H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </a>

                <div class="admin-user">
                    <button class="admin-user__trigger" type="button" aria-label="Ouvrir le menu administrateur">
                        {% if app.user  %}
                            <img src="{{ app.user.profileImage }}" alt="Photo de profil" class="admin-user__avatar">
                        {% else %}
                            <img
                                class="admin-user__avatar"
                                src="{{ asset('images/profile-default.png') }}"
                                alt="Photo de profil"
                            >
                        {% endif %}

                        <span class="admin-user__meta">
                            <span class="admin-user__name">
                                {{ app.user ? app.user.userIdentifier : 'Administrateur' }}
                            </span>
                            <span class="admin-user__role">Administrateur</span>
                        </span>
                    </button>

                    <div class="admin-user__dropdown">
                        <div class="admin-user__dropdown-header">
                            <div class="admin-user__dropdown-title">
                                {{ app.user ? app.user.userIdentifier : 'Administrateur' }}
                            </div>
                            <div class="admin-user__dropdown-text">
                                Gestion du backoffice TravelMate
                            </div>
                        </div>

                        <a href="{{ path('app_profile') }}" class="admin-user__dropdown-link">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" stroke="currentColor" stroke-width="1.7"/>
                                <path d="M4 21C4 17.6863 7.58172 15 12 15C16.4183 15 20 17.6863 20 21" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                            </svg>
                            <span>Mon profil</span>
                        </a>

                        <a href="#" {# path('app_admin_settings') #} class="admin-user__dropdown-link">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M12 8.75C10.2051 8.75 8.75 10.2051 8.75 12C8.75 13.7949 10.2051 15.25 12 15.25C13.7949 15.25 15.25 13.7949 15.25 12C15.25 10.2051 13.7949 8.75 12 8.75Z" stroke="currentColor" stroke-width="1.7"/>
                                <path d="M19.4 15C19.2667 15.3 19.1667 15.6167 19.1 15.95L20.35 17.25L17.25 20.35L15.95 19.1C15.6167 19.1667 15.3 19.2667 15 19.4L14.5 21H9.5L9 19.4C8.7 19.2667 8.38333 19.1667 8.05 19.1L6.75 20.35L3.65 17.25L4.9 15.95C4.83333 15.6167 4.73333 15.3 4.6 15L3 14.5V9.5L4.6 9C4.73333 8.7 4.83333 8.38333 4.9 8.05L3.65 6.75L6.75 3.65L8.05 4.9C8.38333 4.83333 8.7 4.73333 9 4.6L9.5 3H14.5L15 4.6C15.3 4.73333 15.6167 4.83333 15.95 4.9L17.25 3.65L20.35 6.75L19.1 8.05C19.1667 8.38333 19.2667 8.7 19.4 9L21 9.5V14.5L19.4 15Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                            </svg>
                            <span>Paramètres admin</span>
                        </a>

                        <div class="admin-user__dropdown-footer">
                            <a href="{{ path('app_logout') }}" class="admin-user__logout">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M15 17L20 12L15 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M20 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <path d="M12 20H6C4.89543 20 4 19.1046 4 18V6C4 4.89543 4.89543 4 6 4H12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                                <span>Se déconnecter</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="admin-body">
        <aside class="admin-sidebar">
            <div class="admin-sidebar__card">
                <span class="admin-sidebar__title">Backoffice</span>
            </div>

            <nav class="admin-nav" aria-label="Navigation administration">
                <div class="admin-nav__section">Vue globale</div>

                <a href="{{ path('app_admin_users_stats') }}"
                   class="admin-nav__item {{ currentRoute == 'app_admin_users_stats' ? 'is-active' : '' }}">
                    
                    <span>Tableau de bord</span>
                </a>

                <div class="admin-nav__section">Gestion</div>

                <a href="{{ path('app_admin_users') }}"
                   class="admin-nav__item {{ currentRoute == 'app_admin_users' ? 'is-active' : '' }}">
                    
                    <span>Utilisateurs</span>
                </a>

                <a href="{{ path('app_admin_voyages') }}"
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_voyages' ? 'is-active' : '' }}">
                    
                    <span>Voyages</span>
                </a>

                <a href="#" {# path('app_admin_destinations') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_destinations' ? 'is-active' : '' }}">
                    
                    <span>Destinations</span>
                </a>

                <a href="#" {# path('app_admin_hebergements') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_hebergements' ? 'is-active' : '' }}">
                    
                    <span>Hébergements</span>
                </a>

                <a href="#" {# path('app_admin_categories') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_categories' ? 'is-active' : '' }}">
                    
                    <span>Catégories</span>
                </a>

                <a href="#" {# path('app_admin_activites') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_activites' ? 'is-active' : '' }}">
                    
                    <span>Activités</span>
                </a>

                <a href="#" {# path('app_admin_budgets') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_budgets' ? 'is-active' : '' }}">
                    
                    <span>Budgets</span>
                </a>

                <a href="{{ path('app_admin_itineraires') }}"
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_itineraires' ? 'is-active' : '' }}">
                    <span>Itinéraires</span>
                </a>

                <div class="admin-nav__section">Modération</div>

                <a href="#" {# path('app_admin_reports') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_reports' ? 'is-active' : '' }}">
                    <span class="admin-nav__icon">🚩</span>
                    <span>Signalements</span>
                    <span class="admin-nav__badge">7</span>
                </a>

                <a href="#" {# path('app_admin_settings') #}
                   class="admin-nav__item {{ currentRoute starts with 'app_admin_settings' ? 'is-active' : '' }}">
                    <span class="admin-nav__icon">⚙️</span>
                    <span>Paramètres</span>
                </a>
            </nav>

            <div class="admin-sidebar__footer">
                <strong>TravelMate Admin</strong>
                Contrôle, modération et pilotage de la plateforme dans une interface claire et légère.
            </div>
        </aside>

        <main class="admin-main">
            <div class="admin-main__inner">
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>
</div>

{% block javascripts %}{% endblock %}
</body>
</html>