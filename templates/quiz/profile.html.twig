{% extends 'base.html.twig' %}

{% block title %}Vos recommandations — TravelMate{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<style>
.act-hero {
    position: relative; height: 480px; border-radius: var(--radius-xl);
    overflow: hidden; margin-bottom: 3rem; display: flex; align-items: flex-end;
}
.act-hero__bg {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(20,14,10,0.72) 0%, rgba(20,14,10,0.18) 55%, transparent 100%),
        url('/uploads/activites/rand.jpg') center/cover no-repeat;
    transform: scale(1.04); transition: transform 8s ease;
}
.act-hero:hover .act-hero__bg { transform: scale(1); }
.act-hero__content { position: relative; padding: 2.5rem 3rem; max-width: 640px; }
.act-hero__eyebrow {
    display: inline-block; font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-accent); margin-bottom: 0.75rem;
}
.act-hero__title {
    font-family: 'Fraunces', serif; font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600; color: #fff; line-height: 1.1;
    margin-bottom: 0.85rem; letter-spacing: -0.02em;
}
.act-hero__desc { font-size: 1rem; color: rgba(255,255,255,0.75); line-height: 1.65; max-width: 480px; margin-bottom: 1.75rem; }
.act-hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }
.btn-hero-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.5rem; border-radius: 999px;
    background: var(--color-primary); color: #fff;
    font: inherit; font-size: 0.92rem; font-weight: 600;
    border: none; cursor: pointer; text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-primary:hover { background: var(--color-primary-dark); transform: translateY(-1px); }
.btn-hero-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.5rem; border-radius: 999px;
    background: rgba(255,255,255,0.12); color: #fff;
    font: inherit; font-size: 0.92rem; font-weight: 500;
    border: 1px solid rgba(255,255,255,0.3); cursor: pointer; text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-ghost:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }
.act-hero__stats { position: absolute; bottom: 2.5rem; right: 3rem; display: flex; gap: 1.5rem; }
.hero-stat { text-align: center; color: #fff; }
.hero-stat__num { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 600; line-height: 1; }
.hero-stat__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }

.score-badge {
    position: absolute; top: 0.75rem; right: 0.75rem;
    background: var(--color-primary); color: #fff;
    font-size: 0.75rem; font-weight: 700;
    padding: 0.3rem 0.7rem; border-radius: 999px;
    z-index: 2;
}

/* Reprend exactement les styles de act-grid, act-card, badge, tag depuis index */
.act-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
}
.act-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    display: flex; flex-direction: column;
}
.act-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px var(--color-shadow); }
.act-card__img-wrap { position: relative; aspect-ratio: 4/3; overflow: hidden; background: var(--color-border); }
.act-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.act-card:hover .act-card__img { transform: scale(1.05); }
.act-card__img-placeholder {
    width: 100%; height: 100%; display: flex;
    align-items: center; justify-content: center; color: var(--color-border);
}
.act-card__img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.35) 0%, transparent 60%);
}
.act-card__badges { position: absolute; top: 0.75rem; left: 0.75rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
.badge { font-size: 0.72rem; font-weight: 600; padding: 0.28rem 0.65rem; border-radius: 999px; }
.badge--trending { background: var(--color-primary); color: #fff; }
.badge--cat { background: rgba(255,255,255,0.92); color: var(--color-text); }
.act-card__rating {
    position: absolute; bottom: 0.75rem; left: 0.75rem;
    display: flex; align-items: center; gap: 0.3rem;
    background: rgba(0,0,0,0.55); color: #fff;
    font-size: 0.8rem; font-weight: 600;
    padding: 0.25rem 0.6rem; border-radius: 999px;
}
.star { color: #f5a623; }
.act-card__body { padding: 1.1rem 1.25rem 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
.act-card__name { font-size: 1rem; font-weight: 700; color: var(--color-text); line-height: 1.3; }
.act-card__location { display: flex; align-items: center; gap: 0.35rem; font-size: 0.82rem; color: var(--color-muted); }
.act-card__tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.tag { font-size: 0.75rem; padding: 0.22rem 0.6rem; border-radius: 999px; background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-muted); }
.tag--facile { background: #e6f9f0; border-color: #a3e6c8; color: #1a7a4a; }
.tag--intermediaire, .tag--intermédiaire { background: #fff8e6; border-color: #fcd97a; color: #8a6200; }
.tag--difficile { background: #ffeee6; border-color: #ffb899; color: #b84000; }
.tag--expert { background: #fce6e6; border-color: #f5a0a0; color: #9b1c1c; }
.act-card__footer { display: flex; align-items: flex-end; justify-content: space-between; margin-top: auto; padding-top: 0.5rem; }
.act-price-label { font-size: 0.72rem; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.act-price-value { font-size: 1.15rem; font-weight: 700; color: var(--color-primary); }
.act-price-unit { font-size: 0.8rem; font-weight: 500; }
.act-card__arrow {
    width: 2rem; height: 2rem; border-radius: 50%;
    background: var(--color-bg); border: 1px solid var(--color-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--color-primary);
    transition: background var(--transition-fast), color var(--transition-fast);
}
.act-card:hover .act-card__arrow { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

.results-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 0.5rem; }
.results-count { font-size: 0.95rem; color: var(--color-muted); }
.results-count strong { color: var(--color-text); font-size: 1.05rem; }

.act-empty { grid-column: 1/-1; text-align: center; padding: 4rem 2rem; color: var(--color-muted); }
.act-empty__title { font-size: 1.1rem; font-weight: 600; color: var(--color-text); margin: 1rem 0 0.5rem; }

.profile-info {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-xl); padding: 1rem 1.5rem;
    margin-bottom: 1.75rem; display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 1rem;
}
.profile-info__text { font-size: 0.9rem; color: var(--color-muted); }
.profile-info__text strong { color: var(--color-text); }
.btn-refaire {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 1.2rem; border-radius: 999px;
    background: transparent; color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
    font: inherit; font-size: 0.85rem; font-weight: 600;
    cursor: pointer; text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
}
.btn-refaire:hover { background: var(--color-primary); color: #fff; }
</style>
{% endblock %}

{% block body %}
<div class="container" style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">

    {# ── Hero ── #}
    <div class="act-hero">
        <div class="act-hero__bg"></div>
        <div class="act-hero__content">
            <span class="act-hero__eyebrow">RECOMMANDATIONS PERSONNALISÉES</span>
            <h1 class="act-hero__title">Vos activités<br>idéales</h1>
            <p class="act-hero__desc">Sélectionnées par notre IA selon vos préférences.</p>
            <div class="act-hero__actions">
                <a href="{{ path('app_activites') }}" class="btn-hero-primary">
                    Voir toutes les activités
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ path('app_quiz_reset') }}" class="btn-hero-ghost">Refaire le quiz</a>
            </div>
        </div>
        <div class="act-hero__stats">
            <div class="hero-stat">
                <div class="hero-stat__num">{{ recommendations|length }}</div>
                <div class="hero-stat__label">Activités</div>
            </div>
        </div>
    </div>

    {# ── Profil détecté ── #}
    <div class="profile-info">
        <div class="profile-info__text">
            <strong>Profil détecté :</strong> {{ userProfile }}
        </div>
        <a href="{{ path('app_quiz_reset') }}" class="btn-refaire">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M1 4v6h6M23 20v-6h-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Refaire le quiz
        </a>
    </div>

    {# ── Compteur ── #}
    <div class="results-row">
        <p class="results-count">
            <strong>{{ recommendations|length }}</strong>
            activité{{ recommendations|length != 1 ? 's' : '' }} recommandée{{ recommendations|length != 1 ? 's' : '' }}
        </p>
    </div>

    {# ── Grille ── #}
    <div class="act-grid">
        {% if recommendations is empty %}
            <div class="act-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" style="margin:0 auto;color:var(--color-border)"><path d="M3 7h18M3 12h18M3 17h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <div class="act-empty__title">Aucune activité trouvée</div>
                <p>Essayez de refaire le quiz avec d'autres préférences.</p>
            </div>
        {% else %}
            {% for item in recommendations %}
                <a href="{{ path('app_activite_show', {id: item.id}) }}" class="act-card">

                    <div class="act-card__img-wrap">
                        {# Badge score #}
                        <div class="score-badge">{{ (item.score * 100)|round }}% match</div>

                        {% if item.imagePath is defined and item.imagePath %}
                            <img src="{{ asset(item.imagePath) }}"
                                 alt="{{ item.nom }}" class="act-card__img"
                                 onerror="this.style.display='none';this.parentElement.querySelector('.act-card__img-placeholder').style.display='flex'">
                        {% endif %}
                        <div class="act-card__img-placeholder" style="{{ (item.imagePath is defined and item.imagePath) ? 'display:none' : '' }}">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <div class="act-card__img-overlay"></div>
                        <div class="act-card__badges">
                            {% if item.categorie %}
                                <span class="badge badge--cat">{{ item.categorie }}</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="act-card__body">
                        <div class="act-card__name">{{ item.nom }}</div>
                        {% if item.lieu %}
                            <div class="act-card__location">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                                <span>{{ item.lieu|slice(0,42) }}{{ item.lieu|length > 42 ? '…' : '' }}</span>
                            </div>
                        {% endif %}
                        <div class="act-card__tags">
                            {% if item.niveaudifficulte %}
                                <span class="tag tag--{{ item.niveaudifficulte|lower }}">{{ item.niveaudifficulte }}</span>
                            {% endif %}
                        </div>
                        <div class="act-card__footer">
                            <div>
                                <div class="act-price-label">À partir de</div>
                                <div class="act-price-value">{{ item.budget }} <span class="act-price-unit">TND</span></div>
                            </div>
                            <div class="act-card__arrow">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        {% endif %}
    </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/travelmate-mymemory-translate.js') }}"></script>
<script>
(function () {
    function bootTranslate() {
        if (window.TravelMateTranslate) {
            TravelMateTranslate.init({ sourceLang: 'fr' });
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootTranslate);
    } else {
        bootTranslate();
    }
})();
</script>
{% endblock %}