{% extends 'base.html.twig' %}

{% block title %}Événements — TravelMate{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>

/* ═══════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════ */
.eve-hero {
    position: relative;
    height: 480px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 3rem;
    display: flex;
    align-items: flex-end;
}
.eve-hero__bg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to top, rgba(20,14,10,0.72) 0%, rgba(20,14,10,0.18) 55%, transparent 100%),
        url('/uploads/evenements/event.png') center/cover no-repeat;
    transform: scale(1.04);
    transition: transform 8s ease;
}
.eve-hero:hover .eve-hero__bg { transform: scale(1); }
.eve-hero__content {
    position: relative;
    padding: 2.5rem 3rem;
    max-width: 640px;
}
.eve-hero__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
}
.eve-hero__title {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
}
.eve-hero__desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 1.75rem;
}
.eve-hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
}
.btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-primary:hover { background: var(--color-primary-dark); transform: translateY(-1px); }
.btn-hero-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: #fff;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-hero-ghost:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }

.eve-hero__stats {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    display: flex;
    gap: 1.5rem;
}
.hero-stat { text-align: center; color: #fff; }
.hero-stat__num {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1;
}
.hero-stat__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
    margin-top: 0.2rem;
}

/* ═══════════════════════════════════════════════════
   SEARCH
═══════════════════════════════════════════════════ */
.search-bar {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}
.search-field {
    position: relative;
    flex: 1;
    min-width: 220px;
    max-width: 360px;
}
.search-field__icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
}
.search-field__input {
    width: 100%;
    padding: 0.72rem 1rem 0.72rem 2.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    font: inherit;
    font-size: 0.9rem;
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.search-field__input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(196,111,75,0.1);
}
.results-count {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
}

/* ═══════════════════════════════════════════════════
   GRILLE ÉVÉNEMENTS
═══════════════════════════════════════════════════ */
.eve-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
}

.eve-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}
.eve-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.10);
}

.eve-card__img-wrap {
    position: relative;
    height: 200px;
    background: var(--color-bg-soft);
    overflow: hidden;
}
.eve-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}
.eve-card:hover .eve-card__img { transform: scale(1.04); }
.eve-card__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border);
}
.eve-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.35) 0%, transparent 60%);
}
.eve-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--color-primary);
    color: #fff;
}
.eve-card__badge--full {
    background: rgba(0,0,0,0.45);
    color: rgba(255,255,255,0.75);
}
.eve-card__date-badge {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(255,255,255,0.95);
    border-radius: var(--radius-md);
    padding: 0.35rem 0.6rem;
    text-align: center;
    min-width: 42px;
}
.eve-card__date-day {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary);
}
.eve-card__date-month {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-top: 0.1rem;
}
.eve-card__body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
}
.eve-card__title {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
}
.eve-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
}
.eve-card__meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.84rem;
    color: var(--color-text-muted);
}
.eve-card__footer {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.eve-places {
    font-size: 0.82rem;
    color: var(--color-text-muted);
}
.eve-places strong { color: var(--color-text); }
.btn-join {
    padding: 0.45rem 1rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-join:hover { background: var(--color-primary-dark); transform: translateY(-1px); }
.btn-join--full {
    background: var(--color-border);
    color: var(--color-text-muted);
    cursor: not-allowed;
}
.btn-join--full:hover { background: var(--color-border); transform: none; }

.eve-empty {
    grid-column: 1/-1;
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-muted);
}
.eve-empty__title {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem;
    color: var(--color-text);
}

/* ═══════════════════════════════════════════════════
   SECTION SÉPARATRICE
═══════════════════════════════════════════════════ */
.section-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 3rem 0 2rem;
}
.section-divider__line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
}
.section-divider__label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
}

/* ═══════════════════════════════════════════════════
   DESTINATION SEARCH BOX
═══════════════════════════════════════════════════ */
.dest-search-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
}
.dest-search-box__title {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
}
.dest-search-box__sub {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin-bottom: 1.1rem;
}
.dest-search-box__form {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
}
.dest-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    background: rgba(196,111,75,0.1);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 0.75rem;
}

</style>
{% endblock %}

{% block body %}

{% include '_travelmate_mymemory_translate.html.twig' %}

{# ═══════ HERO ═══════ #}
<section class="eve-hero">
    <div class="eve-hero__bg"></div>
    <div class="eve-hero__content">
        <span class="eve-hero__eyebrow" data-translate="true">Événements</span>
        <h1 class="eve-hero__title" data-translate="true">Rejoignez des expériences collectives</h1>
        <p class="eve-hero__desc" data-translate="true">
            Ateliers, sorties, rencontres culturelles —
            participez à des événements uniques et rencontrez d'autres voyageurs.
        </p>
        <div class="eve-hero__actions">
            <a href="#evenements" class="btn-hero-primary">
                <span data-translate="true">Explorer les événements</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="{{ path('app_activites') }}" class="btn-hero-ghost" data-translate="true">Voir les activités</a>
        </div>
    </div>
    <div class="eve-hero__stats">
        <div class="hero-stat">
            <div class="hero-stat__num">{{ evenements|length }}</div>
            <div class="hero-stat__label" data-translate="true">Événements</div>
        </div>
    </div>
</section>

{# ═══════ ÉVÉNEMENTS LOCAUX (admin) ═══════ #}
<div id="evenements">

    <div class="search-bar">
        <div class="search-field">
            <span class="search-field__icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </span>
            <input type="search" class="search-field__input" id="searchInput" placeholder="Rechercher un événement…" data-translate="true">
        </div>
    </div>

    <p class="results-count">
        <strong id="countNum">{{ evenements|length }}</strong>
        <span data-translate="true">événement{% if evenements|length != 1 %}s{% endif %} disponible{% if evenements|length != 1 %}s{% endif %}</span>
    </p>

    <div class="eve-grid" id="eveGrid">
        {% if evenements is empty %}
            <div class="eve-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" style="margin:0 auto;color:var(--color-border)"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <div class="eve-empty__title" data-translate="true">Aucun événement disponible</div>
                <p data-translate="true">Revenez bientôt, de nouveaux événements arrivent.</p>
            </div>
        {% else %}
            {% for evenement in evenements %}
                {% set complet = evenement.isComplet %}
                <a href="{{ path('app_evenement_show', {id: evenement.id}) }}"
                   class="eve-card"
                   data-titre="{{ evenement.titre|lower }}">

                    <div class="eve-card__img-wrap">
                        {% if evenement.imagePath %}
                            <img src="{{ asset('uploads/evenements/' ~ evenement.imagePath) }}"
                                 alt="{{ evenement.titre }}"
                                 class="eve-card__img"
                                 onerror="this.style.display='none'">
                        {% else %}
                            <div class="eve-card__img-placeholder">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                            </div>
                        {% endif %}
                        <div class="eve-card__overlay"></div>

                        {% if complet %}
                            <span class="eve-card__badge eve-card__badge--full" data-translate="true">Complet</span>
                        {% else %}
                            <span class="eve-card__badge" data-translate="true">Ouvert</span>
                        {% endif %}

                        <div class="eve-card__date-badge">
                            <div class="eve-card__date-day">{{ evenement.date|date('d') }}</div>
                            <div class="eve-card__date-month" data-translate="true" data-original="{{ evenement.date|date('M') }}">{{ evenement.date|date('M') }}</div>
                        </div>
                    </div>

                    <div class="eve-card__body">
                        <div class="eve-card__title" data-translate="true" data-original="{{ evenement.titre }}">{{ evenement.titre }}</div>
                        <div class="eve-card__meta">
                            <div class="eve-card__meta-item">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                                <span data-translate="true" data-original="{{ evenement.lieu }}">{{ evenement.lieu }}</span>
                            </div>
                            <div class="eve-card__meta-item">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                                {{ evenement.heure|date('H:i') }}
                            </div>
                            {% if evenement.description %}
                                {% set descPrev = evenement.description|slice(0,90) ~ (evenement.description|length > 90 ? '…' : '') %}
                                <div class="eve-card__meta-item" style="margin-top:.2rem;color:var(--color-text);opacity:.8;font-size:.82rem;line-height:1.4">
                                    <span data-translate="true" data-original="{{ descPrev|e('html_attr') }}">{{ evenement.description|slice(0,90) }}{% if evenement.description|length > 90 %}…{% endif %}</span>
                                </div>
                            {% endif %}
                        </div>

                        <div class="eve-card__footer">
                            <div class="eve-places">
                                <strong>{{ evenement.placesRestantes }}</strong> / {{ evenement.nbPlaces }} <span data-translate="true">places</span>
                            </div>
                            {% if complet %}
                                <span class="btn-join btn-join--full" data-translate="true">Complet</span>
                            {% else %}
                                <span class="btn-join" data-translate="true">Rejoindre →</span>
                            {% endif %}
                        </div>
                    </div>
                </a>
            {% endfor %}
        {% endif %}
    </div>
</div>

{# ═══════ SÉPARATEUR ═══════ #}
<div class="section-divider">
    <div class="section-divider__line"></div>
    <span class="section-divider__label" data-translate="true">Événements par destination</span>
    <div class="section-divider__line"></div>
</div>

{# ═══════ ÉVÉNEMENTS EXTERNES (Ticketmaster) ═══════ #}
<section id="external-events">

    <div class="dest-search-box">
        <div class="dest-search-box__title" data-translate="true">Découvrez les événements dans votre destination</div>
        <p class="dest-search-box__sub" data-translate="true">
            Festivals, concerts, expositions — entrez une ville pour voir ce qui s'y passe prochainement.
        </p>
        <form method="GET" action="{{ path('app_evenements') }}#external-events" class="dest-search-box__form">
            <div class="search-field" style="max-width:320px;">
                <span class="search-field__icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                </span>
                <input
                    type="text"
                    name="destination"
                    class="search-field__input"
                    value="{{ destination }}"
                    placeholder="Paris, London, New York…"
                    autocomplete="off"
                >
            </div>
            <button type="submit" class="btn-join" style="padding:.7rem 1.4rem;font-size:.9rem;" data-translate="true">
                Découvrir des événements 
            </button>
            {% if destination %}
                <a href="{{ path('app_evenements') }}#external-events"
                   style="font-size:.85rem;color:var(--color-text-muted);text-decoration:none;padding:.5rem;"
                   data-translate="true">
                    ✕ Effacer
                </a>
            {% endif %}
        </form>
        {% if destination %}
            <div class="dest-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                {{ destination }}
            </div>
        {% endif %}
    </div>

    {% if destination %}

        <p class="results-count">
            <strong>{{ externalEvents|length }}</strong>
            <span data-translate="true">événement(s) trouvé(s) pour</span>
            « <strong>{{ destination }}</strong> »
            <span style="font-size:.8rem;margin-left:.5rem;opacity:.6;">— via Ticketmaster</span>
        </p>

        {% if externalEvents is empty %}
            <div class="eve-empty" style="padding:2.5rem 0;text-align:left;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" style="color:var(--color-border)">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                </svg>
                <div class="eve-empty__title" data-translate="true">Aucun événement trouvé pour « {{ destination }} »</div>
                <p style="margin-top:.4rem;" data-translate="true">
                    Essayez avec le nom de la ville en anglais (ex: "Paris", "London", "Rome").
                </p>
            </div>
        {% else %}
            <div class="eve-grid">
                {% for ev in externalEvents %}
                    <a href="{{ ev.url }}"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="eve-card"
                       data-titre="{{ ev.titre|lower }}">

                        <div class="eve-card__img-wrap">
                            {% if ev.image %}
                                <img src="{{ ev.image }}"
                                     alt="{{ ev.titre }}"
                                     class="eve-card__img"
                                     loading="lazy"
                                     onerror="this.parentNode.innerHTML='<div class=\'eve-card__img-placeholder\'><svg width=\'40\' height=\'40\' viewBox=\'0 0 24 24\' fill=\'none\'><rect x=\'3\' y=\'4\' width=\'18\' height=\'18\' rx=\'2\' stroke=\'currentColor\' stroke-width=\'1.2\'/></svg></div>'">
                            {% else %}
                                <div class="eve-card__img-placeholder">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
                                        <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.2"/>
                                        <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                                    </svg>
                                </div>
                            {% endif %}
                            <div class="eve-card__overlay"></div>

                            <span class="eve-card__badge" style="background:var(--color-accent);" data-translate="true">
                                {{ ev.categorie }}
                            </span>

                            {% if ev.date %}
                                <div class="eve-card__date-badge">
                                    <div class="eve-card__date-day">{{ ev.date|date('d') }}</div>
                                    <div class="eve-card__date-month">{{ ev.date|date('M') }}</div>
                                </div>
                            {% endif %}
                        </div>

                        <div class="eve-card__body">
                            <div class="eve-card__title">{{ ev.titre }}</div>
                            <div class="eve-card__meta">
                                <div class="eve-card__meta-item">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                                    </svg>
                                    <span>{{ ev.lieu }}{% if ev.ville %}, {{ ev.ville }}{% endif %}</span>
                                </div>
                                {% if ev.heure and ev.heure != '00:00' %}
                                    <div class="eve-card__meta-item">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                                            <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                        </svg>
                                        {{ ev.heure }}
                                    </div>
                                {% endif %}
                                {% if ev.date %}
                                    <div class="eve-card__meta-item">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                                            <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                                            <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                        </svg>
                                        {{ ev.date|date('d/m/Y') }}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="eve-card__footer">
                                <span style="font-size:.75rem;color:var(--color-text-muted);display:flex;align-items:center;gap:.3rem;">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><polyline points="15 3 21 3 21 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><line x1="10" y1="14" x2="21" y2="3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                                    Ticketmaster
                                </span>
                                <span class="btn-join" data-translate="true">Voir billets →</span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

    {% endif %}

</section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/travelmate-mymemory-translate.js') }}"></script>
<script>
(function () {
    function bootTranslate() {
        if (window.TravelMateTranslate) {
            TravelMateTranslate.init({ sourceLang: 'fr' });
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootTranslate);
    } else {
        bootTranslate();
    }
})();
</script>
<script>
(function() {
    const searchInput = document.getElementById('searchInput');
    const cards       = document.querySelectorAll('#eveGrid .eve-card[data-titre]');
    const countEl     = document.getElementById('countNum');

    function filter() {
        const q = searchInput.value.toLowerCase().trim();
        let visible = 0;
        cards.forEach(card => {
            const show = !q || card.dataset.titre.includes(q);
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (countEl) countEl.textContent = visible;
    }

    if (searchInput) searchInput.addEventListener('input', filter);

    document.querySelector('a[href="#evenements"]')?.addEventListener('click', e => {
        e.preventDefault();
        document.getElementById('evenements').scrollIntoView({ behavior: 'smooth' });
    });
})();
</script>
{% endblock %}
