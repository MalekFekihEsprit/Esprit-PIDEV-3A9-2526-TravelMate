{% extends 'base.html.twig' %}

{% block title %}Événements — TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Hero ── */
        .ev-hero {
            background: linear-gradient(135deg, rgba(47,127,121,0.12) 0%, rgba(196,111,75,0.07) 100%);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            padding: 2.5rem 2rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            flex-wrap: wrap;
        }
        .ev-hero__title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            font-weight: 600;
            line-height: 1.15;
        }
        .ev-hero__title span { color: var(--color-secondary); }
        .ev-hero__sub { color: var(--color-text-muted); font-size: 1rem; margin-top: 0.4rem; }

        /* ── Grille ── */
        .ev-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
        }

        /* ── Carte événement ── */
        .ev-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
        }
        .ev-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 40px rgba(71,48,35,0.10);
            border-color: rgba(47,127,121,0.3);
        }

        /* Image */
        .ev-card__img-wrap {
            position: relative;
            height: 180px;
            overflow: hidden;
            background: var(--color-surface-soft);
        }
        .ev-card__img { width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease; }
        .ev-card:hover .ev-card__img { transform: scale(1.05); }
        .ev-card__img-placeholder {
            width:100%;height:100%;
            display:flex;align-items:center;justify-content:center;
            font-size:3rem;color:var(--color-text-muted);
        }

        /* Date badge flottant */
        .ev-date-badge {
            position: absolute;
            top: 0.75rem;
            left: 0.75rem;
            background: rgba(255,253,249,0.95);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: 0.45rem 0.75rem;
            text-align: center;
            backdrop-filter: blur(8px);
            min-width: 54px;
        }
        .ev-date-badge__day {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--color-secondary);
            line-height: 1;
        }
        .ev-date-badge__month {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--color-text-muted);
            margin-top: 0.1rem;
        }

        /* Places badge */
        .ev-places-badge {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            border-radius: 999px;
            padding: 0.3rem 0.7rem;
            font-size: 0.75rem;
            font-weight: 600;
            backdrop-filter: blur(6px);
        }
        .ev-places-badge--ok      { background: rgba(47,127,121,0.88); color:#fff; }
        .ev-places-badge--few     { background: rgba(200,160,50,0.88); color:#fff; }
        .ev-places-badge--complet { background: rgba(150,30,30,0.85);  color:#fff; }

        /* Corps */
        .ev-card__body { padding:1.25rem; flex:1; display:flex; flex-direction:column; gap:0.6rem; }
        .ev-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem; font-weight: 600;
            color: var(--color-text); line-height:1.2;
        }
        .ev-card__meta {
            display:flex; align-items:center; gap:0.4rem;
            font-size:0.83rem; color:var(--color-text-muted);
        }

        /* Progress bar places */
        .ev-progress { margin-top: 0.5rem; }
        .ev-progress__label {
            display:flex; justify-content:space-between;
            font-size:0.78rem; color:var(--color-text-muted); margin-bottom:0.3rem;
        }
        .ev-progress__bar {
            height: 5px; border-radius: 999px;
            background: var(--color-surface-soft);
            overflow: hidden;
        }
        .ev-progress__fill {
            height: 100%; border-radius: 999px;
            background: var(--color-secondary);
            transition: width 0.4s ease;
        }

        /* Footer carte */
        .ev-card__footer {
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1px solid var(--color-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
        }
        .ev-card__heure {
            font-size: 0.85rem;
            color: var(--color-text-muted);
            display: flex; align-items: center; gap: 0.35rem;
        }
        .btn-join {
            display: inline-flex; align-items: center; gap: 0.4rem;
            padding: 0.6rem 1.1rem;
            border-radius: 999px;
            background: var(--color-secondary);
            color: #fff;
            font: inherit; font-size: 0.88rem; font-weight: 600;
            border: none; cursor: pointer;
            text-decoration: none;
            transition: background var(--transition-fast), transform var(--transition-fast);
        }
        .btn-join:hover { background: #256860; transform: translateY(-1px); }
        .btn-join--disabled {
            background: var(--color-surface-soft);
            color: var(--color-text-muted);
            border: 1px solid var(--color-border);
            cursor: not-allowed;
        }
        .btn-join--disabled:hover { transform: none; background: var(--color-surface-soft); }

        /* ── Vide ── */
        .ev-empty {
            grid-column: 1/-1;
            text-align: center; padding: 4rem 2rem;
            color: var(--color-text-muted);
        }
        .ev-empty__icon { font-size: 3.5rem; margin-bottom: 1rem; }
    </style>
{% endblock %}

{% block body %}
{# Hero #}
<div class="ev-hero">
    <div>
        <h1 class="ev-hero__title">Nos <span>Événements</span></h1>
        <p class="ev-hero__sub">Rejoignez des expériences collectives à date fixe et rencontrez d'autres voyageurs</p>
    </div>
    <a href="{{ path('app_activites') }}" class="btn btn--ghost">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Voir les Activités
    </a>
</div>

{# Grille #}
<div class="ev-grid">
    {% if evenements is empty %}
        <div class="ev-empty">
            <div class="ev-empty__icon">📅</div>
            <div style="font-weight:600;color:var(--color-text);font-size:1.2rem;margin-bottom:0.4rem">Aucun événement à venir</div>
            <p>De nouveaux événements seront bientôt annoncés. Restez connectés !</p>
        </div>
    {% else %}
        {% for evenement in evenements %}
            {% set nbParticipants = evenement.participations|length %}
            {% set placesRestantes = evenement.placesRestantes %}
            {% set pct = evenement.nbPlaces > 0 ? ((nbParticipants / evenement.nbPlaces) * 100)|round : 0 %}
            {% set isComplet = evenement.isComplet %}
            {% set isFew = placesRestantes > 0 and placesRestantes <= 5 %}

            <div class="ev-card">
                {# Image #}
                <div class="ev-card__img-wrap">
                    {% if evenement.imagePath %}
                        <img src="{{ asset(evenement.imagePath|replace({'\\\\': '/'})) }}"
                             alt="{{ evenement.titre }}" class="ev-card__img"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div class="ev-card__img-placeholder" style="display:none">🎉</div>
                    {% else %}
                        <div class="ev-card__img-placeholder">🎉</div>
                    {% endif %}

                    {# Date badge #}
                    <div class="ev-date-badge">
                        <div class="ev-date-badge__day">{{ evenement.date|date('d') }}</div>
                        <div class="ev-date-badge__month">{{ evenement.date|date('M')|upper }}</div>
                    </div>

                    {# Places badge #}
                    <div class="ev-places-badge {{ isComplet ? 'ev-places-badge--complet' : (isFew ? 'ev-places-badge--few' : 'ev-places-badge--ok') }}">
                        {% if isComplet %}
                            Complet
                        {% elseif isFew %}
                            ⚡ {{ placesRestantes }} place{{ placesRestantes > 1 ? 's' : '' }}
                        {% else %}
                            {{ placesRestantes }} places
                        {% endif %}
                    </div>
                </div>

                {# Corps #}
                <div class="ev-card__body">
                    <div class="ev-card__title">{{ evenement.titre }}</div>

                    <div class="ev-card__meta">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="currentColor"/></svg>
                        {{ evenement.lieu|slice(0,50) }}{{ evenement.lieu|length > 50 ? '…' : '' }}
                    </div>

                    <div class="ev-card__meta">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                        {{ evenement.date|date('d/m/Y') }}
                    </div>

                    {% if evenement.description %}
                        <p style="font-size:0.85rem;color:var(--color-text-muted);line-height:1.55">
                            {{ evenement.description|slice(0,100) }}{{ evenement.description|length > 100 ? '…' : '' }}
                        </p>
                    {% endif %}

                    {# Progress places #}
                    <div class="ev-progress">
                        <div class="ev-progress__label">
                            <span>{{ nbParticipants }} participant{{ nbParticipants != 1 ? 's' : '' }}</span>
                            <span>{{ evenement.nbPlaces }} places</span>
                        </div>
                        <div class="ev-progress__bar">
                            <div class="ev-progress__fill" style="width:{{ pct }}%;background:{{ isComplet ? '#8b1a1a' : (isFew ? '#9a7a10' : 'var(--color-secondary)') }}"></div>
                        </div>
                    </div>

                    {# Footer #}
                    <div class="ev-card__footer">
                        <div class="ev-card__heure">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                            {{ evenement.heure|date('H\\hi') }}
                        </div>

                        <a href="{{ path('app_evenement_show', {id: evenement.id}) }}"
                           class="btn-join {{ isComplet ? 'btn-join--disabled' : '' }}">
                            {% if isComplet %}
                                Complet
                            {% else %}
                                Rejoindre
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            {% endif %}
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}
