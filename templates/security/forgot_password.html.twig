{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .auth-shell {
            max-width: 760px;
            margin: 0 auto;
            padding: 2rem 0 3rem;
        }

        .auth-card {
            padding: 2rem;
            border: 1px solid var(--color-border);
            border-radius: 30px;
            background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.92));
            box-shadow: 0 16px 36px rgba(71, 48, 35, 0.05);
        }

        .auth-icon {
            width: 76px;
            height: 76px;
            margin: 0 auto 1rem;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(196, 111, 75, 0.12);
            font-size: 2rem;
        }

        .auth-title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            text-align: center;
            margin-bottom: .6rem;
            color: var(--color-text);
        }

        .auth-subtitle {
            text-align: center;
            color: var(--color-text-muted);
            max-width: 52ch;
            margin: 0 auto 1.5rem;
        }

        .flash-stack {
            display: grid;
            gap: .75rem;
            margin-bottom: 1rem;
        }

        .flash-message {
            padding: .95rem 1rem;
            border-radius: 16px;
            font-size: .95rem;
            border: 1px solid transparent;
        }

        .flash-message--success {
            background: rgba(47, 127, 121, 0.10);
            border-color: rgba(47, 127, 121, 0.16);
            color: #245f5a;
        }

        .flash-message--error {
            background: rgba(191, 91, 91, 0.10);
            border-color: rgba(191, 91, 91, 0.16);
            color: #9e4747;
        }

        .form-control-block {
            display: grid;
            gap: .45rem;
            margin-bottom: 1rem;
        }

        .form-control-block label {
            font-weight: 600;
            color: var(--color-text);
            font-size: .94rem;
        }

        .form-control-block input {
            width: 100%;
            min-height: 52px;
            padding: .9rem 1rem;
            border-radius: 16px;
            border: 1px solid var(--color-border);
            background: #fffdfa;
            color: var(--color-text);
            outline: none;
        }

        .form-control-block input:focus {
            border-color: rgba(196, 111, 75, 0.35);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.08);
        }

        .form-error {
            color: #b84d4d;
            font-size: .84rem;
        }

        .auth-submit {
            width: 100%;
            min-height: 52px;
            border: 0;
            border-radius: 999px;
            background: var(--color-primary);
            color: white;
            font-weight: 700;
            cursor: pointer;
            transition: transform .18s ease, background .18s ease;
        }

        .auth-submit:hover {
            background: var(--color-primary-dark);
            transform: translateY(-1px);
        }

        .auth-bottom {
            margin-top: 1rem;
            text-align: center;
            color: var(--color-text-muted);
        }

        .auth-bottom a {
            color: var(--color-primary);
            font-weight: 600;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="auth-shell">
        <div class="auth-card">
            <div class="auth-icon">📨</div>

            <h1 class="auth-title">Mot de passe oublié ?</h1>
            <p class="auth-subtitle">
                Saisissez l’adresse email liée à votre compte TravelMate.
                Nous vous enverrons un code pour réinitialiser votre mot de passe.
            </p>

            <div class="flash-stack">
                {% for message in app.flashes('success') %}
                    <div class="flash-message flash-message--success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-message flash-message--error">{{ message }}</div>
                {% endfor %}
            </div>

            {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="form-control-block">
                    {{ form_label(requestForm.email) }}
                    {{ form_widget(requestForm.email) }}
                    <div class="form-error">{{ form_errors(requestForm.email) }}</div>
                </div>

                <button type="submit" class="auth-submit">
                    Envoyer le code de réinitialisation
                </button>
            {{ form_end(requestForm) }}

            <p class="auth-bottom">
                Vous vous souvenez de votre mot de passe ?
                <a href="{{ path('app_login') }}">Retour à la connexion</a>
            </p>
        </div>
    </section>
{% endblock %}