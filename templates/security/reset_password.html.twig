{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .reset-shell {
            max-width: 760px;
            margin: 0 auto;
            padding: 2rem 0 3rem;
        }

        .reset-card {
            padding: 2rem;
            border: 1px solid var(--color-border);
            border-radius: 30px;
            background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.92));
            box-shadow: 0 16px 36px rgba(71, 48, 35, 0.05);
        }

        .reset-icon {
            width: 76px;
            height: 76px;
            margin: 0 auto 1rem;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(47, 127, 121, 0.12);
            font-size: 2rem;
        }

        .reset-title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            text-align: center;
            margin-bottom: .6rem;
            color: var(--color-text);
        }

        .reset-subtitle {
            text-align: center;
            color: var(--color-text-muted);
            max-width: 52ch;
            margin: 0 auto .85rem;
        }

        .reset-email {
            text-align: center;
            margin-bottom: 1.5rem;
            color: var(--color-primary);
            font-weight: 700;
        }

        .flash-stack {
            display: grid;
            gap: .75rem;
            margin-bottom: 1rem;
        }

        .flash-message {
            padding: .95rem 1rem;
            border-radius: 16px;
            font-size: .95rem;
            border: 1px solid transparent;
        }

        .flash-message--success {
            background: rgba(47, 127, 121, 0.10);
            border-color: rgba(47, 127, 121, 0.16);
            color: #245f5a;
        }

        .flash-message--error {
            background: rgba(191, 91, 91, 0.10);
            border-color: rgba(191, 91, 91, 0.16);
            color: #9e4747;
        }

        .form-grid {
            display: grid;
            gap: 1rem;
        }

        .form-control-block {
            display: grid;
            gap: .45rem;
        }

        .form-control-block label {
            font-weight: 600;
            color: var(--color-text);
            font-size: .94rem;
        }

        .form-control-block input {
            width: 100%;
            min-height: 52px;
            padding: .9rem 1rem;
            border-radius: 16px;
            border: 1px solid var(--color-border);
            background: #fffdfa;
            color: var(--color-text);
            outline: none;
        }

        .form-control-block input:focus {
            border-color: rgba(196, 111, 75, 0.35);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.08);
        }

        .form-error {
            color: #b84d4d;
            font-size: .84rem;
        }

        .reset-submit {
            width: 100%;
            min-height: 52px;
            border: 0;
            border-radius: 999px;
            background: var(--color-primary);
            color: white;
            font-weight: 700;
            cursor: pointer;
            transition: transform .18s ease, background .18s ease;
            margin-top: .4rem;
        }

        .reset-submit:hover {
            background: var(--color-primary-dark);
            transform: translateY(-1px);
        }

        .reset-links {
            margin-top: 1rem;
            text-align: center;
            display: grid;
            gap: .5rem;
        }

        .reset-links a {
            color: var(--color-primary);
            font-weight: 600;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="reset-shell">
        <div class="reset-card">
            <div class="reset-icon">🔐</div>

            <h1 class="reset-title">Réinitialiser le mot de passe</h1>
            <p class="reset-subtitle">
                Entrez le code reçu par email puis choisissez un nouveau mot de passe.
            </p>

            {% if email %}
                <div class="reset-email">{{ email }}</div>
            {% endif %}

            <div class="flash-stack">
                {% for message in app.flashes('success') %}
                    <div class="flash-message flash-message--success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-message flash-message--error">{{ message }}</div>
                {% endfor %}
            </div>

            {{ form_start(resetForm, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="form-grid">
                    <div class="form-control-block">
                        {{ form_label(resetForm.code) }}
                        {{ form_widget(resetForm.code) }}
                        <div class="form-error">{{ form_errors(resetForm.code) }}</div>
                    </div>

                    <div class="form-control-block">
                        {{ form_label(resetForm.plainPassword.first) }}
                        {{ form_widget(resetForm.plainPassword.first) }}
                        <div class="form-error">{{ form_errors(resetForm.plainPassword.first) }}</div>
                    </div>

                    <div class="form-control-block">
                        {{ form_label(resetForm.plainPassword.second) }}
                        {{ form_widget(resetForm.plainPassword.second) }}
                        <div class="form-error">{{ form_errors(resetForm.plainPassword.second) }}</div>
                    </div>
                </div>

                <button type="submit" class="reset-submit">
                    Enregistrer le nouveau mot de passe
                </button>
            {{ form_end(resetForm) }}

            <div class="reset-links">
                <a href="{{ path('app_reset_password_resend', {'email': email}) }}">
                    Renvoyer le code
                </a>
                <a href="{{ path('app_login') }}">
                    Retour à la connexion
                </a>
            </div>
        </div>
    </section>
{% endblock %}