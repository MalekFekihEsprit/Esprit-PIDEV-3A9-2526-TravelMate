{% extends 'base.html.twig' %}

{% block title %}{{ destination.nomDestination }}{% endblock %}

{% block body %}
<section class="destination-detail">
    <div class="destination-detail__header">
        <div class="destination-detail__flag-rating">
            {% if destination.flagDestination %}
                <img src="{{ destination.flagDestination }}" alt="{{ destination.nomDestination }}" class="destination-detail__flag-image">
            {% endif %}
            {% if destination.scoreDestination %}
                <span class="destination-detail__rating">⭐ {{ destination.scoreDestination }}/5</span>
            {% endif %}
        </div>
        <h1>{{ destination.nomDestination }}</h1>
        <p class="destination-detail__location">📍 {{ destination.paysDestination }}{% if destination.regionDestination %} • {{ destination.regionDestination }}{% endif %}</p>
    </div>

    <div class="destination-detail__content">
        <div class="destination-detail__grid">
            <div>
                <h3>Informations principales</h3>
                {% if destination.climatDestination %}
                    <p><strong>Climat:</strong> {{ destination.climatDestination }}</p>
                {% endif %}
                {% if destination.saisonDestination %}
                    <p><strong>Meilleure saison:</strong> {{ destination.saisonDestination }}</p>
                {% endif %}
                {% if destination.currencyDestination %}
                    <p><strong>Devise:</strong> {{ destination.currencyDestination }}</p>
                {% endif %}
                {% if destination.languagesDestination %}
                    <p><strong>Langues:</strong> {{ destination.languagesDestination }}</p>
                {% endif %}
            </div>

            <div>
                <h3>Localisation</h3>
                {% if destination.latitudeDestination and destination.longitudeDestination %}
                    <p><strong>Coordonnées:</strong><br>Lat: {{ destination.latitudeDestination }}<br>Long: {{ destination.longitudeDestination }}</p>
                {% else %}
                    <p>Coordonnées non disponibles</p>
                {% endif %}
            </div>
        </div>

        {% if destination.descriptionDestination %}
            <div class="destination-detail__description">
                <h3>Description</h3>
                <p>{{ destination.descriptionDestination }}</p>
            </div>
        {% endif %}

        {% if destination.videoUrl and destination.videoUrl|trim %}
            <div class="destination-detail__video-wrapper">
                <div class="destination-detail__video-container">
                    {% if 'youtube.com' in destination.videoUrl or 'youtu.be' in destination.videoUrl %}
                        {% set videoId = destination.videoUrl|replace({'https://www.youtube.com/watch?v=': '', 'https://youtu.be/': '', 'https://youtube.com/watch?v=': '', 'http://www.youtube.com/watch?v=': '', 'http://youtu.be/': ''}) %}
                        {% if videoId and videoId|length > 0 %}
                            <iframe width="100%" height="500" src="https://www.youtube.com/embed/{{ videoId }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="destination-detail__actions">
        <a href="{{ path('app_destination_index') }}" class="btn-secondary">← Retour</a>
        <a href="{{ path('app_destination_edit', {'id_destination': destination.idDestination}) }}" class="btn-primary">✎ Modifier</a>
        <button type="button" class="btn-danger" onclick="openDeleteModal()">🗑 Supprimer</button>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="delete-modal">
        <div class="delete-modal__content">
            <h2>Confirmer la suppression</h2>
            <p>Êtes-vous sûr de vouloir supprimer cette destination ?</p>
            
            <div class="delete-modal__details">
                <div class="delete-modal__item">
                    <span class="delete-modal__label">Destination:</span>
                    <span class="delete-modal__value">{{ destination.nomDestination }}</span>
                </div>
                <div class="delete-modal__item">
                    <span class="delete-modal__label">Localisation:</span>
                    <span class="delete-modal__value">{{ destination.paysDestination }}{% if destination.regionDestination %} • {{ destination.regionDestination }}{% endif %}</span>
                </div>
                {% if destination.user %}
                    <div class="delete-modal__item">
                        <span class="delete-modal__label">Ajoutée par:</span>
                        <span class="delete-modal__value">{{ destination.user.prenom }} {{ destination.user.nom }}</span>
                    </div>
                {% endif %}
            </div>
            
            <div class="delete-modal__actions">
                <button type="button" class="btn-secondary" onclick="closeDeleteModal()">Annuler</button>
                <form action="{{ path('app_destination_delete', {'id_destination': destination.idDestination}) }}" method="POST" style="flex: 1;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ destination.idDestination) }}">
                    <button type="submit" class="btn-danger" style="width: 100%;">Supprimer définitivement</button>
                </form>
            </div>
        </div>
    </div>
</section>

<style>
.destination-detail {
    max-width: 900px;
    margin: 0 auto;
}

.destination-detail__flag-image {
    width: 120px;
    height: 120px;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(196, 111, 75, 0.35);
    object-fit: cover;
    border: 4px solid white;
}

.destination-detail__header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 3.5rem 2.5rem;
    background: var(--color-primary);
    border-radius: 20px;
    color: white;
    box-shadow: 0 20px 60px rgba(196, 111, 75, 0.25);
    position: relative;
    overflow: hidden;
}

.destination-detail__header h1 {
    font-size: 3.2rem;
    margin: 1.5rem 0 0.8rem 0;
    font-weight: 900;
    letter-spacing: -1.5px;
    color: white;
    position: relative;
    z-index: 1;
}

.destination-detail__flag-rating {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
}

.destination-detail__flag {
    font-size: 2.5rem;
}

.destination-detail__rating {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    font-weight: 800;
    font-size: 1.1rem;
    backdrop-filter: blur(20px);
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

.destination-detail__location {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1.2rem;
    font-weight: 500;
    position: relative;
    z-index: 1;
    letter-spacing: 0.3px;
}

.destination-detail__content {
    margin-bottom: 3rem;
}

.destination-detail__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
}

.destination-detail__grid > div {
    background: white;
    padding: 2.2rem;
    border-radius: 16px;
    border-left: 5px solid var(--color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transition: all var(--transition-base);
}

.destination-detail__grid > div:hover {
    box-shadow: 0 16px 40px rgba(196, 111, 75, 0.15);
    transform: translateY(-2px);
}

.destination-detail__grid h3 {
    color: var(--color-primary);
    margin-bottom: 1.4rem;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.3px;
}

.destination-detail__grid p {
    margin-bottom: 1rem;
    line-height: 1.9;
    color: var(--color-text);
    font-size: 0.95rem;
}

.destination-detail__grid strong {
    color: var(--color-primary);
    font-weight: 700;
}

.destination-detail__description {
    background: white;
    padding: 2.5rem;
    border-radius: 16px;
    margin-bottom: 2.5rem;
    border-left: 5px solid var(--color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.destination-detail__description h3 {
    color: var(--color-primary);
    margin-bottom: 1.4rem;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.3px;
}

.destination-detail__description p {
    line-height: 2;
    color: var(--color-text);
    font-size: 0.95rem;
}

.destination-detail__video-wrapper {
    margin-bottom: 2.5rem;
}

.destination-detail__video-container {
    position: relative;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(196, 111, 75, 0.2);
    background: #000;
}

.destination-detail__video-container iframe {
    display: block;
    width: 100%;
    height: 500px;
    border: none;
}

.destination-detail__actions {
    display: flex;
    gap: 1.2rem;
    padding-top: 2.5rem;
    border-top: 2px solid var(--color-border);
    align-items: center;
}

.destination-detail__actions a,
.destination-detail__actions button {
    flex: 1;
    text-align: center;
    padding: 1rem 1.8rem;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all var(--transition-base);
    font-size: 0.95rem;
    text-decoration: none;
    display: block;
    letter-spacing: 0.3px;
}

.destination-detail__actions form {
    flex: 1;
}

.destination-detail__actions form button {
    width: 100%;
}

.destination-detail__actions .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 6px 20px rgba(196, 111, 75, 0.25);
}

.destination-detail__actions .btn-primary:hover {
    background: var(--color-primary-dark, #a85a3a);
    box-shadow: 0 10px 30px rgba(196, 111, 75, 0.4);
    transform: translateY(-2px);
}

.destination-detail__actions .btn-secondary {
    background: white;
    color: var(--color-primary);
    border: 2.5px solid var(--color-primary);
    font-weight: 700;
}

.destination-detail__actions .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(196, 111, 75, 0.25);
}

.btn-danger {
    background: #e74c3c;
    color: white;
    padding: 1rem 1.8rem;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all var(--transition-base);
    box-shadow: 0 6px 20px rgba(231, 76, 60, 0.25);
    letter-spacing: 0.3px;
}

.btn-danger:hover {
    background: #c0392b;
    box-shadow: 0 10px 30px rgba(231, 76, 60, 0.4);
    transform: translateY(-2px);
}

@media (max-width: 768px) {
    .destination-detail {
        margin: 0;
    }

    .destination-detail__header {
        padding: 2.5rem 2rem;
    }

    .destination-detail__header h1 {
        font-size: 2.2rem;
    }

    .destination-detail__grid {
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .destination-detail__actions {
        flex-direction: column;
        gap: 1rem;
    }

    .destination-detail__flag-image {
        width: 100px;
        height: 100px;
    }
}

@media (max-width: 480px) {
    .destination-detail__header {
        padding: 2rem 1.5rem;
    }

    .destination-detail__header h1 {
        font-size: 1.8rem;
    }

    .destination-detail__grid > div {
        padding: 1.5rem;
    }

    .destination-detail__description,
    .destination-detail__video {
        padding: 1.8rem;
    }

    .destination-detail__actions a,
    .destination-detail__actions button {
        padding: 0.9rem 1.5rem;
        font-size: 0.85rem;
    }
}

/* Delete Confirmation Modal */
.delete-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    z-index: 3000;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}

.delete-modal.active {
    display: flex;
}

.delete-modal__content {
    background: white;
    border-radius: 20px;
    padding: 2.5rem;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    animation: slideDown 0.3s ease-out;
}

.delete-modal__content h2 {
    color: var(--color-primary);
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
    font-weight: 800;
}

.delete-modal__content > p {
    color: var(--color-text);
    margin-bottom: 2rem;
    font-size: 0.95rem;
}

.delete-modal__details {
    background: var(--color-surface-soft);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    border-left: 4px solid var(--color-primary);
}

.delete-modal__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--color-border);
}

.delete-modal__item:last-child {
    border-bottom: none;
}

.delete-modal__label {
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.85rem;
}

.delete-modal__value {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
}

.delete-modal__actions {
    display: flex;
    gap: 1rem;
    align-items: center;
}

.delete-modal__actions button {
    flex: 1;
    padding: 1rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all var(--transition-base);
    font-size: 0.95rem;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 480px) {
    .delete-modal__content {
        padding: 1.8rem;
    }

    .delete-modal__content h2 {
        font-size: 1.3rem;
    }

    .delete-modal__actions {
        flex-direction: column;
    }

    .delete-modal__actions button {
        width: 100%;
    }
}
</style>

<script>
function openDeleteModal() {
    document.getElementById('deleteModal').classList.add('active');
}

function closeDeleteModal() {
    document.getElementById('deleteModal').classList.remove('active');
}

// Close modal when clicking outside
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('deleteModal');
    window.addEventListener('click', function(event) {
        if (event.target === modal) {
            closeDeleteModal();
        }
    });
});
</script>
{% endblock %}