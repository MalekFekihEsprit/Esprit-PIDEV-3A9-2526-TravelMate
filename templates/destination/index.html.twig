{% extends 'base.html.twig' %}

{% block title %}Destinations | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('vendor/leaflet/leaflet.css') }}" />
    <style>
        .destinations-page .destinations-grid {
            display: grid !important;
            grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
            gap: 2rem !important;
            align-items: stretch;
        }

        .destinations-page .destinations-grid > .destination-card {
            width: 100% !important;
            min-width: 0;
        }

        @media (max-width: 1024px) {
            .destinations-page .destinations-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
            }
        }

        @media (max-width: 768px) {
            .destinations-page .destinations-grid {
                grid-template-columns: 1fr !important;
                gap: 1.2rem !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
<section class="destinations-page">
    <div class="destinations-hero">
        <div class="destinations-hero__content">
            <span class="destinations-hero__eyebrow">DESTINATIONS</span>
            <h1 class="destinations-hero__title">Explorez le monde en une seule galerie</h1>
            <p class="destinations-hero__text">
                Découvrez les plus belles destinations, triées sur le volet. Chaque destination offre des informations détaillées, des vidéos inspirantes et les meilleurs conseils de voyage.
            </p>

            <div class="destinations-hero__stats">
                <div class="destinations-stat">
                    <strong>{{ destinations|length }}</strong>
                    <span>destinations</span>
                </div>
                <div class="destinations-stat">
                    <strong>{{ unique_climates }}</strong>
                    <span>climats</span>
                </div>
                <div class="destinations-stat">
                    <strong>{{ unique_seasons }}</strong>
                    <span>saisons</span>
                </div>
                <div class="destinations-stat">
                    <strong>{{ unique_regions }}</strong>
                    <span>régions</span>
                </div>
            </div>
        </div>
        <div class="destinations-hero__visual">
            <img src="{{ asset('images/destination.jpg') }}" alt="Travel destination" style="width: 100%; height: 100%; object-fit: cover; border-radius: 16px;">
        </div>
    </div>

    {% set successFlashes = app.flashes('success') %}
    {% set warningFlashes = app.flashes('warning') %}
    {% set errorFlashes = app.flashes('error') %}

    {% if successFlashes is not empty or warningFlashes is not empty or errorFlashes is not empty %}
        <div class="destinations-toast-stack" aria-live="polite" aria-atomic="true">
            {% for message in successFlashes %}
                <div class="destinations-flash destinations-flash--success" data-destinations-toast>
                    <strong class="destinations-flash__title">Opération réussie</strong>
                    <div class="destinations-flash__message">{{ message }}</div>
                    <button type="button" class="destinations-flash__close" data-destinations-toast-close aria-label="Fermer la notification">×</button>
                </div>
            {% endfor %}

            {% for message in warningFlashes %}
                <div class="destinations-flash destinations-flash--warning" data-destinations-toast>
                    <strong class="destinations-flash__title">Attention</strong>
                    <div class="destinations-flash__message">{{ message }}</div>
                    <button type="button" class="destinations-flash__close" data-destinations-toast-close aria-label="Fermer la notification">×</button>
                </div>
            {% endfor %}

            {% for message in errorFlashes %}
                <div class="destinations-flash destinations-flash--error" data-destinations-toast>
                    <strong class="destinations-flash__title">Action impossible</strong>
                    <div class="destinations-flash__message">{{ message }}</div>
                    <button type="button" class="destinations-flash__close" data-destinations-toast-close aria-label="Fermer la notification">×</button>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="destinations-toolbar-wrapper">
        <div class="toolbar-header toolbar-header--with-map">
            <div class="toolbar-header__text">
                <h2 class="toolbar-title">Filtrer & Trier</h2>
                <p class="toolbar-subtitle">Trouvez votre destination idéale</p>
            </div>
            <button type="button" id="openMapBtn" class="btn toolbar-map-btn" aria-label="Voir sur la carte" onclick="openMapOverlay(); return false;">
                <span class="toolbar-map-btn__icon" aria-hidden="true">🗺️</span>
                <span>Voir map</span>
            </button>
        </div>

        <div class="destinations-toolbar">
            <div class="toolbar-search">
                <svg class="toolbar-search__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="8.5" cy="8.5" r="6.5" stroke="currentColor" stroke-width="2"/>
                    <path d="M13 13L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <input type="text" id="destSearch" placeholder="Rechercher une destination..." class="toolbar-search__input">
            </div>
            
            <div class="toolbar-divider"></div>
            
            <div class="toolbar-filters">
                <div class="filter-group">
                    <select id="regionFilter" class="toolbar-filter__select" aria-label="Filtrer par région">
                        <option value="">Toutes les régions</option>
                        {% set regionsMap = {} %}
                        {% for destination in destinations %}
                            {% if destination.regionDestination %}
                                {% set regionsMap = regionsMap|merge({(destination.regionDestination): true}) %}
                            {% endif %}
                        {% endfor %}
                        {% for region in regionsMap|keys|sort %}
                            <option value="{{ region }}">{{ region }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <select id="seasonFilter" class="toolbar-filter__select" aria-label="Filtrer par saison">
                        <option value="">Toutes les saisons</option>
                        {% set seasonsMap = {} %}
                        {% for destination in destinations %}
                            {% if destination.saisonDestination %}
                                {% set seasonsMap = seasonsMap|merge({(destination.saisonDestination): true}) %}
                            {% endif %}
                        {% endfor %}
                        {% for season in seasonsMap|keys|sort %}
                            <option value="{{ season }}">{{ season }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <select id="climateFilter" class="toolbar-filter__select" aria-label="Filtrer par climat">
                        <option value="">Tous les climats</option>
                        {% set climatesMap = {} %}
                        {% for destination in destinations %}
                            {% if destination.climatDestination %}
                                {% set climatesMap = climatesMap|merge({(destination.climatDestination): true}) %}
                            {% endif %}
                        {% endfor %}
                        {% for climate in climatesMap|keys|sort %}
                            <option value="{{ climate }}">{{ climate }}</option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="filter-group">
                    <select id="ratingSort" class="toolbar-filter__select" aria-label="Trier les destinations">
                        <option value="default">Par défaut</option>
                        <option value="rating-desc">⭐ Note (élevée → basse)</option>
                        <option value="rating-asc">⭐ Note (basse → élevée)</option>
                        <option value="name">📝 Nom (A-Z)</option>
                    </select>
                </div>

                <div class="filter-group">
                    <select id="favoriteFilter" class="toolbar-filter__select" aria-label="Filtrer les favoris">
                        <option value="all">Tous les destinations</option>
                        <option value="favorites">Mes favoris</option>
                        <option value="non-favorites">Non favoris</option>
                    </select>
                </div>
            </div>
            
            <div class="toolbar-divider"></div>
            
            <div class="toolbar-info">
                <span class="toolbar-count"><strong id="destCount">{{ destinations|length }}</strong> résultat{{ destinations|length > 1 ? 's' : '' }}</span>
            </div>
        </div>
    </div>

    {% if destinations is not empty %}
        <div class="destinations-grid" id="destinationsContainer">
            {% for destination in destinations %}
                <div
                    class="destination-card"
                    onclick="openDestinationModal({{ destination.idDestination }})"
                    data-region="{{ destination.regionDestination ?? 'Sans région' }}"
                    data-season="{{ destination.saisonDestination ?? 'Sans saison' }}"
                    data-climate="{{ destination.climatDestination ?? 'Sans climat' }}"
                    data-rating="{{ average_scores[destination.idDestination]|default(destination.scoreDestination ?? '') }}"
                    data-name="{{ destination.nomDestination }}"
                    data-favorite="{{ favorite_destination_ids[destination.idDestination]|default(false) ? '1' : '0' }}"
                >
                    <div class="destination-card__image-wrapper">
                        {% if destination.imageName %}
                            <img src="{{ asset('uploads/destinations/' ~ destination.imageName) }}" alt="{{ destination.nomDestination }}" class="destination-card__image">
                        {% else %}
                            <div class="destination-card__image-placeholder">🌍</div>
                        {% endif %}

                        <form method="post" action="{{ path('app_destination_favorite_toggle', {'id_destination': destination.idDestination}) }}" class="destination-card__favorite-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('favorite_destination_' ~ destination.idDestination) }}">
                            <button
                                type="submit"
                                class="destination-card__favorite-btn {{ favorite_destination_ids[destination.idDestination]|default(false) ? 'is-favorite' : '' }}"
                                aria-label="{{ favorite_destination_ids[destination.idDestination]|default(false) ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                                title="{{ favorite_destination_ids[destination.idDestination]|default(false) ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                                onclick="event.stopPropagation();"
                            >
                                ♥
                            </button>
                        </form>
                    </div>

                    <div class="destination-card__content">
                    <h3 class="destination-card__title">{{ destination.nomDestination }}</h3>
                    <p class="destination-card__location">
                        📍 {{ destination.paysDestination }}
                        {% if destination.regionDestination %}
                            <span class="destination-card__region">{{ destination.regionDestination }}</span>
                        {% endif %}
                    </p>
                    
                    {% if destination.descriptionDestination %}
                        <p class="destination-card__description">
                            {{ destination.descriptionDestination|slice(0, 90) }}{% if destination.descriptionDestination|length > 90 %}...{% endif %}
                        </p>
                    {% endif %}

                    <div class="destination-card__meta">
                        {% set averageScore = average_scores[destination.idDestination]|default(destination.scoreDestination) %}
                        {% if averageScore is not null %}
                            <span class="destination-card__badge destination-card__badge--season">
                                <span class="badge-icon">⭐</span>{{ averageScore|number_format(2, '.', '') }}/5
                            </span>
                        {% endif %}
                        {% if destination.climatDestination %}
                            <span class="destination-card__badge destination-card__badge--climate">
                                <span class="badge-icon">🌡️</span>{{ destination.climatDestination }}
                            </span>
                        {% endif %}
                        {% if destination.saisonDestination %}
                            <span class="destination-card__badge destination-card__badge--season">
                                <span class="badge-icon">📅</span>{{ destination.saisonDestination }}
                            </span>
                        {% endif %}
                    </div>
                </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="destinations-empty">
            <div class="destinations-empty__icon">🗺️</div>
            <p>Aucune destination trouvée</p>
            <a href="{{ path('app_destination_new') }}" class="btn btn--primary">Créer la première destination</a>
        </div>
    {% endif %}
</section>

<div id="mapOverlay" class="map-overlay" aria-hidden="true">
    <div class="map-overlay__panel" role="dialog" aria-modal="true" aria-label="Carte des destinations">
        <button type="button" class="map-overlay__close" id="closeMapBtn" aria-label="Fermer la carte" onclick="closeMapOverlay(); return false;">×</button>
        <div class="map-overlay__header">
            <div>
                <span class="map-overlay__eyebrow">Carte interactive</span>
                <h2 class="map-overlay__title">Destinations sur la carte</h2>
            </div>
            <div class="map-overlay__legend">Cliquez sur un pin pour ouvrir la destination</div>
        </div>
        <div id="destinationsMap" class="map-overlay__map" style="background: #f5f5f0;">Chargement de la carte...</div>
    </div>
</div>

<!-- Modal pour afficher les détails -->
<div id="destinationModal" class="modal">
    <div class="modal-content">
        <span class="modal-close" onclick="closeDestinationModal()">&times;</span>
        <div id="modalBody">
            <!-- Le contenu sera chargé dynamiquement -->
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('vendor/leaflet/leaflet.js') }}"></script>
<script>
let currentDestinationModalId = null;
let destinationsMapInstance = null;
let destinationsMapMarkers = [];

const destinationsMapData = [
    {% for destination in destinations %}
        {% if destination.latitudeDestination is not null and destination.longitudeDestination is not null %}
        {
            id: {{ destination.idDestination }},
            name: {{ destination.nomDestination|json_encode|raw }},
            country: {{ destination.paysDestination|json_encode|raw }},
            lat: {{ destination.latitudeDestination|json_encode|raw }},
            lng: {{ destination.longitudeDestination|json_encode|raw }},
            url: {{ path('app_destination_show', {'id_destination': destination.idDestination})|json_encode|raw }}
        },
        {% endif %}
    {% endfor %}
];

function buildDestinationLabel(item) {
    return `${item.name} - ${item.country}`;
}

function clearMapMarkers() {
    if (!destinationsMapInstance) {
        return;
    }

    destinationsMapMarkers.forEach(function (marker) {
        destinationsMapInstance.removeLayer(marker);
    });

    destinationsMapMarkers = [];
}

function initDestinationsMap() {
    const mapEl = document.getElementById('destinationsMap');

    if (!mapEl) {
        return;
    }

    if (typeof L === 'undefined') {
        mapEl.innerHTML = '<div style="padding: 2rem; text-align: center; color: #7a5a4a; font-weight: 600;">La carte n\'a pas pu se charger. Veuillez rafraîchir la page.</div>';
        return;
    }

    if (!destinationsMapInstance) {
        mapEl.innerHTML = '';
    }
    
    // Create custom marker icon using SVG data URL
    if (!window.customMarkerIcon) {
        window.customMarkerIcon = L.icon({
            iconUrl: 'data:image/svg+xml;base64,',
            shadowUrl: 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDEiIGhlaWdodD0iNDEiIHZpZXdCb3g9IjAgMCA0MSA0MSIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZWxsaXBzZSBjeD0iMjAuNSIgY3k9IjMzIiByeD0iMTUiIHJ5PSI0IiBmaWxsPSIjMDAwIiBvcGFjaXR5PSIwLjIiLz48L3N2Zz4=',
            iconSize: [25, 41],
            shadowSize: [41, 41],
            iconAnchor: [12, 41],
            shadowAnchor: [12, 41],
            popupAnchor: [1, -34]
        });
    }
    
    if (!destinationsMapInstance) {
        try {
            destinationsMapInstance = L.map(mapEl, {
                scrollWheelZoom: true,
                zoomControl: true
            });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap</a> contributors'
            }).addTo(destinationsMapInstance);
        } catch (error) {
            mapEl.innerHTML = '<div style="padding: 2rem; text-align: center; color: #c84c3c;">Erreur lors du chargement de la carte: ' + error.message + '</div>';
            return;
        }
    }

    clearMapMarkers();
    
    if (destinationsMapData.length === 0) {
        destinationsMapInstance.setView([28.0339, 1.6596], 2);
        destinationsMapInstance.invalidateSize();
        return;
    }

    const bounds = [];

    destinationsMapData.forEach(function (item) {
        const lat = parseFloat(item.lat);
        const lng = parseFloat(item.lng);

        if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
            return;
        }

        const marker = L.marker([lat, lng], { icon: window.customMarkerIcon }).addTo(destinationsMapInstance);
        marker.bindTooltip(buildDestinationLabel(item), {
            direction: 'top',
            sticky: true,
            opacity: 0.96,
            className: 'destination-map-tooltip'
        });
        marker.on('click', function () {
            window.location.href = item.url;
        });

        destinationsMapMarkers.push(marker);
        bounds.push([lat, lng]);
    });
    
    if (bounds.length === 1) {
        destinationsMapInstance.setView(bounds[0], 6);
    } else if (bounds.length > 0) {
        destinationsMapInstance.fitBounds(bounds, { padding: [40, 40] });
    } else {
        destinationsMapInstance.setView([28.0339, 1.6596], 2);
    }

    window.setTimeout(function () {
        destinationsMapInstance.invalidateSize();
    }, 80);
    
    window.setTimeout(function () {
        destinationsMapInstance.invalidateSize();
    }, 260);
}

function openMapOverlay() {
    const overlay = document.getElementById('mapOverlay');
    if (!overlay) {
        return;
    }

    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.classList.add('is-map-open');

    window.requestAnimationFrame(function () {
        window.requestAnimationFrame(function () {
            initDestinationsMap();
        });
    });

    window.setTimeout(function () {
        initDestinationsMap();
    }, 220);
}

function closeMapOverlay() {
    const overlay = document.getElementById('mapOverlay');
    if (!overlay) {
        return;
    }

    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('is-map-open');
}

function openDestinationModal(destinationId) {
    const modal = document.getElementById('destinationModal');
    const modalBody = document.getElementById('modalBody');
    currentDestinationModalId = destinationId;
    
    fetch(`{{ path('app_destination_show', {'id_destination': '__ID__'}) }}`.replace('__ID__', destinationId))
        .then(response => response.text())
        .then(html => {
            modalBody.innerHTML = html;
            modal.classList.add('active');
        })
        .catch(error => console.error('Erreur:', error));
}

function closeDestinationModal() {
    const modal = document.getElementById('destinationModal');
    modal.classList.remove('active');
    currentDestinationModalId = null;
}

document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('destinationModal');
    const modalBody = document.getElementById('modalBody');
    const mapOverlay = document.getElementById('mapOverlay');
    const openMapBtn = document.getElementById('openMapBtn');
    const closeMapBtn = document.getElementById('closeMapBtn');

    if (openMapBtn) {
        openMapBtn.addEventListener('click', openMapOverlay);
    }

    if (closeMapBtn) {
        closeMapBtn.addEventListener('click', closeMapOverlay);
    }

    if (mapOverlay) {
        mapOverlay.addEventListener('click', function (event) {
            if (event.target === mapOverlay) {
                closeMapOverlay();
            }
        });
    }

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeMapOverlay();
        }
    });

    window.onclick = function(event) {
        if (event.target === modal) {
            closeDestinationModal();
        }
    }

    if (modalBody) {
        modalBody.addEventListener('submit', function (event) {
            const form = event.target;
            if (!(form instanceof HTMLFormElement)) {
                return;
            }

            if (!form.classList.contains('destination-rating-form')) {
                return;
            }

            // Keep rating submission inside modal so the user stays on destination index page.
            event.preventDefault();

            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
                .then(function (response) {
                    return response.text();
                })
                .then(function (html) {
                    modalBody.innerHTML = html;
                    if (modal) {
                        modal.classList.add('active');
                    }
                })
                .catch(function () {
                    console.error('Erreur lors de la soumission de la note.');
                });
        });
    }

    // Gestion des toasts
    var toasts = document.querySelectorAll('[data-destinations-toast]');

    function hideToast(toast) {
        if (!toast || toast.classList.contains('is-hiding')) {
            return;
        }

        toast.classList.add('is-hiding');
        window.setTimeout(function () {
            toast.remove();
        }, 220);
    }

    toasts.forEach(function (toast) {
        var closeButton = toast.querySelector('[data-destinations-toast-close]');

        if (closeButton) {
            closeButton.addEventListener('click', function () {
                hideToast(toast);
            });
        }

        window.setTimeout(function () {
            hideToast(toast);
        }, 4200);
    });

    // Search functionality
    const searchInput = document.getElementById('destSearch');
    const regionFilter = document.getElementById('regionFilter');
    const seasonFilter = document.getElementById('seasonFilter');
    const ratingSort = document.getElementById('ratingSort');
    const favoriteFilter = document.getElementById('favoriteFilter');
    const countDisplay = document.getElementById('destCount');
    
    function applyFiltersAndSort() {
        const searchTerm = (searchInput?.value || '').toLowerCase();
        const selectedRegion = regionFilter?.value || '';
        const selectedSeason = seasonFilter?.value || '';
        const sortOption = ratingSort?.value || 'default';
        const selectedFavoriteFilter = favoriteFilter?.value || 'all';
        
        const container = document.getElementById('destinationsContainer');
        if (!container) return;
        
        let allCards = Array.from(container.querySelectorAll('.destination-card'));
        let visibleCards = [];
        
        // Apply filters
        allCards.forEach(function(card) {
            let matches = true;
            
            // Filter by search term
            if (searchTerm) {
                const title = card.querySelector('.destination-card__title')?.textContent.toLowerCase() || '';
                const location = card.querySelector('.destination-card__location')?.textContent.toLowerCase() || '';
                const description = card.querySelector('.destination-card__description')?.textContent.toLowerCase() || '';
                matches = title.includes(searchTerm) || location.includes(searchTerm) || description.includes(searchTerm);
            }
            
            // Filter by region
            if (matches && selectedRegion) {
                matches = card.getAttribute('data-region') === selectedRegion;
            }

            // Filter by season
            if (matches && selectedSeason) {
                matches = card.getAttribute('data-season') === selectedSeason;
            }

            // Filter by favorites
            if (matches && selectedFavoriteFilter === 'favorites') {
                matches = card.getAttribute('data-favorite') === '1';
            }

            if (matches && selectedFavoriteFilter === 'non-favorites') {
                matches = card.getAttribute('data-favorite') !== '1';
            }
            
            if (matches) {
                visibleCards.push(card);
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
        
        // Sort visible cards
        visibleCards.sort(function(a, b) {
            const ratingA = parseFloat(a.getAttribute('data-rating')) || 0;
            const ratingB = parseFloat(b.getAttribute('data-rating')) || 0;
            const nameA = a.getAttribute('data-name') || '';
            const nameB = b.getAttribute('data-name') || '';
            
            if (sortOption === 'rating-desc') {
                if (ratingA === 0 && ratingB === 0) return 0;
                if (ratingA === 0) return 1;
                if (ratingB === 0) return -1;
                return ratingB - ratingA;
            } else if (sortOption === 'rating-asc') {
                if (ratingA === 0 && ratingB === 0) return 0;
                if (ratingA === 0) return 1;
                if (ratingB === 0) return -1;
                return ratingA - ratingB;
            } else if (sortOption === 'name') {
                return nameA.localeCompare(nameB);
            }
            return 0;
        });
        
        // Update DOM order for visible cards
        visibleCards.forEach(function(card) {
            container.appendChild(card);
        });
        
        // Update count
        if (countDisplay) {
            countDisplay.textContent = visibleCards.length;
        }
    }
    
    if (searchInput) {
        searchInput.addEventListener('input', applyFiltersAndSort);
    }
    if (regionFilter) {
        regionFilter.addEventListener('change', applyFiltersAndSort);
    }
    if (seasonFilter) {
        seasonFilter.addEventListener('change', applyFiltersAndSort);
    }
    if (ratingSort) {
        ratingSort.addEventListener('change', applyFiltersAndSort);
    }
    if (favoriteFilter) {
        favoriteFilter.addEventListener('change', applyFiltersAndSort);
    }

    document.querySelectorAll('.destination-card__favorite-form').forEach(function (form) {
        form.addEventListener('submit', function (event) {
            event.preventDefault();

            const button = form.querySelector('.destination-card__favorite-btn');
            const card = form.closest('.destination-card');
            if (!button || !card) {
                return;
            }

            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
                .then(function (response) {
                    return response.json();
                })
                .then(function (data) {
                    if (!data || typeof data.is_favorite === 'undefined') {
                        return;
                    }

                    card.setAttribute('data-favorite', data.is_favorite ? '1' : '0');
                    button.classList.toggle('is-favorite', data.is_favorite);
                    button.setAttribute('aria-label', data.is_favorite ? 'Retirer des favoris' : 'Ajouter aux favoris');
                    button.setAttribute('title', data.is_favorite ? 'Retirer des favoris' : 'Ajouter aux favoris');

                    applyFiltersAndSort();
                })
                .catch(function () {
                    form.submit();
                });
        });
    });
});
</script>
{% endblock %}

