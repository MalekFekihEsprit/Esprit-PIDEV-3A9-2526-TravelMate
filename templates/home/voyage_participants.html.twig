{% extends 'base.html.twig' %}

{% block title %}Participants | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .participants-page {
            display: grid;
            gap: 1.75rem;
        }

        .participants-hero,
        .participants-card,
        .participants-empty,
        .participants-flash {
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71, 48, 35, 0.06);
        }

        .participants-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
            gap: 1.4rem;
            padding: 2rem;
            background:
                radial-gradient(circle at top left, rgba(221, 191, 140, 0.28), transparent 30%),
                linear-gradient(135deg, rgba(255, 253, 249, 0.98), rgba(243, 234, 223, 0.92));
        }

        .participants-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.8rem;
            color: var(--color-primary);
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .participants-hero__title {
            margin-bottom: 0.8rem;
            font-family: 'Fraunces', serif;
            font-size: clamp(2rem, 3vw, 3.25rem);
            line-height: 1.06;
        }

        .participants-hero__text {
            max-width: 58ch;
            color: var(--color-text-muted);
        }

        .participants-hero__actions {
            display: flex;
            gap: 0.85rem;
            flex-wrap: wrap;
            margin-top: 1.3rem;
        }

        .participants-hero__stats {
            display: grid;
            gap: 0.85rem;
            align-content: start;
        }

        .participants-stat {
            padding: 1rem;
            border-radius: var(--radius-lg);
            background: rgba(255, 255, 255, 0.64);
            border: 1px solid rgba(231, 220, 205, 0.85);
        }

        .participants-stat strong {
            display: block;
            font-family: 'Fraunces', serif;
            font-size: 1.55rem;
            color: var(--color-text);
        }

        .participants-stat span {
            color: var(--color-text-muted);
            font-size: 0.88rem;
        }

        .participants-layout {
            display: grid;
            grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.4fr);
            gap: 1.35rem;
            align-items: start;
        }

        .participants-card {
            padding: 1.4rem;
            display: grid;
            gap: 1rem;
        }

        .participants-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.35rem;
        }

        .participants-card__text {
            color: var(--color-text-muted);
        }

        .participants-form {
            display: grid;
            gap: 0.95rem;
        }

        .participants-field {
            display: grid;
            gap: 0.45rem;
        }

        .participants-label {
            font-size: 0.92rem;
            font-weight: 600;
            color: var(--color-text);
        }

        .participants-input,
        .participants-select {
            width: 100%;
            min-height: 48px;
            padding: 0.8rem 0.95rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            color: var(--color-text);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }

        .participants-input:focus,
        .participants-select:focus {
            outline: none;
            border-color: rgba(196, 111, 75, 0.55);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.12);
        }

        .participants-note {
            padding: 0.95rem 1rem;
            border-radius: var(--radius-md);
            background: rgba(47, 127, 121, 0.08);
            color: var(--color-secondary);
            font-size: 0.92rem;
        }

        .participants-toast-stack {
            position: fixed;
            top: calc(var(--navbar-height) + 1rem);
            right: 1.25rem;
            z-index: 1200;
            display: grid;
            gap: 0.85rem;
            width: min(360px, calc(100vw - 2rem));
        }

        .participants-flash {
            position: relative;
            padding: 1rem 3.2rem 1rem 1.2rem;
            animation: participants-toast-in 260ms ease;
        }

        .participants-flash--success {
            border-left: 4px solid var(--color-secondary);
        }

        .participants-flash--warning,
        .participants-flash--error {
            border-left: 4px solid var(--color-primary);
        }

        .participants-flash.is-hiding {
            animation: participants-toast-out 220ms ease forwards;
        }

        .participants-flash__title {
            display: block;
            margin-bottom: 0.2rem;
            font-size: 0.9rem;
            font-weight: 700;
        }

        .participants-flash__message {
            color: var(--color-text-muted);
            line-height: 1.45;
        }

        .participants-flash__close {
            position: absolute;
            top: 0.8rem;
            right: 0.8rem;
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 999px;
            background: rgba(31, 26, 23, 0.06);
            color: var(--color-text-muted);
            font-size: 1rem;
            line-height: 1;
            cursor: pointer;
            transition: background var(--transition-fast), color var(--transition-fast);
        }

        .participants-flash__close:hover {
            background: rgba(196, 111, 75, 0.12);
            color: var(--color-primary);
        }

        .participants-list {
            display: grid;
            gap: 1rem;
        }

        .participants-list__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .participants-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.45rem 0.7rem;
            border-radius: 999px;
            background: rgba(196, 111, 75, 0.08);
            color: var(--color-primary-dark);
            font-size: 0.84rem;
            font-weight: 700;
        }

        .participants-table {
            display: grid;
            gap: 0.9rem;
        }

        .participants-row {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(180px, 0.9fr) auto;
            gap: 1rem;
            align-items: center;
            padding: 1rem;
            border-radius: var(--radius-lg);
            background: var(--color-surface-soft);
        }

        .participants-person {
            display: grid;
            gap: 0.25rem;
        }

        .participants-person__name {
            font-weight: 700;
            color: var(--color-text);
        }

        .participants-person__meta {
            color: var(--color-text-muted);
            font-size: 0.9rem;
            word-break: break-word;
        }

        .participants-role-form {
            display: flex;
            gap: 0.75rem;
            align-items: center;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .participants-role-form .participants-select {
            min-width: 180px;
        }

        .participants-actions {
            display: flex;
            gap: 0.65rem;
            align-items: center;
            justify-content: flex-end;
        }

        .participants-icon-button {
            width: 42px;
            height: 42px;
            border: 1px solid var(--color-border);
            border-radius: 14px;
            background: var(--color-surface);
            color: var(--color-text-muted);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
            cursor: pointer;
        }

        .participants-icon-button:hover {
            transform: translateY(-1px);
        }

        .participants-icon-button--save {
            background: rgba(47, 127, 121, 0.08);
            color: var(--color-secondary);
            border-color: rgba(47, 127, 121, 0.22);
        }

        .participants-icon-button--save:hover {
            background: rgba(47, 127, 121, 0.14);
            border-color: rgba(47, 127, 121, 0.34);
        }

        .participants-icon-button--delete {
            background: rgba(196, 111, 75, 0.08);
            color: var(--color-primary-dark);
            border-color: rgba(168, 90, 57, 0.22);
        }

        .participants-icon-button--delete:hover {
            background: rgba(196, 111, 75, 0.16);
            border-color: rgba(168, 90, 57, 0.34);
        }

        .participants-empty {
            padding: 1.5rem;
            text-align: center;
            color: var(--color-text-muted);
        }

        @keyframes participants-toast-in {
            from {
                opacity: 0;
                transform: translate3d(18px, -12px, 0);
            }
            to {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
        }

        @keyframes participants-toast-out {
            from {
                opacity: 1;
                transform: translate3d(0, 0, 0);
            }
            to {
                opacity: 0;
                transform: translate3d(24px, -10px, 0);
            }
        }

        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }

        @media (max-width: 1080px) {
            .participants-hero,
            .participants-layout {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 820px) {
            .participants-hero {
                padding: 1.5rem;
            }

            .participants-toast-stack {
                right: 1rem;
                left: 1rem;
                width: auto;
            }

            .participants-row {
                grid-template-columns: 1fr;
            }

            .participants-role-form,
            .participants-actions {
                justify-content: stretch;
            }

            .participants-role-form .participants-select,
            .participants-role-form .participants-icon-button,
            .participants-actions form,
            .participants-actions .participants-icon-button {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="participants-page">
        <div class="participants-hero">
            <div>
                <span class="participants-hero__eyebrow">PARTICIPANTS</span>
                <h1 class="participants-hero__title">Pilotez les participants du voyage {{ voyage.titreVoyage }}</h1>
                <p class="participants-hero__text">
                    Ajoutez un utilisateur existant via son email, ajustez son role dans ce voyage et supprimez-le si necessaire, sans quitter l'univers visuel des voyages.
                </p>

                <div class="participants-hero__actions">
                    <a href="{{ path('app_voyages') }}" class="btn btn--ghost">Retour aux voyages</a>
                </div>
            </div>

            <div class="participants-hero__stats">
                <div class="participants-stat">
                    <strong>{{ participants|length }}</strong>
                    <span>participant{% if participants|length > 1 %}s{% endif %} sur ce voyage</span>
                </div>
                <div class="participants-stat">
                    <strong>{{ voyage.destination ? voyage.destination.nomDestination : 'Sans destination' }}</strong>
                    <span>{{ voyage.destination and voyage.destination.paysDestination ? voyage.destination.paysDestination : 'Destination actuelle du voyage' }}</span>
                </div>
            </div>
        </div>

        {% set successFlashes = app.flashes('success') %}
        {% set warningFlashes = app.flashes('warning') %}
        {% set errorFlashes = app.flashes('error') %}

        {% if successFlashes is not empty or warningFlashes is not empty or errorFlashes is not empty %}
            <div class="participants-toast-stack" aria-live="polite" aria-atomic="true">
                {% for message in successFlashes %}
                    <div class="participants-flash participants-flash--success" data-participants-toast>
                        <strong class="participants-flash__title">Operation reussie</strong>
                        <div class="participants-flash__message">{{ message }}</div>
                        <button type="button" class="participants-flash__close" data-participants-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
                {% for message in warningFlashes %}
                    <div class="participants-flash participants-flash--warning" data-participants-toast>
                        <strong class="participants-flash__title">Attention</strong>
                        <div class="participants-flash__message">{{ message }}</div>
                        <button type="button" class="participants-flash__close" data-participants-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
                {% for message in errorFlashes %}
                    <div class="participants-flash participants-flash--error" data-participants-toast>
                        <strong class="participants-flash__title">Action impossible</strong>
                        <div class="participants-flash__message">{{ message }}</div>
                        <button type="button" class="participants-flash__close" data-participants-toast-close aria-label="Fermer la notification">×</button>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="participants-layout">
            <aside class="participants-card">
                <div>
                    <h2 class="participants-card__title">Ajouter un participant</h2>
                    <p class="participants-card__text">Renseignez l'email d'un utilisateur deja present dans votre base pour l'associer a ce voyage.</p>
                </div>

                <form method="post" action="{{ path('app_voyages_participants', {'id_voyage': voyage.idVoyage}) }}" class="participants-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_participant_' ~ voyage.idVoyage) }}">

                    <div class="participants-field">
                        <label for="participant-email" class="participants-label">Email</label>
                        <input
                            id="participant-email"
                            name="email"
                            type="email"
                            value="{{ last_email }}"
                            class="participants-input"
                            placeholder="utilisateur@exemple.com"
                            required
                        >
                    </div>

                    <div class="participants-field">
                        <label for="participant-role" class="participants-label">Role dans le voyage</label>
                        <select id="participant-role" name="role_participation" class="participants-select">
                            {% for role in role_options %}
                                <option value="{{ role }}" {{ role == last_role ? 'selected' : '' }}>{{ role }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <button type="submit" class="btn btn--primary">Ajouter au voyage</button>
                </form>

            </aside>

            <section class="participants-card participants-list">
                <div class="participants-list__header">
                    <div>
                        <h2 class="participants-card__title">Liste des participants</h2>
                        <p class="participants-card__text">Modifiez le role directement sur chaque ligne ou retirez un participant du voyage.</p>
                    </div>
                    <span class="participants-badge">{{ participants|length }} enregistre{% if participants|length > 1 %}s{% endif %}</span>
                </div>

                {% if participants is not empty %}
                    <div class="participants-table">
                        {% for participation in participants %}
                            <div class="participants-row">
                                <div class="participants-person">
                                    <span class="participants-person__name">{{ participation.user.prenom }} {{ participation.user.nom }}</span>
                                    <span class="participants-person__meta">{{ participation.user.email }}</span>
                                    {% if participation.user.telephone %}
                                        <span class="participants-person__meta">{{ participation.user.telephone }}</span>
                                    {% endif %}
                                </div>

                                <form method="post" action="{{ path('app_voyages_participants_update', {'id_voyage': voyage.idVoyage, 'userId': participation.user.id}) }}" class="participants-role-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('update_participant_' ~ voyage.idVoyage ~ '_' ~ participation.user.id) }}">
                                    <select name="role_participation" class="participants-select" aria-label="Role de {{ participation.user.prenom }} {{ participation.user.nom }}">
                                        {% for role in role_options %}
                                            <option value="{{ role }}" {{ role == participation.roleParticipation ? 'selected' : '' }}>{{ role }}</option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="participants-icon-button participants-icon-button--save" title="Mettre a jour le role" aria-label="Mettre a jour le role de {{ participation.user.prenom }} {{ participation.user.nom }}">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                            <path d="M5 20H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                            <path d="M7 4H16L19 7V20H7V4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                            <path d="M9 4V9H15V4" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                            <path d="M9 15H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                        </svg>
                                        <span class="sr-only">Enregistrer</span>
                                    </button>
                                </form>

                                <div class="participants-actions">
                                    <form method="post" action="{{ path('app_voyages_participants_delete', {'id_voyage': voyage.idVoyage, 'userId': participation.user.id}) }}" onsubmit="return confirm('Supprimer ce participant du voyage ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_participant_' ~ voyage.idVoyage ~ '_' ~ participation.user.id) }}">
                                        <button type="submit" class="participants-icon-button participants-icon-button--delete" title="Supprimer le participant" aria-label="Supprimer {{ participation.user.prenom }} {{ participation.user.nom }} du voyage">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                <path d="M4 7H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                <path d="M9 7V5.5C9 4.67157 9.67157 4 10.5 4H13.5C14.3284 4 15 4.67157 15 5.5V7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                <path d="M7 7L7.8 18.2C7.87717 19.2804 8.77596 20.1191 9.85909 20.1191H14.1409C15.224 20.1191 16.1228 19.2804 16.2 18.2L17 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                <path d="M10 11V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                                <path d="M14 11V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                            </svg>
                                            <span class="sr-only">Supprimer</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="participants-empty">
                        Aucun participant n'est encore associe a ce voyage.
                    </div>
                {% endif %}
            </section>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toasts = document.querySelectorAll('[data-participants-toast]');

            function hideToast(toast) {
                if (!toast || toast.classList.contains('is-hiding')) {
                    return;
                }

                toast.classList.add('is-hiding');
                window.setTimeout(function () {
                    toast.remove();
                }, 220);
            }

            toasts.forEach(function (toast) {
                var closeButton = toast.querySelector('[data-participants-toast-close]');

                if (closeButton) {
                    closeButton.addEventListener('click', function () {
                        hideToast(toast);
                    });
                }

                window.setTimeout(function () {
                    hideToast(toast);
                }, 4200);
            });
        });
    </script>
{% endblock %}