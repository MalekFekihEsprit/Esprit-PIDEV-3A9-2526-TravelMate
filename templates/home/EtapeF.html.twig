{% extends 'base.html.twig' %}

{% block title %}{{ activeTimelineDay ? activeTimelineDay.full_label : 'Jour ' ~ jour }} - {{ itineraire.nom_itineraire }} | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .etapes-page {
            display: grid;
            gap: 1.75rem;
        }

        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-success {
            background: rgba(39, 174, 96, 0.1);
            border: 1px solid rgba(39, 174, 96, 0.3);
            color: #27ae60;
        }

        .alert-error {
            background: rgba(231, 76, 60, 0.1);
            border: 1px solid rgba(231, 76, 60, 0.3);
            color: #e74c3c;
        }

        .etapes-hero {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1.15fr) minmax(240px, 0.85fr);
            gap: 1.5rem;
            padding: 2rem;
            overflow: hidden;
            background:
                radial-gradient(circle at top left, rgba(47, 127, 121, 0.2), transparent 28%),
                linear-gradient(135deg, rgba(255, 253, 249, 0.98), rgba(239, 246, 244, 0.92));
            border: 1px solid rgba(231, 220, 205, 0.68);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 36px rgba(71, 48, 35, 0.06);
        }

        .etapes-hero__content {
            position: relative;
            z-index: 1;
            display: grid;
            gap: 0.95rem;
            max-width: 780px;
        }

        .etapes-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--color-secondary);
            font-size: 0.92rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .etapes-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(2.15rem, 3vw, 3.35rem);
            line-height: 1.04;
            color: var(--color-text);
        }

        .etapes-hero__subtitle {
            color: var(--color-text-muted);
            font-size: 1rem;
            line-height: 1.6;
            max-width: 60ch;
        }

        .etapes-hero__meta {
            display: flex;
            gap: 0.7rem;
            flex-wrap: wrap;
        }

        .etapes-hero__pill {
            display: inline-flex;
            align-items: center;
            padding: 0.45rem 0.8rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.74);
            border: 1px solid rgba(231, 220, 205, 0.9);
            color: var(--color-text-muted);
            font-size: 0.84rem;
            font-weight: 600;
        }

        .etapes-hero__pill--accent {
            background: rgba(196, 111, 75, 0.12);
            border-color: rgba(196, 111, 75, 0.18);
            color: var(--color-primary-dark);
        }

        .etapes-hero__stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 160px));
            gap: 0.8rem;
            margin-top: 0.35rem;
        }

        .etapes-stat {
            padding: 0.9rem;
            border-radius: var(--radius-lg);
            background: rgba(255, 255, 255, 0.78);
            border: 1px solid rgba(231, 220, 205, 0.95);
        }

        .etapes-stat strong {
            display: block;
            font-family: 'Fraunces', serif;
            font-size: 1.55rem;
            color: var(--color-text);
        }

        .etapes-stat span {
            color: var(--color-text-muted);
            font-size: 0.82rem;
        }

        .etapes-hero__actions {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            justify-content: center;
        }

        .etapes-hero__actions .btn {
            width: 100%;
        }

        .etapes-export-btn {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            gap: 0.2rem;
            padding: 1rem 1.15rem;
            color: #fff;
            background: linear-gradient(135deg, #1f6d67, #2f7f79);
            border: 1px solid rgba(31, 109, 103, 0.38);
            box-shadow: 0 16px 28px rgba(31, 109, 103, 0.2);
        }

        .etapes-export-btn:hover,
        .etapes-export-btn:focus-visible {
            transform: translateY(-2px);
            box-shadow: 0 20px 34px rgba(31, 109, 103, 0.24);
        }

        .etapes-export-btn span {
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .etapes-export-btn small {
            color: rgba(255, 255, 255, 0.84);
            font-size: 0.8rem;
        }

        .etapes-board {
            padding: 1.5rem;
            background: rgba(255, 253, 249, 0.95);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 14px 28px rgba(71, 48, 35, 0.05);
        }

        .etapes-filters {
            display: grid;
            gap: 1rem;
            padding: 1.3rem 1.35rem;
            background: rgba(255, 253, 249, 0.95);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 14px 28px rgba(71, 48, 35, 0.05);
        }

        .etapes-filters__title {
            font-family: 'Fraunces', serif;
            font-size: 1.2rem;
            color: var(--color-text);
        }

        .etapes-filters__row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            align-items: end;
        }

        .etapes-filter-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .etapes-filter-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .etapes-filter-group input,
        .etapes-filter-group select {
            padding: 0.65rem 0.85rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            color: var(--color-text);
            font-size: 0.95rem;
            transition: all var(--transition-fast);
        }

        .etapes-filter-group input:focus,
        .etapes-filter-group select:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196, 111, 75, 0.1);
        }

        .etapes-board__header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.35rem;
        }

        .etapes-board__title {
            font-family: 'Fraunces', serif;
            font-size: 1.55rem;
            color: var(--color-text);
            margin-bottom: 0.35rem;
        }

        .etapes-board__text {
            color: var(--color-text-muted);
            max-width: 64ch;
            line-height: 1.6;
        }

        .etapes-board__legend {
            display: flex;
            gap: 0.7rem;
            flex-wrap: wrap;
        }

        .etapes-legend {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.5rem 0.8rem;
            border-radius: 999px;
            background: rgba(243, 234, 223, 0.72);
            color: var(--color-text-muted);
            font-size: 0.82rem;
            font-weight: 600;
        }

        .etapes-legend__dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(47, 127, 121, 0.4);
        }

        .etapes-legend__dot.is-active {
            background: var(--color-primary);
        }

        .etapes-timeline {
            display: grid;
            gap: 0.9rem;
        }

        .timeline-row {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 1.25rem;
            align-items: start;
        }

        .timeline-row__rail {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.7rem;
            min-height: 92px;
            padding-bottom: 0.6rem;
        }

        .timeline-row:not(:last-child) .timeline-row__rail::after {
            content: '';
            position: absolute;
            top: 74px;
            bottom: -1rem;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            background: linear-gradient(180deg, rgba(47, 127, 121, 0.55), rgba(47, 127, 121, 0.16));
        }

        .timeline-marker {
            position: relative;
            z-index: 1;
            width: 74px;
            height: 74px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.12rem;
            border-radius: 50%;
            background: rgba(47, 127, 121, 0.08);
            border: 2px solid rgba(47, 127, 121, 0.34);
            color: var(--color-secondary);
            transition: transform var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast), color var(--transition-fast);
        }

        .timeline-row.is-selected .timeline-marker,
        .timeline-marker:hover,
        .timeline-marker:focus-visible {
            background: var(--color-primary);
            border-color: rgba(196, 111, 75, 0.78);
            color: white;
            transform: translateY(-2px) scale(1.04);
            box-shadow: 0 18px 34px rgba(196, 111, 75, 0.22);
            outline: none;
        }

        .timeline-marker__day {
            font-family: 'Fraunces', serif;
            font-size: 1.7rem;
            line-height: 1;
        }

        .timeline-marker__month {
            font-size: 0.72rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            font-weight: 700;
        }

        .timeline-row__label {
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            color: var(--color-text-muted);
            text-transform: uppercase;
            text-align: center;
        }

        .timeline-row.is-selected .timeline-row__label {
            color: var(--color-primary-dark);
        }

        .timeline-content {
            opacity: 0;
            max-height: 0;
            overflow: hidden;
            pointer-events: none;
            transform: translateY(-8px);
            transition: max-height 280ms ease, opacity 180ms ease, transform 180ms ease, padding 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
            padding: 0 1.35rem;
            border: 1px solid transparent;
            border-radius: var(--radius-xl);
            background: linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(247, 242, 234, 0.94));
        }

        .timeline-row.is-selected .timeline-content {
            opacity: 1;
            max-height: 5000px;
            pointer-events: auto;
            transform: none;
            padding: 1.25rem 1.35rem;
            border-color: rgba(231, 220, 205, 0.95);
            box-shadow: 0 18px 34px rgba(71, 48, 35, 0.06);
        }

        .timeline-content__header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        .timeline-content__eyebrow {
            color: var(--color-secondary);
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0.3rem;
        }

        .timeline-content__title {
            font-family: 'Fraunces', serif;
            font-size: 1.45rem;
            color: var(--color-text);
            margin-bottom: 0.2rem;
        }

        .timeline-content__meta {
            color: var(--color-text-muted);
            font-size: 0.92rem;
        }

        .timeline-content__actions {
            display: flex;
            gap: 0.65rem;
            flex-wrap: wrap;
        }

        .timeline-steps {
            display: grid;
            gap: 0.9rem;
        }

        .timeline-step {
            display: grid;
            grid-template-columns: 96px minmax(0, 1fr) auto;
            gap: 1rem;
            align-items: start;
            padding-top: 1rem;
            border-top: 1px dashed rgba(196, 111, 75, 0.18);
        }

        .timeline-step:first-child {
            border-top: none;
            padding-top: 0;
        }

        .timeline-step__time {
            width: fit-content;
            min-width: 86px;
            padding: 0.6rem 0.85rem;
            border-radius: 999px;
            background: rgba(47, 127, 121, 0.12);
            color: var(--color-secondary);
            font-family: 'Fraunces', serif;
            font-size: 1rem;
            text-align: center;
        }

        .timeline-step__body {
            display: grid;
            gap: 0.45rem;
        }

        .timeline-step__description {
            color: var(--color-text);
            line-height: 1.6;
        }

        .timeline-step__activity {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            width: fit-content;
            padding: 0.42rem 0.78rem;
            border-radius: 999px;
            background: rgba(196, 111, 75, 0.12);
            color: var(--color-primary);
            font-weight: 600;
            font-size: 0.82rem;
        }

        .timeline-step__actions {
            display: flex;
            gap: 0.45rem;
            align-items: flex-start;
        }

        .action-btn {
            width: 40px;
            height: 40px;
            border: none;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all var(--transition-fast);
            font-size: 1.05rem;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid var(--color-border);
            color: var(--color-text-muted);
        }

        .action-btn:hover {
            background: var(--color-primary);
            border-color: var(--color-primary);
            color: white;
            transform: scale(1.05);
        }

        .action-btn.danger:hover {
            background: #e74c3c;
            border-color: #e74c3c;
        }

        .timeline-empty {
            display: grid;
            gap: 0.9rem;
            padding-top: 0.2rem;
        }

        .timeline-empty__card {
            padding: 1.15rem 1.2rem;
            border-radius: var(--radius-lg);
            border: 1px dashed rgba(47, 127, 121, 0.32);
            background: rgba(47, 127, 121, 0.05);
        }

        .timeline-empty__title {
            font-family: 'Fraunces', serif;
            font-size: 1.15rem;
            color: var(--color-text);
            margin-bottom: 0.35rem;
        }

        .timeline-empty__text {
            color: var(--color-text-muted);
            line-height: 1.6;
        }

        @media (max-width: 1024px) {
            .etapes-hero {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .etapes-page {
                gap: 1.35rem;
            }

            .etapes-hero {
                padding: 1.35rem;
            }

            .etapes-hero__title {
                font-size: 1.9rem;
            }

            .etapes-hero__stats {
                grid-template-columns: 1fr;
            }

            .etapes-board {
                padding: 1.1rem;
            }

            .etapes-filters {
                padding: 1.1rem;
            }

            .timeline-row {
                grid-template-columns: 82px minmax(0, 1fr);
                gap: 0.9rem;
            }

            .timeline-marker {
                width: 62px;
                height: 62px;
            }

            .timeline-marker__day {
                font-size: 1.38rem;
            }

            .timeline-row:not(:last-child) .timeline-row__rail::after {
                top: 62px;
            }

            .timeline-row.is-selected .timeline-content {
                padding: 1rem;
            }

            .timeline-step {
                grid-template-columns: 1fr;
            }

            .timeline-step__actions {
                justify-content: flex-start;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="etapes-page">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">
                <span>!</span>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <section class="etapes-hero">
            <div class="etapes-hero__content">
                <div class="etapes-hero__eyebrow">
                    📌 Page étapes
                </div>

                <h1 class="etapes-hero__title">{{ itineraire.nom_itineraire }}</h1>

                <p class="etapes-hero__subtitle">
                    {% if itineraire.voyage and itineraire.voyage.destination %}
                        {{ itineraire.voyage.destination.nom_destination }} ·
                    {% endif %}
                    {{ activeTimelineDay ? activeTimelineDay.full_label : 'Jour ' ~ jour }}
                </p>

                <div class="etapes-hero__meta">
                    <span class="etapes-hero__pill">Jour actif : {{ jour }}</span>
                    <span class="etapes-hero__pill">
                        {{ activeTimelineDay ? activeTimelineDay.count : 0 }} étape{% if activeTimelineDay and activeTimelineDay.count > 1 %}s{% endif %}
                    </span>
                    <span class="etapes-hero__pill etapes-hero__pill--accent">Survole un cercle pour voir son contenu</span>
                </div>

                <div class="etapes-hero__stats">
                    <div class="etapes-stat">
                        <strong>{{ totalDays }}</strong>
                        <span>Jours du voyage</span>
                    </div>
                    <div class="etapes-stat">
                        <strong>{{ plannedDays }}</strong>
                        <span>Jours planifiés</span>
                    </div>
                    <div class="etapes-stat">
                        <strong>{{ totalEtapes }}</strong>
                        <span>Étapes au total</span>
                    </div>
                </div>
            </div>

            <div class="etapes-hero__actions">
                <a href="{{ path('app_etapes_export_pdf', {itineraireId: itineraire.id_itineraire, jour: jour, q: search_q ?: null, sort: sort ?: null}) }}" class="btn etapes-export-btn" target="_blank" rel="noopener">
                    <span>Exporter en PDF</span>
                    <small>Toutes les étapes visibles avec leurs détails</small>
                </a>
                <a href="{{ itineraire.voyage ? path('app_itineraires_index', {voyageId: itineraire.voyage.id_voyage}) : path('app_voyages') }}" class="btn btn--secondary">
                    ← Retour aux itinéraires
                </a>
            </div>
        </section>

        <section class="etapes-filters" aria-label="Recherche et tri des étapes">
            <h2 class="etapes-filters__title">Recherche et tri</h2>
            <form
                method="get"
                action="{{ path('app_etapes_jour', {itineraireId: itineraire.id_itineraire, jour: jour}) }}"
                class="etapes-filters__row"
                data-etapes-filter-form
                data-current-day="{{ jour }}"
                data-route-template="{{ path('app_etapes_jour', {itineraireId: itineraire.id_itineraire, jour: '__JOUR__'}) }}"
            >
                <div class="etapes-filter-group">
                    <label for="etape-day">Jour</label>
                    <select id="etape-day" data-etapes-day-select>
                        {% for timelineDay in timelineDays %}
                            <option value="{{ timelineDay.number }}" {% if timelineDay.number == jour %}selected{% endif %}>
                                Jour {{ timelineDay.number }} · {{ timelineDay.full_label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="etapes-filter-group">
                    <label for="etape-q">Recherche</label>
                    <input type="search" id="etape-q" name="q" value="{{ search_q }}" placeholder="Description ou activité..." autocomplete="off">
                </div>
                <div class="etapes-filter-group">
                    <label for="etape-sort">Tri</label>
                    <select id="etape-sort" name="sort">
                        <option value="heure_asc" {% if sort == 'heure_asc' %}selected{% endif %}>Heure ↑ croissant</option>
                        <option value="heure_desc" {% if sort == 'heure_desc' %}selected{% endif %}>Heure ↓ décroissant</option>
                        <option value="alpha_asc" {% if sort == 'alpha_asc' %}selected{% endif %}>Description A → Z</option>
                        <option value="alpha_desc" {% if sort == 'alpha_desc' %}selected{% endif %}>Description Z → A</option>
                    </select>
                </div>
            </form>
        </section>

        <section class="etapes-board">
            <div class="etapes-board__header">
                <div>
                    <h2 class="etapes-board__title">Timeline du voyage</h2>
                    <p class="etapes-board__text">
                        Clique sur un cercle pour garder ce jour actif. Le survol montre immédiatement les étapes du jour correspondant.
                    </p>
                </div>

                <div class="etapes-board__legend">
                    <span class="etapes-legend">
                        <span class="etapes-legend__dot is-active"></span>
                        Jour actif
                    </span>
                    <span class="etapes-legend">
                        <span class="etapes-legend__dot"></span>
                        Jour disponible
                    </span>
                </div>
            </div>

            <div class="etapes-timeline" data-timeline data-active-day="{{ jour }}">
                {% for timelineDay in timelineDays %}
                    <article class="timeline-row {% if timelineDay.number == jour %}is-selected{% endif %}" data-timeline-row data-day="{{ timelineDay.number }}">
                        <div class="timeline-row__rail">
                            <a href="{{ path('app_etapes_jour', {itineraireId: itineraire.id_itineraire, jour: timelineDay.number, q: search_q ?: null, sort: sort ?: null}) }}" class="timeline-marker" data-timeline-marker {% if timelineDay.number == jour %}aria-current="page"{% endif %}>
                                <span class="timeline-marker__day">{{ timelineDay.calendar_day }}</span>
                                <span class="timeline-marker__month">{{ timelineDay.month_label }}</span>
                            </a>
                            <span class="timeline-row__label">Jour {{ timelineDay.number }}</span>
                        </div>

                        <div class="timeline-content">
                            <div class="timeline-content__header">
                                <div>
                                    <p class="timeline-content__eyebrow">{{ timelineDay.weekday_short }} · Jour {{ timelineDay.number }}</p>
                                    <h3 class="timeline-content__title">{{ timelineDay.full_label }}</h3>
                                    <p class="timeline-content__meta">
                                        {{ timelineDay.count }} étape{% if timelineDay.count > 1 %}s{% endif %} planifiée{% if timelineDay.count > 1 %}s{% endif %}
                                    </p>
                                </div>

                                <div class="timeline-content__actions">
                                    <a href="{{ path('app_etapes_create', {itineraireId: itineraire.id_itineraire, jour: timelineDay.number}) }}" class="btn btn--secondary">
                                        + Ajouter une étape
                                    </a>
                                </div>
                            </div>

                            {% if timelineDay.etapes|length > 0 %}
                                <div class="timeline-steps">
                                    {% for etape in timelineDay.etapes %}
                                        <article class="timeline-step">
                                            <div class="timeline-step__time">
                                                {{ etape.heure ? etape.heure|date('H:i') : '--:--' }}
                                            </div>

                                            <div class="timeline-step__body">
                                                <p class="timeline-step__description">
                                                    {{ etape.description_etape }}
                                                </p>
                                                {% if etape.activite %}
                                                    <span class="timeline-step__activity">🎯 {{ etape.activite.nom }}</span>
                                                {% endif %}
                                            </div>

                                            <div class="timeline-step__actions">
                                                <a href="{{ path('app_etapes_edit', {id: etape.id_etape}) }}" class="action-btn" title="Éditer">✏️</a>
                                                <form method="POST" action="{{ path('app_etapes_delete', {id: etape.id_etape}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette étape ?');">
                                                    <button type="submit" class="action-btn danger" title="Supprimer">🗑️</button>
                                                </form>
                                            </div>
                                        </article>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="timeline-empty">
                                    <div class="timeline-empty__card">
                                        <h4 class="timeline-empty__title">Aucune étape prévue</h4>
                                        <p class="timeline-empty__text">
                                            Ce jour est encore vide. Ajoute une étape pour remplir la timeline.
                                        </p>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var filterForm = document.querySelector('[data-etapes-filter-form]');
            if (filterForm) {
                var daySelect = filterForm.querySelector('[data-etapes-day-select]');
                var searchInput = filterForm.querySelector('[name="q"]');
                var sortSelect = filterForm.querySelector('[name="sort"]');
                var routeTemplate = filterForm.dataset.routeTemplate || '';
                var currentDay = filterForm.dataset.currentDay || '';
                var debounceTimer = null;

                var updateFormAction = function () {
                    if (!routeTemplate) {
                        return;
                    }

                    var selectedDay = daySelect && daySelect.value ? daySelect.value : currentDay;
                    filterForm.action = routeTemplate.replace('__JOUR__', selectedDay);
                };

                var submitFilters = function () {
                    updateFormAction();
                    filterForm.requestSubmit();
                };

                updateFormAction();

                if (searchInput) {
                    searchInput.addEventListener('input', function () {
                        window.clearTimeout(debounceTimer);
                        debounceTimer = window.setTimeout(submitFilters, 250);
                    });
                }

                if (sortSelect) {
                    sortSelect.addEventListener('change', submitFilters);
                }

                if (daySelect) {
                    daySelect.addEventListener('change', submitFilters);
                }

                filterForm.addEventListener('submit', updateFormAction);
            }

            var timeline = document.querySelector('[data-timeline]');
            if (!timeline) {
                return;
            }

            var rows = Array.prototype.slice.call(timeline.querySelectorAll('[data-timeline-row]'));
            var persistedDay = timeline.dataset.activeDay || '';

            var selectDay = function (day) {
                rows.forEach(function (row) {
                    row.classList.toggle('is-selected', row.dataset.day === day);
                });
            };

            selectDay(persistedDay);

            rows.forEach(function (row) {
                var marker = row.querySelector('[data-timeline-marker]');
                if (marker) {
                    marker.addEventListener('mouseenter', function () {
                        selectDay(row.dataset.day);
                    });
                }

                row.addEventListener('focusin', function () {
                    selectDay(row.dataset.day);
                });
            });

            timeline.addEventListener('mouseleave', function () {
                selectDay(persistedDay);
            });

            timeline.addEventListener('focusout', function (event) {
                if (!event.relatedTarget || !timeline.contains(event.relatedTarget)) {
                    selectDay(persistedDay);
                }
            });
        });
    </script>
{% endblock %}