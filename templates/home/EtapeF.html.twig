{% extends 'base.html.twig' %}

{% block title %}Jour {{ jour }} - {{ itineraire.nom_itineraire }} | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .etapes-page {
            display: grid;
            gap: 1.75rem;
        }

        .etapes-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.5rem;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 2px 8px rgba(71, 48, 35, 0.04);
        }

        .etapes-header__left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .etapes-header__back {
            display: inline-block;
            padding: 0.75rem 1.25rem;
            background: var(--color-secondary);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            cursor: pointer;
            text-decoration: none;
            font-weight: 600;
            transition: all var(--transition-fast);
            font-size: 0.95rem;
        }

        .etapes-header__back:hover {
            background: var(--color-secondary-dark);
            transform: translateY(-2px);
        }

        .etapes-header__day-number {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--color-primary);
            color: white;
            border-radius: var(--radius-lg);
            font-family: 'Fraunces', serif;
            font-size: 1.75rem;
            font-weight: 700;
        }

        .etapes-header__info {
            display: grid;
            gap: 0.25rem;
        }

        .etapes-header__title {
            font-family: 'Fraunces', serif;
            font-size: 1.75rem;
            color: var(--color-text);
            margin: 0;
        }

        .etapes-header__subtitle {
            color: var(--color-text-muted);
            font-size: 0.95rem;
            margin: 0;
        }

        .etapes-header__actions {
            display: flex;
            gap: 0.75rem;
        }

        .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.25rem;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-fast);
            font-size: 0.9rem;
            text-decoration: none;
        }

        .btn-action.primary {
            background: var(--color-primary);
            color: white;
        }

        .btn-action.primary:hover {
            background: var(--color-primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(196, 111, 75, 0.25);
        }

        .etapes-list {
            display: grid;
            gap: 1rem;
        }

        .etape-card {
            padding: 1.5rem;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 2px 8px rgba(71, 48, 35, 0.04);
            transition: all var(--transition-base);
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 1.5rem;
            align-items: start;
        }

        .etape-card:hover {
            border-color: rgba(196, 111, 75, 0.3);
            box-shadow: 0 12px 24px rgba(71, 48, 35, 0.08);
            transform: translateY(-2px);
        }

        .etape-card__content {
            display: grid;
            gap: 0.75rem;
        }

        .etape-card__time {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-primary);
        }

        .etape-card__description {
            color: var(--color-text-muted);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .etape-card__actions {
            display: flex;
            gap: 0.5rem;
        }

        .action-btn {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            border-radius: var(--radius-md);
            background: rgba(196, 111, 75, 0.1);
            color: var(--color-primary);
            cursor: pointer;
            transition: all var(--transition-fast);
            font-size: 1.1rem;
        }

        .action-btn:hover {
            background: rgba(196, 111, 75, 0.2);
            transform: scale(1.05);
        }

        .etapes-empty {
            text-align: center;
            padding: 3rem 2rem;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
        }

        .etapes-empty__icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .etapes-empty__title {
            font-family: 'Fraunces', serif;
            font-size: 1.35rem;
            color: var(--color-text);
            margin-bottom: 0.5rem;
        }

        .etapes-empty__text {
            color: var(--color-text-muted);
            margin-bottom: 1.5rem;
        }

        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-md);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-success {
            background: rgba(39, 174, 96, 0.1);
            border: 1px solid rgba(39, 174, 96, 0.3);
            color: #27ae60;
        }

        .alert-error {
            background: rgba(231, 76, 60, 0.1);
            border: 1px solid rgba(231, 76, 60, 0.3);
            color: #e74c3c;
        }

        .etapes-toolbar {
            padding: 1.25rem 1.35rem;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 2px 8px rgba(71, 48, 35, 0.04);
        }

        .etapes-toolbar__title {
            font-family: 'Fraunces', serif;
            font-size: 1.15rem;
            color: var(--color-text);
            margin: 0 0 1rem;
        }

        .etapes-filter-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            align-items: end;
        }

        .etapes-filter-group {
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
        }

        .etapes-filter-group label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .etapes-filter-group input,
        .etapes-filter-group select {
            padding: 0.65rem 0.85rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            color: var(--color-text);
            font-size: 0.95rem;
        }

        .etapes-filter-group input:focus,
        .etapes-filter-group select:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196, 111, 75, 0.1);
        }

        .etapes-filter-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .btn-etape-filter {
            padding: 0.65rem 1.2rem;
            background: var(--color-primary);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            cursor: pointer;
        }

        .btn-etape-reset {
            padding: 0.65rem 1rem;
            background: transparent;
            color: var(--color-text-muted);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
        }

        @media (max-width: 768px) {
            .etapes-header {
                flex-direction: column;
                gap: 1.5rem;
                align-items: flex-start;
            }

            .etapes-header__left {
                width: 100%;
            }

            .etapes-header__actions {
                width: 100%;
                flex-wrap: wrap;
            }

            .btn-action {
                flex: 1;
                min-width: 120px;
            }

            .etape-card {
                grid-template-columns: 1fr;
            }

            .etape-card__actions {
                justify-content: flex-start;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="etapes-page">
        <!-- Messages Flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">
                <span>!</span>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <!-- Header avec navigation -->
        <div class="etapes-header">
            <div class="etapes-header__left">
                <a href="{{ path('app_itineraires_index', {voyageId: itineraire.voyage.id_voyage}) }}" class="etapes-header__back">
                    ← Afficher la carte
                </a>
                
                <div class="etapes-header__day-number">{{ jour }}</div>
                
                <div class="etapes-header__info">
                    <h1 class="etapes-header__title">Jour {{ jour }}</h1>
                    <p class="etapes-header__subtitle">{{ itineraire.nom_itineraire }}</p>
                </div>
            </div>

            <div class="etapes-header__actions">
                <a href="{{ path('app_etapes_create', {itineraireId: itineraire.id_itineraire, jour: jour}) }}" class="btn-action primary">
                    + Ajouter une étape
                </a>
            </div>
        </div>

        <section class="etapes-toolbar" aria-label="Recherche et tri des étapes">
            <h2 class="etapes-toolbar__title">Recherche et tri</h2>
            <form method="get" action="{{ path('app_etapes_jour', {itineraireId: itineraire.id_itineraire, jour: jour}) }}" class="etapes-filter-row">
                <div class="etapes-filter-group">
                    <label for="etape-q">Recherche</label>
                    <input type="search" id="etape-q" name="q" value="{{ search_q }}" placeholder="Description ou activité…" autocomplete="off">
                </div>
                <div class="etapes-filter-group">
                    <label for="etape-sort">Tri</label>
                    <select id="etape-sort" name="sort">
                        <option value="heure_asc" {% if sort == 'heure_asc' %}selected{% endif %}>Heure ↑ croissant</option>
                        <option value="heure_desc" {% if sort == 'heure_desc' %}selected{% endif %}>Heure ↓ décroissant</option>
                        <option value="alpha_asc" {% if sort == 'alpha_asc' %}selected{% endif %}>Description A → Z</option>
                        <option value="alpha_desc" {% if sort == 'alpha_desc' %}selected{% endif %}>Description Z → A</option>
                    </select>
                </div>
                <div class="etapes-filter-actions">
                    <button type="submit" class="btn-etape-filter">Appliquer</button>
                    <a href="{{ path('app_etapes_jour', {itineraireId: itineraire.id_itineraire, jour: jour}) }}" class="btn-etape-reset">Réinitialiser</a>
                </div>
            </form>
        </section>

        <!-- Liste des étapes -->
        {% if etapes|length > 0 %}
            <div class="etapes-list">
                {% for etape in etapes %}
                    <div class="etape-card">
                        <div class="etape-card__content">
                            {% if etape.heure %}
                                <div class="etape-card__time">
                                    ⏰ {{ etape.heure|date('H:i') }}
                                </div>
                            {% endif %}
                            <p class="etape-card__description">
                                {{ etape.description_etape }}
                            </p>
                            {% if etape.activite %}
                                <div style="color: var(--color-primary); font-weight: 500; font-size: 0.9rem;">
                                    🎯 {{ etape.activite.nom }}
                                </div>
                            {% endif %}
                        </div>

                        <div class="etape-card__actions">
                            <a href="{{ path('app_etapes_edit', {id: etape.id_etape}) }}" class="action-btn" title="Éditer">✏️</a>
                            <form method="POST" action="{{ path('app_etapes_delete', {id: etape.id_etape}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette étape?');">
                                <button type="submit" class="action-btn" title="Supprimer" style="background: rgba(231, 76, 60, 0.1); color: #e74c3c;">🗑️</button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="etapes-empty">
                <div class="etapes-empty__icon">📋</div>
                <h3 class="etapes-empty__title">Aucune étape pour ce jour</h3>
                <p class="etapes-empty__text">
                    Planifiez vos activités pour le jour {{ jour }}!
                </p>
                <a href="{{ path('app_etapes_create', {itineraireId: itineraire.id_itineraire, jour: jour}) }}" class="btn btn--primary">
                    + Ajouter une étape
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}