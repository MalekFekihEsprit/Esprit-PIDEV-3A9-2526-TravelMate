{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var bindCultureCardToggle = function () {
                var cultureCard = document.querySelector('[data-culture-card]');
                var toggleButton = document.querySelector('[data-culture-toggle]');
                var toggleLabel = document.querySelector('[data-culture-toggle-label]');

                if (!cultureCard || !toggleButton || toggleButton.dataset.cultureToggleBound === 'true') {
                    return;
                }

                toggleButton.dataset.cultureToggleBound = 'true';
                toggleButton.addEventListener('click', function () {
                    var isOpen = cultureCard.classList.toggle('is-open');
                    toggleButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

                    if (toggleLabel) {
                        toggleLabel.textContent = isOpen ? 'Masquer les conseils' : 'Afficher les conseils';
                    }
                });
            };

            bindCultureCardToggle();

            var bindCardNavigation = function (root) {
                var cards = Array.prototype.slice.call(root.querySelectorAll('[data-card-link]'));

                cards.forEach(function (card) {
                    if (card.dataset.cardLinkBound === 'true') {
                        return;
                    }

                    card.dataset.cardLinkBound = 'true';

                    var navigate = function () {
                        var href = card.getAttribute('data-card-link');
                        if (href) {
                            window.location.href = href;
                        }
                    };

                    card.addEventListener('click', function (event) {
                        if (event.target.closest('[data-card-link-ignore]')) {
                            return;
                        }

                        navigate();
                    });

                    card.addEventListener('keydown', function (event) {
                        if (event.key !== 'Enter' && event.key !== ' ') {
                            return;
                        }

                        if (event.target.closest('[data-card-link-ignore]')) {
                            return;
                        }

                        event.preventDefault();
                        navigate();
                    });
                });
            };

            bindCardNavigation(document);

            var form = document.querySelector('[data-itineraires-filter-form]');
            var resultsContainer = document.querySelector('[data-itineraires-results]');
            if (!form || !resultsContainer) {
                return;
            }

            var searchInput = form.querySelector('[name="q"]');
            var sortSelect = form.querySelector('[name="sort"]');
            var resetLink = form.querySelector('[data-itineraires-reset]');
            var debounceTimer = null;
            var currentController = null;
            var activeRequestId = 0;

            var buildUrl = function () {
                var url = new URL(form.getAttribute('action') || window.location.pathname, window.location.href);
                var formData = new FormData(form);

                formData.forEach(function (value, key) {
                    var normalizedValue = typeof value === 'string' ? value.trim() : value;
                    if (normalizedValue === '' || normalizedValue === null) {
                        return;
                    }

                    url.searchParams.set(key, normalizedValue);
                });

                if (!url.searchParams.has('sort') && sortSelect && sortSelect.value) {
                    url.searchParams.set('sort', sortSelect.value);
                }

                return url;
            };

            var fetchResults = function () {
                var url = buildUrl();

                activeRequestId += 1;
                var requestId = activeRequestId;

                if (currentController) {
                    currentController.abort();
                }

                currentController = new AbortController();
                resultsContainer.classList.add('is-loading');

                fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    signal: currentController.signal
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('HTTP ' + response.status);
                        }

                        return response.text();
                    })
                    .then(function (html) {
                        var parsedDocument = new DOMParser().parseFromString(html, 'text/html');
                        var newResults = parsedDocument.querySelector('[data-itineraires-results]');

                        if (!newResults) {
                            throw new Error('Conteneur de résultats introuvable.');
                        }

                        resultsContainer.innerHTML = newResults.innerHTML;
                        bindCardNavigation(resultsContainer);
                        window.history.replaceState({}, '', url.pathname + url.search);
                    })
                    .catch(function (error) {
                        if (error.name === 'AbortError') {
                            return;
                        }

                        console.error(error);
                    })
                    .finally(function () {
                        if (requestId === activeRequestId) {
                            resultsContainer.classList.remove('is-loading');
                        }
                    });
            };

            var scheduleFetch = function () {
                window.clearTimeout(debounceTimer);
                debounceTimer = window.setTimeout(fetchResults, 250);
            };

            if (searchInput) {
                searchInput.addEventListener('input', scheduleFetch);
            }

            if (sortSelect) {
                sortSelect.addEventListener('change', fetchResults);
            }

            form.addEventListener('submit', function (event) {
                event.preventDefault();
                fetchResults();
            });

            if (resetLink) {
                resetLink.addEventListener('click', function (event) {
                    event.preventDefault();

                    if (searchInput) {
                        searchInput.value = '';
                    }

                    if (sortSelect) {
                        sortSelect.value = 'nom_asc';
                    }

                    fetchResults();

                    if (searchInput) {
                        searchInput.focus();
                    }
                });
            }
        });
    </script>

    {# ── Cinematic Video Player JS ── #}
    <script>
    (function () {
        /* ─── State ─── */
        let slides = [];
        let blobUrls = {};  // cache: slide index -> blob URL or src
        let current = 0;
        let playing = false;
        let timer = null;
        let elapsed = 0;        // seconds elapsed total
        let slideElapsed = 0;   // seconds on current slide
        const SLIDE_DURATION = 6; // seconds per slide
        let audioCtx = null;
        let audioNodes = null;
        let muted = false;

        /* ─── DOM refs ─── */
        const overlay     = document.getElementById('videoPlayerOverlay');
        const slideA      = document.getElementById('videoSlideA');
        const slideB      = document.getElementById('videoSlideB');
        const titleEl     = document.getElementById('videoTitle');
        const descEl      = document.getElementById('videoDesc');
        const emojiEl     = document.getElementById('videoEmoji');
        const playBtn     = document.getElementById('videoPlayBtn');
        const prevBtn     = document.getElementById('videoPrevBtn');
        const nextBtn     = document.getElementById('videoNextBtn');
        const closeBtn    = document.getElementById('videoCloseBtn');
        const timeEl      = document.getElementById('videoTime');
        const timeTotalEl = document.getElementById('videoTimeTotal');
        const progressBar = document.getElementById('videoProgressBar');
        const progressFill= document.getElementById('videoProgressFill');
        const muteBtn     = document.getElementById('videoMuteBtn');
        const volumeEl    = document.getElementById('videoVolume');
        const fsBtn       = document.getElementById('videoFullscreenBtn');

        /* ─── Cinematic Piano + Strings Music (Web Audio API) ─── */
        function createAmbientMusic() {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const master = ctx.createGain();
            master.gain.value = 0.25;
            master.connect(ctx.destination);

            // Reverb via convolver (synthetic impulse)
            const convolver = ctx.createConvolver();
            const reverbLen = ctx.sampleRate * 2.5;
            const reverbBuf = ctx.createBuffer(2, reverbLen, ctx.sampleRate);
            for (let ch = 0; ch < 2; ch++) {
                const d = reverbBuf.getChannelData(ch);
                for (let i = 0; i < reverbLen; i++) {
                    d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / reverbLen, 2.2);
                }
            }
            convolver.buffer = reverbBuf;
            const reverbGain = ctx.createGain();
            reverbGain.gain.value = 0.3;
            convolver.connect(reverbGain);
            reverbGain.connect(master);

            const dryGain = ctx.createGain();
            dryGain.gain.value = 0.7;
            dryGain.connect(master);

            // Strings pad (warm sustained chord: Cmaj7)
            const stringNotes = [
                { freq: 130.81, type: 'sawtooth', gain: 0.012 }, // C3
                { freq: 164.81, type: 'sawtooth', gain: 0.010 }, // E3
                { freq: 196.00, type: 'sawtooth', gain: 0.010 }, // G3
                { freq: 246.94, type: 'sawtooth', gain: 0.008 }, // B3
            ];

            const stringsFilter = ctx.createBiquadFilter();
            stringsFilter.type = 'lowpass';
            stringsFilter.frequency.value = 800;
            stringsFilter.Q.value = 0.7;
            stringsFilter.connect(dryGain);
            stringsFilter.connect(convolver);

            const stringOscs = stringNotes.map(n => {
                const osc = ctx.createOscillator();
                osc.type = n.type;
                osc.frequency.value = n.freq;
                osc.detune.value = (Math.random() - 0.5) * 12;
                const g = ctx.createGain();
                g.gain.value = n.gain;
                osc.connect(g);
                // Add a slightly detuned copy for chorus
                const osc2 = ctx.createOscillator();
                osc2.type = n.type;
                osc2.frequency.value = n.freq;
                osc2.detune.value = 8 + (Math.random() - 0.5) * 6;
                const g2 = ctx.createGain();
                g2.gain.value = n.gain * 0.7;
                osc2.connect(g2);
                g.connect(stringsFilter);
                g2.connect(stringsFilter);
                return [osc, osc2];
            }).flat();

            // Piano melody: arpeggio pattern using triangle waves
            const melodyNotes = [
                // Pattern repeats ~every 16 beats at tempo ~55 bpm
                { freq: 523.25, time: 0,    dur: 1.8 },  // C5
                { freq: 659.25, time: 2.0,  dur: 1.5 },  // E5
                { freq: 783.99, time: 4.0,  dur: 2.0 },  // G5
                { freq: 659.25, time: 6.5,  dur: 1.2 },  // E5
                { freq: 587.33, time: 8.0,  dur: 2.0 },  // D5
                { freq: 523.25, time: 10.5, dur: 1.8 },  // C5
                { freq: 493.88, time: 12.5, dur: 2.5 },  // B4
                { freq: 440.00, time: 15.0, dur: 2.0 },  // A4
                { freq: 523.25, time: 17.5, dur: 2.2 },  // C5
                { freq: 659.25, time: 20.0, dur: 1.5 },  // E5
                { freq: 698.46, time: 22.0, dur: 2.0 },  // F5
                { freq: 783.99, time: 24.5, dur: 2.5 },  // G5
                { freq: 659.25, time: 27.5, dur: 1.5 },  // E5
                { freq: 523.25, time: 29.5, dur: 3.0 },  // C5
            ];
            const melodyLoopLen = 32.5; // seconds per loop

            let melodyTimers = [];
            function scheduleMelody(startTime) {
                melodyNotes.forEach(note => {
                    const osc = ctx.createOscillator();
                    osc.type = 'triangle';
                    osc.frequency.value = note.freq;
                    const env = ctx.createGain();
                    env.gain.value = 0;
                    osc.connect(env);
                    env.connect(dryGain);
                    env.connect(convolver);

                    const t = startTime + note.time;
                    // Soft attack and release envelope
                    env.gain.setValueAtTime(0, t);
                    env.gain.linearRampToValueAtTime(0.045, t + 0.08);
                    env.gain.setValueAtTime(0.045, t + note.dur * 0.6);
                    env.gain.exponentialRampToValueAtTime(0.001, t + note.dur);

                    osc.start(t);
                    osc.stop(t + note.dur + 0.1);
                });
            }

            // Schedule first 4 loops
            let loopCount = 0;
            function scheduleLoops() {
                const now = ctx.currentTime;
                for (let i = 0; i < 4; i++) {
                    scheduleMelody(now + (loopCount + i) * melodyLoopLen);
                }
                loopCount += 4;
            }

            // LFO for strings gentle swell
            const lfo = ctx.createOscillator();
            lfo.type = 'sine';
            lfo.frequency.value = 0.08;
            const lfoGain = ctx.createGain();
            lfoGain.gain.value = 0.004;
            lfo.connect(lfoGain);
            lfoGain.connect(stringsFilter.frequency);

            let loopInterval = null;

            return {
                ctx, master,
                start() {
                    stringOscs.forEach(o => o.start());
                    lfo.start();
                    scheduleLoops();
                    // Re-schedule more loops before they run out
                    loopInterval = setInterval(() => scheduleLoops(), melodyLoopLen * 3 * 1000);
                },
                stop() {
                    clearInterval(loopInterval);
                    stringOscs.forEach(o => { try { o.stop(); } catch(e){} });
                    try { lfo.stop(); } catch(e){}
                    ctx.close();
                },
                setVolume(v) {
                    master.gain.value = v;
                }
            };
        }

        /* ─── Format time ─── */
        function fmt(s) {
            const m = Math.floor(s / 60);
            const sec = Math.floor(s % 60);
            return m + ':' + (sec < 10 ? '0' : '') + sec;
        }

        /* ─── Show a slide with crossfade ─── */
        let activeSlot = 'A'; // which slot is visible
        function showSlide(index, animate) {
            if (slides.length === 0) return;
            current = ((index % slides.length) + slides.length) % slides.length;
            const slide = slides[current];

            // Use blob URL (cached preloaded image) if available, fallback to original URL
            const imgSrc = blobUrls[current] || slide.image_url || '';

            const incoming = activeSlot === 'A' ? slideB : slideA;
            const outgoing = activeSlot === 'A' ? slideA : slideB;

            incoming.innerHTML = imgSrc
                ? '<img src="' + imgSrc + '" alt="' + (slide.titre||'').replace(/"/g,'') + '" style="width:100%;height:100%;object-fit:cover;">'
                : '';

            if (animate !== false) {
                incoming.style.opacity = '1';
                outgoing.style.opacity = '0';
            } else {
                incoming.style.transition = 'none';
                incoming.style.opacity = '1';
                outgoing.style.transition = 'none';
                outgoing.style.opacity = '0';
                // Re-enable transitions
                requestAnimationFrame(() => {
                    incoming.style.transition = 'opacity 1.5s ease';
                    outgoing.style.transition = 'opacity 1.5s ease';
                });
            }

            activeSlot = activeSlot === 'A' ? 'B' : 'A';

            // Update text overlay with fresh animation
            const overlayDiv = document.getElementById('videoOverlay');
            overlayDiv.style.animation = 'none';
            overlayDiv.offsetHeight; // trigger reflow
            overlayDiv.style.animation = '';
            emojiEl.textContent = slide.emoji || '';
            titleEl.textContent = 'Jour ' + (slide.jour||'') + ' — ' + (slide.titre||'');
            descEl.textContent = slide.description || '';

            slideElapsed = 0;
        }

        /* ─── Update progress ─── */
        function updateProgress() {
            const totalDuration = slides.length * SLIDE_DURATION;
            const currentTime = current * SLIDE_DURATION + slideElapsed;
            progressFill.style.width = (currentTime / totalDuration * 100) + '%';
            timeEl.textContent = fmt(currentTime);
            timeTotalEl.textContent = fmt(totalDuration);
        }

        /* ─── Play / Pause ─── */
        function play() {
            if (slides.length === 0) return;
            playing = true;
            playBtn.textContent = '⏸';

            // Start music
            if (!audioCtx) {
                audioNodes = createAmbientMusic();
                audioCtx = audioNodes.ctx;
                audioNodes.setVolume(volumeEl.value / 100 * 0.3);
                audioNodes.start();
            } else if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }

            clearInterval(timer);
            timer = setInterval(tick, 1000);
        }

        function pause() {
            playing = false;
            playBtn.textContent = '▶';
            clearInterval(timer);
        }

        function stop() {
            pause();
            elapsed = 0;
            slideElapsed = 0;
            current = 0;
            if (audioNodes) {
                audioNodes.stop();
                audioNodes = null;
                audioCtx = null;
            }
        }

        function tick() {
            slideElapsed++;
            elapsed++;
            updateProgress();

            if (slideElapsed >= SLIDE_DURATION) {
                if (current >= slides.length - 1) {
                    // End of video
                    pause();
                    return;
                }
                showSlide(current + 1, true);
            }
        }

        /* ─── Build the video from slide data ─── */
        function buildVideo(slidesData) {
            slides = slidesData;
            blobUrls = {};
            current = 0;
            elapsed = 0;
            slideElapsed = 0;

            // Show preloading progress
            const loadingDiv = document.getElementById('loadingMsg');
            const loadingP   = loadingDiv.querySelector('p');
            loadingDiv.style.display = 'block';
            let loaded = 0;
            const total = slides.length;

            function updateLoadTxt() {
                loadingP.innerHTML = '🖼️ Chargement des images IA : <strong>' + loaded + ' / ' + total + '</strong>...';
            }
            updateLoadTxt();

            // Fetch each image as blob to avoid re-generation on every showSlide()
            const promises = slides.map(function(slide, idx) {
                return new Promise(function(resolve) {
                    const src = slide.image_url || '';
                    if (!src) { loaded++; updateLoadTxt(); resolve(); return; }

                    fetch(src)
                        .then(function(r) {
                            if (!r.ok) throw new Error('HTTP ' + r.status);
                            return r.blob();
                        })
                        .then(function(blob) {
                            if (blob.size > 500) {
                                blobUrls[idx] = URL.createObjectURL(blob);
                            } else {
                                blobUrls[idx] = src; // use original if blob too small
                            }
                        })
                        .catch(function() {
                            blobUrls[idx] = src; // fallback to original URL
                        })
                        .finally(function() {
                            loaded++; updateLoadTxt(); resolve();
                        });
                });
            });

            Promise.all(promises).then(function() {
                loadingDiv.style.display = 'none';
                showSlide(0, false);
                updateProgress();
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
                play();
            });
        }

        /* ─── Close video ─── */
        function closeVideo() {
            stop();
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        /* ─── Error display ─── */
        function showError(msg) {
            const el = document.getElementById('errorMsg');
            el.textContent = msg;
            el.style.display = 'block';
        }

        /* ─── Event listeners ─── */
        playBtn.addEventListener('click', () => playing ? pause() : play());
        prevBtn.addEventListener('click', () => { showSlide(current - 1, true); slideElapsed = 0; updateProgress(); });
        nextBtn.addEventListener('click', () => { showSlide(current + 1, true); slideElapsed = 0; updateProgress(); });
        closeBtn.addEventListener('click', closeVideo);

        // Click overlay background to close
        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) closeVideo();
        });

        // ESC to close
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && overlay.classList.contains('active')) closeVideo();
            if (e.key === ' ' && overlay.classList.contains('active')) { e.preventDefault(); playing ? pause() : play(); }
            if (e.key === 'ArrowRight' && overlay.classList.contains('active')) { showSlide(current + 1, true); slideElapsed = 0; updateProgress(); }
            if (e.key === 'ArrowLeft' && overlay.classList.contains('active')) { showSlide(current - 1, true); slideElapsed = 0; updateProgress(); }
        });

        // Progress bar seeking
        progressBar.addEventListener('click', (e) => {
            const rect = progressBar.getBoundingClientRect();
            const pct = (e.clientX - rect.left) / rect.width;
            const totalDuration = slides.length * SLIDE_DURATION;
            const targetTime = pct * totalDuration;
            const targetSlide = Math.min(Math.floor(targetTime / SLIDE_DURATION), slides.length - 1);
            const targetSlideElapsed = targetTime - targetSlide * SLIDE_DURATION;

            current = targetSlide;
            slideElapsed = Math.floor(targetSlideElapsed);
            elapsed = Math.floor(targetTime);
            showSlide(current, true);
            updateProgress();
        });

        // Volume
        volumeEl.addEventListener('input', () => {
            const v = volumeEl.value / 100;
            if (audioNodes) audioNodes.setVolume(v * 0.3);
            muted = v === 0;
            muteBtn.textContent = muted ? '🔇' : '🔊';
        });

        muteBtn.addEventListener('click', () => {
            muted = !muted;
            if (muted) {
                volumeEl.value = 0;
                if (audioNodes) audioNodes.setVolume(0);
                muteBtn.textContent = '🔇';
            } else {
                volumeEl.value = 40;
                if (audioNodes) audioNodes.setVolume(0.12);
                muteBtn.textContent = '🔊';
            }
        });

        // Fullscreen
        fsBtn.addEventListener('click', () => {
            const vp = document.getElementById('videoPlayer');
            if (!document.fullscreenElement) {
                vp.requestFullscreen().catch(() => {});
            } else {
                document.exitFullscreen();
            }
        });

        /* ─── Trigger from card button ─── */
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('[data-video-generate]');
            if (!btn) return;
            e.preventDefault();
            e.stopPropagation();

            const itineraireId = btn.getAttribute('data-video-generate');

            // Reset
            document.getElementById('errorMsg').style.display = 'none';
            document.getElementById('loadingMsg').style.display = 'block';
            btn.disabled = true;

            fetch('/itineraires/' + itineraireId + '/generate-video', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(function (r) {
                    return r.json().then(function (data) {
                        return data;
                    }).catch(function () {
                        throw new Error('HTTP ' + r.status + ' — réponse non-JSON');
                    });
                })
                .then(function (data) {
                    document.getElementById('loadingMsg').style.display = 'none';

                    if (data.status === 'ok' && data.slides) {
                        buildVideo(data.slides);
                    } else {
                        showError(data.message || 'Erreur inconnue.');
                    }
                })
                .catch(function (err) {
                    document.getElementById('loadingMsg').style.display = 'none';
                    showError('Erreur de connexion : ' + err.message);
                })
                .finally(function () {
                    btn.disabled = false;
                });
        });
    })();
    </script>
