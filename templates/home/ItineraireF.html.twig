{% extends 'base.html.twig' %}

{% block title %}Mes Itinéraires | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .itineraires-page {
            display: grid;
            gap: 1.75rem;
        }

        .itineraires-hero {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.85fr);
            gap: 1.4rem;
            padding: 2rem;
            overflow: hidden;
            background:
                radial-gradient(circle at top left, rgba(221, 191, 140, 0.28), transparent 30%),
                linear-gradient(135deg, rgba(255, 253, 249, 0.98), rgba(243, 234, 223, 0.92));
            border: 1px solid rgba(231, 220, 205, 0.6);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71, 48, 35, 0.06);
        }

        .itineraires-hero__content {
            position: relative;
            z-index: 1;
            max-width: 760px;
        }

        .itineraires-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.8rem;
            color: var(--color-primary);
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .itineraires-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(2.2rem, 3vw, 3.5rem);
            line-height: 1.05;
            margin-bottom: 0.85rem;
            color: var(--color-text);
        }

        .itineraires-hero__stats {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 160px));
            gap: 0.8rem;
            margin-top: 1.5rem;
        }

        .itineraires-stat {
            padding: 0.85rem;
            border: 1px solid rgba(231, 220, 205, 0.85);
            border-radius: var(--radius-lg);
            background: rgba(255, 255, 255, 0.72);
        }

        .itineraires-stat strong {
            display: block;
            font-family: 'Fraunces', serif;
            font-size: 1.5rem;
            color: var(--color-text);
        }

        .itineraires-stat span {
            color: var(--color-text-muted);
            font-size: 0.8rem;
        }

        .itineraires-hero__visual {
            position: relative;
            min-height: 280px;
            border-radius: calc(var(--radius-xl) - 4px);
            overflow: hidden;
            background: linear-gradient(145deg, rgba(196, 111, 75, 0.18), rgba(47, 127, 121, 0.2));
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.3);
        }

        .itineraires-hero__visual::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(22, 18, 15, 0.04), rgba(22, 18, 15, 0.15));
            pointer-events: none;
        }

        .itineraires-hero__icon {
            font-size: 3.5rem;
            z-index: 1;
            opacity: 0.6;
        }

        .itineraires-hero__cta {
            z-index: 1;
        }

        .itineraires-toolbar {
            display: grid;
            gap: 1rem;
            padding: 1.35rem;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71, 48, 35, 0.06);
        }

        .culture-card {
            position: relative;
            display: grid;
            gap: 0;
            padding: 0;
            overflow: hidden;
            background:
                radial-gradient(circle at top right, rgba(212, 112, 81, 0.18), transparent 32%),
                radial-gradient(circle at bottom left, rgba(232, 190, 129, 0.2), transparent 28%),
                linear-gradient(135deg, rgba(255, 249, 242, 0.99), rgba(255, 239, 229, 0.97));
            border: 1px solid rgba(212, 112, 81, 0.18);
            border-radius: var(--radius-xl);
            box-shadow: 0 22px 42px rgba(94, 56, 41, 0.09);
        }

        .culture-card::before {
            content: '';
            position: absolute;
            inset: 0 0 auto 0;
            height: 4px;
            background: linear-gradient(90deg, rgba(212, 112, 81, 0.96), rgba(236, 176, 96, 0.92));
        }

        .culture-card__toggle {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1.15rem;
            align-items: start;
            width: 100%;
            padding: 1.55rem 1.7rem;
            background: transparent;
            border: none;
            text-align: left;
            cursor: pointer;
            transition: background var(--transition-fast);
        }

        .culture-card__toggle:hover,
        .culture-card__toggle:focus-visible {
            background: rgba(255, 255, 255, 0.18);
            outline: none;
        }

        .culture-card__intro {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
        }

        .culture-card__icon {
            flex: 0 0 58px;
            width: 58px;
            height: 58px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(212, 112, 81, 0.14), rgba(255, 255, 255, 0.96));
            border: 1px solid rgba(212, 112, 81, 0.18);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
            font-size: 1.6rem;
        }

        .culture-card__eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            margin-bottom: 0.45rem;
            color: #b55a37;
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .culture-card__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(1.45rem, 2vw, 1.8rem);
            color: var(--color-text);
            margin: 0 0 0.35rem;
        }

        .culture-card__summary {
            max-width: 64ch;
            color: #6d5545;
            line-height: 1.75;
            font-size: 0.98rem;
        }

        .culture-card__badge {
            display: inline-flex;
            align-items: center;
            align-self: start;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(212, 112, 81, 0.14);
            color: #b55a37;
            font-size: 0.82rem;
            font-weight: 700;
            white-space: nowrap;
            box-shadow: 0 10px 20px rgba(71, 48, 35, 0.05);
        }

        .culture-card__chevron {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 42px;
            height: 42px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(212, 112, 81, 0.16);
            color: #b55a37;
            font-size: 1.1rem;
            box-shadow: 0 10px 20px rgba(71, 48, 35, 0.05);
            transition: transform var(--transition-fast), background var(--transition-fast);
        }

        .culture-card.is-open .culture-card__chevron {
            transform: rotate(180deg);
            background: rgba(255, 255, 255, 0.98);
        }

        .culture-card__meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
            margin-top: 0.95rem;
        }

        .culture-card__chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.52rem 0.8rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.84);
            border: 1px solid rgba(229, 204, 184, 0.92);
            color: #7a5d49;
            font-size: 0.84rem;
            font-weight: 600;
        }

        .culture-card__chip strong {
            color: var(--color-text);
        }

        .culture-card__grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(245px, 1fr));
            gap: 1.05rem;
        }

        .culture-card__content {
            display: none;
            padding: 0 1.7rem 1.7rem;
            border-top: 1px solid rgba(212, 112, 81, 0.12);
        }

        .culture-card.is-open .culture-card__content {
            display: block;
        }

        .culture-rule {
            position: relative;
            display: grid;
            gap: 0.65rem;
            padding: 1.05rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 246, 239, 0.94));
            border: 1px solid rgba(235, 208, 186, 0.9);
            border-radius: 20px;
            box-shadow: 0 16px 26px rgba(71, 48, 35, 0.05);
        }

        .culture-rule::before {
            content: '';
            position: absolute;
            inset: 0 auto 0 0;
            width: 4px;
            border-radius: 20px 0 0 20px;
            background: linear-gradient(180deg, rgba(212, 112, 81, 0.92), rgba(236, 176, 96, 0.78));
        }

        .culture-rule__top {
            display: flex;
            align-items: center;
            gap: 0.7rem;
        }

        .culture-rule__index {
            width: 30px;
            height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(212, 112, 81, 0.12);
            color: #b55a37;
            font-size: 0.85rem;
            font-weight: 800;
        }

        .culture-rule__title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--color-text);
        }

        .culture-rule__advice {
            color: var(--color-text);
            line-height: 1.65;
        }

        .culture-rule__why {
            color: var(--color-text-muted);
            line-height: 1.6;
            font-size: 0.92rem;
        }

        .culture-card--inactive {
            background: rgba(255, 253, 249, 0.94);
            border-color: rgba(229, 204, 184, 0.78);
        }

        .culture-card--inactive::before {
            background: linear-gradient(90deg, rgba(212, 112, 81, 0.8), rgba(236, 176, 96, 0.9));
        }

        .itineraires-toolbar__title {
            font-family: 'Fraunces', serif;
            font-size: 1.35rem;
            color: var(--color-text);
        }

        .itineraires-toolbar__hint {
            color: var(--color-text-muted);
            font-size: 0.9rem;
            margin-top: -0.35rem;
        }

        .filter-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            align-items: end;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .filter-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .filter-group select,
        .filter-group input {
            padding: 0.65rem 0.85rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            color: var(--color-text);
            font-size: 0.95rem;
            transition: all var(--transition-fast);
        }

        .filter-group select:focus,
        .filter-group input:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196, 111, 75, 0.1);
        }

        .filter-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .btn-filter-apply {
            padding: 0.65rem 1.25rem;
            background: var(--color-primary);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .btn-filter-apply:hover {
            background: var(--color-primary-dark);
            transform: translateY(-2px);
        }

        .btn-reset {
            padding: 0.65rem 1rem;
            background: transparent;
            color: var(--color-text-muted);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: all var(--transition-fast);
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            text-decoration: none;
        }

        .btn-reset:hover {
            background: var(--color-hover);
            color: var(--color-primary);
        }

        .itineraires-list {
            display: grid;
            gap: 1rem;
        }

        .itineraires-results {
            transition: opacity var(--transition-fast);
        }

        .itineraires-results.is-loading {
            opacity: 0.55;
            pointer-events: none;
        }

        .itineraire-card {
            position: relative;
            padding: 1.5rem;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 2px 8px rgba(71, 48, 35, 0.04);
            transition: all var(--transition-base);
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1.5rem;
            align-items: start;
            cursor: pointer;
            overflow: hidden;
        }

        .itineraire-card:hover {
            border-color: rgba(196, 111, 75, 0.34);
            box-shadow: 0 18px 30px rgba(71, 48, 35, 0.08);
            transform: translateY(-3px);
        }

        .itineraire-card:focus-visible {
            outline: 3px solid rgba(196, 111, 75, 0.28);
            outline-offset: 3px;
        }

        .itineraire-card__body,
        .itineraire-card__actions {
            position: relative;
            z-index: 2;
        }

        .itineraire-card__body {
            display: grid;
            gap: 1rem;
        }

        .itineraire-card__header {
            display: grid;
            gap: 0.35rem;
        }

        .itineraire-card__title-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .itineraire-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--color-text);
            margin: 0;
        }

        .itineraire-card__hint {
            display: inline-flex;
            align-items: center;
            padding: 0.35rem 0.7rem;
            border-radius: 999px;
            background: rgba(47, 127, 121, 0.12);
            color: var(--color-secondary);
            font-size: 0.76rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .itineraire-card__location {
            color: var(--color-primary);
            font-size: 0.92rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .itineraire-card__description {
            color: var(--color-text-muted);
            font-size: 0.98rem;
            line-height: 1.6;
            max-width: 75ch;
        }

        .itineraire-card__footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .itineraire-card__meta {
            display: flex;
            gap: 0.7rem;
            flex-wrap: wrap;
        }

        .itineraire-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.55rem 0.85rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.78);
            border: 1px solid rgba(231, 220, 205, 0.95);
            color: var(--color-text-muted);
            font-size: 0.85rem;
        }

        .itineraire-chip strong {
            color: var(--color-text);
            font-weight: 700;
        }

        .itineraire-chip--accent {
            background: rgba(196, 111, 75, 0.12);
            color: var(--color-primary-dark);
            border-color: rgba(196, 111, 75, 0.18);
        }

        .itineraire-card__open {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            color: var(--color-secondary);
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .itineraire-card:hover .itineraire-card__open {
            color: var(--color-primary);
        }

        .itineraire-card__actions {
            display: flex;
            gap: 0.6rem;
            flex-direction: column;
            align-items: flex-end;
            justify-content: flex-start;
        }

        .action-btn {
            width: 40px;
            height: 40px;
            border: none;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all var(--transition-fast);
            font-size: 1.1rem;
            background: var(--color-surface-soft);
            color: var(--color-text-muted);
            border: 1px solid var(--color-border);
        }

        .action-btn:hover {
            background: var(--color-primary);
            color: white;
            border-color: var(--color-primary);
            transform: scale(1.05);
        }

        .action-btn.danger:hover {
            background: #e74c3c;
            border-color: #e74c3c;
        }

        .itineraires-empty {
            padding: 3rem;
            text-align: center;
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 2px 8px rgba(71, 48, 35, 0.04);
        }

        .itineraires-empty__icon {
            font-size: 3.5rem;
            margin-bottom: 1rem;
            opacity: 0.4;
        }

        .itineraires-empty__title {
            font-family: 'Fraunces', serif;
            font-size: 1.5rem;
            color: var(--color-text);
            margin-bottom: 0.5rem;
        }

        .itineraires-empty__text {
            color: var(--color-text-muted);
            max-width: 40ch;
            margin: 0 auto 1.5rem;
        }

        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-md);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-success {
            background: rgba(39, 174, 96, 0.1);
            border: 1px solid rgba(39, 174, 96, 0.3);
            color: #27ae60;
        }

        .alert-error {
            background: rgba(231, 76, 60, 0.1);
            border: 1px solid rgba(231, 76, 60, 0.3);
            color: #e74c3c;
        }

        @media (max-width: 1200px) {
            .itineraires-hero {
                grid-template-columns: 1fr;
            }

            .itineraire-card {
                grid-template-columns: 1fr;
            }

            .itineraire-card__actions {
                flex-direction: row;
                justify-content: flex-start;
            }
        }

        @media (max-width: 768px) {
            .itineraires-hero {
                padding: 1.5rem;
            }

            .culture-card {
                padding: 0;
            }

            .culture-card__toggle {
                grid-template-columns: 1fr;
                padding: 1.2rem;
            }

            .culture-card__intro {
                flex-direction: column;
            }

            .culture-card__content {
                padding: 0 1.2rem 1.2rem;
            }

            .itineraires-hero__title {
                font-size: 1.8rem;
            }

            .itineraires-hero__stats {
                grid-template-columns: 1fr;
            }

            .filter-row {
                grid-template-columns: 1fr;
            }

            .itineraire-card {
                padding: 1.2rem;
            }

            .itineraire-card__footer {
                align-items: flex-start;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="itineraires-page">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">
                <span>!</span>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <section class="itineraires-hero">
            <div class="itineraires-hero__content">
                <div class="itineraires-hero__eyebrow">
                    📍 Itinéraires du voyage
                </div>
                <h1 class="itineraires-hero__title">
                    {{ voyageSelectionne.titre_voyage }}
                </h1>
                {% if voyageSelectionne.date_debut and voyageSelectionne.date_fin %}
                    <p style="color: var(--color-text-muted); margin-bottom: 1rem;">
                        {{ voyageSelectionne.date_debut|date('d/m/Y') }} - {{ voyageSelectionne.date_fin|date('d/m/Y') }}
                    </p>
                {% endif %}
                <div class="itineraires-hero__stats">
                    <div class="itineraires-stat">
                        <strong>{{ totalItineraires }}</strong>
                        <span>Itinéraires</span>
                    </div>
                    <div class="itineraires-stat">
                        <strong>{{ totalJours }}</strong>
                        <span>Jours d'aventure</span>
                    </div>
                </div>
            </div>
            <div class="itineraires-hero__visual">
                <div class="itineraires-hero__icon">🗺️</div>
                <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; z-index: 1; justify-content: center;">
                    <a href="{{ path('app_itineraires_create', {voyageId: voyageId}) }}" class="btn btn--primary itineraires-hero__cta">
                        + Créer
                    </a>
                    <a href="{{ path('app_itineraires_export_pdf', {voyageId: voyageId}) }}" class="btn btn--secondary itineraires-hero__cta">
                        📄 PDF
                    </a>
                    <a href="{{ path('app_flights', {voyageId: voyageId}) }}" class="btn btn--primary itineraires-hero__cta" style="background: var(--color-secondary);">
                        ✈️ Vols
                    </a>
                    <a href="{{ path('app_voyages') }}" class="btn btn--secondary itineraires-hero__cta">
                        ← Mes voyages
                    </a>
                </div>
            </div>
        </section>

        {% if culturalRules is not null %}
            <section class="culture-card {% if culturalRules.status != 'ready' %}culture-card--inactive{% endif %}" aria-label="Conseils culturels pour la destination du voyage" data-culture-card>
                <button type="button" class="culture-card__toggle" data-culture-toggle aria-expanded="false" aria-controls="culture-card-content">
                    <div class="culture-card__intro">
                        <div class="culture-card__icon" aria-hidden="true">🧭</div>
                        <div>
                            <div class="culture-card__eyebrow">Conseils culturels IA</div>
                            <h2 class="culture-card__title">{{ culturalRules.title }}</h2>
                            <p class="culture-card__summary">{{ culturalRules.summary }}</p>

                            <div class="culture-card__meta">
                                {% if voyageSelectionne.destination %}
                                    <span class="culture-card__chip">
                                        📍
                                        <strong>{{ voyageSelectionne.destination.nom_destination }}</strong>
                                    </span>
                                {% endif %}
                                {% if culturalRules.status == 'ready' %}
                                    <span class="culture-card__chip">
                                        ✨
                                        <strong>{{ culturalRules.rules|length }}</strong>
                                        repères utiles
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; justify-content: flex-end;">
                        <span class="culture-card__badge" data-culture-toggle-label>Afficher les conseils</span>
                        <span class="culture-card__chevron" aria-hidden="true">⌃</span>
                    </div>
                </button>

                <div class="culture-card__content" id="culture-card-content" data-culture-content>
                    {% if culturalRules.status == 'ready' and culturalRules.rules|length > 0 %}
                        <div class="culture-card__grid">
