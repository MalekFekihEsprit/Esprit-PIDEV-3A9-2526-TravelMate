{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        .voyage-form-page {
            display: grid;
            gap: 1.5rem;
        }

        .voyage-form-hero,
        .voyage-form-card,
        .voyage-form-flash {
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71, 48, 35, 0.06);
        }

        .voyage-form-hero,
        .voyage-form-card {
            padding: 1.8rem;
        }

        .voyage-form-hero__eyebrow {
            display: inline-block;
            margin-bottom: 0.75rem;
            color: var(--color-primary);
            font-size: 0.84rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .voyage-form-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(2rem, 2.4vw, 2.8rem);
            margin-bottom: 0.7rem;
        }

        .voyage-form-hero__text {
            color: var(--color-text-muted);
            max-width: 60ch;
        }

        .voyage-form-card__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .voyage-form-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.6rem;
        }

        .voyage-form-card__text {
            color: var(--color-text-muted);
            margin-top: 0.35rem;
        }

        .voyage-form {
            display: grid;
            gap: 1.2rem;
        }

        .voyage-form__grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
        }

        .voyage-form__field {
            display: grid;
            gap: 0.45rem;
        }

        .voyage-form__field--full {
            grid-column: 1 / -1;
        }

        .voyage-form__label {
            font-size: 0.95rem;
            font-weight: 600;
        }

        .travel-form__input {
            width: 100%;
            padding: 0.9rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            color: var(--color-text);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }

        .travel-form__input:focus {
            outline: none;
            border-color: rgba(196, 111, 75, 0.65);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.12);
        }

        .travel-form__input--multiple {
            min-height: 12rem;
            padding-block: 0.55rem;
        }

        .travel-form__input--multiple option {
            padding: 0.45rem 0.35rem;
        }

        .voyage-activity-picker {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.9rem;
        }

        .voyage-activity-option {
            position: relative;
            display: flex;
            align-items: flex-start;
            gap: 0.8rem;
            padding: 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            background: rgba(255, 253, 249, 0.92);
            transition:
                border-color var(--transition-fast),
                background var(--transition-fast),
                transform var(--transition-fast),
                box-shadow var(--transition-fast);
            cursor: pointer;
        }

        .voyage-activity-option:hover {
            transform: translateY(-1px);
            border-color: rgba(196, 111, 75, 0.3);
            box-shadow: 0 12px 24px rgba(71, 48, 35, 0.06);
        }

        .voyage-activity-option.is-hidden {
            display: none;
        }

        .voyage-activity-option__input {
            width: 1.05rem;
            height: 1.05rem;
            margin-top: 0.18rem;
            accent-color: var(--color-primary);
            flex-shrink: 0;
        }

        .voyage-activity-option__body {
            display: grid;
            gap: 0.28rem;
        }

        .voyage-activity-option__title {
            font-weight: 600;
            color: var(--color-text);
        }

        .voyage-activity-option__meta {
            color: var(--color-text-muted);
            font-size: 0.88rem;
        }

        .voyage-activity-empty {
            padding: 1rem;
            border: 1px dashed rgba(196, 111, 75, 0.28);
            border-radius: var(--radius-lg);
            color: var(--color-text-muted);
            background: rgba(255, 253, 249, 0.72);
        }

        .voyage-form__errors {
            color: var(--color-primary-dark);
            font-size: 0.86rem;
        }

        .voyage-form__errors ul {
            list-style: none;
        }

        .voyage-form__actions {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
            justify-content: flex-end;
            padding-top: 0.5rem;
        }

        .voyage-form__actions .btn[disabled] {
            opacity: 0.72;
            cursor: wait;
            pointer-events: none;
        }

        .voyage-form-flash {
            padding: 1rem 1.2rem;
            border-left: 4px solid var(--color-primary);
        }

        @media (max-width: 820px) {
            .voyage-form-card__header {
                flex-direction: column;
                align-items: flex-start;
            }

            .voyage-form__grid {
                grid-template-columns: 1fr;
            }

            .voyage-activity-picker {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="voyage-form-page">
        <div class="voyage-form-hero">
            <span class="voyage-form-hero__eyebrow">Formulaire voyage</span>
            <h1 class="voyage-form-hero__title">{{ page_title }}</h1>
        </div>

        {% for message in app.flashes('warning') %}
            <div class="voyage-form-flash">{{ message }}</div>
        {% endfor %}

        {% if not has_destinations %}
            <div class="voyage-form-flash">
                Aucune destination n'est disponible pour le moment. Ajoutez d'abord une destination pour pouvoir enregistrer un voyage.
            </div>
        {% endif %}

        {% if not has_activites %}
            <div class="voyage-form-flash">
                Aucune activite n'est disponible pour le moment. Ajoutez d'abord des activites pour pouvoir les associer au voyage.
            </div>
        {% endif %}

        <div class="voyage-form-card">
            <div class="voyage-form-card__header">
                <div>
                    <h2 class="voyage-form-card__title">Informations du voyage</h2>
                </div>

                <a href="{{ path('app_voyages') }}" class="btn btn--ghost">Retour a la liste</a>
            </div>

            {{ form_start(form, {'attr': {'class': 'voyage-form'}}) }}
                <input type="hidden" name="_voyage_form_nonce" value="{{ form_nonce }}">
                <div class="voyage-form__errors">{{ form_errors(form) }}</div>

                <div class="voyage-form__grid">
                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.titre_voyage.vars.id }}">{{ form.titre_voyage.vars.label }}</label>
                        {{ form_widget(form.titre_voyage) }}
                        <div class="voyage-form__errors">{{ form_errors(form.titre_voyage) }}</div>
                    </div>

                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.destination.vars.id }}">{{ form.destination.vars.label }}</label>
                        {{ form_widget(form.destination) }}
                        <div class="voyage-form__errors">{{ form_errors(form.destination) }}</div>
                    </div>

                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.activites.vars.id }}">{{ form.activites.vars.label }}</label>
                        <div class="voyage-activity-picker" data-activity-picker>
                            {% for activityField in form.activites %}
                                {% set activityLieu = activityField.vars.attr['data-activity-lieu'] ?? '' %}
                                {% set activityDuree = activityField.vars.attr['data-activity-duree'] ?? '' %}
                                {% set activityHaystack = activityField.vars.attr['data-activity-haystack'] ?? '' %}

                                <label class="voyage-activity-option" data-activity-option data-activity-haystack="{{ activityHaystack }}">
                                    {{ form_widget(activityField) }}
                                    <span class="voyage-activity-option__body">
                                        <span class="voyage-activity-option__title">{{ activityField.vars.label }}</span>
                                        <span class="voyage-activity-option__meta">
                                            {% if activityLieu %}
                                                {{ activityLieu }}
                                            {% else %}
                                                Lieu non precise
                                            {% endif %}

                                            {% if activityDuree %}
                                                • {{ activityDuree }} h
                                            {% endif %}
                                        </span>
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                        <div class="voyage-activity-empty" data-activity-empty>
                            Selectionnez une destination pour afficher uniquement les activites correspondantes.
                        </div>
                        <div class="voyage-form__errors">{{ form_errors(form.activites) }}</div>
                    </div>

                    <div class="voyage-form__field">
                        <label class="voyage-form__label" for="{{ form.date_debut.vars.id }}">{{ form.date_debut.vars.label }}</label>
                        {{ form_widget(form.date_debut) }}
                        <div class="voyage-form__errors">{{ form_errors(form.date_debut) }}</div>
                    </div>

                    <div class="voyage-form__field">
                        <label class="voyage-form__label" for="{{ form.date_fin.vars.id }}">{{ form.date_fin.vars.label }}</label>
                        {{ form_widget(form.date_fin) }}
                        <div class="voyage-form__errors">{{ form_errors(form.date_fin) }}</div>
                    </div>

                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.statut.vars.id }}">{{ form.statut.vars.label }}</label>
                        {{ form_widget(form.statut) }}
                        <div class="voyage-form__errors">{{ form_errors(form.statut) }}</div>
                    </div>
                </div>

                <div class="voyage-form__actions">
                    <a href="{{ path('app_voyages') }}" class="btn btn--ghost">Annuler</a>
                    <button type="submit" class="btn btn--primary">{{ submit_label }}</button>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var voyageForm = document.querySelector('.voyage-form');
            var submitButton = voyageForm ? voyageForm.querySelector('button[type="submit"]') : null;
            var destinationField = document.getElementById('{{ form.destination.vars.id }}');
            var activityOptions = document.querySelectorAll('[data-activity-option]');
            var activityEmpty = document.querySelector('[data-activity-empty]');

            if (voyageForm && submitButton) {
                var initialSubmitLabel = submitButton.textContent;

                voyageForm.addEventListener('submit', function (event) {
                    if (voyageForm.dataset.submitting === 'true') {
                        event.preventDefault();
                        return;
                    }

                    voyageForm.dataset.submitting = 'true';
                    submitButton.disabled = true;
                    submitButton.textContent = 'Enregistrement...';
                });

                window.addEventListener('pageshow', function () {
                    voyageForm.dataset.submitting = 'false';
                    submitButton.disabled = false;
                    submitButton.textContent = initialSubmitLabel;
                });
            }

            function normalize(value) {
                return (value || '')
                    .toString()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .toLowerCase()
                    .trim();
            }

            function tokenize(values) {
                return values
                    .flatMap(function (value) {
                        return normalize(value).split(/[^a-z0-9]+/);
                    })
                    .filter(function (token, index, tokens) {
                        return token.length >= 4 && tokens.indexOf(token) === index;
                    });
            }

            function getDestinationTerms() {
                var selectedOption = destinationField.options[destinationField.selectedIndex];

                if (!selectedOption || !selectedOption.value) {
                    return [];
                }

                return [
                    selectedOption.dataset.destinationName,
                    selectedOption.dataset.destinationCountry,
                    selectedOption.dataset.destinationRegion,
                    selectedOption.dataset.destinationAliases,
                ]
                    .flatMap(function (value) {
                        return (value || '').split('|');
                    })
                    .map(normalize)
                    .filter(function (term) {
                        return term.length > 0;
                    });
            }

            // Datepickers (flatpickr)
            (function () {
                var script = document.createElement('script');
                script.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
                script.async = true;
                script.onload = function () {
                    var startInput = document.getElementById('{{ form.date_debut.vars.id }}');
                    var endInput = document.getElementById('{{ form.date_fin.vars.id }}');

                    if (startInput) {
                        var startPicker = flatpickr(startInput, {
                            dateFormat: 'Y-m-d',
                            altInput: true,
                            altFormat: 'd/m/Y',
                            allowInput: true,
                            onChange: function (selectedDates) {
                                if (selectedDates && selectedDates[0] && endPicker) {
                                    endPicker.set('minDate', selectedDates[0]);
                                }
                            }
                        });
                    }

                    var endPicker = null;
                    if (endInput) {
                        endPicker = flatpickr(endInput, {
                            dateFormat: 'Y-m-d',
                            altInput: true,
                            altFormat: 'd/m/Y',
                            allowInput: true,
                        });
                    }
                };
                document.head.appendChild(script);
            }());

            function applyActivityVisibility(option, shouldShow) {
                var input = option.querySelector('input');

                option.classList.toggle('is-hidden', !shouldShow);

                if (!input) {
                    return;
                }

                input.disabled = !shouldShow;

                if (!shouldShow) {
                    input.checked = false;
                }
            }

            function syncActivities() {
                if (!destinationField || activityOptions.length === 0) {
                    return;
                }

                var destinationTerms = getDestinationTerms();
                var destinationTokens = tokenize(destinationTerms);
                var strictMatchCount = 0;

                activityOptions.forEach(function (option) {
                    var haystack = normalize(option.dataset.activityHaystack);
                    var matches = destinationTerms.length > 0 && (
                        destinationTerms.some(function (term) {
                            return haystack.includes(term);
                        }) || destinationTokens.some(function (token) {
                            return haystack.includes(token);
                        })
                    );

                    if (matches) {
                        strictMatchCount += 1;
                    }

                    option.dataset.strictMatch = matches ? 'true' : 'false';
                });

                activityOptions.forEach(function (option) {
                    var shouldShow = destinationTerms.length > 0 && option.dataset.strictMatch === 'true';

                    applyActivityVisibility(option, shouldShow);
                });

                if (activityEmpty) {
                    if (destinationTerms.length === 0) {
                        activityEmpty.textContent = 'Selectionnez une destination pour afficher uniquement les activites correspondantes.';
                        activityEmpty.hidden = false;
                    } else if (strictMatchCount === 0) {
                        activityEmpty.textContent = 'Aucune activite ne correspond a la destination choisie.';
                        activityEmpty.hidden = false;
                    } else {
                        activityEmpty.hidden = true;
                    }
                }
            }

            if (destinationField && activityOptions.length > 0) {
                destinationField.addEventListener('change', syncActivities);
                syncActivities();
            }
        });
    </script>
{% endblock %}