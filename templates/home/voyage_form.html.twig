{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .voyage-form-page {
            display: grid;
            gap: 1.5rem;
        }

        .voyage-form-hero,
        .voyage-form-card,
        .voyage-form-flash {
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71, 48, 35, 0.06);
        }

        .voyage-form-hero,
        .voyage-form-card {
            padding: 1.8rem;
        }

        .voyage-form-hero__eyebrow {
            display: inline-block;
            margin-bottom: 0.75rem;
            color: var(--color-primary);
            font-size: 0.84rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .voyage-form-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(2rem, 2.4vw, 2.8rem);
            margin-bottom: 0.7rem;
        }

        .voyage-form-hero__text {
            color: var(--color-text-muted);
            max-width: 60ch;
        }

        .voyage-form-card__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .voyage-form-card__title {
            font-family: 'Fraunces', serif;
            font-size: 1.6rem;
        }

        .voyage-form-card__text {
            color: var(--color-text-muted);
            margin-top: 0.35rem;
        }

        .voyage-form {
            display: grid;
            gap: 1.2rem;
        }

        .voyage-form__grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
        }

        .voyage-form__field {
            display: grid;
            gap: 0.45rem;
        }

        .voyage-form__field--full {
            grid-column: 1 / -1;
        }

        .voyage-form__label {
            font-size: 0.95rem;
            font-weight: 600;
        }

        .travel-form__input {
            width: 100%;
            padding: 0.9rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            color: var(--color-text);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }

        .travel-form__input:focus {
            outline: none;
            border-color: rgba(196, 111, 75, 0.65);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.12);
        }

        .voyage-form__errors {
            color: var(--color-primary-dark);
            font-size: 0.86rem;
        }

        .voyage-form__errors ul {
            list-style: none;
        }

        .voyage-form__actions {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
            justify-content: flex-end;
            padding-top: 0.5rem;
        }

        .voyage-form-flash {
            padding: 1rem 1.2rem;
            border-left: 4px solid var(--color-primary);
        }

        @media (max-width: 820px) {
            .voyage-form-card__header {
                flex-direction: column;
                align-items: flex-start;
            }

            .voyage-form__grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="voyage-form-page">
        <div class="voyage-form-hero">
            <span class="voyage-form-hero__eyebrow">Formulaire voyage</span>
            <h1 class="voyage-form-hero__title">{{ page_title }}</h1>
        </div>

        {% for message in app.flashes('warning') %}
            <div class="voyage-form-flash">{{ message }}</div>
        {% endfor %}

        {% if not has_destinations %}
            <div class="voyage-form-flash">
                Aucune destination n'est disponible pour le moment. Ajoutez d'abord une destination pour pouvoir enregistrer un voyage.
            </div>
        {% endif %}

        <div class="voyage-form-card">
            <div class="voyage-form-card__header">
                <div>
                    <h2 class="voyage-form-card__title">Informations du voyage</h2>
                </div>

                <a href="{{ path('app_voyages') }}" class="btn btn--ghost">Retour a la liste</a>
            </div>

            {{ form_start(form, {'attr': {'class': 'voyage-form'}}) }}
                <div class="voyage-form__errors">{{ form_errors(form) }}</div>

                <div class="voyage-form__grid">
                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.titre_voyage.vars.id }}">{{ form.titre_voyage.vars.label }}</label>
                        {{ form_widget(form.titre_voyage) }}
                        <div class="voyage-form__errors">{{ form_errors(form.titre_voyage) }}</div>
                    </div>

                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.destination.vars.id }}">{{ form.destination.vars.label }}</label>
                        {{ form_widget(form.destination) }}
                        <div class="voyage-form__errors">{{ form_errors(form.destination) }}</div>
                    </div>

                    <div class="voyage-form__field">
                        <label class="voyage-form__label" for="{{ form.date_debut.vars.id }}">{{ form.date_debut.vars.label }}</label>
                        {{ form_widget(form.date_debut) }}
                        <div class="voyage-form__errors">{{ form_errors(form.date_debut) }}</div>
                    </div>

                    <div class="voyage-form__field">
                        <label class="voyage-form__label" for="{{ form.date_fin.vars.id }}">{{ form.date_fin.vars.label }}</label>
                        {{ form_widget(form.date_fin) }}
                        <div class="voyage-form__errors">{{ form_errors(form.date_fin) }}</div>
                    </div>

                    <div class="voyage-form__field voyage-form__field--full">
                        <label class="voyage-form__label" for="{{ form.statut.vars.id }}">{{ form.statut.vars.label }}</label>
                        {{ form_widget(form.statut) }}
                        <div class="voyage-form__errors">{{ form_errors(form.statut) }}</div>
                    </div>
                </div>

                <div class="voyage-form__actions">
                    <a href="{{ path('app_voyages') }}" class="btn btn--ghost">Annuler</a>
                    <button type="submit" class="btn btn--primary">{{ submit_label }}</button>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}