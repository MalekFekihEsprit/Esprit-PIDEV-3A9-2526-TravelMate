{% extends 'base.html.twig' %}

{% block title %}{{ hebergement.nomHebergement }} | TravelMate{% endblock %}

{% block body %}
<section class="destination-detail">
    <div class="destination-detail__header">
        <div class="destination-detail__flag-rating">
            <div style="font-size: 5rem;">🏨</div>
        </div>
        <h1>{{ hebergement.nomHebergement }}</h1>
        <p style="color: rgba(255, 255, 255, 0.85); font-size: 1.1rem;">
            {% if hebergement.destination %}
                {{ hebergement.destination.nomDestination }}
            {% endif %}
        </p>
    </div>

    <div class="destination-detail__grid">
        <div>
            <h3>📍 Localisation</h3>
            <p><strong>Adresse:</strong> {{ hebergement.adresseHebergement ?? 'Non disponible' }}</p>
            {% if hebergement.destination %}
                <p><strong>Destination:</strong> {{ hebergement.destination.nomDestination }}</p>
                <p><strong>Pays:</strong> {{ hebergement.destination.paysDestination }}</p>
            {% endif %}
        </div>

        <div>
            <h3>🏠 Détails de l'hébergement</h3>
            {% if hebergement.typeHebergement %}
                <p><strong>Type:</strong> {{ hebergement.typeHebergement }}</p>
            {% endif %}
            {% if hebergement.prixNuitHebergement %}
                <p><strong>Prix par nuit:</strong> {{ hebergement.prixNuitHebergement }} €</p>
            {% endif %}
            {% if hebergement.noteHebergement %}
                <p><strong>Note:</strong> <span style="color: #ffb800;">⭐ {{ hebergement.noteHebergement }}/5</span></p>
            {% endif %}
        </div>
    </div>

    <div class="destination-detail__actions">
        <a href="{{ path('app_hebergement_index') }}" class="btn-secondary">← Retour</a>
    </div>
</section>

<style>
.destination-detail {
    max-width: 900px;
    margin: 0 auto;
}

.destination-detail__header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 3.5rem 2.5rem;
    background: var(--color-primary);
    border-radius: 20px;
    color: white;
    box-shadow: 0 20px 60px rgba(196, 111, 75, 0.25);
    position: relative;
    overflow: hidden;
}

.destination-detail__header h1 {
    font-size: 3.2rem;
    margin: 1.5rem 0 0.8rem 0;
    font-weight: 900;
    letter-spacing: -1.5px;
    color: white;
    position: relative;
    z-index: 1;
}

.destination-detail__flag-rating {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
}

.destination-detail__flag-image {
    width: 120px;
    height: 120px;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(196, 111, 75, 0.35);
    object-fit: cover;
    border: 4px solid white;
}

.destination-detail__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
    margin-bottom: 3rem;
}

.destination-detail__grid > div {
    background: white;
    padding: 2.5rem;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-left: 5px solid var(--color-primary);
    transition: all var(--transition-base);
}

.destination-detail__grid > div:hover {
    box-shadow: 0 12px 40px rgba(196, 111, 75, 0.15);
    transform: translateY(-2px);
}

.destination-detail__grid h3 {
    color: var(--color-primary);
    margin-bottom: 1.4rem;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.3px;
}

.destination-detail__grid p {
    margin-bottom: 1rem;
    line-height: 1.9;
    color: var(--color-text);
    font-size: 0.95rem;
}

.destination-detail__grid strong {
    color: var(--color-primary);
    font-weight: 700;
}

.destination-detail__actions {
    display: flex;
    gap: 1.2rem;
    padding-top: 2.5rem;
    border-top: 2px solid var(--color-border);
    align-items: center;
}

.destination-detail__actions a,
.destination-detail__actions button {
    flex: 1;
    text-align: center;
    padding: 1rem 1.8rem;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all var(--transition-base);
    font-size: 0.95rem;
    text-decoration: none;
    display: block;
    letter-spacing: 0.3px;
}

.destination-detail__actions form {
    flex: 1;
}

.destination-detail__actions form button {
    width: 100%;
}

.destination-detail__actions .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 6px 20px rgba(196, 111, 75, 0.25);
}

.destination-detail__actions .btn-primary:hover {
    background: var(--color-primary-dark, #a85a3a);
    box-shadow: 0 10px 30px rgba(196, 111, 75, 0.4);
    transform: translateY(-2px);
}

.destination-detail__actions .btn-secondary {
    background: white;
    color: var(--color-primary);
    border: 2.5px solid var(--color-primary);
    font-weight: 700;
}

.destination-detail__actions .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(196, 111, 75, 0.25);
}

@media (max-width: 768px) {
    .destination-detail {
        margin: 0;
    }

    .destination-detail__header {
        padding: 2.5rem 2rem;
    }

    .destination-detail__header h1 {
        font-size: 2.2rem;
    }

    .destination-detail__grid {
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .destination-detail__actions {
        flex-direction: column;
        gap: 1rem;
    }

    .destination-detail__flag-image {
        width: 100px;
        height: 100px;
    }
}

@media (max-width: 480px) {
    .destination-detail__header {
        padding: 2rem 1.5rem;
    }

    .destination-detail__header h1 {
        font-size: 1.8rem;
    }

    .destination-detail__grid > div {
        padding: 1.5rem;
    }

    .destination-detail__actions a,
    .destination-detail__actions button {
        padding: 0.9rem 1.5rem;
        font-size: 0.85rem;
    }
}
</style>
{% endblock %}
