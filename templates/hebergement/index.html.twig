{% extends 'base.html.twig' %}

{% block title %}Hébergements | TravelMate{% endblock %}

{% block body %}
<section class="destinations-page">
    <div class="destinations-hero">
        <div class="destinations-hero__content">
            <span class="destinations-hero__eyebrow">HÉBERGEMENTS</span>
            <h1 class="destinations-hero__title">Découvrez nos meilleures adresses</h1>
            <p class="destinations-hero__text">
                Explorez une sélection de logements soigneusement sélectionnés. Du luxe à l'économie, trouvez l'hébergement parfait pour votre prochain séjour.
            </p>

            <div class="destinations-hero__stats">
                <div class="destinations-stat">
                    <strong>{{ hebergements|length }}</strong>
                    <span>hébergements</span>
                </div>
                <div class="destinations-stat">
                    <strong>{{ unique_types }}</strong>
                    <span>types</span>
                </div>
                <div class="destinations-stat">
                    <strong>{{ unique_destinations }}</strong>
                    <span>destinations</span>
                </div>
            </div>

            {% if selected_destination %}
                <div class="toolbar-count" style="margin-top: 1rem; display: inline-flex;">
                    Filtre actif : {{ selected_destination.nomDestination }}
                    {% if selected_destination.paysDestination %} - {{ selected_destination.paysDestination }}{% endif %}
                </div>
            {% endif %}
        </div>
        <div class="destinations-hero__visual">
            <img src="{{ asset('images/destination.jpg') }}" alt="Accommodations" style="width: 100%; height: 100%; object-fit: cover; border-radius: 16px;">
        </div>
    </div>

    {# ── Flash messages ──────────────────────────────────────────────────────── #}
    {% set successFlashes = app.flashes('success') %}
    {% set warningFlashes = app.flashes('warning') %}
    {% set errorFlashes   = app.flashes('error') %}

    {% if successFlashes is not empty or warningFlashes is not empty or errorFlashes is not empty %}
        <div class="destinations-toast-stack" aria-live="polite" aria-atomic="true">
            {% for message in successFlashes %}
                <div class="destinations-flash destinations-flash--success" data-destinations-toast>
                    <strong class="destinations-flash__title">Opération réussie</strong>
                    <div class="destinations-flash__message">{{ message }}</div>
                    <button type="button" class="destinations-flash__close" data-destinations-toast-close aria-label="Fermer">×</button>
                </div>
            {% endfor %}
            {% for message in warningFlashes %}
                <div class="destinations-flash destinations-flash--warning" data-destinations-toast>
                    <strong class="destinations-flash__title">Attention</strong>
                    <div class="destinations-flash__message">{{ message }}</div>
                    <button type="button" class="destinations-flash__close" data-destinations-toast-close aria-label="Fermer">×</button>
                </div>
            {% endfor %}
            {% for message in errorFlashes %}
                <div class="destinations-flash destinations-flash--error" data-destinations-toast>
                    <strong class="destinations-flash__title">Action impossible</strong>
                    <div class="destinations-flash__message">{{ message }}</div>
                    <button type="button" class="destinations-flash__close" data-destinations-toast-close aria-label="Fermer">×</button>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {# ── Toolbar ─────────────────────────────────────────────────────────────── #}
    <div class="destinations-toolbar-wrapper">
        <div class="toolbar-header">
            <h2 class="toolbar-title">Filtrer & Trier</h2>
            <p class="toolbar-subtitle">Découvrez nos meilleures adresses</p>
        </div>

        <div class="destinations-toolbar">
            <div class="toolbar-search">
                <svg class="toolbar-search__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="8.5" cy="8.5" r="6.5" stroke="currentColor" stroke-width="2"/>
                    <path d="M13 13L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <input type="text" id="hbergSearch" placeholder="Rechercher un hébergement..." class="toolbar-search__input" value="{{ search }}">
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-filters">
                <div class="filter-group">
                    <label for="typeFilter" class="filter-label">Type</label>
                    <select id="typeFilter" class="toolbar-filter__select">
                        <option value="">Tous les types</option>
                        {% set typesMap = {} %}
                        {% for hebergement in hebergements %}
                            {% if hebergement.typeHebergement %}
                                {% set typesMap = typesMap|merge({(hebergement.typeHebergement): true}) %}
                            {% endif %}
                        {% endfor %}
                        {% for type in typesMap|keys|sort %}
                            <option value="{{ type }}" {{ selected_type == type ? 'selected' : '' }}>{{ type }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <label for="destinationFilter" class="filter-label">Destination</label>
                    <select id="destinationFilter" class="toolbar-filter__select">
                        <option value="">Toutes les destinations</option>
                        {% for destinationOption in destination_options %}
                            <option value="{{ destinationOption.id }}" {{ selected_destination_id == destinationOption.id ? 'selected' : '' }}>
                                {{ destinationOption.name }}{% if destinationOption.country %} - {{ destinationOption.country }}{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <label for="hebergSort" class="filter-label">Trier par</label>
                    <select id="hebergSort" class="toolbar-filter__select">
                        <option value="default"    {{ selected_sort == 'default'    ? 'selected' : '' }}>Par défaut</option>
                        <option value="name"       {{ selected_sort == 'name'       ? 'selected' : '' }}>📝 Nom (A-Z)</option>
                        <option value="price-asc"  {{ selected_sort == 'price-asc'  ? 'selected' : '' }}>💰 Prix (bas → élevé)</option>
                        <option value="price-desc" {{ selected_sort == 'price-desc' ? 'selected' : '' }}>💰 Prix (élevé → bas)</option>
                        <option value="rating-desc"{{ selected_sort == 'rating-desc'? 'selected' : '' }}>⭐ Note (élevée → basse)</option>
                        <option value="rating-asc" {{ selected_sort == 'rating-asc' ? 'selected' : '' }}>⭐ Note (basse → élevée)</option>
                    </select>
                </div>
            </div>

            <div class="toolbar-divider"></div>

            <div class="toolbar-info">
                {# ── Main suggestion button (now linked to RapidAPI flow) ── #}
                <button type="button" id="suggestHebergementButton" class="btn btn--primary toolbar-suggest-btn" disabled>
                    <span class="toolbar-suggest-btn__icon">✨</span>
                    <span>Suggérer des hébergements</span>
                </button>
            </div>
        </div>
    </div>

    {# ── Cards grid ──────────────────────────────────────────────────────────── #}
    {% if hebergements is not empty %}
        <div class="destinations-grid" id="hebergementContainer">
            {% for hebergement in hebergements %}
                <div class="destination-card"
                     onclick="openHebergementModal({{ hebergement.idHebergement }})"
                     data-type="{{ hebergement.typeHebergement ?? 'Sans type' }}"
                     data-price="{{ hebergement.prixNuitHebergement ?? 0 }}"
                     data-rating="{{ hebergement.noteHebergement ?? '' }}"
                     data-name="{{ hebergement.nomHebergement }}"
                     data-destination-id="{{ hebergement.destination ? hebergement.destination.idDestination : '' }}">

                    <div class="destination-card__image-wrapper">
                        <div class="destination-card__image-placeholder">🏨</div>
                    </div>
                    <div class="destination-card__content">
                        <h3 class="destination-card__title">{{ hebergement.nomHebergement }}</h3>
                        <p class="destination-card__location">
                            📍 {{ hebergement.adresseHebergement ?? 'Adresse non disponible' }}
                        </p>
                        {% if hebergement.destination %}
                            <p class="destination-card__description">À {{ hebergement.destination.nomDestination }}</p>
                        {% endif %}
                        <div class="destination-card__meta">
                            {% if hebergement.typeHebergement %}
                                <span class="destination-card__badge destination-card__badge--climate">
                                    <span class="badge-icon">🏠</span>{{ hebergement.typeHebergement }}
                                </span>
                            {% endif %}
                            {% if hebergement.prixNuitHebergement is not null %}
                                <span class="destination-card__badge destination-card__badge--climate">
                                    <span class="badge-icon">💰</span>{{ hebergement.prixNuitHebergement }} €/nuit
                                </span>
                            {% endif %}
                            {% if hebergement.noteHebergement %}
                                <span class="destination-card__badge destination-card__badge--season">
                                    <span class="badge-icon">⭐</span>{{ hebergement.noteHebergement }}/5
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="destinations-empty">
            <div class="destinations-empty__icon">🏨</div>
            <p>Aucun hébergement trouvé</p>
        </div>
    {% endif %}
</section>

{# ── Detail modal (existing) ─────────────────────────────────────────────────── #}
<div id="hebergementModal" class="modal">
    <div class="modal-content">
        <span class="modal-close" onclick="closeHebergementModal()">&times;</span>
        <div id="modalBody"></div>
    </div>
</div>

{# ── Scrape modal (new) ──────────────────────────────────────────────────────── #}
{{ include('hebergement/_scrape_modal.html.twig') }}

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Suggest button (existing) ── */
        .toolbar-suggest-btn {
            display: inline-flex; align-items: center; gap: .5rem;
            border: 0; border-radius: 999px; padding: .72rem 1.2rem;
            font-size: .9rem; font-weight: 700; letter-spacing: .2px;
            background: linear-gradient(135deg,#c46f4b,#a85a3a);
            color: #fff; box-shadow: 0 10px 24px rgba(196,111,75,.28);
            transition: transform .2s,box-shadow .2s,opacity .2s; cursor: pointer;
        }
        .toolbar-suggest-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 14px 30px rgba(196,111,75,.34); }
        .toolbar-suggest-btn:disabled {
            background: linear-gradient(135deg,#d9dbe1,#c9cdd6);
            color: #6c727a; box-shadow: none; cursor: not-allowed; opacity: .95;
        }

        /* ── Scrape modal overlay ── */
        .scrape-modal-overlay {
            position: fixed; inset: 0; z-index: 1100;
            background: rgba(0,0,0,.55); display: flex;
            align-items: center; justify-content: center;
            padding: 1rem;
        }
        .scrape-modal-overlay[hidden] { display: none; }

        .scrape-modal {
            background: #fff; border-radius: 16px; width: 100%; max-width: 860px;
            max-height: 90vh; display: flex; flex-direction: column;
            box-shadow: 0 24px 60px rgba(0,0,0,.25); overflow: hidden;
        }

        /* header */
        .scrape-modal__header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.25rem 1.5rem; border-bottom: 1px solid #e5e7eb;
        }
        .scrape-modal__title { font-size: 1.2rem; font-weight: 700; margin: 0; color: #111827; }
        .scrape-modal__close {
            background: none; border: none; font-size: 1.6rem; cursor: pointer;
            color: #6b7280; line-height: 1; padding: 0 .25rem;
        }
        .scrape-modal__close:hover { color: #111827; }

        /* buttons inside modal */
        .scrape-modal__btn {
            display: inline-flex; align-items: center; gap: .4rem;
            border-radius: 8px; padding: .6rem 1.1rem; font-size: .9rem;
            font-weight: 600; cursor: pointer; transition: background .15s, opacity .15s;
        }
        .scrape-modal__btn--ghost { background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; }
        .scrape-modal__btn--ghost:hover { background: #e5e7eb; }
        .scrape-modal__btn--save { background: #16a34a; color: #fff; border: none; }
        .scrape-modal__btn--save:hover:not(:disabled) { background: #15803d; }
        .scrape-modal__btn:disabled { opacity: .5; cursor: not-allowed; }

        /* status */
        .scrape-modal__status {
            padding: .75rem 1.5rem; font-size: .9rem; color: #6b7280;
            border-bottom: 1px solid #f3f4f6;
        }

        /* results wrapper */
        #scrapeResultsWrapper {
            flex: 1; overflow-y: auto; display: flex; flex-direction: column;
        }
        #scrapeResultsWrapper[hidden] { display: none; }

        .scrape-modal__results-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 1.5rem; border-bottom: 1px solid #f3f4f6; flex-shrink: 0;
        }
        .scrape-modal__count { font-size: .85rem; color: #6b7280; font-weight: 600; }
        .scrape-modal__bulk-actions { display: flex; gap: .5rem; }

        /* results grid */
        .scrape-results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 1rem; padding: 1rem 1.5rem; overflow-y: auto;
        }

        /* individual scrape card */
        .scrape-card {
            border: 2px solid #e5e7eb; border-radius: 12px; overflow: hidden;
            cursor: pointer; transition: border-color .2s, box-shadow .2s;
            display: flex; flex-direction: column; position: relative;
            min-height: 360px;
        }
        .scrape-card:hover { border-color: #2563eb; box-shadow: 0 4px 16px rgba(37,99,235,.15); }
        .scrape-card.is-selected { border-color: #2563eb; background: #eff6ff; }
        .scrape-card.is-selected .scrape-card__check { opacity: 1; }

        /* checkbox overlay */
        .scrape-card__check {
            position: absolute; top: .5rem; right: .5rem;
            width: 22px; height: 22px; background: #2563eb; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: .8rem; opacity: 0; transition: opacity .2s;
        }

        /* image */
        .scrape-card__img {
            width: 100%; height: 160px; object-fit: cover; background: #f3f4f6;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.5rem; color: #9ca3af; flex-shrink: 0;
        }
        .scrape-card__img img { width: 100%; height: 100%; object-fit: cover; }

        /* body */
        .scrape-card__body { padding: .85rem; flex: 1; display: flex; flex-direction: column; gap: .45rem; }
        .scrape-card__name { font-weight: 700; font-size: .9rem; margin: 0 0 .3rem; color: #111827; }
        .scrape-card__meta { font-size: .78rem; color: #6b7280; line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .scrape-card__badge {
            display: inline-block; background: #f3f4f6; border-radius: 999px;
            padding: .15rem .55rem; font-size: .72rem; font-weight: 600;
            margin: .2rem .15rem 0 0; color: #374151;
        }

        /* footer */
        .scrape-modal__footer {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 1.5rem; border-top: 1px solid #e5e7eb; flex-shrink: 0;
        }

        /* spinner */
        .scrape-spinner {
            width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4);
            border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
{% endblock %}

{% block javascripts %}
<script>
// ── Existing detail-modal helpers ────────────────────────────────────────────
function openHebergementModal(hebergementId) {
    const modal    = document.getElementById('hebergementModal');
    const modalBody = document.getElementById('modalBody');
    fetch(`/hebergement/${hebergementId}`)
        .then(r => r.text())
        .then(html => { modalBody.innerHTML = html; modal.classList.add('active'); })
        .catch(err => console.error('Erreur:', err));
}
function closeHebergementModal() {
    document.getElementById('hebergementModal').classList.remove('active');
}

// ── Scrape modal ─────────────────────────────────────────────────────────────
(function () {
    'use strict';

    const SCRAPE_URL      = '{{ path('app_hebergement_scrape') }}';
    const SAVE_URL        = '{{ path('app_hebergement_save_scraped') }}';

    // DOM refs (resolved after DOMContentLoaded)
    let overlay, closeBtn, openBtn,
        statusMsg, resultsWrapper, resultsGrid,
        resultsCount, selectedCount,
        selectAllBtn, deselectAllBtn,
        saveBtn, saveBtnLabel, saveBtnSpinner;

    let scrapedItems = [];   // full data from last scrape
    let selectedIndices = new Set();

    // ── Open / Close ──────────────────────────────────────────────────────────
    function openModal()  {
        overlay.hidden = false;
        closeBtn?.focus();
    }
    function closeModal() { overlay.hidden = true; }

    // ── Fetch scrape results ──────────────────────────────────────────────────
    function getSelectedDestinationName() {
        const destinationFilter = document.getElementById('destinationFilter');
        const selectedText = destinationFilter?.options[destinationFilter.selectedIndex]?.textContent?.trim() || '';
        if (!selectedText || selectedText.toLowerCase().includes('toutes les destinations')) {
            return '';
        }

        return selectedText.includes(' - ')
            ? selectedText.split(' - ')[0].trim()
            : selectedText;
    }

    function startScrape() {
        const dest = getSelectedDestinationName();
        if (!dest) {
            showStatus('Veuillez sélectionner une destination.', 'error');
            return;
        }

        setStartLoading(true);
        showStatus('Recherche en cours, cela peut prendre quelques secondes…');
        resultsWrapper.hidden = true;
        scrapedItems = [];
        selectedIndices.clear();

        fetch(`${SCRAPE_URL}?destination=${encodeURIComponent(dest)}`)
            .then(r => r.json())
            .then(data => {
                setStartLoading(false);
                if (!data.success) { showStatus('Erreur : ' + (data.error || 'Inconnue'), 'error'); return; }
                if (!data.data || data.data.length === 0) {
                    showStatus('Aucun hébergement trouvé pour cette destination.', 'warn');
                    return;
                }
                scrapedItems = data.data;
                renderResults(scrapedItems);
            })
            .catch(err => {
                setStartLoading(false);
                showStatus('Erreur réseau : ' + err.message, 'error');
                console.error(err);
            });
    }

    // ── Render cards ──────────────────────────────────────────────────────────
    function renderResults(items) {
        resultsGrid.innerHTML = '';
        items.forEach((item, idx) => {
            resultsGrid.appendChild(buildCard(item, idx));
        });
        resultsCount.textContent = items.length + ' hébergement(s) trouvé(s)';
        updateSelectedCount();
        statusMsg.hidden = true;
        resultsWrapper.hidden = false;
    }

    function buildCard(item, idx) {
        const card = document.createElement('div');
        card.className = 'scrape-card';
        card.dataset.idx = idx;

        // checkmark overlay
        const check = document.createElement('div');
        check.className = 'scrape-card__check';
        check.innerHTML = '✓';
        card.appendChild(check);

        // image
        const imgBox = document.createElement('div');
        imgBox.className = 'scrape-card__img';
        if (item.image_url) {
            const img = document.createElement('img');
            img.src = item.image_url;
            img.alt = item.name;
            img.onerror = () => { imgBox.textContent = '🏨'; };
            imgBox.appendChild(img);
        } else {
            imgBox.textContent = '🏨';
        }
        card.appendChild(imgBox);

        // body
        const body = document.createElement('div');
        body.className = 'scrape-card__body';

        const name = document.createElement('p');
        name.className = 'scrape-card__name';
        name.textContent = item.name || 'Sans nom';
        body.appendChild(name);

        const meta = document.createElement('p');
        meta.className = 'scrape-card__meta';
        if (item.address) meta.appendChild(makeSpan('📍 ' + item.address));
        body.appendChild(meta);

        const badges = document.createElement('div');
        if (item.type)   badges.appendChild(makeBadge('🏠 ' + item.type));
        if (item.price)  badges.appendChild(makeBadge('💰 ' + item.price + ' €/nuit'));
        if (item.rating) badges.appendChild(makeBadge('⭐ ' + item.rating + '/5'));
        body.appendChild(badges);

        card.appendChild(body);

        card.addEventListener('click', () => toggleCard(card, idx));
        return card;
    }

    function makeSpan(text) {
        const s = document.createElement('span');
        s.textContent = text;
        return s;
    }
    function makeBadge(text) {
        const b = document.createElement('span');
        b.className = 'scrape-card__badge';
        b.textContent = text;
        return b;
    }

    // ── Selection ─────────────────────────────────────────────────────────────
    function toggleCard(card, idx) {
        if (selectedIndices.has(idx)) {
            selectedIndices.delete(idx);
            card.classList.remove('is-selected');
        } else {
            selectedIndices.add(idx);
            card.classList.add('is-selected');
        }
        updateSelectedCount();
    }

    function selectAll() {
        resultsGrid.querySelectorAll('.scrape-card').forEach((card, idx) => {
            selectedIndices.add(idx);
            card.classList.add('is-selected');
        });
        updateSelectedCount();
    }

    function deselectAll() {
        selectedIndices.clear();
        resultsGrid.querySelectorAll('.scrape-card').forEach(c => c.classList.remove('is-selected'));
        updateSelectedCount();
    }

    function updateSelectedCount() {
        const n = selectedIndices.size;
        selectedCount.textContent = n + ' sélectionné(s)';
        saveBtn.disabled = n === 0;
    }

    // ── Save selected ─────────────────────────────────────────────────────────
    function saveSelected() {
        if (selectedIndices.size === 0) return;

        const items = Array.from(selectedIndices).map(i => scrapedItems[i]);
        const destinationFilter = document.getElementById('destinationFilter');
        const destinationId = destinationFilter?.value || '';
        if (!destinationId) {
            showStatus('Veuillez sélectionner une destination avant l\'enregistrement.', 'error');
            return;
        }

        setSaveLoading(true);

        fetch(SAVE_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items, destination_id: destinationId }),
        })
        .then(r => r.json())
        .then(data => {
            setSaveLoading(false);
            if (data.success) {
                showStatus(`✅ ${data.saved} hébergement(s) enregistré(s) avec succès !`, 'success');
                deselectAll();
                // Optionally reload the page to show new items in the list
                setTimeout(() => { closeModal(); window.location.reload(); }, 1800);
            } else {
                showStatus('Erreur lors de l\'enregistrement : ' + (data.error || 'Inconnue'), 'error');
            }
        })
        .catch(err => {
            setSaveLoading(false);
            showStatus('Erreur réseau : ' + err.message, 'error');
        });
    }

    // ── UI helpers ────────────────────────────────────────────────────────────
    function showStatus(msg, level = 'info') {
        statusMsg.textContent = msg;
        statusMsg.style.color = level === 'error' ? '#dc2626'
                              : level === 'success' ? '#16a34a'
                              : level === 'warn'    ? '#d97706'
                              : '#6b7280';
        statusMsg.hidden = false;
    }

    function setStartLoading(on) {
        if (openBtn) {
            openBtn.disabled = on;
            openBtn.setAttribute('aria-busy', on ? 'true' : 'false');
        }
    }

    function setSaveLoading(on) {
        saveBtn.disabled          = on;
        saveBtnLabel.textContent  = on ? 'Enregistrement…' : '💾 Enregistrer la sélection';
        saveBtnSpinner.hidden     = !on;
    }

    // ── Boot ──────────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        overlay          = document.getElementById('scrapeModal');
        closeBtn         = document.getElementById('scrapeModalClose');
        openBtn          = document.getElementById('suggestHebergementButton');
        statusMsg        = document.getElementById('scrapeStatusMsg');
        resultsWrapper   = document.getElementById('scrapeResultsWrapper');
        resultsGrid      = document.getElementById('scrapeResultsGrid');
        resultsCount     = document.getElementById('scrapeResultsCount');
        selectedCount    = document.getElementById('scrapeSelectedCount');
        selectAllBtn     = document.getElementById('scrapeSelectAll');
        deselectAllBtn   = document.getElementById('scrapeDeselectAll');
        saveBtn          = document.getElementById('scrapeSaveBtn');
        saveBtnLabel     = document.getElementById('scrapeSaveBtnLabel');
        saveBtnSpinner   = document.getElementById('scrapeSaveBtnSpinner');

        openBtn.addEventListener('click', function () {
            openModal();
            startScrape();
        });
        closeBtn.addEventListener('click', closeModal);
        overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
        selectAllBtn.addEventListener('click', selectAll);
        deselectAllBtn.addEventListener('click', deselectAll);
        saveBtn.addEventListener('click', saveSelected);

        // ── existing filter / sort / suggest logic ────────────────────────────
        const searchInput        = document.getElementById('hbergSearch');
        const typeFilter         = document.getElementById('typeFilter');
        const destinationFilter  = document.getElementById('destinationFilter');
        const hebergSort         = document.getElementById('hebergSort');
        const suggestButton      = document.getElementById('suggestHebergementButton');

        function updateSuggestButtonState() {
            if (!suggestButton) return;
            const val  = (destinationFilter?.value || '').trim().toLowerCase();
            const text = destinationFilter?.options[destinationFilter.selectedIndex]?.textContent.trim().toLowerCase() || '';
            const none = val === '' || val === '0' || val === 'all' || text.includes('toutes les destinations');
            suggestButton.disabled = none;
            suggestButton.setAttribute('aria-disabled', none ? 'true' : 'false');
        }

        function applyFilters() {
            const term    = (searchInput?.value || '').toLowerCase();
            const selType = typeFilter?.value || '';
            const selDest = destinationFilter?.value || '';
            const sort    = hebergSort?.value || 'default';
            const container = document.getElementById('hebergementContainer');
            if (!container) return;

            let cards = Array.from(container.querySelectorAll('.destination-card'));
            let visible = [];

            cards.forEach(card => {
                let ok = true;
                if (term) {
                    const haystack = [
                        card.querySelector('.destination-card__title')?.textContent || '',
                        card.querySelector('.destination-card__location')?.textContent || '',
                        card.querySelector('.destination-card__description')?.textContent || '',
                    ].join(' ').toLowerCase();
                    ok = haystack.includes(term);
                }
                if (ok && selType) ok = card.dataset.type === selType;
                if (ok && selDest) ok = card.dataset.destinationId === selDest;
                card.style.display = ok ? 'block' : 'none';
                if (ok) visible.push(card);
            });

            visible.sort((a, b) => {
                const na = a.dataset.name || '', nb = b.dataset.name || '';
                const pa = parseFloat(a.dataset.price) || 0, pb = parseFloat(b.dataset.price) || 0;
                const ra = parseFloat(a.dataset.rating) || 0, rb = parseFloat(b.dataset.rating) || 0;
                if (sort === 'name')        return na.localeCompare(nb);
                if (sort === 'price-asc')   return (pa || Infinity) - (pb || Infinity);
                if (sort === 'price-desc')  return (pb || -1) - (pa || -1);
                if (sort === 'rating-desc') return (rb || -1) - (ra || -1);
                if (sort === 'rating-asc')  return (ra || Infinity) - (rb || Infinity);
                return 0;
            });
            visible.forEach(c => container.appendChild(c));
            updateSuggestButtonState();
        }

        searchInput?.addEventListener('input', applyFilters);
        typeFilter?.addEventListener('change', applyFilters);
        destinationFilter?.addEventListener('change', () => { applyFilters(); updateSuggestButtonState(); });
        hebergSort?.addEventListener('change', applyFilters);

        updateSuggestButtonState();
        applyFilters();

        // ── Existing detail-modal backdrop close ──────────────────────────────
        const detailModal = document.getElementById('hebergementModal');
        window.addEventListener('click', e => { if (e.target === detailModal) closeHebergementModal(); });

        // ── Toasts ────────────────────────────────────────────────────────────
        document.querySelectorAll('[data-destinations-toast]').forEach(toast => {
            toast.querySelector('[data-destinations-toast-close]')?.addEventListener('click', () => hideToast(toast));
            setTimeout(() => hideToast(toast), 4200);
        });

        function hideToast(toast) {
            if (!toast || toast.classList.contains('is-hiding')) return;
            toast.classList.add('is-hiding');
            setTimeout(() => toast.remove(), 220);
        }
    });
}());
</script>
{% endblock %}
