{% extends 'base.html.twig' %}

{% block title %}{{ categorie.nom }} | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── HERO CATÉGORIE ────────────────────────── */
        .cshow-hero {
            position: relative;
            height: 320px;
            border-radius: var(--radius-xl);
            overflow: hidden;
            margin-bottom: 2rem;
        }
        .cshow-hero__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .cshow-hero__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 30%, rgba(31,26,23,.7));
        }
        .cshow-hero__content {
            position: absolute;
            bottom: 1.75rem;
            left: 2rem;
            right: 2rem;
            color: #fff;
        }
        .cshow-hero__type {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            background: rgba(196,111,75,.85);
            border-radius: 999px;
            padding: 0.28rem 0.85rem;
            display: inline-block;
            margin-bottom: 0.6rem;
        }
        .cshow-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(1.5rem, 4vw, 2.4rem);
            font-weight: 600;
            line-height: 1.15;
        }

        /* ── LAYOUT ────────────────────────────────── */
        .cshow-layout {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 2rem;
            align-items: start;
        }
        @media (max-width: 768px) {
            .cshow-layout { grid-template-columns: 1fr; }
        }

        /* ── MAIN CONTENT ──────────────────────────── */
        .cshow-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            padding: 2rem;
        }
        .cshow-section-label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--color-text-muted);
            margin-bottom: 0.5rem;
        }
        .cshow-desc {
            font-size: 1rem;
            line-height: 1.7;
            color: var(--color-text);
            margin-bottom: 1.5rem;
        }
        .cshow-divider { border: none; border-top: 1px solid var(--color-border); margin: 1.5rem 0; }

        /* ── SIDEBAR ───────────────────────────────── */
        .cshow-sidebar { display: flex; flex-direction: column; gap: 1rem; }

        .cshow-info-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.25rem 1.4rem;
        }
        .cshow-info-card__label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-text-muted);
            margin-bottom: 0.35rem;
        }
        .cshow-info-card__value {
            font-size: 1rem;
            font-weight: 500;
            color: var(--color-text);
        }
        .cshow-info-card--primary {
            background: rgba(196,111,75,.06);
            border-color: rgba(196,111,75,.2);
        }
        .cshow-info-card--primary .cshow-info-card__value { color: var(--color-primary); }
        .cshow-info-card--secondary {
            background: rgba(47,127,121,.05);
            border-color: rgba(47,127,121,.2);
        }
        .cshow-info-card--secondary .cshow-info-card__value { color: var(--color-secondary); }

        /* ── BACK LINK ─────────────────────────────── */
        .cshow-back {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--color-text-muted);
            font-size: 0.88rem;
            font-weight: 500;
            margin-bottom: 1.5rem;
            transition: color var(--transition-fast);
        }
        .cshow-back:hover { color: var(--color-primary); }
    </style>
{% endblock %}

{% block body %}

{# ── Image mapping ───────────────────────────────────────────────────── #}
{% set imageMap = {
    'randon':   'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&q=80',
    'montagne': 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=900&q=80',
    'nautique': 'https://images.unsplash.com/photo-1530053969600-caed2596d242?w=900&q=80',
    'mer':      'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=900&q=80',
    'plage':    'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=900&q=80',
    'culture':  'https://images.unsplash.com/photo-1499856871958-5b9627545d1a?w=900&q=80',
    'ville':    'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=900&q=80',
    'gastrono': 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=900&q=80',
    'sport':    'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=900&q=80',
    'bien':     'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=900&q=80',
    'zen':      'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=900&q=80',
    'aventure': 'https://images.unsplash.com/photo-1551632811-561732d1e306?w=900&q=80',
    'famille':  'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=900&q=80',
    'nature':   'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=900&q=80',
    'ski':      'https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=900&q=80',
    'art':      'https://images.unsplash.com/photo-1561214115-f2f134cc4912?w=900&q=80',
    'default':  'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=900&q=80'
} %}
{% set nomLower = categorie.nom|lower %}
{% set imgUrl = imageMap['default'] %}
{% for key, url in imageMap %}
    {% if key != 'default' and key in nomLower %}
        {% set imgUrl = url %}
    {% endif %}
{% endfor %}

<a href="{{ path('app_categories') }}" class="cshow-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Retour aux catégories
</a>

<div class="cshow-hero">
    <img src="{{ imgUrl }}" alt="{{ categorie.nom }}" class="cshow-hero__img">
    <div class="cshow-hero__overlay"></div>
    <div class="cshow-hero__content">
        <span class="cshow-hero__type">{{ categorie.type }}</span>
        <h1 class="cshow-hero__title">{{ categorie.nom }}</h1>
    </div>
</div>

<div class="cshow-layout">
    <div class="cshow-card">
        <p class="cshow-section-label">À propos de cette catégorie</p>
        <p class="cshow-desc">{{ categorie.description }}</p>

        <hr class="cshow-divider">

        <p class="cshow-section-label">Activités associées</p>
        {% if categorie.activites is defined and categorie.activites|length > 0 %}
            <ul style="list-style:none; display:flex; flex-direction:column; gap:0.5rem;">
                {% for activite in categorie.activites %}
                    <li style="padding:0.75rem 1rem; background:var(--color-surface-soft); border-radius:var(--radius-sm); font-size:0.9rem;">
                        {{ activite.nom ?? activite }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p style="color:var(--color-text-muted); font-size:0.9rem;">Aucune activité dans cette catégorie pour le moment.</p>
        {% endif %}
    </div>

    <aside class="cshow-sidebar">
        <div class="cshow-info-card cshow-info-card--primary">
            <p class="cshow-info-card__label">🗓 Saison idéale</p>
            <p class="cshow-info-card__value">{{ categorie.saison }}</p>
        </div>
        <div class="cshow-info-card cshow-info-card--secondary">
            <p class="cshow-info-card__label">⚡ Niveau d'intensité</p>
            <p class="cshow-info-card__value">{{ categorie.niveauintensite }}</p>
        </div>
        <div class="cshow-info-card">
            <p class="cshow-info-card__label">👥 Public cible</p>
            <p class="cshow-info-card__value">{{ categorie.publiccible }}</p>
        </div>
        <div class="cshow-info-card">
            <p class="cshow-info-card__label">🏷 Type</p>
            <p class="cshow-info-card__value">{{ categorie.type }}</p>
        </div>
    </aside>
</div>

{% endblock %}
