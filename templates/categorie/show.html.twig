{% extends 'base.html.twig' %}

{% block title %}{{ categorie.nom }} | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── HERO CATÉGORIE ────────────────────────── */
        .cshow-hero {
            position: relative;
            height: 320px;
            border-radius: var(--radius-xl);
            overflow: hidden;
            margin-bottom: 2rem;
        }
        .cshow-hero__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .cshow-hero__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 30%, rgba(31,26,23,.7));
        }
        .cshow-hero__content {
            position: absolute;
            bottom: 1.75rem;
            left: 2rem;
            right: 2rem;
            color: #fff;
        }
        .cshow-hero__type {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            background: rgba(196,111,75,.85);
            border-radius: 999px;
            padding: 0.28rem 0.85rem;
            display: inline-block;
            margin-bottom: 0.6rem;
        }
        .cshow-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(1.5rem, 4vw, 2.4rem);
            font-weight: 600;
            line-height: 1.15;
        }

        /* ── LAYOUT INFO (sidebar) ─────────────────── */
        .cshow-layout {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 2rem;
            align-items: start;
            margin-bottom: 2.5rem;
        }
        @media (max-width: 768px) {
            .cshow-layout { grid-template-columns: 1fr; }
        }

        /* ── MAIN CONTENT ──────────────────────────── */
        .cshow-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            padding: 2rem;
        }
        .cshow-section-label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--color-text-muted);
            margin-bottom: 0.5rem;
        }
        .cshow-desc {
            font-size: 1rem;
            line-height: 1.7;
            color: var(--color-text);
        }

        /* ── SIDEBAR ───────────────────────────────── */
        .cshow-sidebar { display: flex; flex-direction: column; gap: 1rem; }

        .cshow-info-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 1.25rem 1.4rem;
        }
        .cshow-info-card__label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--color-text-muted);
            margin-bottom: 0.35rem;
        }
        .cshow-info-card__value {
            font-size: 1rem;
            font-weight: 500;
            color: var(--color-text);
        }
        .cshow-info-card--primary {
            background: rgba(196,111,75,.06);
            border-color: rgba(196,111,75,.2);
        }
        .cshow-info-card--primary .cshow-info-card__value { color: var(--color-primary); }
        .cshow-info-card--secondary {
            background: rgba(47,127,121,.05);
            border-color: rgba(47,127,121,.2);
        }
        .cshow-info-card--secondary .cshow-info-card__value { color: var(--color-secondary); }

        /* ── BACK LINK ─────────────────────────────── */
        .cshow-back {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--color-text-muted);
            font-size: 0.88rem;
            font-weight: 500;
            margin-bottom: 1.5rem;
            transition: color var(--transition-fast);
            text-decoration: none;
        }
        .cshow-back:hover { color: var(--color-primary); }

        /* ── SECTION TITRE ACTIVITÉS ───────────────── */
        .act-section-header {
            display: flex;
            align-items: baseline;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }
        .act-section-title {
            font-family: 'Fraunces', serif;
            font-size: clamp(1.3rem, 3vw, 1.8rem);
            font-weight: 600;
            color: var(--color-text);
        }
        .act-section-count {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--color-primary);
            background: rgba(196,111,75,.1);
            border: 1px solid rgba(196,111,75,.2);
            border-radius: 999px;
            padding: 0.2rem 0.7rem;
        }

        /* ── GRILLE D'ACTIVITÉS ────────────────────── */
        .act-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            padding-bottom: 3rem;
        }

        /* ── CARD ACTIVITÉ ─────────────────────────── */
        .act-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform var(--transition-base), box-shadow var(--transition-base);
            text-decoration: none;
            color: inherit;
        }
        .act-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(71,48,35,.1);
        }

        .act-card__visual {
            position: relative;
            height: 190px;
            overflow: hidden;
            background: var(--color-surface-soft);
        }
        .act-card__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .act-card:hover .act-card__img { transform: scale(1.05); }
        .act-card__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 40%, rgba(31,26,23,.5));
        }
        .act-card__badge {
            position: absolute;
            top: 0.85rem;
            left: 0.85rem;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #fff;
            border-radius: 999px;
            padding: 0.28rem 0.75rem;
            backdrop-filter: blur(6px);
        }
        .act-card__badge--facile       { background: rgba(47,127,121,.85); }
        .act-card__badge--intermediaire { background: rgba(196,150,75,.85); }
        .act-card__badge--difficile    { background: rgba(196,111,75,.85); }
        .act-card__badge--expert       { background: rgba(150,50,50,.85); }
        .act-card__badge--default      { background: rgba(100,100,100,.75); }

        .act-card__price {
            position: absolute;
            top: 0.85rem;
            right: 0.85rem;
            font-size: 0.78rem;
            font-weight: 700;
            color: #fff;
            background: rgba(0,0,0,.3);
            border-radius: 999px;
            padding: 0.25rem 0.7rem;
            backdrop-filter: blur(6px);
        }

        .act-card__body {
            padding: 1.2rem 1.4rem 1.4rem;
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
            flex: 1;
        }
        .act-card__name {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-text);
            line-height: 1.2;
        }
        .act-card__desc {
            font-size: 0.85rem;
            color: var(--color-text-muted);
            line-height: 1.55;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .act-card__meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-top: 0.3rem;
        }
        .act-card__tag {
            font-size: 0.72rem;
            font-weight: 500;
            padding: 0.22rem 0.65rem;
            border-radius: 999px;
            border: 1px solid var(--color-border);
            color: var(--color-text-muted);
            background: var(--color-surface-soft);
        }
        .act-card__cta {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: auto;
            padding-top: 0.8rem;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--color-primary);
            border-top: 1px solid var(--color-border);
        }
        .act-card__cta svg { transition: transform var(--transition-fast); }
        .act-card:hover .act-card__cta svg { transform: translateX(3px); }

        /* ── EMPTY STATE ───────────────────────────── */
        .act-empty {
            text-align: center;
            padding: 3.5rem 1rem;
            color: var(--color-text-muted);
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
        }
        .act-empty__icon { font-size: 2.8rem; margin-bottom: 0.75rem; }
        .act-empty__title {
            font-family: 'Fraunces', serif;
            font-size: 1.3rem;
            margin-bottom: 0.4rem;
            color: var(--color-text);
        }
    </style>
{% endblock %}

{% block body %}

