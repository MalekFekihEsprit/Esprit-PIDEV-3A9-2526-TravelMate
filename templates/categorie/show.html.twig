} %}

{# ── Back link ───────────────────────────────────────────────────────── #}
<a href="{{ path('app_categories') }}" class="cshow-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Retour aux catégories
</a>

{# ── Hero ────────────────────────────────────────────────────────────── #}
<div class="cshow-hero">
    <img src="{{ imgUrl }}" alt="{{ categorie.nom }}" class="cshow-hero__img">
    <div class="cshow-hero__overlay"></div>
    <div class="cshow-hero__content">
        <span class="cshow-hero__type">{{ categorie.type }}</span>
        <h1 class="cshow-hero__title">{{ categorie.nom }}</h1>
    </div>
</div>

{# ── Layout : description + sidebar ──────────────────────────────────── #}
<div class="cshow-layout">
    <div class="cshow-card">
        <p class="cshow-section-label">À propos de cette catégorie</p>
        <p class="cshow-desc">{{ categorie.description }}</p>
    </div>

    <aside class="cshow-sidebar">
        <div class="cshow-info-card cshow-info-card--primary">
            <p class="cshow-info-card__label">🗓 Saison idéale</p>
            <p class="cshow-info-card__value">{{ categorie.saison }}</p>
        </div>
        <div class="cshow-info-card cshow-info-card--secondary">
            <p class="cshow-info-card__label">⚡ Niveau d'intensité</p>
            <p class="cshow-info-card__value">{{ categorie.niveauintensite }}</p>
        </div>
        <div class="cshow-info-card">
            <p class="cshow-info-card__label">👥 Public cible</p>
            <p class="cshow-info-card__value">{{ categorie.publiccible }}</p>
        </div>
        <div class="cshow-info-card">
            <p class="cshow-info-card__label">🏷 Type</p>
            <p class="cshow-info-card__value">{{ categorie.type }}</p>
        </div>
    </aside>
</div>

{# ── Section activités associées ─────────────────────────────────────── #}
<div class="act-section-header">
    <h2 class="act-section-title">Activités dans cette catégorie</h2>
    {% if categorie.activites is defined %}
        <span class="act-section-count">{{ categorie.activites|length }} activité{{ categorie.activites|length > 1 ? 's' : '' }}</span>
    {% endif %}
</div>

{% if categorie.activites is not defined or categorie.activites|length == 0 %}
    <div class="act-empty">
        <div class="act-empty__icon">🏕️</div>
        <p class="act-empty__title">Aucune activité pour le moment</p>
        <p>Cette catégorie ne contient pas encore d'activités. Revenez bientôt !</p>
    </div>
{% else %}
    <div class="act-grid">
        {% for activite in categorie.activites %}

            {# Résolution de l'image : d'abord imagePath, sinon fallback par nom #}
            {% if activite.imagePath is defined and activite.imagePath %}
                {% set actImgUrl = asset('uploads/activites/' ~ activite.imagePath) %}
            {% else %}
                {% set actNomLower = activite.nom|lower %}
                {% set actImgUrl = actImageMap['default'] %}
                {% for key, url in actImageMap %}
                    {% if key != 'default' and key in actNomLower %}
                        {% set actImgUrl = url %}
                    {% endif %}
                {% endfor %}
            {% endif %}

            {# Badge couleur selon niveau de difficulté #}
            {% set difficulte = activite.niveaudifficulte ?? 'default' %}
            {% set badgeClass = 'act-card__badge--' ~ difficulte|lower|replace({' ': '-', 'é': 'e', 'è': 'e'}) %}

            <a href="{{ path('app_activite_show', {'id': activite.id}) }}" class="act-card">
                <div class="act-card__visual">
                    <img
                        src="{{ actImgUrl }}"
                        alt="{{ activite.nom }}"
                        class="act-card__img"
                        loading="lazy"
                    >
                    <div class="act-card__overlay"></div>
                    <span class="act-card__badge {{ badgeClass }}">{{ difficulte }}</span>
                    {% if activite.budget is defined and activite.budget %}
                        <span class="act-card__price">{{ activite.budget }} DT</span>
                    {% endif %}
                </div>

                <div class="act-card__body">
                    <h3 class="act-card__name">{{ activite.nom }}</h3>

                    {% if activite.description is defined and activite.description %}
                        <p class="act-card__desc">{{ activite.description }}</p>
                    {% endif %}

                    <div class="act-card__meta">
                        {% if activite.lieu is defined and activite.lieu %}
                            <span class="act-card__tag">📍 {{ activite.lieu }}</span>
                        {% endif %}
                        {% if activite.duree is defined and activite.duree %}
                            <span class="act-card__tag">⏱ {{ activite.duree }}h</span>
                        {% endif %}
                        {% if activite.agemin is defined and activite.agemin %}
                            <span class="act-card__tag">🎂 {{ activite.agemin }}+ ans</span>
                        {% endif %}
                    </div>

                    <span class="act-card__cta">
                        Voir le détail
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </div>
            </a>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
