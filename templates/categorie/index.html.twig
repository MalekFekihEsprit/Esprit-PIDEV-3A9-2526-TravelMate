{% extends 'base.html.twig' %}

{% block title %}Catégories d'activités | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── PAGE HEADER ───────────────────────────── */
        .cat-hero {
            text-align: center;
            padding: 2.5rem 0 2rem;
        }
        .cat-hero__eyebrow {
            display: inline-block;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: var(--color-primary);
            background: rgba(196,111,75,.1);
            border: 1px solid rgba(196,111,75,.2);
            border-radius: 999px;
            padding: 0.3rem 1rem;
            margin-bottom: 1rem;
        }
        .cat-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            font-weight: 600;
            color: var(--color-text);
            line-height: 1.15;
            margin-bottom: 0.75rem;
        }
        .cat-hero__desc {
            font-size: 1rem;
            color: var(--color-text-muted);
            max-width: 540px;
            margin: 0 auto;
            line-height: 1.6;
        }

        /* ── GRID ──────────────────────────────────── */
        .cat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            padding: 1.5rem 0 3rem;
        }

        /* ── CARD ──────────────────────────────────── */
        .cat-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform var(--transition-base), box-shadow var(--transition-base);
            text-decoration: none;
            color: inherit;
        }
        .cat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(71,48,35,.1);
        }

        .cat-card__visual {
            position: relative;
            height: 180px;
            overflow: hidden;
        }
        .cat-card__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .cat-card:hover .cat-card__img {
            transform: scale(1.05);
        }
        .cat-card__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 40%, rgba(31,26,23,.55));
        }
        .cat-card__badge {
            position: absolute;
            top: 0.85rem;
            left: 0.85rem;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #fff;
            background: rgba(196,111,75,.85);
            border-radius: 999px;
            padding: 0.28rem 0.75rem;
            backdrop-filter: blur(6px);
        }
        .cat-card__saison {
            position: absolute;
            top: 0.85rem;
            right: 0.85rem;
            font-size: 0.7rem;
            color: rgba(255,255,255,.9);
            background: rgba(0,0,0,.25);
            border-radius: 999px;
            padding: 0.25rem 0.7rem;
            backdrop-filter: blur(6px);
        }

        .cat-card__body {
            padding: 1.2rem 1.4rem 1.4rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            flex: 1;
        }
        .cat-card__name {
            font-family: 'Fraunces', serif;
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--color-text);
            line-height: 1.2;
        }
        .cat-card__desc {
            font-size: 0.86rem;
            color: var(--color-text-muted);
            line-height: 1.55;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .cat-card__meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-top: 0.4rem;
        }
        .cat-card__tag {
            font-size: 0.72rem;
            font-weight: 500;
            padding: 0.22rem 0.65rem;
            border-radius: 999px;
            border: 1px solid var(--color-border);
            color: var(--color-text-muted);
            background: var(--color-surface-soft);
        }
        .cat-card__tag--intensity {
            color: var(--color-secondary);
            border-color: rgba(47,127,121,.25);
            background: rgba(47,127,121,.06);
        }
        .cat-card__tag--public {
            color: var(--color-primary);
            border-color: rgba(196,111,75,.25);
            background: rgba(196,111,75,.06);
        }
        .cat-card__cta {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: auto;
            padding-top: 0.8rem;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--color-primary);
            border-top: 1px solid var(--color-border);
        }
        .cat-card__cta svg {
            transition: transform var(--transition-fast);
        }
        .cat-card:hover .cat-card__cta svg {
            transform: translateX(3px);
        }

        /* ── EMPTY STATE ───────────────────────────── */
        .cat-empty {
            text-align: center;
            padding: 4rem 1rem;
            color: var(--color-text-muted);
        }
        .cat-empty__icon { font-size: 3rem; margin-bottom: 1rem; }
        .cat-empty__title { font-family: 'Fraunces', serif; font-size: 1.4rem; margin-bottom: 0.5rem; color: var(--color-text); }
    </style>
{% endblock %}

{% block body %}

{% include '_travelmate_mymemory_translate.html.twig' %}

