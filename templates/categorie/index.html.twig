{# Macro : trouve l'image selon le nom de la catégorie #}
{% macro getCategoryImage(nom, imageMap) %}
    {% set nomLower = nom|lower %}
    {% set found = imageMap['default'] %}
    {% for key, url in imageMap %}
        {% if key != 'default' and nomLower|slice(0, key|length) == key %}
            {% set found = url %}
        {% endif %}
        {% if key != 'default' and key in nomLower %}
            {% set found = url %}
        {% endif %}
    {% endfor %}
    {{ found }}
{% endmacro %}

<section class="cat-hero">
    <span class="cat-hero__eyebrow" data-translate="true">Explorer & Découvrir</span>
    <h1 class="cat-hero__title" data-translate="true">Catégories d'activités</h1>
    <p class="cat-hero__desc" data-translate="true">
        Trouvez l'activité qui vous ressemble — randonnée, culture, aventure ou détente,
        il y en a pour tous les voyageurs.
    </p>
</section>

{% if categories is empty %}
    <div class="cat-empty">
        <div class="cat-empty__icon">🗂️</div>
        <p class="cat-empty__title" data-translate="true">Aucune catégorie disponible pour le moment.</p>
        <p data-translate="true">Revenez bientôt, de nouvelles catégories sont en cours d'ajout.</p>
    </div>
{% else %}
    <div class="cat-grid">
        {% for categorie in categories %}
            {% set nomLower = categorie.nom|lower %}
            {% set imgUrl = imageMap['default'] %}
            {% for key, url in imageMap %}
                {% if key != 'default' and key in nomLower %}
                    {% set imgUrl = url %}
                {% endif %}
            {% endfor %}

            <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="cat-card">
                <div class="cat-card__visual">
                    <img
                        src="{{ imgUrl }}"
                        alt="{{ categorie.nom }}"
                        class="cat-card__img"
                        loading="lazy"
                    >
                    <div class="cat-card__overlay"></div>
                    <span class="cat-card__badge" data-translate="true" data-original="{{ categorie.type|e('html_attr') }}">{{ categorie.type }}</span>
                    <span class="cat-card__saison" data-translate="true" data-original="{{ ('🗓 ' ~ categorie.saison)|e('html_attr') }}">🗓 {{ categorie.saison }}</span>
                </div>

                <div class="cat-card__body">
                    <h2 class="cat-card__name" data-translate="true" data-original="{{ categorie.nom|e('html_attr') }}">{{ categorie.nom }}</h2>
                    <p class="cat-card__desc" data-translate="true" data-original="{{ categorie.description|e('html_attr') }}">{{ categorie.description }}</p>

                    <div class="cat-card__meta">
                        <span class="cat-card__tag cat-card__tag--intensity" data-translate="true" data-original="{{ categorie.niveauintensite|e('html_attr') }}">
                             {{ categorie.niveauintensite }}
                        </span>
                        <span class="cat-card__tag cat-card__tag--public" data-translate="true" data-original="{{ ('👥 ' ~ categorie.publiccible)|e('html_attr') }}">
                            👥 {{ categorie.publiccible }}
                        </span>
                    </div>

                    <span class="cat-card__cta">
                        <span data-translate="true">Voir les activités</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </div>
            </a>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/travelmate-mymemory-translate.js') }}"></script>
<script>
(function () {
    function bootTranslate() {
        if (window.TravelMateTranslate) {
            TravelMateTranslate.init({ sourceLang: 'fr' });
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootTranslate);
    } else {
        bootTranslate();
    }
})();
</script>
{% endblock %}
