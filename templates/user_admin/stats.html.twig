{% extends 'base_admin.html.twig' %}

{% block title %}Statistiques utilisateurs | Administration TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stats-page {
            display: grid;
            gap: 1.5rem;
        }

        .admin-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.6rem;
            border-radius: 28px;
            border: 1px solid var(--admin-border);
            background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.9));
        }

        .admin-page-header__eyebrow {
            display: inline-block;
            margin-bottom: .45rem;
            color: var(--admin-secondary);
            font-size: .8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

        .admin-page-header__title {
            font-family: 'Fraunces', serif;
            font-size: 1.9rem;
            line-height: 1.08;
            color: var(--admin-text);
            margin-bottom: .45rem;
        }

        .admin-page-header__desc {
            max-width: 60ch;
            color: var(--admin-text-muted);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            padding: .82rem 1.1rem;
            border-radius: 999px;
            border: 1px solid transparent;
            cursor: pointer;
            transition: all .18s ease;
            text-decoration: none;
            font-weight: 600;
        }

        .btn:hover {
            transform: translateY(-1px);
        }

        .btn--ghost {
            background: transparent;
            color: var(--admin-text-muted);
            border-color: var(--admin-border);
        }

        .btn--ghost:hover {
            background: rgba(196, 111, 75, 0.08);
            color: var(--admin-primary);
            border-color: rgba(196, 111, 75, 0.28);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1rem;
        }

        .stat-card,
        .chart-card {
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--admin-border);
            border-radius: 26px;
            padding: 1.25rem;
            box-shadow: var(--admin-shadow-soft);
        }

        .stat-card__label {
            display: block;
            color: var(--admin-text-muted);
            font-size: .84rem;
            margin-bottom: .35rem;
        }

        .stat-card__value {
            display: block;
            font-size: 2rem;
            font-weight: 700;
            color: var(--admin-text);
            line-height: 1;
        }

        .stat-card__meta {
            display: block;
            margin-top: .45rem;
            color: var(--admin-text-muted);
            font-size: .84rem;
        }

        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1.1fr;
            gap: 1rem;
        }

        .chart-title {
            font-size: 1.2rem;
            color: var(--admin-text);
            margin-bottom: .35rem;
        }

        .chart-subtitle {
            color: var(--admin-text-muted);
            margin-bottom: 1rem;
        }

        .role-bars {
            display: grid;
            gap: 1rem;
        }

        .role-bar__top {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: .4rem;
            color: var(--admin-text-muted);
            font-size: .9rem;
        }

        .role-bar__top strong {
            color: var(--admin-text);
        }

        .progress {
            height: 14px;
            border-radius: 999px;
            background: rgba(196, 111, 75, 0.10);
            overflow: hidden;
        }

        .progress span {
            display: block;
            height: 100%;
            border-radius: inherit;
        }

        .progress--admin span {
            background: linear-gradient(90deg, var(--admin-primary), #d69372);
        }

        .progress--user {
            background: rgba(47, 127, 121, 0.10);
        }

        .progress--user span {
            background: linear-gradient(90deg, var(--admin-secondary), #63aaa4);
        }

        .daily-chart {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: .75rem;
            align-items: end;
            min-height: 280px;
            padding-top: 1rem;
        }

        .daily-chart__item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: end;
            gap: .65rem;
            min-height: 260px;
        }

        .daily-chart__value {
            font-size: .85rem;
            font-weight: 700;
            color: var(--admin-text);
        }

        .daily-chart__bar-wrap {
            width: 100%;
            max-width: 52px;
            height: 190px;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            background: rgba(243, 234, 223, 0.45);
            border-radius: 18px;
            padding: .4rem;
        }

        .daily-chart__bar {
            width: 100%;
            border-radius: 14px;
            background: linear-gradient(180deg, var(--admin-secondary), var(--admin-primary));
            min-height: 10px;
            transition: height .3s ease;
        }

        .daily-chart__label {
            font-size: .8rem;
            color: var(--admin-text-muted);
            text-align: center;
        }

        @media (max-width: 980px) {
            .charts-grid,
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .admin-page-header {
                padding: 1.2rem;
            }

            .admin-page-header__title {
                font-size: 1.5rem;
            }

            .daily-chart {
                gap: .45rem;
            }
        }

        /* Second row of stat cards */
        .stats-grid--insights {
            margin-top: 1.5rem;
        }
        .stat-card--highlight {
            background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
            border-left: 4px solid #4f46e5;
        }
        .progress--verified span { background: #10b981; }
        .progress--unverified span { background: #f59e0b; }
        .chart-card--wide {
            grid-column: span 2;
        }
        .daily-chart--30 .daily-chart__item {
            min-width: 24px;
        }
        @media (max-width: 1024px) {
            .daily-chart--30 .daily-chart__item {
                min-width: 20px;
            }
        }

        /* Age Statistics */
        .stats-section {
            margin-top: 3rem;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #1f2937;
        }

        .section-subtitle {
            color: #6b7280;
            margin-bottom: 1.5rem;
        }

        .stats-grid--age {
            grid-template-columns: repeat(3, 1fr);
            margin-bottom: 2rem;
        }

        .stat-card--age-summary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .stat-card--age-summary .stat-card__label,
        .stat-card--age-summary .stat-card__meta {
            color: rgba(255, 255, 255, 0.9);
        }

        .age-distribution {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .age-range__header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .age-range__label {
            font-weight: 500;
            color: #374151;
        }

        .age-range__count {
            color: #6b7280;
        }

        .birth-years {
            overflow-x: auto;
        }

        .birth-years__chart {
            display: flex;
            align-items: flex-end;
            gap: 0.5rem;
            min-height: 200px;
            padding: 1rem 0;
        }

        .birth-year__item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }

        .birth-year__bar-wrap {
            height: 150px;
            display: flex;
            align-items: flex-end;
            width: 100%;
        }

        .birth-year__bar {
            width: 100%;
            background: linear-gradient(to top, #667eea, #764ba2);
            border-radius: 4px 4px 0 0;
            transition: height 0.3s ease;
            min-height: 2px;
        }

        .birth-year__label {
            font-size: 0.7rem;
            color: #6b7280;
            transform: rotate(-45deg);
            white-space: nowrap;
        }

        .birth-year__count {
            font-size: 0.75rem;
            font-weight: 600;
            color: #374151;
        }

        .progress--neutral span {
            background: #9ca3af;
        }

        @media (max-width: 768px) {
            .stats-grid--age {
                grid-template-columns: 1fr;
            }
            
            .birth-year__label {
                transform: rotate(-90deg);
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="stats-page">
        <div class="admin-page-header">
            <div>
                <span class="admin-page-header__eyebrow">Administration</span>
                <h1 class="admin-page-header__title">Statistiques utilisateurs</h1>
                <p class="admin-page-header__desc">
                    Analyse complète de la répartition des rôles, de la vérification des comptes et de l’évolution des inscriptions.
                </p>
            </div>
            <a href="{{ path('app_admin_users') }}" class="btn btn--ghost">Retour à la liste</a>
        </div>

        {# First row: core stats #}
        <div class="stats-grid">
            <article class="stat-card">
                <span class="stat-card__label">Total utilisateurs</span>
                <span class="stat-card__value">{{ totalUsers }}</span>
                <span class="stat-card__meta">Comptes présents</span>
            </article>
            <article class="stat-card">
                <span class="stat-card__label">Administrateurs</span>
                <span class="stat-card__value">{{ adminCount }}</span>
                <span class="stat-card__meta">{{ adminPercentage }}% du total</span>
            </article>
            <article class="stat-card">
                <span class="stat-card__label">Utilisateurs standards</span>
                <span class="stat-card__value">{{ userCount }}</span>
                <span class="stat-card__meta">{{ userPercentage }}% du total</span>
            </article>
            <article class="stat-card">
                <span class="stat-card__label">✅ Comptes vérifiés</span>
                <span class="stat-card__value">{{ verifiedCount }}</span>
                <span class="stat-card__meta">{{ verifiedPercentage }}% du total</span>
            </article>
            <article class="stat-card">
                <span class="stat-card__label">⚠️ Non vérifiés</span>
                <span class="stat-card__value">{{ unverifiedCount }}</span>
                <span class="stat-card__meta">En attente d’activation</span>
            </article>
            <article class="stat-card">
                <span class="stat-card__label">📱 Actifs (30j)</span>
                <span class="stat-card__value">{{ activeLast30 }}</span>
                <span class="stat-card__meta">{{ activePercentage }}% se sont connectés récemment</span>
            </article>
        </div>

        {# Second row: registration insights #}
        <div class="stats-grid stats-grid--insights">
            <article class="stat-card stat-card--highlight">
                <span class="stat-card__label">📈 Inscriptions (7j)</span>
                <span class="stat-card__value">{{ registrationsByDay|sum }}</span>
                <span class="stat-card__meta">Moyenne : {{ avgDailyRegistrations }}/jour</span>
            </article>
            <article class="stat-card stat-card--highlight">
                <span class="stat-card__label">🏆 Pic d’inscriptions</span>
                <span class="stat-card__value">{{ peakDay ? peakDay|date('d/m') : 'N/A' }}</span>
                <span class="stat-card__meta">{{ registrationsByDay[peakDay] ?? 0 }} nouveaux comptes</span>
            </article>
            <article class="stat-card stat-card--highlight">
                <span class="stat-card__label">📊 Croissance (30j vs 30j préc.)</span>
                <span class="stat-card__value">{{ growth.percentageChange > 0 ? '+' : '' }}{{ growth.percentageChange }}%</span>
                <span class="stat-card__meta">
                    {{ growth.last30Total }} inscriptions récentes vs {{ growth.previous30Total }} avant
                </span>
            </article>
        </div>

        {# Charts row #}
        <div class="charts-grid">
            {# Role distribution bar chart #}
            <article class="chart-card">
                <h2 class="chart-title">Répartition des rôles</h2>
                <div class="role-bars">
                    <div>
                        <div class="role-bar__top">
                            <span>Administrateurs</span>
                            <strong>{{ adminCount }} ({{ adminPercentage }}%)</strong>
                        </div>
                        <div class="progress progress--admin">
                            <span style="width: {{ adminPercentage }}%;"></span>
                        </div>
                    </div>
                    <div>
                        <div class="role-bar__top">
                            <span>Utilisateurs</span>
                            <strong>{{ userCount }} ({{ userPercentage }}%)</strong>
                        </div>
                        <div class="progress progress--user">
                            <span style="width: {{ userPercentage }}%;"></span>
                        </div>
                    </div>
                </div>
            </article>

            {# Verification status pie-like (simplified bar) #}
            <article class="chart-card">
                <h2 class="chart-title">Vérification des comptes</h2>
                <div class="role-bars">
                    <div>
                        <div class="role-bar__top">
                            <span>✅ Vérifiés</span>
                            <strong>{{ verifiedCount }} ({{ verifiedPercentage }}%)</strong>
                        </div>
                        <div class="progress progress--verified">
                            <span style="width: {{ verifiedPercentage }}%;"></span>
                        </div>
                    </div>
                    <div>
                        <div class="role-bar__top">
                            <span>⚠️ Non vérifiés</span>
                            <strong>{{ unverifiedCount }} ({{ 100 - verifiedPercentage }}%)</strong>
                        </div>
                        <div class="progress progress--unverified">
                            <span style="width: {{ 100 - verifiedPercentage }}%;"></span>
                        </div>
                    </div>
                </div>
            </article>

            {# Daily registrations (7 days) #}
            <article class="chart-card">
                <h2 class="chart-title">Inscriptions sur 7 jours</h2>
                <div class="daily-chart">
                    {% for date, count in registrationsByDay %}
                        {% set height = maxRegistrations > 0 ? (count / maxRegistrations) * 100 : 5 %}
                        <div class="daily-chart__item">
                            <div class="daily-chart__value">{{ count }}</div>
                            <div class="daily-chart__bar-wrap">
                                <div class="daily-chart__bar" style="height: {{ height < 8 and count > 0 ? 8 : height }}%;"></div>
                            </div>
                            <div class="daily-chart__label">{{ date|date('d/m') }}</div>
                        </div>
                    {% endfor %}
                </div>
            </article>

            {# Optional: 30-day trend line (simplified as bar chart) #}
            <article class="chart-card chart-card--wide">
                <h2 class="chart-title">Évolution sur 30 jours</h2>
                <div class="daily-chart daily-chart--30">
                    {% for date, count in registrationsLast30 %}
                        {% set height = max30 > 0 ? (count / max30) * 100 : 5 %}
                        <div class="daily-chart__item">
                            <div class="daily-chart__value" style="font-size: 0.7rem;">{{ count }}</div>
                            <div class="daily-chart__bar-wrap">
                                <div class="daily-chart__bar" style="height: {{ height < 8 and count > 0 ? 8 : height }}%;"></div>
                            </div>
                            <div class="daily-chart__label">{{ date|date('d/m') }}</div>
                        </div>
                    {% endfor %}
                </div>
            </article>
        </div>

        {# Age Statistics Section #}
        <div class="stats-section">
            <h2 class="section-title">📊 Démographie par âge</h2>
            <p class="section-subtitle">Répartition des utilisateurs par tranche d'âge</p>

            <div class="stats-grid stats-grid--age">
                <article class="stat-card">
                    <span class="stat-card__label">Âge moyen</span>
                    <span class="stat-card__value">{{ averageAge }} ans</span>
                    <span class="stat-card__meta">Moyenne globale</span>
                </article>

                <article class="stat-card">
                    <span class="stat-card__label">Plus jeune</span>
                    <span class="stat-card__value">{{ youngestAge ?? 'N/A' }} ans</span>
                    <span class="stat-card__meta">Âge minimum</span>
                </article>

                <article class="stat-card">
                    <span class="stat-card__label">Plus âgé</span>
                    <span class="stat-card__value">{{ oldestAge ?? 'N/A' }} ans</span>
                    <span class="stat-card__meta">Âge maximum</span>
                </article>
            </div>

            <div class="charts-grid">
                {# Age distribution bar chart #}
                <article class="chart-card">
                    <h2 class="chart-title">Répartition par tranche d'âge</h2>
                    
                    <div class="age-distribution">
                        {% for range, count in ageDistribution %}
                            {% if range != 'unknown' %}
                                {% set percentage = totalWithAge > 0 ? (count / totalWithAge) * 100 : 0 %}
                                <div class="age-range">
                                    <div class="age-range__header">
                                        <span class="age-range__label">
                                            {% if range == 'under-18' %}
                                                Moins de 18 ans
                                            {% else %}
                                                {{ range }} ans
                                            {% endif %}
                                        </span>
                                        <span class="age-range__count">{{ count }} utilisateurs ({{ percentage|round(1) }}%)</span>
                                    </div>
                                    <div class="progress progress--admin">
                                        <span style="width: {{ percentage }}%;"></span>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                        
                        {% if ageDistribution.unknown is defined and ageDistribution.unknown > 0 %}
                            <div class="age-range">
                                <div class="age-range__header">
                                    <span class="age-range__label">Non renseigné</span>
                                    <span class="age-range__count">{{ ageDistribution.unknown }} utilisateurs</span>
                                </div>
                                <div class="progress progress--neutral">
                                    <span style="width: {{ (ageDistribution.unknown / totalUsers) * 100 }}%;"></span>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </article>

                {# Birth year distribution (compact version) #}
                <article class="chart-card">
                    <h2 class="chart-title">Distribution par année de naissance</h2>
                    <div class="birth-years">
                        {% if birthYears|length > 0 %}
                            {% set maxYearCount = birthYears|max %}
                            <div class="birth-years__chart">
                                {% for year, count in birthYears %}
                                    {% set height = (count / maxYearCount) * 100 %}
                                    <div class="birth-year__item">
                                        <div class="daily-chart__bar-wrap">
                                            <div class="daily-chart__bar" style="height: {{ height < 8 and count > 0 ? 8 : height }}%;"></div>
                                        </div>
                                        <div class="birth-year__label">{{ year }}</div>
                                        <div class="birth-year__count">{{ count }}</div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-muted">Aucune donnée d'âge disponible</p>
                        {% endif %}
                    </div>
                </article>
            </div>
        </div>
    </section>
{% endblock %}