{% extends 'base_admin.html.twig' %}

{% block title %}Utilisateurs | Administration TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-users-page {
            display: grid;
            gap: 1.5rem;
        }

        .admin-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.6rem;
            border-radius: 28px;
            border: 1px solid var(--admin-border);
            background: linear-gradient(135deg, rgba(255,253,249,0.96), rgba(243,234,223,0.9));
        }

        .admin-page-header__eyebrow {
            display: inline-block;
            margin-bottom: .45rem;
            color: var(--admin-secondary);
            font-size: .8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

        .admin-page-header__title {
            font-family: 'Fraunces', serif;
            font-size: 1.9rem;
            line-height: 1.08;
            color: var(--admin-text);
            margin-bottom: .45rem;
        }

        .admin-page-header__desc {
            max-width: 60ch;
            color: var(--admin-text-muted);
        }

        .admin-page-header__actions {
            display: flex;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .flash-stack {
            display: grid;
            gap: .75rem;
        }

        .flash-message {
            padding: .95rem 1rem;
            border-radius: 16px;
            font-size: .95rem;
            border: 1px solid transparent;
        }

        .flash-message--success {
            background: rgba(47, 127, 121, 0.10);
            border-color: rgba(47, 127, 121, 0.16);
            color: #245f5a;
        }

        .flash-message--error {
            background: rgba(191, 91, 91, 0.10);
            border-color: rgba(191, 91, 91, 0.16);
            color: #9e4747;
        }

        .admin-card {
            background: rgba(255, 253, 249, 0.94);
            border: 1px solid var(--admin-border);
            border-radius: 26px;
            padding: 1.25rem;
            box-shadow: var(--admin-shadow-soft);
        }

        .toolbar {
            display: grid;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .toolbar__top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .toolbar__count {
            padding: .55rem .9rem;
            border-radius: 999px;
            background: rgba(196, 111, 75, 0.1);
            color: var(--admin-primary);
            font-weight: 700;
            font-size: .84rem;
        }

        .filters-form {
            display: grid;
            grid-template-columns: minmax(240px, 1.5fr) 180px 180px auto auto;
            gap: .75rem;
            align-items: end;
        }

        .filters-form__group {
            display: grid;
            gap: .4rem;
        }

        .filters-form__group label {
            font-size: .82rem;
            color: var(--admin-text-muted);
            font-weight: 700;
        }

        .filters-form input,
        .filters-form select {
            min-height: 46px;
            padding: .8rem 1rem;
            border-radius: 14px;
            border: 1px solid var(--admin-border);
            background: #fffdfa;
            outline: none;
        }

        .filters-form input:focus,
        .filters-form select:focus {
            border-color: rgba(196, 111, 75, 0.35);
            box-shadow: 0 0 0 4px rgba(196, 111, 75, 0.08);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            padding: .82rem 1.1rem;
            border-radius: 999px;
            border: 1px solid transparent;
            cursor: pointer;
            transition: all .18s ease;
            text-decoration: none;
            font-weight: 600;
        }

        .btn:hover {
            transform: translateY(-1px);
        }

        .btn--primary {
            background: var(--admin-primary);
            color: #fff;
        }

        .btn--primary:hover {
            background: var(--admin-primary-dark);
        }

        .btn--ghost {
            background: transparent;
            color: var(--admin-text-muted);
            border-color: var(--admin-border);
        }

        .btn--ghost:hover {
            background: rgba(196, 111, 75, 0.08);
            color: var(--admin-primary);
            border-color: rgba(196, 111, 75, 0.28);
        }

        .users-table-wrap {
            overflow-x: auto;
        }

        .users-table {
            width: 100%;
            min-width: 980px;
            border-collapse: collapse;
        }

        .users-table th {
            text-align: left;
            padding: 0 0 .85rem;
            border-bottom: 1px solid var(--admin-border);
            color: var(--admin-text-muted);
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            font-weight: 700;
        }

        .users-table td {
            padding: 1rem 0;
            border-bottom: 1px solid rgba(231, 220, 205, 0.7);
            color: var(--admin-text);
            font-size: .94rem;
            vertical-align: middle;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: .8rem;
        }

        .user-cell__avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            object-fit: cover;
            background: var(--admin-surface-alt);
            border: 2px solid rgba(196,111,75,.12);
            flex-shrink: 0;
        }

        .user-cell__name {
            font-weight: 700;
            color: var(--admin-text);
        }

        .user-cell__email {
            font-size: .85rem;
            color: var(--admin-text-muted);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: .38rem .75rem;
            border-radius: 999px;
            font-size: .74rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .status-pill--success {
            background: var(--admin-success-soft);
            color: var(--admin-success);
        }

        .status-pill--warning {
            background: var(--admin-warning-soft);
            color: var(--admin-warning);
        }

        .status-pill--role-admin {
            background: rgba(196, 111, 75, 0.12);
            color: var(--admin-primary);
        }

        .status-pill--role-user {
            background: rgba(47, 127, 121, 0.12);
            color: var(--admin-secondary);
        }

        .table-actions {
            display: flex;
            gap: .6rem;
            flex-wrap: wrap;
        }

        .empty-state {
            padding: 2rem 1rem;
            text-align: center;
            color: var(--admin-text-muted);
        }

        .danger-inline {
            display: inline;
        }

        .btn-delete {
            background: rgba(191, 91, 91, 0.12);
            color: #aa4f4f;
            border-color: rgba(191, 91, 91, 0.18);
        }

        .btn-delete:hover {
            background: rgba(191, 91, 91, 0.18);
        }

        @media (max-width: 1100px) {
            .filters-form {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 760px) {
            .admin-page-header {
                padding: 1.2rem;
            }

            .admin-page-header__title {
                font-size: 1.5rem;
            }

            .filters-form {
                grid-template-columns: 1fr;
            }
        }

        .users-table th[data-sort] {
            cursor: pointer;
            user-select: none;
            position: relative;
            padding-right: 20px;
        }

        .users-table th[data-sort]:hover {
            background-color: rgba(0,0,0,0.05);
        }

        .sort-arrow {
            position: absolute;
            right: 8px;
            font-size: 0.8rem;
            opacity: 0.7;
        }
    </style>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
        const table = document.querySelector('.users-table');
        if (!table) return;

        const headers = table.querySelectorAll('thead th[data-sort]');
        let currentSort = { column: null, direction: 'asc' };

        headers.forEach(header => {
            header.style.cursor = 'pointer';
            header.addEventListener('click', () => sortTable(header));
        });

        function sortTable(header) {
            const columnIndex = Array.from(header.parentElement.children).indexOf(header);
            const sortType = header.getAttribute('data-sort');
            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            // Toggle direction if same column, else default to asc
            if (currentSort.column === columnIndex) {
                currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
            } else {
                currentSort.direction = 'asc';
            }
            currentSort.column = columnIndex;

            // Sort rows
            rows.sort((rowA, rowB) => {
                let cellA = rowA.children[columnIndex];
                let cellB = rowB.children[columnIndex];
                let valueA, valueB;

                switch (sortType) {
                    case 'string':
                        // For "Utilisateur" column, we need to get the name from inner div
                        if (columnIndex === 0) {
                            const nameA = cellA.querySelector('.user-cell__name');
                            const nameB = cellB.querySelector('.user-cell__name');
                            valueA = nameA ? nameA.textContent.trim() : '';
                            valueB = nameB ? nameB.textContent.trim() : '';
                        } else {
                            valueA = cellA.textContent.trim();
                            valueB = cellB.textContent.trim();
                        }
                        return compareStrings(valueA, valueB, currentSort.direction);
                    
                    case 'role':
                        const roleOrder = { 'ADMIN': 1, 'USER': 2 };
                        const roleA = cellA.querySelector('.status-pill--role-admin, .status-pill--role-user');
                        const roleB = cellB.querySelector('.status-pill--role-admin, .status-pill--role-user');
                        valueA = roleA ? (roleA.classList.contains('status-pill--role-admin') ? 'ADMIN' : 'USER') : '';
                        valueB = roleB ? (roleB.classList.contains('status-pill--role-admin') ? 'ADMIN' : 'USER') : '';
                        return compareNumbers(roleOrder[valueA] || 3, roleOrder[valueB] || 3, currentSort.direction);
                    
                    case 'verification':
                        const verifiedOrder = { 'Vérifié': 1, 'Non vérifié': 2 };
                        const statusSpanA = cellA.querySelector('.status-pill--success, .status-pill--warning');
                        const statusSpanB = cellB.querySelector('.status-pill--success, .status-pill--warning');
                        valueA = statusSpanA ? statusSpanA.textContent.trim() : '';
                        valueB = statusSpanB ? statusSpanB.textContent.trim() : '';
                        return compareNumbers(verifiedOrder[valueA] || 3, verifiedOrder[valueB] || 3, currentSort.direction);
                    
                    case 'date':
                        // Parse date from format "dd/mm/yyyy HH:ii"
                        const dateA = parseDate(cellA.textContent.trim());
                        const dateB = parseDate(cellB.textContent.trim());
                        return compareNumbers(dateA, dateB, currentSort.direction);
                    
                    default:
                        return 0;
                }
            });

            // Reorder rows in the DOM
            rows.forEach(row => tbody.appendChild(row));

            // Update visual indicator on headers (optional)
            updateSortIcons(header);
        }

        function compareStrings(a, b, direction) {
            a = a.toLowerCase();
            b = b.toLowerCase();
            if (a === b) return 0;
            const result = a > b ? 1 : -1;
            return direction === 'asc' ? result : -result;
        }

        function compareNumbers(a, b, direction) {
            if (a === b) return 0;
            const result = a > b ? 1 : -1;
            return direction === 'asc' ? result : -result;
        }

        function parseDate(dateStr) {
            if (!dateStr || dateStr === '—') return 0;
            // Format: "dd/mm/yyyy HH:ii"
            const [datePart, timePart] = dateStr.split(' ');
            const [day, month, year] = datePart.split('/');
            const [hour, minute] = timePart ? timePart.split(':') : ['00', '00'];
            return new Date(year, month - 1, day, hour, minute).getTime();
        }

        function updateSortIcons(clickedHeader) {
            // Remove any existing arrow indicators
            headers.forEach(h => {
                h.classList.remove('sort-asc', 'sort-desc');
                // Optional: remove inner arrow spans
                const arrow = h.querySelector('.sort-arrow');
                if (arrow) arrow.remove();
            });

            // Add arrow to current column
            const arrowSpan = document.createElement('span');
            arrowSpan.className = 'sort-arrow';
            arrowSpan.textContent = currentSort.direction === 'asc' ? ' ↑' : ' ↓';
            clickedHeader.appendChild(arrowSpan);
            clickedHeader.classList.add(currentSort.direction === 'asc' ? 'sort-asc' : 'sort-desc');
        }
    });
    </script>
{% endblock %}

{% block body %}
    <section class="admin-users-page">
        <div class="admin-page-header">
            <div>
                <span class="admin-page-header__eyebrow">Administration</span>
                <h1 class="admin-page-header__title">Gestion des utilisateurs</h1>
                <p class="admin-page-header__desc">
                    Consultez, recherchez, filtrez, triez, ajoutez, modifiez et supprimez les comptes utilisateurs.
                </p>
            </div>

            <div class="admin-page-header__actions">
                <a href="{{ path('app_admin_users_stats') }}" class="btn btn--ghost">Voir les statistiques</a>
                <a href="{{ path('app_admin_users_new') }}" class="btn btn--primary">+ Ajouter un utilisateur</a>
            </div>
        </div>

        <div class="flash-stack">
            {% for message in app.flashes('success') %}
                <div class="flash-message flash-message--success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash-message flash-message--error">{{ message }}</div>
            {% endfor %}
        </div>

        <div class="admin-card">
            <div class="toolbar">
                <div class="toolbar__top">
                    <span class="toolbar__count">
                        {{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }}
                    </span>
                </div>

                <form method="get" class="filters-form">
                    <div class="filters-form__group">
                        <label for="q">Recherche</label>
                        <input
                            id="q"
                            type="text"
                            name="q"
                            value="{{ search }}"
                            placeholder="Nom, prénom ou email..."
                        >
                    </div>

                    <div class="filters-form__group">
                        <label for="role">Rôle</label>
                        <select name="role" id="role">
                            <option value="" {{ selectedRole == '' ? 'selected' : '' }}>Tous</option>
                            <option value="ADMIN" {{ selectedRole == 'ADMIN' ? 'selected' : '' }}>Administrateurs</option>
                            <option value="USER" {{ selectedRole == 'USER' ? 'selected' : '' }}>Utilisateurs</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn--ghost">Appliquer</button>

                    <a href="{{ path('app_admin_users') }}" class="btn btn--ghost">Réinitialiser</a>
                </form>
            </div>

            {% if users is not empty %}
                <div class="users-table-wrap">
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th data-sort="string">Utilisateur</th>
                                <th data-sort="string">Téléphone</th>
                                <th data-sort="role">Rôle</th>
                                <th data-sort="verification">Vérification</th>
                                <th data-sort="date">Date création</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <img src="{{ user.profileImage }}" alt="Photo" class="user-cell__avatar">
                                            <div>
                                                <div class="user-cell__name">{{ user.prenom }} {{ user.nom }}</div>
                                                <div class="user-cell__email">{{ user.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>{{ user.telephone ?: '—' }}</td>
                                    <td>
                                        <span class="status-pill {{ user.role == 'ADMIN' ? 'status-pill--role-admin' : 'status-pill--role-user' }}">
                                            {{ user.role }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-pill {{ user.isVerified ? 'status-pill--success' : 'status-pill--warning' }}">
                                            {{ user.isVerified ? 'Vérifié' : 'Non vérifié' }}
                                        </span>
                                    </td>
                                    <td>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '—' }}</td>
                                    <td>
                                        <div class="table-actions">
                                            <a href="{{ path('app_admin_users_edit', {'id': user.id}) }}" class="btn btn--ghost">
                                                Modifier
                                            </a>

                                            <form method="post"
                                                  action="{{ path('app_admin_users_delete', {'id': user.id}) }}"
                                                  class="danger-inline"
                                                  onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                                <button type="submit" class="btn btn-delete">
                                                    Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="empty-state">
                    Aucun utilisateur trouvé avec ces critères.
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}