{% extends 'base.html.twig' %}

{% block title %}Recherche de vols | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .flights-page { display: grid; gap: 1.75rem; }

        .flights-hero {
            position: relative; padding: 2.2rem; overflow: hidden;
            background: radial-gradient(circle at top left, rgba(221,191,140,.28), transparent 30%),
                linear-gradient(135deg, rgba(255,253,249,.98), rgba(243,234,223,.92));
            border: 1px solid rgba(231,220,205,.6); border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71,48,35,.06);
        }
        .flights-hero__eyebrow {
            display: inline-flex; align-items: center; gap: .5rem;
            color: var(--color-primary); font-size: .95rem; font-weight: 700;
            letter-spacing: .14em; text-transform: uppercase; margin-bottom: .6rem;
        }
        .flights-hero__title { font-family: 'Fraunces', serif; font-size: clamp(2rem, 2.8vw, 3rem); line-height: 1.08; color: var(--color-text); margin-bottom: .5rem; }
        .flights-hero__subtitle { color: var(--color-text-muted); font-size: 1.05rem; max-width: 600px; }

        .flights-search {
            display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;
            background: var(--color-surface); border: 1px solid var(--color-border);
            border-radius: var(--radius-xl); padding: 1.5rem 1.8rem;
            box-shadow: 0 6px 24px rgba(71,48,35,.04);
        }
        .flights-search__field { display: flex; flex-direction: column; gap: .35rem; flex: 1 1 200px; }
        .flights-search__label { font-size: .82rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: .08em; }
        .flights-search__input {
            padding: .78rem 1rem; border-radius: var(--radius-md);
            border: 1px solid var(--color-border); background: var(--color-surface-soft);
            font-family: inherit; font-size: .95rem; color: var(--color-text);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }
        .flights-search__input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(196,111,75,.12); }
        .flights-search__btn {
            padding: .82rem 1.6rem; border-radius: 999px; background: var(--color-primary);
            color: #fff; border: none; font-weight: 600; font-size: .95rem; cursor: pointer;
            transition: background var(--transition-fast), transform var(--transition-fast);
            display: inline-flex; align-items: center; gap: .5rem; flex-shrink: 0;
        }
        .flights-search__btn:hover { background: var(--color-primary-dark); transform: translateY(-1px); }

        .flights-alert { padding: 1.2rem 1.5rem; border-radius: var(--radius-lg); font-size: .95rem; line-height: 1.5; }
        .flights-alert--warning { background: rgba(196,111,75,.08); color: #8a4a2e; border: 1px solid rgba(196,111,75,.2); }
        .flights-alert--info { background: rgba(47,127,121,.08); color: var(--color-secondary); border: 1px solid rgba(47,127,121,.18); }
        .flights-alert--error { background: rgba(180,40,40,.07); color: #923030; border: 1px solid rgba(180,40,40,.18); }

        .flights-count {
            font-size: 1.05rem; color: var(--color-text-muted); padding: .5rem 0;
        }
        .flights-count strong { color: var(--color-primary); }

        /* Flight card */
        .flight-card {
            display: grid; grid-template-columns: 1fr auto;
            gap: 1rem; padding: 1.5rem;
            background: var(--color-surface); border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            transition: box-shadow var(--transition-fast), transform var(--transition-fast);
        }
        .flight-card:hover { box-shadow: 0 12px 32px rgba(71,48,35,.1); transform: translateY(-2px); }

        .flight-card__main { display: flex; flex-direction: column; gap: .8rem; }

        .flight-card__header {
            display: flex; align-items: center; gap: .8rem; flex-wrap: wrap;
        }
        .flight-card__flight-number {
            font-family: 'Fraunces', serif; font-weight: 700; font-size: 1.1rem;
            color: var(--color-primary); background: rgba(196,111,75,.08);
            padding: .25rem .7rem; border-radius: var(--radius-md);
        }
        .flight-card__airline-name { font-weight: 600; font-size: .9rem; color: var(--color-text); }

        .flight-card__route {
            display: flex; align-items: center; gap: 1rem;
        }
        .flight-card__time {
            font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 700;
            color: var(--color-text); line-height: 1;
        }
        .flight-card__airport-code { font-size: .8rem; color: var(--color-text-muted); font-weight: 600; }
        .flight-card__airport-name { font-size: .72rem; color: var(--color-text-muted); max-width: 120px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        .flight-card__path {
            flex: 1; display: flex; flex-direction: column; align-items: center; gap: .2rem;
            min-width: 100px;
        }
        .flight-card__duration { font-size: .8rem; color: var(--color-text-muted); font-weight: 600; }
        .flight-card__line {
            width: 100%; height: 2px; position: relative;
            background: linear-gradient(90deg, var(--color-border), var(--color-primary), var(--color-border));
            border-radius: 2px;
        }
        .flight-card__line::after { content: '✈'; position: absolute; top: -10px; right: -4px; font-size: .8rem; color: var(--color-primary); }
        .flight-card__stops {
            font-size: .78rem; font-weight: 600; padding: .15rem .5rem;
            border-radius: 999px;
        }
        .flight-card__stops--direct { background: rgba(47,127,121,.1); color: var(--color-secondary); }

        .flight-card__info-box {
            display: flex; flex-direction: column; align-items: flex-end;
            justify-content: center; gap: .4rem; min-width: 110px;
        }
        .flight-card__status {
            font-size: .82rem; font-weight: 700; padding: .25rem .7rem;
            border-radius: 999px; text-transform: uppercase; letter-spacing: .05em;
        }
        .flight-card__status--scheduled { background: rgba(47,127,121,.1); color: var(--color-secondary); }
        .flight-card__status--active { background: rgba(59,130,246,.12); color: #2563eb; }
        .flight-card__status--landed { background: rgba(34,197,94,.1); color: #16a34a; }
        .flight-card__status--cancelled { background: rgba(239,68,68,.1); color: #dc2626; }
        .flight-card__status--delayed { background: rgba(245,158,11,.1); color: #d97706; }
        .flight-card__status--default { background: var(--color-surface-soft); color: var(--color-text-muted); }

        .flight-card__meta { font-size: .78rem; color: var(--color-text-muted); text-align: right; }
        .flight-card__meta strong { color: var(--color-text); }

        .flights-empty {
            text-align: center; padding: 3rem 1.5rem; background: var(--color-surface);
            border: 1px dashed var(--color-border); border-radius: var(--radius-xl);
        }
        .flights-empty__icon { font-size: 3rem; margin-bottom: .8rem; }
        .flights-empty__title { font-family: 'Fraunces', serif; font-size: 1.4rem; color: var(--color-text); margin-bottom: .4rem; }
        .flights-empty__text { color: var(--color-text-muted); font-size: .95rem; }

        @media (max-width: 700px) {
            .flight-card { grid-template-columns: 1fr; }
            .flight-card__info-box { flex-direction: row; align-items: center; gap: 1rem; }
            .flight-card__route { flex-wrap: wrap; }
            .flights-search { flex-direction: column; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="flights-page">


    <section class="flights-hero">
        <div class="flights-hero__eyebrow">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 1L1 8l6 3 7-7-7 7 3 6z"/></svg>
            Recherche de vols
        </div>
        <h1 class="flights-hero__title">Trouvez votre vol</h1>
        <p class="flights-hero__subtitle">
            <span style="display:inline-block;padding:.4em 1em;margin-bottom:.5em;background:rgba(47,127,121,.08);color:var(--color-secondary);border-radius:999px;font-size:.98em;font-weight:600;">
                <svg style="vertical-align:middle;margin-right:.3em;" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="7"/><path d="M8 4v4l3 3"/></svg>
                <span>Seuls les vols en <strong>temps réel</strong> sont affichés (données du jour uniquement)</span>
            </span><br>
            Consultez les vols en temps réel depuis Tunis-Carthage.
            {% if voyageSelectionne %}
                Voyage : <strong>{{ voyageSelectionne.titre_voyage }}</strong>
            {% endif %}
        </p>
    </section>

    <form class="flights-search" method="GET" action="{{ path('app_flights') }}">
        {% if voyageId %}
            <input type="hidden" name="voyageId" value="{{ voyageId }}">
        {% endif %}

        <div class="flights-search__field">
            <label class="flights-search__label" for="f_origin">Départ</label>
            <input class="flights-search__input" id="f_origin" type="text" value="Tunis (TUN)" disabled>
        </div>

        <div class="flights-search__field">
            <label class="flights-search__label" for="f_dest">Destination</label>
            <input class="flights-search__input" id="f_dest" type="text" name="destination"
                   value="{{ destination }}" placeholder="Ex : Paris, Istanbul, CDG…" required>
        </div>

        <div class="flights-search__field">
            <label class="flights-search__label" for="f_date">Date (info voyage)</label>
            <input class="flights-search__input" id="f_date" type="date" name="date"
                   value="{{ date }}">
        </div>

        <button class="flights-search__btn" type="submit">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            Rechercher
        </button>
    </form>

    {% if searched %}

        {% if results and results.status == 'error' %}
            <div class="flights-alert flights-alert--error">
                <strong>⚠️ Erreur</strong><br>
                {{ results.message|default('Une erreur est survenue.') }}
            </div>
        {% endif %}

        {% if results and results.status == 'no_results' %}
            <div class="flights-alert flights-alert--warning">
                <strong>✈️ Aucun vol trouvé</strong><br>
                {{ results.message }}
            </div>
        {% endif %}

        {% if results and results.status == 'ok' %}

            <div class="flights-count">
                <strong>{{ results.count }}</strong> vol{{ results.count > 1 ? 's' : '' }} en temps réel
                vers <strong>{{ destination }}</strong>
            </div>

            {% for flight in results.flights %}
                <article class="flight-card">
                    <div class="flight-card__main">
                        {# Flight number + airline #}
                        <div class="flight-card__header">
                            {% if flight.flightNumber %}
                                <span class="flight-card__flight-number">{{ flight.flightNumber }}</span>
                            {% endif %}
                            <span class="flight-card__airline-name">{{ flight.airlines|join(', ') }}</span>
                        </div>

                        {# Route: departure → arrival #}
                        <div class="flight-card__route">
                            <div>
                                <div class="flight-card__time">{{ flight.departure ? flight.departure|date('H:i') : '--:--' }}</div>
                                <div class="flight-card__airport-code">{{ flight.originCode }}</div>
                                <div class="flight-card__airport-name">{{ flight.originName }}</div>
                            </div>

                            <div class="flight-card__path">
                                {% if flight.durationFormatted %}
                                    <div class="flight-card__duration">{{ flight.durationFormatted }}</div>
                                {% endif %}
                                <div class="flight-card__line"></div>
                                <span class="flight-card__stops flight-card__stops--direct">
                                    {{ flight.stopsLabel }}
                                </span>
                            </div>

                            <div>
                                <div class="flight-card__time">{{ flight.arrival ? flight.arrival|date('H:i') : '--:--' }}</div>
                                <div class="flight-card__airport-code">{{ flight.destCode }}</div>
                                <div class="flight-card__airport-name">{{ flight.destName }}</div>
                            </div>
                        </div>
                    </div>

                    {# Status + meta info #}
                    <div class="flight-card__info-box">
                        {% set statusClass = 'default' %}
                        {% if flight.status == 'scheduled' %}{% set statusClass = 'scheduled' %}
                        {% elseif flight.status == 'active' %}{% set statusClass = 'active' %}
                        {% elseif flight.status == 'landed' %}{% set statusClass = 'landed' %}
                        {% elseif flight.status == 'cancelled' %}{% set statusClass = 'cancelled' %}
                        {% elseif flight.status == 'delayed' %}{% set statusClass = 'delayed' %}
                        {% endif %}
                        <span class="flight-card__status flight-card__status--{{ statusClass }}">
                            {{ flight.statusLabel }}
                        </span>

                        {% if flight.depTerminal or flight.depGate %}
                            <div class="flight-card__meta">
                                {% if flight.depTerminal %}Terminal <strong>{{ flight.depTerminal }}</strong>{% endif %}
                                {% if flight.depGate %} · Porte <strong>{{ flight.depGate }}</strong>{% endif %}
                            </div>
                        {% endif %}
                        {% if flight.arrBaggage %}
                            <div class="flight-card__meta">Bagages : <strong>{{ flight.arrBaggage }}</strong></div>
                        {% endif %}
                    </div>
                </article>
            {% endfor %}

        {% endif %}

    {% else %}
        <div class="flights-empty">
            <div class="flights-empty__icon">✈️</div>
            <h2 class="flights-empty__title">Commencez votre recherche</h2>
            <p class="flights-empty__text">
                Entrez une destination et une date pour rechercher des vols en temps réel depuis Tunis.
            </p>
        </div>
    {% endif %}

</div>
{% endblock %}
