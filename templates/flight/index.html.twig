{% extends 'base.html.twig' %}

{% block title %}Recherche de vols | TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ===== PAGE FLIGHTS ===== */
        .flights-page { display: grid; gap: 1.75rem; }

        /* ---------- HERO ---------- */
        .flights-hero {
            position: relative;
            padding: 2.2rem;
            overflow: hidden;
            background:
                radial-gradient(circle at top left, rgba(221,191,140,.28), transparent 30%),
                linear-gradient(135deg, rgba(255,253,249,.98), rgba(243,234,223,.92));
            border: 1px solid rgba(231,220,205,.6);
            border-radius: var(--radius-xl);
            box-shadow: 0 18px 40px rgba(71,48,35,.06);
        }
        .flights-hero__eyebrow {
            display: inline-flex; align-items: center; gap: .5rem;
            color: var(--color-primary); font-size: .95rem;
            font-weight: 700; letter-spacing: .14em; text-transform: uppercase;
            margin-bottom: .6rem;
        }
        .flights-hero__title {
            font-family: 'Fraunces', serif;
            font-size: clamp(2rem, 2.8vw, 3rem); line-height: 1.08;
            color: var(--color-text); margin-bottom: .5rem;
        }
        .flights-hero__subtitle {
            color: var(--color-text-muted); font-size: 1.05rem; max-width: 600px;
        }

        /* ---------- SEARCH FORM ---------- */
        .flights-search {
            display: flex; flex-wrap: wrap; gap: 1rem;
            align-items: flex-end;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            padding: 1.5rem 1.8rem;
            box-shadow: 0 6px 24px rgba(71,48,35,.04);
        }
        .flights-search__field { display: flex; flex-direction: column; gap: .35rem; flex: 1 1 200px; }
        .flights-search__label {
            font-size: .82rem; font-weight: 600; color: var(--color-text-muted);
            text-transform: uppercase; letter-spacing: .08em;
        }
        .flights-search__input {
            padding: .78rem 1rem; border-radius: var(--radius-md);
            border: 1px solid var(--color-border); background: var(--color-surface-soft);
            font-family: inherit; font-size: .95rem; color: var(--color-text);
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }
        .flights-search__input:focus {
            outline: none; border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196,111,75,.12);
        }
        .flights-search__btn {
            padding: .82rem 1.6rem; border-radius: 999px;
            background: var(--color-primary); color: #fff; border: none;
            font-weight: 600; font-size: .95rem; cursor: pointer;
            transition: background var(--transition-fast), transform var(--transition-fast);
            display: inline-flex; align-items: center; gap: .5rem;
            flex-shrink: 0;
        }
        .flights-search__btn:hover { background: var(--color-primary-dark); transform: translateY(-1px); }

        /* ---------- METADATA BAR ---------- */
        .flights-meta {
            display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
            padding: .8rem 0;
        }
        .flights-meta__chip {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .45rem .9rem; border-radius: 999px;
            background: rgba(196,111,75,.08); color: var(--color-primary);
            font-size: .85rem; font-weight: 600;
        }

        /* ---------- ALERT / MESSAGE ---------- */
        .flights-alert {
            padding: 1.2rem 1.5rem; border-radius: var(--radius-lg);
            font-size: .95rem; line-height: 1.5;
        }
        .flights-alert--warning {
            background: rgba(196,111,75,.08); color: #8a4a2e;
            border: 1px solid rgba(196,111,75,.2);
        }
        .flights-alert--info {
            background: rgba(47,127,121,.08); color: var(--color-secondary);
            border: 1px solid rgba(47,127,121,.18);
        }
        .flights-alert--error {
            background: rgba(180,40,40,.07); color: #923030;
            border: 1px solid rgba(180,40,40,.18);
        }

        /* ---------- ROUTE INFO ---------- */
        .flights-route {
            display: flex; align-items: center; justify-content: center;
            gap: 1.5rem; padding: 1.5rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
        }
        .flights-route__point {
            text-align: center;
        }
        .flights-route__code {
            font-family: 'Fraunces', serif;
            font-size: 2rem; font-weight: 700; color: var(--color-text);
            line-height: 1;
        }
        .flights-route__name {
            font-size: .85rem; color: var(--color-text-muted); margin-top: .2rem;
        }
        .flights-route__arrow {
            display: flex; flex-direction: column; align-items: center; gap: .25rem;
        }
        .flights-route__line {
            width: 100px; height: 2px;
            background: linear-gradient(90deg, var(--color-border), var(--color-primary), var(--color-border));
            border-radius: 2px; position: relative;
        }
        .flights-route__line::after {
            content: '✈'; position: absolute; top: -10px; right: -4px;
            font-size: .85rem; color: var(--color-primary);
        }
        .flights-route__date {
            font-size: .8rem; font-weight: 600; color: var(--color-primary);
        }

        /* ---------- AIRLINES ---------- */
        .flights-airlines {
            display: flex; flex-wrap: wrap; gap: .5rem;
            justify-content: center; padding: .5rem 0;
        }
        .flights-airlines__tag {
            padding: .35rem .75rem; border-radius: 999px;
            background: rgba(47,127,121,.08); color: var(--color-secondary);
            font-size: .82rem; font-weight: 600;
            border: 1px solid rgba(47,127,121,.15);
        }

        /* ---------- PLATFORM CARDS ---------- */
        .flights-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.2rem;
        }

        .platform-card {
            display: flex; flex-direction: column;
            padding: 1.8rem 1.5rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            transition: box-shadow var(--transition-fast), transform var(--transition-fast);
            text-align: center;
        }
        .platform-card:hover {
            box-shadow: 0 12px 32px rgba(71,48,35,.1);
            transform: translateY(-3px);
        }
        .platform-card__icon {
            font-size: 2.5rem; margin-bottom: .8rem;
        }
        .platform-card__name {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem; font-weight: 700; color: var(--color-text);
            margin-bottom: .4rem;
        }
        .platform-card__desc {
            font-size: .9rem; color: var(--color-text-muted);
            line-height: 1.5; margin-bottom: 1.2rem; flex: 1;
        }
        .platform-card__link {
            display: inline-flex; align-items: center; justify-content: center;
            gap: .4rem; padding: .75rem 1.5rem;
            border-radius: 999px; color: #fff;
            font-weight: 600; font-size: .95rem;
            text-decoration: none;
            transition: filter var(--transition-fast), transform var(--transition-fast);
        }
        .platform-card__link:hover {
            filter: brightness(1.1); transform: translateY(-1px);
        }

        /* ---------- EMPTY STATE ---------- */
        .flights-empty {
            text-align: center; padding: 3rem 1.5rem;
            background: var(--color-surface);
            border: 1px dashed var(--color-border);
            border-radius: var(--radius-xl);
        }
        .flights-empty__icon { font-size: 3rem; margin-bottom: .8rem; }
        .flights-empty__title {
            font-family: 'Fraunces', serif; font-size: 1.4rem;
            color: var(--color-text); margin-bottom: .4rem;
        }
        .flights-empty__text { color: var(--color-text-muted); font-size: .95rem; }

        /* ---------- RESPONSIVE ---------- */
        @media (max-width: 800px) {
            .flights-route { flex-direction: column; gap: .8rem; }
            .flights-route__line { width: 2px; height: 40px;
                background: linear-gradient(180deg, var(--color-border), var(--color-primary), var(--color-border));
            }
            .flights-route__line::after { top: auto; bottom: -12px; right: -6px; }
            .flights-search { flex-direction: column; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="flights-page">

    {# ===== HERO ===== #}
    <section class="flights-hero">
        <div class="flights-hero__eyebrow">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 1L1 8l6 3 7-7-7 7 3 6z"/></svg>
            Recherche de vols
        </div>
        <h1 class="flights-hero__title">Trouvez votre vol</h1>
        <p class="flights-hero__subtitle">
            Comparez les prix sur Kayak, Google Flights et Skyscanner depuis Tunis.
            {% if voyageSelectionne %}
                Voyage : <strong>{{ voyageSelectionne.titre_voyage }}</strong>
            {% endif %}
        </p>
    </section>

    {# ===== SEARCH FORM ===== #}
    <form class="flights-search" method="GET" action="{{ path('app_flights') }}">
        {% if voyageId %}
            <input type="hidden" name="voyageId" value="{{ voyageId }}">
        {% endif %}

        <div class="flights-search__field">
            <label class="flights-search__label" for="f_origin">Départ</label>
            <input class="flights-search__input" id="f_origin" type="text" value="Tunis (TUN)" disabled>
        </div>

        <div class="flights-search__field">
            <label class="flights-search__label" for="f_dest">Destination</label>
            <input class="flights-search__input" id="f_dest" type="text" name="destination"
                   value="{{ destination }}" placeholder="Ex : Paris, Istanbul, CDG…" required>
        </div>

        <div class="flights-search__field">
            <label class="flights-search__label" for="f_date">Date de départ</label>
            <input class="flights-search__input" id="f_date" type="date" name="date"
                   value="{{ date }}" required>
        </div>

        <button class="flights-search__btn" type="submit">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            Rechercher
        </button>
    </form>

    {# ===== RESULTS ===== #}
    {% if searched %}

        {# --- Erreur --- #}
        {% if results and results.status != 'ok' %}
            <div class="flights-alert flights-alert--error">
                <strong>⚠️ Erreur</strong><br>
                {{ results.message|default('Une erreur est survenue.') }}
            </div>
        {% endif %}

        {# --- Résultats --- #}
        {% if results and results.status == 'ok' %}

            {# Route visual #}
            <div class="flights-route">
                <div class="flights-route__point">
                    <div class="flights-route__code">TUN</div>
                    <div class="flights-route__name">{{ results.origin_name }}</div>
                </div>
                <div class="flights-route__arrow">
                    <div class="flights-route__date">{{ date }}</div>
                    <div class="flights-route__line"></div>
                </div>
                <div class="flights-route__point">
                    <div class="flights-route__code">{{ destCode }}</div>
                    <div class="flights-route__name">{{ results.dest_name }}</div>
                </div>
            </div>

            {# Airlines on this route #}
            {% if results.airlines|length > 0 %}
                <div class="flights-airlines">
                    {% for airline in results.airlines %}
                        <span class="flights-airlines__tag">{{ airline }}</span>
                    {% endfor %}
                </div>
            {% endif %}

            {# Platform cards #}
            <div class="flights-grid">
                {% for flight in results.flights %}
                    <article class="platform-card">
                        <div class="platform-card__icon">{{ flight.icon }}</div>
                        <h3 class="platform-card__name">{{ flight.platform }}</h3>
                        <p class="platform-card__desc">{{ flight.description }}</p>
                        <a href="{{ flight.url }}" target="_blank" rel="noopener"
                           class="platform-card__link"
                           style="background: {{ flight.color }};">
                            Rechercher sur {{ flight.platform }} →
                        </a>
                    </article>
                {% endfor %}
            </div>

            <div class="flights-alert flights-alert--info" style="margin-top:.5rem">
                <strong>💡 Conseil</strong><br>
                Les liens ci-dessus ouvrent directement la recherche de vols <strong>TUN → {{ destCode }}</strong>
                le <strong>{{ date }}</strong> sur chaque plateforme. Comparez les prix pour trouver la meilleure offre !
            </div>

        {% endif %}

    {% else %}
        {# --- État initial --- #}
        <div class="flights-empty">
            <div class="flights-empty__icon">✈️</div>
            <h2 class="flights-empty__title">Commencez votre recherche</h2>
            <p class="flights-empty__text">
                Entrez une destination et une date pour comparer les vols sur Kayak, Google Flights et Skyscanner.
            </p>
        </div>
    {% endif %}

</div>
{% endblock %}
