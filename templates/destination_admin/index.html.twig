{% extends 'base_admin.html.twig' %}

{% block title %}Destinations | Administration TravelMate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-destinations-page {
            display: grid;
            gap: 1.5rem;
            animation: fadeIn .35s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* FLASH */
        .flash-stack {
            display: grid;
            gap: .75rem;
        }

        .flash-message {
            padding: .95rem 1rem;
            border-radius: 16px;
            font-size: .95rem;
        }

        .flash-message--success {
            background: rgba(47,127,121,0.1);
            color: #245f5a;
        }

        .flash-message--error {
            background: rgba(191,91,91,0.1);
            color: #9e4747;
        }

        /* TOOLBAR */
        .toolbar {
            display: grid;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .toolbar__top {
            display: flex;
            justify-content: space-between;
        }

        .toolbar__count {
            padding: .55rem .9rem;
            border-radius: 999px;
            background: rgba(196,111,75,0.1);
            color: var(--admin-primary);
            font-weight: 700;
            font-size: .84rem;
        }

        /* FILTER */
        .filters-form {
            display: flex;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .filters-form__group {
            display: grid;
            gap: .4rem;
        }

        .filters-form input {
            min-height: 46px;
            padding: .8rem 1rem;
            border-radius: 14px;
            border: 1px solid var(--admin-border);
        }

        /* DESTINATION CELL */
        .destination-cell {
            display: flex;
            align-items: center;
            gap: .8rem;
        }

        .destination-cell__image {
            width: 56px;
            height: 46px;
            border-radius: 10px;
            object-fit: cover;
            border: 2px solid rgba(196,111,75,.12);
        }

        .destination-cell__name {
            font-weight: 700;
        }

        .destination-cell__country {
            font-size: .85rem;
            color: var(--admin-text-muted);
        }

        /* TABLE */
        .destinations-table {
            width: 100%;
            border-collapse: collapse;
        }

        .destinations-table th {
            text-align: left;
            padding-bottom: .85rem;
            border-bottom: 1px solid var(--admin-border);
            font-size: .75rem;
            text-transform: uppercase;
        }

        .destinations-table td {
            padding: 1rem 0;
            border-bottom: 1px solid rgba(231,220,205,0.7);
        }

        /* ACTIONS */
        .table-actions {
            display: flex;
            gap: .6rem;
        }

        .btn-delete {
            background: rgba(191,91,91,0.12);
            color: #aa4f4f;
        }

        .btn-delete:hover {
            background: rgba(191,91,91,0.18);
        }

        /* EMPTY */
        .empty-state {
            padding: 2rem;
            text-align: center;
            color: var(--admin-text-muted);
        }
    </style>
{% endblock %}

{% block body %}
<section class="admin-destinations-page">

    <!-- HEADER -->
    <div class="admin-page-header">
        <div>
            <span class="admin-page-header__eyebrow">Administration</span>
            <h1 class="admin-page-header__title">Gestion des destinations</h1>
            <p class="admin-page-header__desc">
                Gérez les destinations disponibles.
            </p>
        </div>

        <div class="admin-page-header__actions">
            <a href="{{ path('app_admin_destinations_new') }}" class="btn btn--primary">
                + Ajouter
            </a>
        </div>
    </div>

    <!-- FLASH -->
    <div class="flash-stack">
        {% for message in app.flashes('success') %}
            <div class="flash-message flash-message--success">{{ message }}</div>
        {% endfor %}
    </div>

    <!-- TABLE -->
    <div class="admin-card">

        <div class="toolbar">
            <div class="toolbar__top">
                <span class="toolbar__count">
                    {{ destinations|length }} destination{{ destinations|length > 1 ? 's' : '' }}
                </span>
            </div>

            <form method="get" class="filters-form">
                <div class="filters-form__group">
                    <input type="text" name="q" value="{{ search }}" placeholder="Recherche...">
                </div>

                <button class="btn btn--ghost">Filtrer</button>
            </form>
        </div>

        {% if destinations is not empty %}
            <table class="destinations-table">
                <thead>
                    <tr>
                        <th>Destination</th>
                        <th>Pays</th>
                        <th>Description</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for destination in destinations %}
                        <tr>
                            <td>
                                <div class="destination-cell">
                                    <img src="{{ destination.image ?? asset('images/default-destination.jpg') }}" class="destination-cell__image">
                                    <div>
                                        <div class="destination-cell__name">{{ destination.nom }}</div>
                                        <div class="destination-cell__country">{{ destination.pays }}</div>
                                    </div>
                                </div>
                            </td>

                            <td>{{ destination.pays }}</td>

                            <td>
                                {{ destination.description ? destination.description|slice(0,50) ~ '...' : '—' }}
                            </td>

                            <td>{{ destination.createdAt ? destination.createdAt|date('d/m/Y') : '—' }}</td>

                            <td>
                                <div class="table-actions">
                                    <a href="{{ path('app_admin_destinations_edit', {id: destination.id}) }}" class="btn btn--ghost">
                                        Modifier
                                    </a>

                                    <form method="post" action="{{ path('app_admin_destinations_delete', {id: destination.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_destination_' ~ destination.id) }}">
                                        <button class="btn btn-delete">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-state">
                Aucune destination trouvée.
            </div>
        {% endif %}
    </div>

</section>
{% endblock %}