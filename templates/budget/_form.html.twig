</div>

<div style="margin-bottom:1rem">
    {{ form_label(form.montantTotal) }}
    {{ form_widget(form.montantTotal) }}
</div>

<div style="margin-bottom:1rem">
    {{ form_label(form.deviseBudget) }}
    {{ form_widget(form.deviseBudget) }}
</div>

<div style="margin-bottom:1rem">
    {{ form_label(form.descriptionBudget) }}
