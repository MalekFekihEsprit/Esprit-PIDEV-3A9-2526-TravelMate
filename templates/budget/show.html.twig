function runBudgetConversion() {
    const montant = parseFloat(document.getElementById('convAmount')?.value);
    const from = document.getElementById('convFrom')?.value.trim().toUpperCase();
    const to = document.getElementById('convTo')?.value;
    const box = document.getElementById('convInlineResult');
    if (!montant || montant <= 0) {
        if (box) box.textContent = '⚠ Montant invalide.';
        return;
    }
    if (box) box.innerHTML = '<span style="opacity:.5;font-style:italic;">⏳ calcul…</span>';
    fetch('{{ path('app_budget_ai_convert') }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ montant, from, to })
    })
    .then(r => r.json())
    .then(d => { if (box) box.textContent = d.result ?? '—'; })
    .catch(() => { if (box) box.textContent = '⚠ Service indisponible.'; });
}

