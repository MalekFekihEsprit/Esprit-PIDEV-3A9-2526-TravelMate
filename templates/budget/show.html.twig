/* ── Result helpers ── */
function aiShow(id, html) {
    const el = document.getElementById(id);
    if (!el) return;
    el.querySelector('.ai-result__inner').innerHTML = html;
    el.classList.add('visible');
}
function aiLoading(id, msg = 'Analyse en cours…') {
    const el = document.getElementById(id);
    if (!el) return;
    el.querySelector('.ai-result__inner').innerHTML = `
        <div style="display:flex;align-items:center;gap:.6rem;color:var(--color-text-muted);font-style:italic">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            ${msg}
        </div>`;
    el.classList.add('visible');
}
function aiError(id, msg) {
    aiShow(id, `<div style="color:#dc2626;font-size:.8rem">${msg}</div>`);
}
function fmtAiText(text) {
    // Convert markdown-like to HTML
    return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/^[-•]\s(.+)/gm, '<li>$1</li>')
        .replace(/(<li>.*<\/li>)/s, '<ul style="margin:.4rem 0 0 1rem;padding:0">$1</ul>')
        .replace(/\n\n/g, '</p><p style="margin-top:.4rem">')
        .replace(/\n/g, '<br>');
}

async function callAI(route, payload, resultId, loadingMsg) {
    aiLoading(resultId, loadingMsg);
    try {
        const res = await fetch(route, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.error) { aiError(resultId, 'Erreur : ' + data.error); return; }
        aiShow(resultId, `
            <div class="ai-result__inner">
                <div style="display:flex;align-items:center;gap:.4rem;margin-bottom:.5rem;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-primary)">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    Réponse Mistral AI
                </div>
                <div style="font-size:.82rem;line-height:1.65;color:var(--color-text)">${fmtAiText(data.result)}</div>
            </div>`);
    } catch (err) {
        aiError(resultId, 'Impossible de contacter le modèle IA. Vérifiez votre connexion.');
    }
}

