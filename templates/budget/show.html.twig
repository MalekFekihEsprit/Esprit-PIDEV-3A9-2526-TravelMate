// Make sure this runs AFTER your depense items are loaded
document.addEventListener('DOMContentLoaded', function() {
    
    // Define depItems - select all depense item elements
    // Adjust the selector based on your actual HTML structure
    const depItems = document.querySelectorAll('.depense-item, .dep-item, [data-depense-id]');
    
    // If you're dynamically adding items, you might need to use a different selector
    // Common alternatives:
    // const depItems = document.querySelectorAll('.depense-card');
    // const depItems = document.querySelectorAll('[data-montant]');
    
    console.log('Found depense items:', depItems.length); // Debug - check console
    
    /* ============================================================
       EXPORT CSV
    ============================================================ */
    document.getElementById('depExportCsvBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        
        try {
            // Check if depItems exists and has items
            if (!depItems || depItems.length === 0) {
                alert('Aucune dépense à exporter.');
                return;
            }
            
            const visibleItems = Array.from(depItems).filter(i => !i.classList.contains('dep-hidden'));
            
            if (visibleItems.length === 0) {
                alert('Aucune dépense à exporter.');
                return;
            }
            
            const headers = ['Libellé', 'Catégorie', 'Montant', 'Devise', 'Date', 'Type de paiement', 'Description'];
            
            const rows = visibleItems.map(item => {
                const label = item.querySelector('.dep-label')?.textContent.trim() || 
                             item.querySelector('[data-label]')?.textContent.trim() || '';
                const categorie = item.dataset.catDisplay || 
                                 item.querySelector('.dep-categorie')?.textContent.trim() || '';
                const montantValue = parseFloat(item.dataset.montant || 0);
                const montant = isNaN(montantValue) ? '0,00' : montantValue.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                const devise = item.dataset.devise || 'TND';
                const date = item.dataset.date || 
                            item.querySelector('.dep-date')?.textContent.trim() || '';
                const type = item.dataset.type || 
                            item.querySelector('.dep-type')?.textContent.trim() || '';
                const description = item.dataset.description || 
                                   item.querySelector('.dep-description')?.textContent.trim() || '';
                return [label, categorie, montant, devise, date, type, description];
            });
            
            const csvContent = [headers, ...rows]
                .map(row => row.map(cell => `"${String(cell).replace(/"/g, '""')}"`).join(','))
                .join('\n');
            
            const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.href = url;
            
            // Get budget name safely
            let budgetName = 'depenses';
            const budgetElement = document.querySelector('[data-budget-libelle], .budget-title');
            if (budgetElement) {
                budgetName = budgetElement.textContent.trim().replace(/[^a-z0-9]/gi, '_');
            }
            
            link.download = `${budgetName}_${new Date().toISOString().slice(0,10)}.csv`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
            
            const btn = document.getElementById('depExportCsvBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '✓ Exporté !';
            setTimeout(() => { btn.innerHTML = originalText; }, 2000);
        } catch (error) {
            console.error('Erreur export CSV:', error);
            alert('Erreur lors de l\'export CSV: ' + error.message);
        }
    });
    
    /* ============================================================
       EXPORT PDF
    ============================================================ */
    document.getElementById('depExportPdfBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        
        try {
            // Check if jspdf is loaded
            if (typeof window.jspdf === 'undefined') {
                alert('La bibliothèque PDF n\'est pas chargée. Veuillez rafraîchir la page.');
                return;
            }
            
            if (!depItems || depItems.length === 0) {
                alert('Aucune dépense à exporter.');
                return;
            }
            
