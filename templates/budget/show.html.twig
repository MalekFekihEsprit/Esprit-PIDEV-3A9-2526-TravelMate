<div class="modal-overlay" id="modal-convert-all" onclick="if(event.target===this)closeConvertModal()">
    <div class="dep-modal" style="max-width:400px">
        <div class="dep-modal__header">
            <span class="dep-modal__title">Convertir toutes les dépenses</span>
            <button class="dep-modal__close" onclick="closeConvertModal()" aria-label="Fermer">×</button>
        </div>
        <div class="dep-modal__body" style="padding:1.5rem;">
            <p style="margin-bottom:1rem;font-size:0.9rem;">Convertir toutes les dépenses vers une nouvelle devise :</p>
            <div class="mf-field">
                <label class="mf-label" for="convert-target-devise">Nouvelle devise</label>
                <select id="convert-target-devise" class="mf-select">
                    <option value="EUR">EUR - Euro</option>
                    <option value="USD">USD - Dollar US</option>
                    <option value="TND" {{ (budget.deviseBudget ?? 'TND') == 'TND' ? 'selected' : '' }}>TND - Dinar Tunisien</option>
                    <option value="GBP">GBP - Livre Sterling</option>
                    <option value="MAD">MAD - Dirham Marocain</option>
                    <option value="CHF">CHF - Franc Suisse</option>
                    <option value="JPY">JPY - Yen Japonais</option>
                    <option value="CAD">CAD - Dollar Canadien</option>
                </select>
            </div>
            <div id="convert-progress" style="display:none;margin-top:1rem;">
                <div class="progress-track" style="height:4px;">
                    <div class="progress-fill" style="width:0%;height:100%;"></div>
                </div>
                <p style="font-size:0.75rem;margin-top:0.5rem;text-align:center;" id="convert-progress-text">Conversion en cours...</p>
            </div>
        </div>
        <div class="dep-modal__footer">
            <button class="btn-modal-cancel" onclick="closeConvertModal()">Annuler</button>
            <button class="btn-modal-submit" onclick="executeConvertAll()">Convertir</button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script>
/* ============================================================
   MODAL HELPERS
============================================================ */
function openModal(id) { 
    document.getElementById(id).classList.add('open'); 
    document.body.style.overflow = 'hidden'; 
}
function closeModal(id) { 
    document.getElementById(id).classList.remove('open'); 
    document.body.style.overflow = ''; 
}
function handleOverlayClick(e, id) { 
    if (e.target === document.getElementById(id)) closeModal(id); 
}
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.querySelectorAll('.modal-overlay.open').forEach(m => closeModal(m.id));
});

// Set default date
const dateInput = document.getElementById('add-date');
if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];

/* ============================================================
   OPEN EDIT MODAL
============================================================ */
function openEditModal(item) {
    const id = item.dataset.id;
    const libelle = item.dataset.libelle || item.querySelector('.dep-label')?.textContent || '';
    const montant = item.dataset.montant;
    const categorie = item.dataset.catDisplay;
    const description = item.dataset.description;
    const devise = item.dataset.devise;
    const typePaiement = item.dataset.type;
    const date = item.dataset.date; // format Y-m-d pour l'input[type=date]
    
    const editUrl = item.dataset.editUrl || "{{ path('app_depense_edit', {'id': 'ID'}) }}".replace('ID', id);
    document.getElementById('form-edit').action = editUrl;
    // Récupère le token CSRF depuis l'élément de la dépense
    const csrfToken = item.dataset.csrfEdit || item.dataset.csrf || '';
    document.getElementById('edit-token').value = csrfToken;
    document.getElementById('edit-libelle').value = libelle;
    document.getElementById('edit-montant').value = montant;
    document.getElementById('edit-date').value = date;
    document.getElementById('edit-desc').value = description;
    
    const catSel = document.getElementById('edit-categorie');
    for(let i = 0; i < catSel.options.length; i++) {
        if(catSel.options[i].value.toLowerCase() === (categorie || '').toLowerCase()) {
            catSel.selectedIndex = i;
            break;
        }
    }
    
    const typeSel = document.getElementById('edit-type');
    for(let i = 0; i < typeSel.options.length; i++) {
        if(typeSel.options[i].value.toLowerCase() === (typePaiement || '').toLowerCase()) {
            typeSel.selectedIndex = i;
            break;
        }
    }
    
    const devSel = document.getElementById('edit-devise');
    for(let i = 0; i < devSel.options.length; i++) {
        if(devSel.options[i].value === devise) {
            devSel.selectedIndex = i;
            break;
        }
    }
    
    document.getElementById('edit-prefix').textContent = devise || '{{ budget.deviseBudget ?? "TND" }}';
    
    document.querySelectorAll('#form-edit .mf-input, #form-edit .mf-select, #form-edit .mf-textarea')
        .forEach(el => el.classList.remove('ok','err'));
    document.querySelectorAll('#form-edit .mf-error').forEach(e => e.classList.remove('show'));
    
    openModal('modal-edit');
}

/* ============================================================
   OPEN DELETE MODAL
============================================================ */
function openDeleteModal(item) {
    const id = item.dataset.id;
    const libelle = item.dataset.libelle || item.querySelector('.dep-label')?.textContent || '';
    const deleteUrl = item.dataset.deleteUrl || "{{ path('app_depense_delete', {'id': 'ID'}) }}".replace('ID', id);
    document.getElementById('form-delete').action = deleteUrl;
    // Récupère le token CSRF depuis l'élément de la dépense
    const csrfToken = item.dataset.csrf || '';
    document.getElementById('delete-token').value = csrfToken;
    document.getElementById('delete-dep-name').textContent = '"' + libelle + '"';
    openModal('modal-delete');
}

/* ============================================================
   VALIDATION FORMULAIRE
============================================================ */
function vField(fieldId, errorId, condition) {
    const el = document.getElementById(fieldId);
    const err = document.getElementById(errorId);
    if (!el) return true;
    const ok = condition(el.value);
    el.classList.toggle('ok', ok);
    el.classList.toggle('err', !ok);
    if (err) err.classList.toggle('show', !ok);
    return ok;
}

function validateDepForm(formId) {
    const prefix = formId === 'form-add' ? 'add' : 'edit';
    let ok = true;
    ok = vField(`${prefix}-libelle`, `err-${prefix}-libelle`, v => v.trim().length > 0 && v.trim().length <= 60) && ok;
    ok = vField(`${prefix}-montant`, `err-${prefix}-montant`, v => parseFloat(v) > 0) && ok;
    ok = vField(`${prefix}-categorie`, `err-${prefix}-categorie`, v => !!v) && ok;
    ok = vField(`${prefix}-type`, `err-${prefix}-type`, v => !!v) && ok;
    ok = vField(`${prefix}-date`, `err-${prefix}-date`, v => !!v) && ok;
    ok = vField(`${prefix}-desc`, `err-${prefix}-desc`, v => v.trim().length > 0 && v.trim().length <= 255) && ok;
    return ok;
}

// Attach validation events on blur
['libelle','montant','categorie','type','date','desc'].forEach(f => {
    ['add','edit'].forEach(prefix => {
        const el = document.getElementById(`${prefix}-${f}`);
        if (el) el.addEventListener('blur', () => validateDepForm(`form-${prefix}`));
    });
});

// Validation on form submit
document.getElementById('form-add')?.addEventListener('submit', function(e) {
    if (!validateDepForm('form-add')) {
        e.preventDefault();
        e.stopPropagation();
    }
});

document.getElementById('form-edit')?.addEventListener('submit', function(e) {
    if (!validateDepForm('form-edit')) {
        e.preventDefault();
        e.stopPropagation();
    }
});

// Update prefix when devise changes
document.getElementById('add-devise')?.addEventListener('change', function() {
    document.getElementById('add-prefix').textContent = this.value || '{{ budget.deviseBudget ?? "TND" }}';
});
document.getElementById('edit-devise')?.addEventListener('change', function() {
    document.getElementById('edit-prefix').textContent = this.value || '{{ budget.deviseBudget ?? "TND" }}';
});

/* ============================================================
   DÉPENSES — RECHERCHE DYNAMIQUE + FILTRE CATÉGORIE
============================================================ */
let depItems = [];
let depSearch = '';
let depCatSel = 'all';

function refreshDepItems() {
    depItems = Array.from(document.querySelectorAll('.dep-item[data-id]'));
}

function applyDepFilters() {
    const q = depSearch.toLowerCase().trim();
    let visible = 0;
    depItems.forEach(item => {
        const label = item.querySelector('.dep-label')?.textContent.toLowerCase() || '';
        const matchTxt = !q || label.includes(q);
        const matchCat = depCatSel === 'all' || item.dataset.cat === depCatSel;
        const show = matchTxt && matchCat;
        item.classList.toggle('dep-hidden', !show);
        if (show) visible++;
    });
    const noResults = document.getElementById('depNoResults');
    if (noResults) noResults.classList.toggle('visible', visible === 0);
}

// Initialiser la recherche et les filtres
document.addEventListener('DOMContentLoaded', function() {
    refreshDepItems();
    
    // Catégories uniques pour les chips
    const catFilter = document.getElementById('depCatFilter');
    if (catFilter && depItems.length > 0) {
        const cats = [...new Set(depItems.map(i => i.dataset.catDisplay))].sort();
        cats.forEach(cat => {
            const btn = document.createElement('button');
            btn.className = 'dep-chip';
            btn.dataset.cat = cat.toLowerCase();
            btn.textContent = cat;
            catFilter.appendChild(btn);
        });
    }
    
    // Écouteur recherche
    const searchInput = document.getElementById('depSearchInput');
    const searchClear = document.getElementById('depSearchClear');
    
    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            depSearch = e.target.value;
            if (searchClear) searchClear.classList.toggle('visible', depSearch.length > 0);
            applyDepFilters();
        });
    }
    
    if (searchClear) {
        searchClear.addEventListener('click', () => {
            if (searchInput) searchInput.value = '';
            depSearch = '';
            searchClear.classList.remove('visible');
            if (searchInput) searchInput.focus();
            applyDepFilters();
        });
    }
    
    // Écouteur filtre catégorie
    if (catFilter) {
        catFilter.addEventListener('click', (e) => {
            const btn = e.target.closest('.dep-chip');
            if (!btn) return;
            depCatSel = btn.dataset.cat;
            catFilter.querySelectorAll('.dep-chip').forEach(c => c.classList.toggle('active', c.dataset.cat === depCatSel));
            applyDepFilters();
        });
    }
});

/* ============================================================
   MULTI-SELECT DÉPENSES
============================================================ */
let selectedDepIds = new Set();
let depSelMode = false;

function toggleDepSel(item) {
    const id = item.dataset.id;
    if (selectedDepIds.has(id)) {
        selectedDepIds.delete(id);
        item.classList.remove('dep-selected');
    } else {
        selectedDepIds.add(id);
        item.classList.add('dep-selected');
    }
    const selBar = document.getElementById('depSelBar');
    const selCount = document.getElementById('depSelCount');
    if (selectedDepIds.size === 0) {
        depSelMode = false;
        if (selBar) selBar.classList.remove('visible');
    } else {
        depSelMode = true;
        if (selBar) selBar.classList.add('visible');
        if (selCount) selCount.textContent = selectedDepIds.size;
    }
}

document.getElementById('btnDepSelCancel')?.addEventListener('click', () => {
    selectedDepIds.clear();
    depSelMode = false;
    const selBar = document.getElementById('depSelBar');
    if (selBar) selBar.classList.remove('visible');
    depItems.forEach(i => i.classList.remove('dep-selected'));
});

document.getElementById('btnDepSelAll')?.addEventListener('click', () => {
    const visItems = depItems.filter(i => !i.classList.contains('dep-hidden'));
    const allSel = visItems.every(i => selectedDepIds.has(i.dataset.id));
    if (allSel) {
        visItems.forEach(i => {
            selectedDepIds.delete(i.dataset.id);
            i.classList.remove('dep-selected');
        });
        if (selectedDepIds.size === 0) {
            depSelMode = false;
            const selBar = document.getElementById('depSelBar');
            if (selBar) selBar.classList.remove('visible');
        }
    } else {
        visItems.forEach(i => {
            selectedDepIds.add(i.dataset.id);
            i.classList.add('dep-selected');
        });
        depSelMode = true;
        const selBar = document.getElementById('depSelBar');
        if (selBar) selBar.classList.add('visible');
    }
    const selCount = document.getElementById('depSelCount');
    if (selCount) selCount.textContent = selectedDepIds.size;
});

document.getElementById('btnDepSelDelete')?.addEventListener('click', () => {
    if (selectedDepIds.size === 0) return;
    const names = [...selectedDepIds].map(id => {
        const el = document.querySelector(`.dep-item[data-id="${id}"]`);
        return el ? el.querySelector('.dep-label').textContent.trim() : id;
    });
    const bulkCount = document.getElementById('bulk-dep-count');
    const bulkNames = document.getElementById('bulk-dep-names');
    if (bulkCount) bulkCount.textContent = selectedDepIds.size;
    if (bulkNames) bulkNames.innerHTML = names.map(n => `<div>• ${escapeHtml(n)}</div>`).join('');
    openModal('modal-bulk-dep');
});

async function executeBulkDepDelete() {
    closeModal('modal-bulk-dep');
    const ids = [...selectedDepIds];
    for (const id of ids) {
        const item = document.querySelector(`.dep-item[data-id="${id}"]`);
        if (!item) continue;
        const fd = new FormData();
        fd.append('_token', item.dataset.csrf || '');
        fd.append('_method', 'DELETE');
        try {
            await fetch(item.dataset.deleteUrl, { method: 'POST', body: fd });
        } catch(e) {}
        item.remove();
    }
    selectedDepIds.clear();
    depSelMode = false;
    const selBar = document.getElementById('depSelBar');
    if (selBar) selBar.classList.remove('visible');
    const selCount = document.getElementById('depSelCount');
    if (selCount) selCount.textContent = 0;
    refreshDepItems();
    applyDepFilters();
    window.location.reload();
}

function escapeHtml(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ==================================================================
   EXPORT EXCEL (SheetJS XLSX — styled)
================================================================== */
document.addEventListener('DOMContentLoaded', function() {
    const depItems = document.querySelectorAll('.dep-item[data-id]');

    document.getElementById('depExportCsvBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        try {
            if (typeof XLSX === 'undefined') {
                alert('La bibliothèque Excel n\'est pas chargée. Veuillez rafraîchir la page.');
                return;
            }

            const visibleItems = Array.from(depItems).filter(i => !i.classList.contains('dep-hidden'));
            if (!visibleItems.length) { alert('Aucune dépense à exporter.'); return; }

            const budgetLibelle = '{{ budget.libelleBudget|e('js') }}';
            const budgetTotal   = '{{ budget.montantTotal|number_format(2,",","") }}';
            const devise        = '{{ budget.deviseBudget ?? "TND" }}';
            const today         = new Date().toLocaleDateString('fr-FR');

            /* ── Build rows ── */
            const dataRows = visibleItems.map((item, idx) => ({
                '#':            idx + 1,
                'Libellé':      item.querySelector('.dep-label')?.textContent.trim() || '',
                'Catégorie':    item.dataset.catDisplay || '',
                'Montant':      parseFloat(item.dataset.montant || 0),
                'Devise':       item.dataset.devise || devise,
                'Date':         item.dataset.date || '',
                'Type paiement':item.dataset.type || '',
                'Description':  item.dataset.description || ''
            }));

            const totalDep = dataRows.reduce((s, r) => s + r['Montant'], 0);

            /* ── Worksheet ── */
            const ws = XLSX.utils.json_to_sheet(dataRows, { origin: 'A5' });

            /* ── Header rows (title block) ── */
            XLSX.utils.sheet_add_aoa(ws, [
                ['TravelMate — Export Dépenses'],
                [`Budget : ${budgetLibelle}`],
                [`Total budget : ${budgetTotal} ${devise}   |   Total dépensé : ${totalDep.toFixed(2)} ${devise}   |   Date : ${today}`],
                []  // blank row before data
            ], { origin: 'A1' });

            /* ── Summary row at bottom ── */
            const lastRow = 5 + dataRows.length;
            XLSX.utils.sheet_add_aoa(ws, [
                ['', 'TOTAL', '', totalDep, devise, '', '', '']
            ], { origin: `A${lastRow}` });

            /* ── Column widths ── */
            ws['!cols'] = [
                { wch: 4 },   // #
                { wch: 28 },  // Libellé
                { wch: 16 },  // Catégorie
                { wch: 12 },  // Montant
                { wch: 8 },   // Devise
                { wch: 12 },  // Date
                { wch: 16 },  // Type paiement
                { wch: 36 }   // Description
            ];

            /* ── Merge title cells ── */
            ws['!merges'] = [
                { s: { r: 0, c: 0 }, e: { r: 0, c: 7 } },
                { s: { r: 1, c: 0 }, e: { r: 1, c: 7 } },
                { s: { r: 2, c: 0 }, e: { r: 2, c: 7 } }
            ];

            /* ── Cell styles (requires xlsx-style or SheetJS Pro — apply via cell format) ── */
            // Title
            if (ws['A1']) ws['A1'].s = { font: { bold: true, sz: 14, color: { rgb: 'C46F4B' } }, alignment: { horizontal: 'center' } };
            if (ws['A2']) ws['A2'].s = { font: { bold: true, sz: 11 }, alignment: { horizontal: 'center' } };
            if (ws['A3']) ws['A3'].s = { font: { sz: 9, color: { rgb: '6E6258' } }, alignment: { horizontal: 'center' } };

            // Header row (row index 4 = row 5 in sheet)
            const headers = ['#','Libellé','Catégorie','Montant','Devise','Date','Type paiement','Description'];
            headers.forEach((h, ci) => {
                const addr = XLSX.utils.encode_cell({ r: 4, c: ci });
                if (ws[addr]) ws[addr].s = {
                    font: { bold: true, color: { rgb: 'FFFFFF' } },
                    fill: { fgColor: { rgb: 'C46F4B' } },
                    alignment: { horizontal: 'center' }
                };
            });

            // Data rows — alternate shading
            dataRows.forEach((_, ri) => {
                const rowIdx = 5 + ri;
                const isEven = ri % 2 === 0;
                for (let ci = 0; ci < 8; ci++) {
                    const addr = XLSX.utils.encode_cell({ r: rowIdx, c: ci });
                    if (!ws[addr]) ws[addr] = { t: 'z' };
                    ws[addr].s = {
                        fill: { fgColor: { rgb: isEven ? 'FFF8F4' : 'FFFFFF' } },
                        border: {
                            bottom: { style: 'thin', color: { rgb: 'E7DCCD' } },
                            right:  { style: 'thin', color: { rgb: 'E7DCCD' } }
                        }
                    };
                }
                // Montant column — right align + number format
                const montantAddr = XLSX.utils.encode_cell({ r: rowIdx, c: 3 });
                if (ws[montantAddr]) {
                    ws[montantAddr].t = 'n';
                    ws[montantAddr].z = '#,##0.00';
                    ws[montantAddr].s = { ...ws[montantAddr].s, alignment: { horizontal: 'right' } };
                }
            });

            // Total row
            for (let ci = 0; ci < 8; ci++) {
                const addr = XLSX.utils.encode_cell({ r: lastRow - 1, c: ci });
                if (!ws[addr]) ws[addr] = { t: 'z' };
                ws[addr].s = {
                    font: { bold: true, color: { rgb: '3B2A1A' } },
                    fill: { fgColor: { rgb: 'F5EDE3' } },
                    border: { top: { style: 'medium', color: { rgb: 'C46F4B' } } }
                };
            }
            const totalAddr = XLSX.utils.encode_cell({ r: lastRow - 1, c: 3 });
            if (ws[totalAddr]) { ws[totalAddr].t = 'n'; ws[totalAddr].z = '#,##0.00'; }

            /* ── Workbook ── */
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Dépenses');

            /* ── Download ── */
            const filename = `${budgetLibelle.replace(/[^a-z0-9]/gi,'_')}_${new Date().toISOString().slice(0,10)}.xlsx`;
            XLSX.writeFile(wb, filename);

            const btn = document.getElementById('depExportCsvBtn');
            const orig = btn.innerHTML;
            btn.innerHTML = '✓ Excel créé !';
            setTimeout(() => { btn.innerHTML = orig; }, 2000);

        } catch (err) {
            console.error('Erreur export Excel:', err);
            alert('Erreur export Excel : ' + err.message);
        }
    });
    
    /* ============================================================
       EXPORT PDF
    ============================================================ */
    document.getElementById('depExportPdfBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        
        try {
            // Check if jspdf is loaded
            if (typeof window.jspdf === 'undefined') {
                alert('La bibliothèque PDF n\'est pas chargée. Veuillez rafraîchir la page.');
                return;
            }
            
            if (!depItems || depItems.length === 0) {
                alert('Aucune dépense à exporter.');
                return;
            }
            
            const visibleItems = Array.from(depItems).filter(i => !i.classList.contains('dep-hidden'));
            
            if (visibleItems.length === 0) {
                alert('Aucune dépense à exporter.');
                return;
            }
            
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
            const pageWidth = 210;
            const today = new Date().toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
            
            // Get currency from first item or default
            const devise = visibleItems[0]?.dataset.devise || 'TND';
            
            // Get budget info from the page
            let budgetTitle = 'Rapport de Dépenses';
            let budgetTotal = 0;
            let totalDepense = 0;
            
            const budgetTitleEl = document.querySelector('[data-budget-title], .budget-title, h1');
            if (budgetTitleEl) budgetTitle = budgetTitleEl.textContent.trim();
            
            // Calculate total
            totalDepense = visibleItems.reduce((sum, item) => {
                const montant = parseFloat(item.dataset.montant || 0);
                return sum + (isNaN(montant) ? 0 : montant);
            }, 0);
            
            // En-tête
            doc.setFillColor(59, 42, 26);
            doc.rect(0, 0, pageWidth, 25, 'F');
            doc.setFillColor(196, 111, 75);
            doc.rect(0, 17, pageWidth, 8, 'F');
            
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.text('✦ TravelMate', 14, 11);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.text('Rapport de Dépenses', 14, 20.5);
            doc.setFontSize(7.5);
            doc.setTextColor(255, 230, 200);
            doc.text(`Généré le ${today}`, pageWidth - 14, 20.5, { align: 'right' });
            
            // Infos budget
            doc.setFillColor(250, 245, 240);
            doc.rect(0, 25, pageWidth, 22, 'F');
            doc.setTextColor(59, 42, 26);
            doc.setFontSize(13);
            doc.setFont('helvetica', 'bold');
            doc.text(budgetTitle, 14, 34);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(110, 90, 70);
            const budgetInfo = `Total dépenses : ${totalDepense.toLocaleString('fr-FR', {minimumFractionDigits: 2, maximumFractionDigits: 2})} ${devise}  |  ${visibleItems.length} dépense(s)`;
            doc.text(budgetInfo, 14, 42);
            
            // Statistiques
            const sumVisible = totalDepense;
            const stats = [
                { label: `${visibleItems.length} dépense(s)`, value: '', color: [196, 111, 75] },
                { label: 'Total', value: `${sumVisible.toLocaleString('fr-FR')} ${devise}`, color: [59, 130, 246] }
            ];
            
            let startX = 14;
            stats.forEach((stat) => {
                const width = 55;
                doc.setFillColor(...stat.color);
                doc.roundedRect(startX, 52, width, 10, 2, 2, 'F');
                doc.setTextColor(255, 255, 255);
                doc.setFontSize(7);
                doc.setFont('helvetica', 'bold');
                doc.text(stat.label, startX + 3, 57);
                if (stat.value) {
                    doc.setFontSize(8);
                    doc.text(stat.value, startX + width - 3, 57, { align: 'right' });
                }
                startX += width + 6;
            });
            
            // Tableau
            const tableBody = visibleItems.map((item, idx) => {
                const label = item.querySelector('.dep-label')?.textContent.trim() || 
                             item.querySelector('[data-label]')?.textContent.trim() || 
                             `Dépense ${idx + 1}`;
                const categorie = item.dataset.catDisplay || 
                                 item.querySelector('.dep-categorie')?.textContent.trim() || '';
                const montant = parseFloat(item.dataset.montant || 0);
                const montantDisplay = isNaN(montant) ? '0,00' : montant.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                const date = item.dataset.date || 
                            item.querySelector('.dep-date')?.textContent.trim() || '';
                
                return [
                    String(idx + 1),
                    label.substring(0, 50), // Limit length
                    categorie.substring(0, 30),
                    montantDisplay,
                    date
                ];
            });
            
            // Check if autoTable plugin is available
            if (typeof doc.autoTable !== 'function') {
                alert('Le plugin autoTable pour PDF n\'est pas chargé.');
                return;
            }
            
            doc.autoTable({
                startY: 68,
                head: [['#', 'Libellé', 'Catégorie', `Montant (${devise})`, 'Date']],
                body: tableBody,
                headStyles: { 
                    fillColor: [59, 42, 26], 
                    textColor: [255, 230, 200], 
                    fontStyle: 'bold', 
                    fontSize: 9, 
