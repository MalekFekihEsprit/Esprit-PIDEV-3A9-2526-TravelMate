   INFLATION GENERALE
============================================================ */
function loadInflation(country) {
    const body = document.getElementById('inflWidgetBody');
    if (!body) return;
    body.innerHTML = '<p class="inflation-loading">⏳ Chargement des données…</p>';
    fetch('{{ path('app_budget_ai_inflation_country') }}?country=' + country)
        .then(r => r.json())
        .then(d => {
            if (d.error) {
                body.innerHTML = '<p class="inflation-loading">⚠ Données indisponibles pour ce pays.</p>';
                return;
            }
            const rate = d.rate !== null ? d.rate : null;
            const delta = d.delta;
            let deltaHtml = '';
            let insight = '';
            if (delta !== null) {
                const sign = delta > 0 ? '+' : '';
                const cls = delta > 2 ? 'up' : delta < -1 ? 'down' : 'flat';
                const arrow = delta > 0 ? '↑' : delta < 0 ? '↓' : '→';
                const prevYear = d.year ? parseInt(d.year) - 1 : '—';
                deltaHtml = `<span class="inflation-delta inflation-delta--${cls}">${arrow} ${sign}${delta}% vs ${prevYear}</span>`;
                if (delta > 5) {
                    insight = `⚠️ L'inflation a fortement progressé de <strong>+${delta}%</strong> par rapport à l'année précédente. Prévoyez un budget plus généreux pour cette destination.`;
                } else if (delta > 2) {
                    insight = `📈 L'inflation a augmenté de <strong>+${delta}%</strong>. Les prix ont progressé — ajustez votre budget en conséquence.`;
                } else if (delta < -1) {
                    insight = `📉 Bonne nouvelle : l'inflation a baissé de <strong>${delta}%</strong>. Cette destination est plus abordable que l'an dernier.`;
                } else {
                    insight = `✅ L'inflation est stable à <strong>${rate !== null ? rate + '%' : 'N/A'}</strong> pour cette destination.`;
                }
            }
            body.innerHTML = `
                <div class="inflation-did-you-know">Le saviez-vous ?</div>
                <div class="inflation-rate-big">${rate !== null ? rate + '%' : 'N/A'}</div>
                <div class="inflation-country-label">${d.country} · ${d.year ?? '—'} · CPI annuel</div>
                ${deltaHtml}
                ${insight ? `<div class="inflation-insight">${insight}</div>` : ''}
            `;
        })
        .catch(() => {
            body.innerHTML = '<p class="inflation-loading">⚠ Service indisponible.</p>';
        });
}

