            if (budgetTitleEl) budgetTitle = budgetTitleEl.textContent.trim();
            
            // Calculate total
            totalDepense = visibleItems.reduce((sum, item) => {
                const montant = parseFloat(item.dataset.montant || 0);
                return sum + (isNaN(montant) ? 0 : montant);
            }, 0);
            
            // En-tête
            doc.setFillColor(59, 42, 26);
            doc.rect(0, 0, pageWidth, 25, 'F');
            doc.setFillColor(196, 111, 75);
            doc.rect(0, 17, pageWidth, 8, 'F');
            
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.text('✦ TravelMate', 14, 11);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.text('Rapport de Dépenses', 14, 20.5);
            doc.setFontSize(7.5);
            doc.setTextColor(255, 230, 200);
            doc.text(`Généré le ${today}`, pageWidth - 14, 20.5, { align: 'right' });
            
            // Infos budget
            doc.setFillColor(250, 245, 240);
            doc.rect(0, 25, pageWidth, 22, 'F');
