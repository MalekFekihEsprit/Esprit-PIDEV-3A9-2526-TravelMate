</div>

{# ══ MODAL — Ajouter une dépense ══ #}
<div class="modal-overlay" id="modal-add" onclick="handleOverlayClick(event,'modal-add')">
    <div class="dep-modal">
        <div class="dep-modal__header">
            <span class="dep-modal__title">Nouvelle dépense</span>
            <button class="dep-modal__close" onclick="closeModal('modal-add')" aria-label="Fermer">×</button>
        </div>
        <form method="post" action="{{ path('app_depense_new', {'budgetId': budget.idBudget}) }}"
              id="form-add" novalidate>
            <input type="hidden" name="_token" value="{{ csrf_token('depense_new') }}">
            <div class="dep-modal__body">
                <div class="mf-row">
                    <div class="mf-field">
                        <label class="mf-label" for="add-libelle">Libellé <span class="req">*</span></label>
                        <input class="mf-input" id="add-libelle" name="libelle_depense" type="text"
                               placeholder="Ex : Taxi aéroport" maxlength="60" required>
                        <span class="mf-error" id="err-add-libelle">Libellé requis (max 60 car.)</span>
                    </div>
                    <div class="mf-field">
                        <label class="mf-label" for="add-montant">Montant <span class="req">*</span></label>
                        <div class="mf-amount-wrap">
                            <span class="mf-amount-prefix" id="add-prefix">{{ budget.deviseBudget ?? 'TND' }}</span>
                            <input class="mf-input" id="add-montant" name="montant_depense" type="number"
                                   placeholder="0.00" min="0.01" step="0.01" required>
                        </div>
                        <span class="mf-error" id="err-add-montant">Montant supérieur à 0 requis</span>
                    </div>
                </div>
                <div class="mf-row">
                    <div class="mf-field">
                        <label class="mf-label" for="add-categorie">Catégorie <span class="req">*</span></label>
                        <select class="mf-select" id="add-categorie" name="categorie_depense" required>
                            <option value="">-- Choisir --</option>
                            <option value="Hébergement">Hébergement</option>
                            <option value="Transport">Transport</option>
                            <option value="Restauration">Restauration</option>
                            <option value="Loisirs">Loisirs</option>
                            <option value="Achats">Achats</option>
                            <option value="Santé">Santé</option>
                            <option value="Autre">Autre</option>
                        </select>
                        <span class="mf-error" id="err-add-categorie">Catégorie requise</span>
                    </div>
                    <div class="mf-field">
                        <label class="mf-label" for="add-type">Type de paiement <span class="req">*</span></label>
                        <select class="mf-select" id="add-type" name="type_paiement" required>
                            <option value="">-- Choisir --</option>
                            <option value="Espèces">Espèces</option>
                            <option value="Carte bancaire">Carte bancaire</option>
                            <option value="Virement">Virement</option>
                            <option value="Mobile Pay">Mobile Pay</option>
                            <option value="Autre">Autre</option>
                        </select>
                        <span class="mf-error" id="err-add-type">Type de paiement requis</span>
                    </div>
                </div>
                <div class="mf-row">
                    <div class="mf-field">
                        <label class="mf-label" for="add-devise">Devise</label>
                        <select class="mf-select" id="add-devise" name="devise_depense">
                            <option value="">Devise du budget</option>
                            <option value="TND" {% if (budget.deviseBudget ?? 'TND') == 'TND' %}selected{% endif %}>TND</option>
                            <option value="EUR" {% if (budget.deviseBudget ?? '') == 'EUR' %}selected{% endif %}>EUR</option>
                            <option value="USD" {% if (budget.deviseBudget ?? '') == 'USD' %}selected{% endif %}>USD</option>
                            <option value="GBP">GBP</option>
                            <option value="MAD">MAD</option>
                            <option value="CHF">CHF</option>
                        </select>
                    </div>
                    <div class="mf-field">
                        <label class="mf-label" for="add-date">Date <span class="req">*</span></label>
                        <input class="mf-input" id="add-date" name="date_creation" type="date" required>
                        <span class="mf-error" id="err-add-date">Date requise</span>
                    </div>
                </div>
                <div class="mf-row mf-row--full">
                    <div class="mf-field">
                        <label class="mf-label" for="add-desc">Description <span class="req">*</span></label>
                        <textarea class="mf-textarea" id="add-desc" name="description_depense"
                                  placeholder="Détails de la dépense…" maxlength="255" required></textarea>
                        <span class="mf-error" id="err-add-desc">Description requise (max 255 car.)</span>
                    </div>
                </div>
            </div>
            <div class="dep-modal__footer">
                <button type="button" class="btn-modal-cancel" onclick="closeModal('modal-add')">Annuler</button>
                <button type="submit" class="btn-modal-submit">
                    Ajouter la dépense
                </button>
            </div>
        </form>
    </div>
</div>

