        });

        dilemmas.push({
            q: 'Si tu devais couper 20% du budget…',
            a: { emoji:'🚌', label:'Transports en commun uniquement',
                 saving: BUDGET_TOTAL * 0.20,
                 detail: `Zéro taxi/Uber → économie de ${fmt(BUDGET_TOTAL * 0.20)} ${DEVISE}. Plus d'aventure, moins de confort.` },
            b: { emoji:'🛍️', label:'Zéro shopping souvenirs',
                 saving: BUDGET_TOTAL * 0.08,
                 detail: `Pas d'achats → économie de ${fmt(BUDGET_TOTAL * 0.08)} ${DEVISE}. Les souvenirs sont dans les photos.` }
        });

        return dilemmas;
    }

    function catEmoji(cat) {
        const map = { 'Hébergement':'🏨','Transport':'🚗','Restauration':'🍽️',
                      'Loisirs':'🎭','Achats':'🛍️','Santé':'💊','Autre':'💸' };
        return map[cat] || '💰';
    }

    /* ── State ── */
    let dilemmas = [];
    let current  = 0;
    let chosen   = null;

    function render() {
        if (!dilemmas.length) return;
        const d = dilemmas[current];
        chosen = null;

        document.getElementById('wyrQuestion').textContent = d.q;
        document.getElementById('wyrEmojiA').textContent   = d.a.emoji;
        document.getElementById('wyrLabelA').textContent   = d.a.label;
        document.getElementById('wyrSavingA').innerHTML    = d.a.saving > 0
            ? `Économie : <strong>+${fmt(d.a.saving)} ${DEVISE}</strong>` : '';
        document.getElementById('wyrEmojiB').textContent   = d.b.emoji;
        document.getElementById('wyrLabelB').textContent   = d.b.label;
        document.getElementById('wyrSavingB').innerHTML    = d.b.saving > 0
            ? `Économie : <strong>+${fmt(d.b.saving)} ${DEVISE}</strong>` : '';

        // Reset bars & styles
        ['wyrOptA','wyrOptB'].forEach(id => {
            const el = document.getElementById(id);
            el.classList.remove('chosen-a','chosen-b','winner');
        });
        document.getElementById('wyrBarA').style.width = '0%';
        document.getElementById('wyrBarB').style.width = '0%';
        const res = document.getElementById('wyrResult');
        res.className = 'wyr-result';
        res.textContent = '';
    }

    window.wyrChoose = function (side) {
        if (chosen) return; // already chosen
        chosen = side;
        const d = dilemmas[current];
        const opt = side === 'a' ? d.a : d.b;
        const other = side === 'a' ? d.b : d.a;

        // Highlight chosen
        document.getElementById('wyrOpt' + side.toUpperCase()).classList.add('chosen-' + side);

        // Animate bars based on savings comparison
        const totalSaving = (d.a.saving || 0) + (d.b.saving || 0) || 1;
        const pctA = Math.round((d.a.saving / totalSaving) * 100);
        const pctB = 100 - pctA;
        setTimeout(() => {
            document.getElementById('wyrBarA').style.width = pctA + '%';
            document.getElementById('wyrBarB').style.width = pctB + '%';
        }, 100);

        // Mark winner (bigger saving)
        const winnerId = d.a.saving >= d.b.saving ? 'wyrOptA' : 'wyrOptB';
        setTimeout(() => document.getElementById(winnerId).classList.add('winner'), 400);

        // Show result
        const res = document.getElementById('wyrResult');
        const bigger = opt.saving >= other.saving;
        res.className = 'wyr-result visible wyr-result--' + side;
        res.innerHTML = `<strong>${bigger ? '✓ Meilleur choix financièrement !' : 'Choix émotionnel !'}</strong><br>${opt.detail}`;
    };

    window.wyrNext = function () {
        current = (current + 1) % dilemmas.length;
        render();
    };

    window.wyrReset = function () { render(); };

    // Init after DOM ready
    document.addEventListener('DOMContentLoaded', () => {
        dilemmas = buildDilemmas();
        if (dilemmas.length) render();
        else document.getElementById('wyrQuestion').textContent = 'Ajoutez des dépenses pour jouer !';
    });
})();
</script>

{# ══ GAMIFICATION JS ══ #}
<script>
(function () {
    const ICONS = {
        star:   '⭐', shield: '🛡️', fire: '🔥',
        piggy:  '🐷', list:   '📋', globe: '🌍'
    };

    fetch('{{ path("app_budget_gamification", {id: budget.idBudget}) }}')
        .then(r => r.json())
        .then(data => {
            // Score ring
            const score = data.score ?? 0;
            const circle = document.getElementById('gamiScoreCircle');
            const valEl  = document.getElementById('gamiScoreVal');
            if (circle) {
                const circumference = 125.66;
                const offset = circumference - (score / 100) * circumference;
                circle.style.strokeDashoffset = offset;
                circle.style.stroke = score >= 70 ? '#10b981' : score >= 40 ? '#f59e0b' : '#ef4444';
            }
            if (valEl) valEl.textContent = score;

            // Streak
            const streak = data.current_streak ?? 0;
            const numEl  = document.getElementById('gamiStreakNum');
            const lblEl  = document.getElementById('gamiStreakLabel');
            if (numEl) numEl.textContent = streak;
            if (lblEl) {
                lblEl.textContent = streak === 0
                    ? 'Aucune série en cours'
                    : `jour${streak > 1 ? 's' : ''} sous le budget journalier (${data.daily_budget} ${data.devise}/j)`;
            }

            // Badges
            const container = document.getElementById('gamiBadges');
            if (container && data.achievements) {
                container.innerHTML = data.achievements.map(a => `
                    <div class="gami-badge ${a.earned ? 'gami-badge--earned' : 'gami-badge--locked'}">
                        <div class="gami-badge__icon" style="background:${a.earned ? a.color + '22' : 'var(--color-border)'};color:${a.earned ? a.color : '#9ca3af'}">
                            ${ICONS[a.icon] ?? '🏅'}
                        </div>
                        <div class="gami-badge__text">
                            <div class="gami-badge__name">${a.title}</div>
                            <div class="gami-badge__desc">${a.desc}</div>
                            ${!a.earned && a.progress !== undefined ? `
                            <div class="gami-badge__progress">
                                <div class="gami-badge__progress-track">
                                    <div class="gami-badge__progress-fill" style="width:${Math.min(100,(a.progress/a.target)*100)}%;background:${a.color}"></div>
                                </div>
                                <div class="gami-badge__progress-label">${a.progress} / ${a.target}</div>
                            </div>` : ''}
                        </div>
                        ${a.earned ? `<div class="gami-badge__check">✓</div>` : ''}
                    </div>`).join('');
            }

            // Challenge
            if (data.challenge) {
                const ch = data.challenge;
                document.getElementById('gamiChallenge').style.display = 'block';
                document.getElementById('gamiChallengeDesc').textContent =
                    `vs "${ch.prev_budget}" (${ch.prev_pct}% consommé) — objectif : ${ch.target_pct}%`;
                const progress = Math.min(100, ch.target_pct > 0
                    ? Math.max(0, (1 - ch.current_pct / ch.target_pct) * 100) : 0);
                const fill = document.getElementById('gamiChallengeFill');
                if (fill) {
                    fill.style.width = (ch.winning ? 100 : Math.max(5, 100 - (ch.current_pct / Math.max(ch.target_pct, 1)) * 100)) + '%';
                    fill.style.background = ch.winning ? '#10b981' : '#f59e0b';
                }
                document.getElementById('gamiChallengeLeft').textContent =
                    `Actuel : ${ch.current_pct}%`;
                document.getElementById('gamiChallengeStatus').textContent =
                    ch.winning ? '✓ Défi réussi !' : `Écart : +${ch.gap}%`;
            }
        })
        .catch(() => {});
})();
</script>
{% endblock %}