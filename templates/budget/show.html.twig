============================================================ */
function closeConvertModal() {
    const modal = document.getElementById('modal-convert-all');
    if (modal) modal.classList.remove('open');
}

async function executeConvertAll() {
    const targetDevise = document.getElementById('convert-target-devise')?.value;
    const progressDiv = document.getElementById('convert-progress');
    const progressBar = progressDiv?.querySelector('.progress-fill');
    const progressText = document.getElementById('convert-progress-text');
    const submitBtn = document.querySelector('#modal-convert-all .btn-modal-submit');
    const cancelBtn = document.querySelector('#modal-convert-all .btn-modal-cancel');
    
    if (submitBtn) submitBtn.disabled = true;
    if (cancelBtn) cancelBtn.disabled = true;
    if (progressDiv) progressDiv.style.display = 'block';
    if (progressText) progressText.textContent = 'Conversion en cours...';
    if (progressBar) progressBar.style.width = '30%';
    
    try {
        const formData = new FormData();
        formData.append('target_devise', targetDevise);
        if (progressBar) progressBar.style.width = '60%';
        const response = await fetch('{{ path('app_budget_convert_depenses', {id: budget.idBudget}) }}', {
            method: 'POST',
            body: formData
        });
        const result = await response.json();
        if (result.success) {
            if (progressBar) progressBar.style.width = '100%';
            if (progressText) progressText.textContent = '✓ ' + result.message;
            setTimeout(() => {
                closeConvertModal();
                window.location.reload();
            }, 1500);
        } else {
            if (progressText) progressText.textContent = '❌ ' + (result.error || 'Erreur lors de la conversion');
            if (progressBar) progressBar.style.backgroundColor = '#dc2626';
            if (submitBtn) submitBtn.disabled = false;
            if (cancelBtn) cancelBtn.disabled = false;
        }
    } catch (error) {
        if (progressText) progressText.textContent = '❌ Erreur réseau. Veuillez réessayer.';
        if (progressBar) progressBar.style.backgroundColor = '#dc2626';
        if (submitBtn) submitBtn.disabled = false;
        if (cancelBtn) cancelBtn.disabled = false;
    }
}

document.getElementById('massConvertBtn')?.addEventListener('click', () => {
    const modal = document.getElementById('modal-convert-all');
    if (modal) modal.classList.add('open');
});

