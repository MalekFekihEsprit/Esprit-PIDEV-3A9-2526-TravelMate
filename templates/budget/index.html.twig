        {% endfor %}

        </div>

        <div id="noResults" style="display:none;text-align:center;padding:3rem 1rem;color:var(--color-text-muted)">
            <div style="font-size:2.5rem;margin-bottom:.75rem">🔍</div>
            <div style="font-weight:700;font-size:1rem;color:var(--color-text);margin-bottom:.35rem">Aucun résultat</div>
            <p>Essayez de modifier vos filtres ou votre recherche.</p>
