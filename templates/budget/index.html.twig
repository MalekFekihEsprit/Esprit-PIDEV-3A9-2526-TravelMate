        <div class="dp-stats">
            <div class="dp-stat">
                <div class="dp-stat__label">Budget alloué</div>
                <div class="dp-stat__value dp-stat__value--primary" id="dp-montant-total">—</div>
            </div>
            <div class="dp-stat">
                <div class="dp-stat__label">Total dépensé</div>
                <div class="dp-stat__value" id="dp-depense-total">—</div>
            </div>
            <div class="dp-stat">
                <div class="dp-stat__label">Restant / Excès</div>
                <div class="dp-stat__value" id="dp-restant">—</div>
