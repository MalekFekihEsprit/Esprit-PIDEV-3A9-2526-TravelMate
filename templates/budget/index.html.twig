{% block javascripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script>
/* ════════════════════════════════════════════════════════
   STATE
════════════════════════════════════════════════════════ */
const PER_PAGE = 6;
const state = {
    search: '', devises: new Set(['all']),
    statut: 'all', sort: 'default', view: 'grid',
    page: 1
};

const grid         = document.getElementById('budgetGrid');
const noResults    = document.getElementById('noResults');
const resultsCount = document.getElementById('resultsCount');
const activeFilLbl = document.getElementById('activeFiltersLabel');
const pagWrap      = document.getElementById('paginationWrap');
const layout       = document.getElementById('budgetLayout');
const detailPanel  = document.getElementById('detailPanel');
const selBar       = document.getElementById('selectionBar');
const allCards     = Array.from(document.querySelectorAll('.act-card'));

/* ════════════════════════════════════════════════════════
   SEARCH — DYNAMIC (instant filtering)
════════════════════════════════════════════════════════ */
const searchInput = document.getElementById('searchInput');
const searchClear = document.getElementById('searchClear');

searchInput.addEventListener('input', e => {
    state.search = e.target.value;
    searchClear.classList.toggle('visible', state.search.length > 0);
    resetAndApply();
});
searchClear.addEventListener('click', () => {
    searchInput.value = '';
    state.search = '';
    searchClear.classList.remove('visible');
    searchInput.focus();
    resetAndApply();
});

/* ── Build devise chips ─────────────────────────── */
(function() {
    const deviseFilter = document.getElementById('deviseFilter');
    const devises = [...new Set(allCards.map(c => c.dataset.devise))].sort();
    devises.forEach(d => {
        const b = document.createElement('button');
        b.className = 'chip'; b.dataset.devise = d; b.textContent = d;
        deviseFilter.appendChild(b);
    });
})();

/* ════════════════════════════════════════════════════════
   CORE: filter → sort → paginate → render
════════════════════════════════════════════════════════ */
function applyAll() {
    const q = state.search.toLowerCase().trim();

    let visible = allCards.filter(c => {
        const txt = !q || c.dataset.name.includes(q) || c.dataset.voyage.includes(q) || c.dataset.devise.toLowerCase().includes(q);
        const dev = state.devises.has('all') || state.devises.has(c.dataset.devise);
        const sta = state.statut === 'all' || c.dataset.statut === state.statut;
        return txt && dev && sta;
    });

    visible = [...visible].sort((a, b) => {
        switch (state.sort) {
            case 'name-asc':      return a.dataset.name.localeCompare(b.dataset.name);
            case 'name-desc':     return b.dataset.name.localeCompare(a.dataset.name);
            case 'montant-asc':   return +a.dataset.montant  - +b.dataset.montant;
            case 'montant-desc':  return +b.dataset.montant  - +a.dataset.montant;
            case 'depenses-asc':  return +a.dataset.depenses - +b.dataset.depenses;
            case 'depenses-desc': return +b.dataset.depenses - +a.dataset.depenses;
            case 'restant-asc':   return +a.dataset.restant  - +b.dataset.restant;
            case 'restant-desc':  return +b.dataset.restant  - +a.dataset.restant;
            default: return 0;
        }
    });

    const totalPages = Math.max(1, Math.ceil(visible.length / PER_PAGE));
    if (state.page > totalPages) state.page = totalPages;

    const start = (state.page - 1) * PER_PAGE;
    const pageItems = visible.slice(start, start + PER_PAGE);

    allCards.forEach(c => { c.style.display = 'none'; });
    pageItems.forEach(c => { c.style.display = ''; grid.appendChild(c); });

    const from = visible.length === 0 ? 0 : start + 1;
    const to   = Math.min(start + PER_PAGE, visible.length);
    resultsCount.innerHTML = visible.length === 0
        ? `<strong>0</strong> résultat`
        : `<strong>${from}–${to}</strong> sur <strong>${visible.length}</strong> budget(s)`;

    const parts = [];
    if (q) parts.push(`🔍 "${q}"`);
    if (!state.devises.has('all')) parts.push([...state.devises].join(', '));
    if (state.statut !== 'all') parts.push(state.statut === 'over' ? '⚠ Dépassés' : '✔ Contrôlés');
    if (state.sort !== 'default') parts.push('Trié');
    activeFilLbl.textContent = parts.length ? '— ' + parts.join(' · ') : '';

    noResults.style.display  = visible.length === 0 ? 'block' : 'none';
    pagWrap.style.display    = visible.length <= PER_PAGE ? 'none' : 'flex';

    renderPagination(totalPages);
}

function renderPagination(total) {
    if (total <= 1) { pagWrap.innerHTML = ''; return; }
    let html = '';
    html += `<button class="pag-btn" onclick="goPage(${state.page - 1})" ${state.page === 1 ? 'disabled' : ''}>‹ Préc.</button>`;
    buildPageRange(state.page, total).forEach(p => {
        if (p === '…') html += `<span class="pag-ellipsis">…</span>`;
        else html += `<button class="pag-btn ${p === state.page ? 'active' : ''}" onclick="goPage(${p})">${p}</button>`;
    });
    html += `<button class="pag-btn" onclick="goPage(${state.page + 1})" ${state.page === total ? 'disabled' : ''}>Suiv. ›</button>`;
    html += `<span class="pag-info">Page ${state.page} / ${total}</span>`;
    pagWrap.innerHTML = html;
}

function buildPageRange(current, total) {
    if (total <= 7) return Array.from({length: total}, (_, i) => i + 1);
    const pages = [];
    if (current <= 4) {
        for (let i = 1; i <= 5; i++) pages.push(i);
        pages.push('…'); pages.push(total);
    } else if (current >= total - 3) {
        pages.push(1); pages.push('…');
        for (let i = total - 4; i <= total; i++) pages.push(i);
    } else {
        pages.push(1); pages.push('…');
        for (let i = current - 1; i <= current + 1; i++) pages.push(i);
        pages.push('…'); pages.push(total);
    }
    return pages;
}

function goPage(p) { state.page = p; applyAll(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
function resetAndApply() { state.page = 1; applyAll(); }

/* ── Filters ───────────────────────────────────────── */
document.getElementById('deviseFilter').addEventListener('click', e => {
    const btn = e.target.closest('.chip[data-devise]');
    if (!btn) return;
    const d = btn.dataset.devise;
    if (d === 'all') { state.devises.clear(); state.devises.add('all'); }
    else {
        state.devises.delete('all');
        state.devises.has(d) ? state.devises.delete(d) : state.devises.add(d);
        if (!state.devises.size) state.devises.add('all');
    }
    document.querySelectorAll('#deviseFilter .chip').forEach(c => c.classList.toggle('active', state.devises.has(c.dataset.devise)));
    resetAndApply();
});

document.getElementById('statutFilter').addEventListener('click', e => {
    const btn = e.target.closest('.chip[data-statut]');
    if (!btn) return;
    state.statut = btn.dataset.statut;
    document.querySelectorAll('#statutFilter .chip').forEach(c => c.classList.toggle('active', c.dataset.statut === state.statut));
    resetAndApply();
});

document.getElementById('sortSelect').addEventListener('change', e => { state.sort = e.target.value; resetAndApply(); });

document.getElementById('toggleView').addEventListener('click', () => {
    state.view = state.view === 'grid' ? 'list' : 'grid';
    grid.style.gridTemplateColumns = state.view === 'list' ? '1fr' : '';
    document.getElementById('viewIcon').innerHTML = state.view === 'list'
        ? `<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>`
        : `<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>`;
});

/* ════════════════════════════════════════════════════════
   DETAIL PANEL
════════════════════════════════════════════════════════ */
let activeDetailCard = null;

const CAT_ICON = {
    'hébergement':'🏨','hebergement':'🏨','transport':'✈️',
    'restauration':'🍽️','nourriture':'🍽️','loisirs':'🎭',
    'activité':'🎭','achats':'🛍️','shopping':'🛍️','santé':'💊','sante':'💊'
};
const CAT_COLOR = {
    'hébergement':'#fef3c7','hebergement':'#fef3c7','transport':'#dbeafe',
    'restauration':'#d1fae5','nourriture':'#d1fae5','loisirs':'#ede9fe',
    'activité':'#ede9fe','achats':'#fce7f3','shopping':'#fce7f3','santé':'#fee2e2','sante':'#fee2e2'
};

function openDetailPanel(card) {
    if (activeDetailCard) activeDetailCard.classList.remove('active-detail');
    activeDetailCard = card;
    card.classList.add('active-detail');

    const devise     = card.dataset.devise;
    const montant    = parseFloat(card.dataset.montant);
    const depensed   = parseFloat(card.dataset.totalDepense);
    const restant    = parseFloat(card.dataset.restant);
    const isOver     = card.dataset.isOver === '1';
    const pct        = Math.min(parseInt(card.dataset.pct), 100);
    const deps       = JSON.parse(card.dataset.deps || '[]');

    document.getElementById('dp-title').textContent = card.dataset.libelle;
    document.getElementById('dp-pct-label').textContent = isOver
        ? `⚠ Dépassé de ${Math.abs(restant).toLocaleString('fr-FR')} ${devise}`
        : `${card.dataset.pct}% consommé`;
    document.getElementById('dp-montant-label').textContent = `${montant.toLocaleString('fr-FR')} ${devise}`;

    const fill = document.getElementById('dp-progress-fill');
    fill.style.width = pct + '%';
    fill.className = 'dp-progress-fill' + (isOver ? ' dp-progress-fill--over' : (parseInt(card.dataset.pct) > 75 ? ' dp-progress-fill--warn' : ''));

    document.getElementById('dp-montant-total').textContent = `${montant.toLocaleString('fr-FR')} ${devise}`;
    document.getElementById('dp-depense-total').textContent = `${depensed.toLocaleString('fr-FR')} ${devise}`;

    const restEl = document.getElementById('dp-restant');
    restEl.textContent = (isOver ? '- ' : '+ ') + Math.abs(restant).toLocaleString('fr-FR') + ' ' + devise;
    restEl.className = 'dp-stat__value ' + (isOver ? 'dp-stat__value--danger' : 'dp-stat__value--success');

    document.getElementById('dp-nb-dep').textContent = deps.length;
    document.getElementById('dp-dep-count').textContent = deps.length;

    // Render depenses list
    const list = document.getElementById('dp-dep-list');
    if (deps.length === 0) {
        list.innerHTML = '<li class="dp-empty">📭 Aucune dépense enregistrée</li>';
    } else {
        list.innerHTML = deps.map(d => {
            const cat = (d.categorie || '').toLowerCase();
            const icon = CAT_ICON[cat] || '💸';
            const bg   = CAT_COLOR[cat] || 'var(--color-surface-soft)';
            return `<li class="dp-dep-item">
                <div class="dp-dep-icon" style="background:${bg}">${icon}</div>
                <div class="dp-dep-body">
                    <div class="dp-dep-label">${escHtml(d.label)}</div>
                    <div class="dp-dep-meta">${escHtml(d.categorie)} · ${escHtml(d.date)}</div>
                </div>
                <div class="dp-dep-amount">${parseFloat(d.montant).toLocaleString('fr-FR',{minimumFractionDigits:2})} <small style="font-weight:400;color:var(--color-text-muted)">${escHtml(d.devise)}</small></div>
            </li>`;
        }).join('');
    }

    // Actions
    document.getElementById('dp-actions').innerHTML = `
        <a href="${card.dataset.urlShow}" class="dp-btn dp-btn--view">
            <span>→</span> Voir le détail complet
        </a>
        <a href="${card.dataset.urlEdit}" class="dp-btn dp-btn--edit">
            <span>✏️</span> Modifier le budget
        </a>
        <button class="dp-btn dp-btn--delete" onclick="confirmDeleteOneByCard(document.querySelector('.act-card.active-detail'))">
            <span>🗑️</span> Supprimer ce budget
        </button>
    `;

    layout.classList.add('with-detail');
    detailPanel.classList.add('visible');
}

function closeDetailPanel() {
    if (activeDetailCard) activeDetailCard.classList.remove('active-detail');
    activeDetailCard = null;
    layout.classList.remove('with-detail');
    detailPanel.classList.remove('visible');
}

function escHtml(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ════════════════════════════════════════════════════════
   MULTI-SELECTION
════════════════════════════════════════════════════════ */
let selectedIds = new Set();
let selectMode  = false;

function toggleSelectMode(on) {
    selectMode = on;
    grid.classList.toggle('select-mode', on);
    selBar.classList.toggle('visible', on);
    if (!on) {
        selectedIds.clear();
        allCards.forEach(c => c.classList.remove('selected'));
        updateSelCount();
    }
}

function toggleCardSelection(card) {
    const id = card.dataset.id;
    if (selectedIds.has(id)) {
        selectedIds.delete(id);
        card.classList.remove('selected');
    } else {
        selectedIds.add(id);
        card.classList.add('selected');
    }
    if (selectedIds.size === 0) {
        toggleSelectMode(false);
    } else {
        selectMode = true;
        selBar.classList.add('visible');
        updateSelCount();
    }
}

function updateSelCount() {
    document.getElementById('selCount').textContent = selectedIds.size;
}

function handleCardClick(e, card) {
    // If clicking inside action buttons — let them handle it
    if (e.target.closest('.act-card__actions')) return;

    // If click on checkbox or in select mode — toggle selection
    if (e.target.closest('.card-checkbox-wrap') || selectMode) {
        toggleCardSelection(card);
        return;
    }

    // Otherwise open detail panel
    openDetailPanel(card);
}

document.getElementById('btnCancelSel').addEventListener('click', () => toggleSelectMode(false));
document.getElementById('btnSelectAll').addEventListener('click', () => {
    const visible = allCards.filter(c => c.style.display !== 'none');
    const allSelected = visible.every(c => selectedIds.has(c.dataset.id));
    if (allSelected) {
        visible.forEach(c => { selectedIds.delete(c.dataset.id); c.classList.remove('selected'); });
        if (selectedIds.size === 0) toggleSelectMode(false);
    } else {
        visible.forEach(c => { selectedIds.add(c.dataset.id); c.classList.add('selected'); });
        selectMode = true;
        selBar.classList.add('visible');
    }
    updateSelCount();
});

document.getElementById('btnDeleteSel').addEventListener('click', () => {
    if (selectedIds.size === 0) return;
    const names = [...selectedIds].map(id => {
        const c = document.querySelector(`.act-card[data-id="${id}"]`);
        return c ? escHtml(c.dataset.libelle) : id;
    });
    document.getElementById('bulk-count').textContent = selectedIds.size;
    document.getElementById('bulk-names').innerHTML = names.map(n => `<div>• ${n}</div>`).join('');
    document.getElementById('modal-bulk-delete').classList.add('open');
});

function closeBulkModal() {
    document.getElementById('modal-bulk-delete').classList.remove('open');
}

async function executeBulkDelete() {
    closeBulkModal();
    const ids = [...selectedIds];
    for (const id of ids) {
        const card = document.querySelector(`.act-card[data-id="${id}"]`);
        if (!card) continue;
        const form = document.getElementById('form-budget-delete');
        form.action = card.dataset.urlDelete;
        document.getElementById('budget-delete-token').value = card.dataset.csrfDelete;
        // Submit via fetch
        const fd = new FormData(form);
        try {
            await fetch(form.action, { method: 'POST', body: fd });
        } catch(e) {}
        card.remove();
    }
    toggleSelectMode(false);
    // Reload to refresh server state
    window.location.reload();
}

/* ── Single card delete ─────────────────────── */
function confirmDeleteOne(btn) {
    const card = btn.closest('.act-card');
    confirmDeleteOneByCard(card);
}
function confirmDeleteOneByCard(card) {
    if (!card) return;
    if (!confirm(`Supprimer le budget "${card.dataset.libelle}" et toutes ses dépenses ?`)) return;
    const form = document.getElementById('form-budget-delete');
    form.action = card.dataset.urlDelete;
    document.getElementById('budget-delete-token').value = card.dataset.csrfDelete;
    form.submit();
}

