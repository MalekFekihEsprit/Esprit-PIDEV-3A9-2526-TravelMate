document.getElementById('exportPdf').addEventListener('click', () => {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation:'landscape', unit:'mm', format:'a4' });
    const vis = allCards.filter(c => c.style.display !== 'none');
    const pageW = 297;
    const today = new Date().toLocaleDateString('fr-FR',{day:'2-digit',month:'long',year:'numeric'});

    /* ── Cover Header ── */
    // Gradient header band
    doc.setFillColor(59, 42, 26);
    doc.rect(0, 0, pageW, 28, 'F');
    doc.setFillColor(196, 111, 75);
    doc.rect(0, 18, pageW, 10, 'F');

    // Logo area
    doc.setFillColor(255, 255, 255, 0.15);
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(18); doc.setFont('helvetica', 'bold');
    doc.text('✦ TravelMate', 14, 12);
    doc.setFontSize(9); doc.setFont('helvetica', 'normal');
    doc.text('Rapport de Budgets de Voyage', 14, 22);
    doc.setFontSize(8); doc.setTextColor(255, 230, 200);
    doc.text(`Généré le ${today}`, pageW - 14, 22, { align: 'right' });

    /* ── Summary Section ── */
    const sumMontant  = vis.reduce((s,c) => s + parseFloat(c.dataset.montant), 0);
    const sumDepense  = vis.reduce((s,c) => s + parseFloat(c.dataset.totalDepense || 0), 0);
    const sumRestant  = vis.reduce((s,c) => s + parseFloat(c.dataset.restant), 0);
    const nbOver      = vis.filter(c => c.dataset.statut === 'over').length;
    const nbOk        = vis.length - nbOver;

    // Stats cards
    const statY = 35;
    const statW = 60, statH = 16, statGap = 6;
    const stats = [
        { label: 'Budgets analysés', value: String(vis.length), color: [196,111,75] },
        { label: 'Montant total alloué', value: sumMontant.toLocaleString('fr-FR') + ' (multi-devises)', color: [59,130,246] },
        { label: 'Total dépensé', value: sumDepense.toLocaleString('fr-FR'), color: [107,114,128] },
        { label: 'Budgets dépassés', value: String(nbOver) + ' / ' + vis.length, color: nbOver > 0 ? [185,28,28] : [4,120,87] },
    ];
    stats.forEach((s, i) => {
        const x = 14 + i * (statW + statGap);
        doc.setFillColor(...s.color);
        doc.roundedRect(x, statY, statW, statH, 2, 2, 'F');
        doc.setTextColor(255,255,255);
        doc.setFontSize(7); doc.setFont('helvetica','normal');
        doc.text(s.label, x + 4, statY + 5.5);
        doc.setFontSize(10); doc.setFont('helvetica','bold');
        doc.text(s.value, x + 4, statY + 12);
    });

    /* ── Table ── */
    doc.autoTable({
        startY: statY + statH + 8,
        head: [['#', 'Nom du budget', 'Voyage', 'Devise', 'Alloué', 'Dépensé', 'Restant', '% Consommé', 'Statut']],
        body: vis.map((c, i) => {
            const montant  = parseFloat(c.dataset.montant);
            const depensed = parseFloat(c.dataset.totalDepense || 0);
            const restant  = parseFloat(c.dataset.restant);
            const pct      = parseInt(c.dataset.pct || 0);
            return [
                String(i + 1),
                c.dataset.libelle,
                c.dataset.voyageTitle || '—',
                c.dataset.devise,
                montant.toLocaleString('fr-FR'),
                depensed.toLocaleString('fr-FR'),
                Math.abs(restant).toLocaleString('fr-FR'),
                pct + '%',
                c.dataset.statut === 'over' ? 'Dépassé' : 'Contrôlé'
            ];
        }),
        headStyles: {
            fillColor: [59, 42, 26], textColor: [255, 230, 200],
            fontStyle: 'bold', fontSize: 8.5, cellPadding: 4
        },
        bodyStyles: { fontSize: 8, textColor: [40, 40, 40], cellPadding: 3.5 },
        alternateRowStyles: { fillColor: [252, 248, 243] },
        columnStyles: {
            0: { cellWidth: 8,  halign: 'center' },
            1: { cellWidth: 62 },
            2: { cellWidth: 40 },
            3: { cellWidth: 18, halign: 'center' },
            4: { cellWidth: 28, halign: 'right' },
            5: { cellWidth: 28, halign: 'right' },
            6: { cellWidth: 28, halign: 'right' },
            7: { cellWidth: 20, halign: 'center' },
            8: { cellWidth: 24, halign: 'center' }
        },
        didParseCell(data) {
            if (data.section === 'body') {
                // Statut column coloring
                if (data.column.index === 8) {
                    if (data.cell.raw === 'Dépassé') {
                        data.cell.styles.textColor = [185, 28, 28];
                        data.cell.styles.fontStyle = 'bold';
                        data.cell.styles.fillColor = [254, 226, 226];
                    } else {
                        data.cell.styles.textColor = [4, 120, 87];
                        data.cell.styles.fontStyle = 'bold';
                        data.cell.styles.fillColor = [209, 250, 229];
                    }
                }
                // Restant column — red if over
                if (data.column.index === 6) {
                    const rowIdx = data.row.index;
                    const card = vis.filter(c => c.style.display !== 'none')[rowIdx];
                    if (card && card.dataset.statut === 'over') {
                        data.cell.styles.textColor = [185, 28, 28];
                        data.cell.styles.fontStyle = 'bold';
                    }
                }
                // % column — color based on value
                if (data.column.index === 7) {
                    const pct = parseInt(data.cell.raw);
                    if (pct >= 100) data.cell.styles.textColor = [185, 28, 28];
                    else if (pct >= 75) data.cell.styles.textColor = [217, 119, 6];
                    else data.cell.styles.textColor = [4, 120, 87];
                    data.cell.styles.fontStyle = 'bold';
                }
            }
        },
        margin: { left: 14, right: 14 },
        tableLineColor: [220, 210, 200],
        tableLineWidth: 0.3,
    });

    /* ── Footer on each page ── */
    const n = doc.internal.getNumberOfPages();
    for (let i = 1; i <= n; i++) {
        doc.setPage(i);
        doc.setFillColor(245, 237, 227);
        doc.rect(0, 197, pageW, 8, 'F');
        doc.setFontSize(7); doc.setFont('helvetica','normal');
        doc.setTextColor(160, 140, 120);
        doc.text('TravelMate — Rapport confidentiel', 14, 202);
        doc.text(`Page ${i} / ${n}`, pageW - 14, 202, { align: 'right' });
    }

    doc.save(`budgets_travelmate_${new Date().toISOString().slice(0,10)}.pdf`);
});

/* Initial render */
applyAll();

/* ════════════════════════════════════════════════════════
   TOAST NOTIFICATION — flying message bottom-right
════════════════════════════════════════════════════════ */
(function () {
    function showToast(message) {
        let container = document.getElementById('toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.style.cssText = [
                'position:fixed',
                'bottom:1.5rem',
                'right:1.5rem',
                'z-index:9999',
                'display:flex',
                'flex-direction:column',
                'gap:.5rem',
                'pointer-events:none'
            ].join(';');
            document.body.appendChild(container);
        }

        const toast = document.createElement('div');
        toast.textContent = message;
        toast.style.cssText = [
            'background:#3b2a1a',
            'color:#fff',
            'padding:.75rem 1.1rem',
            'border-radius:8px',
            'font-size:.85rem',
            'max-width:320px',
            'line-height:1.5',
            'opacity:0',
            'transform:translateY(10px)',
            'transition:opacity .25s ease, transform .25s ease'
        ].join(';');

        container.appendChild(toast);

        requestAnimationFrame(() => requestAnimationFrame(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
        }));

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(10px)';
            toast.addEventListener('transitionend', () => toast.remove(), { once: true });
        }, 4000);
    }

    const _fetch = window.fetch;
    window.fetch = async function (...args) {
        const res = await _fetch(...args);
        const url = typeof args[0] === 'string' ? args[0] : (args[0]?.url ?? '');
        if (url.includes('/ai/notification')) {
            res.clone().json().then(data => {
                if (data?.message) showToast(data.message);
            }).catch(() => {});
        }
        return res;
    };
})();
</script>
{% endblock %}
