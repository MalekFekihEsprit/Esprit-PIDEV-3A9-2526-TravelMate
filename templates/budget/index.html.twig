{% block javascripts %}
<script>
/* ============================================================
   CORE FILTERING - VOYAGE EN LISTE DEROULANTE
   ============================================================ */

const PER_PAGE = 6;

// Filter state
let state = {
    search: '',
    selectedVoyage: 'all',  // Pour le select (un seul voyage à la fois)
    devises: new Set(['all']),
    statuts: new Set(['all']),
    sort: 'default',
    page: 1
};

let allCards = [];
let activeDetailCard = null;
let selectedIds = new Set();
let selectMode = false;

// Helper: refresh card list from DOM
function refreshCards() {
    allCards = Array.from(document.querySelectorAll('.act-card'));
}

// ============================================================
// VOYAGE FILTER - Liste déroulante (SELECT)
// ============================================================
function populateVoyageSelect() {
    const select = document.getElementById('voyageSelect');
    if (!select) return;

    // Garder l'option "Tous les voyages"
    select.innerHTML = '<option value="all">Tous les voyages</option>';

    // Collecter les voyages uniques depuis les cartes
    const voyagesMap = new Map();
    allCards.forEach(card => {
        const voyageId = card.dataset.voyageId;
        const voyageTitle = card.dataset.voyageTitle;
        if (voyageId && voyageTitle && !voyagesMap.has(voyageId)) {
            voyagesMap.set(voyageId, voyageTitle);
        }
    });

    // Trier et ajouter les options
    const sorted = Array.from(voyagesMap.entries()).sort((a, b) => a[1].localeCompare(b[1]));
    for (const [id, title] of sorted) {
        const option = document.createElement('option');
        option.value = id;
        option.textContent = title;
        select.appendChild(option);
    }

    // Écouter le changement de sélection
    select.addEventListener('change', (e) => {
        state.selectedVoyage = e.target.value;
        state.page = 1;
        applyAllFilters();
    });
}

// ============================================================
// DEVISE FILTERS - Multi-select chips
// ============================================================
function populateDeviseFilters() {
    const container = document.getElementById('deviseChipsContainer');
    if (!container) return;

    // Garder seulement "Toutes" au début
    container.innerHTML = '';
    const allBtn = document.createElement('button');
    allBtn.className = 'chip active';
    allBtn.dataset.devise = 'all';
    allBtn.textContent = 'Toutes';
    container.appendChild(allBtn);

    // Collecter les devises uniques
    const devisesSet = new Set();
    allCards.forEach(card => {
        const devise = card.dataset.devise;
        if (devise) devisesSet.add(devise);
    });

    // Ajouter les chips
    const sorted = Array.from(devisesSet).sort();
    for (const devise of sorted) {
        const chip = document.createElement('button');
        chip.className = 'chip';
        chip.dataset.devise = devise;
        chip.textContent = devise;
        container.appendChild(chip);
    }

    // Attacher les événements click
    document.querySelectorAll('#deviseChipsContainer .chip').forEach(chip => {
        chip.addEventListener('click', (e) => {
            e.stopPropagation();
            const value = chip.dataset.devise;
            if (value === 'all') {
                state.devises.clear();
                state.devises.add('all');
                document.querySelectorAll('#deviseChipsContainer .chip').forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
            } else {
                state.devises.delete('all');
                if (state.devises.has(value)) {
                    state.devises.delete(value);
                    chip.classList.remove('active');
                } else {
                    state.devises.add(value);
                    chip.classList.add('active');
                }
                if (state.devises.size === 0) {
                    state.devises.add('all');
                    const allChip = document.querySelector('#deviseChipsContainer .chip[data-devise="all"]');
                    if (allChip) allChip.classList.add('active');
                } else {
                    const allChip = document.querySelector('#deviseChipsContainer .chip[data-devise="all"]');
                    if (allChip) allChip.classList.remove('active');
                }
            }
            state.page = 1;
            applyAllFilters();
        });
    });
}

// ============================================================
// STATUT FILTERS - Multi-select chips
// ============================================================
function initStatutFilters() {
    document.querySelectorAll('#statutChipsContainer .chip').forEach(chip => {
        chip.addEventListener('click', (e) => {
            e.stopPropagation();
            const value = chip.dataset.statut;
            if (value === 'all') {
                state.statuts.clear();
                state.statuts.add('all');
                document.querySelectorAll('#statutChipsContainer .chip').forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
            } else {
                state.statuts.delete('all');
                if (state.statuts.has(value)) {
                    state.statuts.delete(value);
                    chip.classList.remove('active');
                } else {
                    state.statuts.add(value);
                    chip.classList.add('active');
                }
                if (state.statuts.size === 0) {
                    state.statuts.add('all');
                    const allChip = document.querySelector('#statutChipsContainer .chip[data-statut="all"]');
                    if (allChip) allChip.classList.add('active');
                } else {
                    const allChip = document.querySelector('#statutChipsContainer .chip[data-statut="all"]');
                    if (allChip) allChip.classList.remove('active');
                }
            }
            state.page = 1;
            applyAllFilters();
        });
    });
}

// ============================================================
// SEARCH
// ============================================================
function initSearch() {
    const searchInput = document.getElementById('searchInput');
    const searchClear = document.getElementById('searchClear');
    if (!searchInput) return;

    searchInput.addEventListener('input', (e) => {
        state.search = e.target.value;
        searchClear.classList.toggle('visible', state.search.length > 0);
        state.page = 1;
        applyAllFilters();
    });

    searchClear.addEventListener('click', () => {
        searchInput.value = '';
        state.search = '';
        searchClear.classList.remove('visible');
        state.page = 1;
        applyAllFilters();
    });
}

// ============================================================
// SORT
// ============================================================
function initSort() {
    const sortSelect = document.getElementById('sortSelect');
    if (!sortSelect) return;
    sortSelect.addEventListener('change', (e) => {
        state.sort = e.target.value;
        state.page = 1;
        applyAllFilters();
    });
}

// ============================================================
// RESET ALL FILTERS
// ============================================================
function initResetButton() {
    const resetBtn = document.getElementById('resetFiltersBtn');
    if (!resetBtn) return;
    resetBtn.addEventListener('click', () => {
        // Reset state
        state.search = '';
        state.selectedVoyage = 'all';
        state.devises.clear();
        state.devises.add('all');
        state.statuts.clear();
        state.statuts.add('all');
        state.sort = 'default';
        state.page = 1;

        // Reset UI
        const searchInput = document.getElementById('searchInput');
        if (searchInput) searchInput.value = '';
        const searchClear = document.getElementById('searchClear');
        if (searchClear) searchClear.classList.remove('visible');
        const sortSelect = document.getElementById('sortSelect');
        if (sortSelect) sortSelect.value = 'default';
        const voyageSelect = document.getElementById('voyageSelect');
        if (voyageSelect) voyageSelect.value = 'all';

        // Reset devise chips
        document.querySelectorAll('#deviseChipsContainer .chip').forEach(c => {
            c.classList.remove('active');
            if (c.dataset.devise === 'all') c.classList.add('active');
        });

        // Reset statut chips
        document.querySelectorAll('#statutChipsContainer .chip').forEach(c => {
            c.classList.remove('active');
            if (c.dataset.statut === 'all') c.classList.add('active');
        });

        applyAllFilters();
    });
}

// ============================================================
// CORE FILTER & PAGINATION
// ============================================================
function applyAllFilters() {
    const q = state.search.toLowerCase().trim();

    let visible = allCards.filter(card => {
        // Text search
        const textMatch = !q ||
            card.dataset.name.includes(q) ||
            (card.dataset.voyage && card.dataset.voyage.includes(q)) ||
            card.dataset.devise.toLowerCase().includes(q);

        // Voyage filter (select - une seule valeur)
        let voyageMatch = state.selectedVoyage === 'all';
        if (!voyageMatch && card.dataset.voyageId) {
            voyageMatch = state.selectedVoyage === card.dataset.voyageId;
        }

        // Devise filter
        let deviseMatch = state.devises.has('all') || state.devises.has(card.dataset.devise);

        // Statut filter
        let statutMatch = state.statuts.has('all') || state.statuts.has(card.dataset.statut);

        return textMatch && voyageMatch && deviseMatch && statutMatch;
    });

    // Sort
    visible.sort((a, b) => {
        switch (state.sort) {
            case 'name-asc': return a.dataset.name.localeCompare(b.dataset.name);
            case 'name-desc': return b.dataset.name.localeCompare(a.dataset.name);
            case 'montant-asc': return parseFloat(a.dataset.montant) - parseFloat(b.dataset.montant);
            case 'montant-desc': return parseFloat(b.dataset.montant) - parseFloat(a.dataset.montant);
            case 'depenses-asc': return parseInt(a.dataset.depenses) - parseInt(b.dataset.depenses);
            case 'depenses-desc': return parseInt(b.dataset.depenses) - parseInt(a.dataset.depenses);
            case 'restant-asc': return parseFloat(a.dataset.restant) - parseFloat(b.dataset.restant);
            case 'restant-desc': return parseFloat(b.dataset.restant) - parseFloat(a.dataset.restant);
            default: return 0;
        }
    });

    // Pagination
    const totalPages = Math.max(1, Math.ceil(visible.length / PER_PAGE));
    if (state.page > totalPages) state.page = totalPages;

    const start = (state.page - 1) * PER_PAGE;
    const pageItems = visible.slice(start, start + PER_PAGE);

    // Hide all, show page items
    allCards.forEach(c => c.style.display = 'none');
    pageItems.forEach(c => c.style.display = '');

    // Update results count
    const from = visible.length === 0 ? 0 : start + 1;
    const to = Math.min(start + PER_PAGE, visible.length);
    const resultsSpan = document.getElementById('resultsCount');
    if (resultsSpan) {
        resultsSpan.innerHTML = visible.length === 0
            ? `<strong>0</strong> résultat`
            : `<strong>${from}–${to}</strong> sur <strong>${visible.length}</strong> budget(s)`;
    }

    // Update active filters label
    const parts = [];
    if (q) parts.push(`🔍 "${q}"`);
    if (state.selectedVoyage !== 'all') {
        const select = document.getElementById('voyageSelect');
        const selectedText = select?.options[select.selectedIndex]?.textContent || state.selectedVoyage;
        parts.push(`Voyage: ${selectedText}`);
    }
    if (!state.devises.has('all')) parts.push(`Devise: ${[...state.devises].join(', ')}`);
    if (!state.statuts.has('all')) parts.push(`Statut: ${[...state.statuts].map(s => s === 'ok' ? 'Contrôlé' : 'Dépassé').join(', ')}`);
    if (state.sort !== 'default') parts.push('Trié');
    const activeLabel = document.getElementById('activeFiltersLabel');
    if (activeLabel) activeLabel.textContent = parts.length ? '— ' + parts.join(' · ') : '';

    // Show/hide no results
    const noResultsDiv = document.getElementById('noResults');
    if (noResultsDiv) noResultsDiv.style.display = visible.length === 0 ? 'block' : 'none';

    // Show/hide pagination
    const pagWrap = document.getElementById('paginationWrap');
    if (pagWrap) {
        if (visible.length <= PER_PAGE) {
            pagWrap.style.display = 'none';
        } else {
            pagWrap.style.display = 'flex';
            renderPagination(totalPages);
        }
    }
}

function renderPagination(total) {
    const pagWrap = document.getElementById('paginationWrap');
    if (!pagWrap) return;
    if (total <= 1) {
        pagWrap.innerHTML = '';
        return;
    }
    let html = '';
    html += `<button class="pag-btn" onclick="goPage(${state.page - 1})" ${state.page === 1 ? 'disabled' : ''}>‹ Préc.</button>`;
    for (let i = 1; i <= total; i++) {
        if (i === state.page) {
            html += `<button class="pag-btn active">${i}</button>`;
        } else if (i === 1 || i === total || (i >= state.page - 2 && i <= state.page + 2)) {
            html += `<button class="pag-btn" onclick="goPage(${i})">${i}</button>`;
        } else if (i === state.page - 3 || i === state.page + 3) {
            html += `<span class="pag-ellipsis">…</span>`;
        }
    }
    html += `<button class="pag-btn" onclick="goPage(${state.page + 1})" ${state.page === total ? 'disabled' : ''}>Suiv. ›</button>`;
    html += `<span class="pag-info">Page ${state.page} / ${total}</span>`;
    pagWrap.innerHTML = html;
}

function goPage(page) {
    state.page = page;
    applyAllFilters();
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ============================================================
// DETAIL PANEL
// ============================================================
const CAT_ICON = {
    'hébergement':'🏨','hebergement':'🏨','transport':'✈️',
    'restauration':'🍽️','nourriture':'🍽️','loisirs':'🎭',
    'activité':'🎭','achats':'🛍️','shopping':'🛍️','santé':'💊','sante':'💊'
};

function openDetailPanel(card) {
    if (activeDetailCard) activeDetailCard.classList.remove('active-detail');
    activeDetailCard = card;
    card.classList.add('active-detail');

    const devise = card.dataset.devise;
    const montant = parseFloat(card.dataset.montant);
    const depensed = parseFloat(card.dataset.totalDepense);
    const restant = parseFloat(card.dataset.restant);
    const isOver = card.dataset.isOver === '1';
    const pct = Math.min(parseInt(card.dataset.pct), 100);
    const deps = JSON.parse(card.dataset.deps || '[]');

    document.getElementById('dp-title').textContent = card.dataset.libelle;
    document.getElementById('dp-montant-total').textContent = `${montant.toLocaleString('fr-FR')} ${devise}`;
    document.getElementById('dp-depense-total').textContent = `${depensed.toLocaleString('fr-FR')} ${devise}`;
    document.getElementById('dp-restant').textContent = (isOver ? '- ' : '+ ') + Math.abs(restant).toLocaleString('fr-FR') + ' ' + devise;
    document.getElementById('dp-nb-dep').textContent = deps.length;

    const fill = document.getElementById('dp-progress-fill');
    fill.style.width = pct + '%';
    fill.className = 'dp-progress-fill' + (isOver ? ' dp-progress-fill--over' : '');

    const list = document.getElementById('dp-dep-list');
    if (deps.length === 0) {
        list.innerHTML = '<li class="dp-empty">📭 Aucune dépense enregistrée</li>';
    } else {
        list.innerHTML = deps.map(d => {
            const cat = (d.categorie || '').toLowerCase();
            const icon = CAT_ICON[cat] || '💸';
            return `<li class="dp-dep-item">
                <div class="dp-dep-icon">${icon}</div>
                <div style="flex:1">
                    <div class="dp-dep-label">${escapeHtml(d.label)}</div>
                    <div class="dp-dep-meta">${escapeHtml(d.categorie)} · ${escapeHtml(d.date)}</div>
                </div>
                <div class="dp-dep-amount">${parseFloat(d.montant).toLocaleString('fr-FR')} <small>${escapeHtml(d.devise)}</small></div>
            </li>`;
        }).join('');
    }

    document.getElementById('dp-actions').innerHTML = `
        <a href="${card.dataset.urlShow}" class="dp-btn dp-btn--view">→ Voir le détail complet</a>
        <a href="${card.dataset.urlEdit}" class="dp-btn dp-btn--edit">Modifier le budget</a>
        <button class="dp-btn dp-btn--delete" onclick="confirmDeleteOneByCard(document.querySelector('.act-card.active-detail'))">Supprimer ce budget</button>
    `;

    document.getElementById('budgetLayout').classList.add('with-detail');
    document.getElementById('detailPanel').classList.add('visible');
}

function closeDetailPanel() {
    if (activeDetailCard) activeDetailCard.classList.remove('active-detail');
    activeDetailCard = null;
    document.getElementById('budgetLayout').classList.remove('with-detail');
    document.getElementById('detailPanel').classList.remove('visible');
}

function escapeHtml(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ============================================================
// SELECTION & BULK DELETE
// ============================================================
function updateSelCount() {
    document.getElementById('selCount').textContent = selectedIds.size;
}

function toggleSelectMode(on) {
    selectMode = on;
    document.getElementById('budgetGrid').classList.toggle('select-mode', on);
    document.getElementById('selectionBar').classList.toggle('visible', on);
    if (!on) {
        selectedIds.clear();
        allCards.forEach(c => c.classList.remove('selected'));
        updateSelCount();
    }
}

function toggleCardSelection(card) {
    const id = card.dataset.id;
    if (selectedIds.has(id)) {
        selectedIds.delete(id);
        card.classList.remove('selected');
    } else {
        selectedIds.add(id);
        card.classList.add('selected');
    }
    if (selectedIds.size === 0) {
        toggleSelectMode(false);
    } else {
        selectMode = true;
        document.getElementById('selectionBar').classList.add('visible');
        updateSelCount();
    }
}

function handleCardClick(e, card) {
    if (e.target.closest('.act-card__actions')) return;
    if (e.target.closest('.card-checkbox-wrap') || selectMode) {
        toggleCardSelection(card);
        return;
    }
    openDetailPanel(card);
}

document.getElementById('btnCancelSel')?.addEventListener('click', () => toggleSelectMode(false));
document.getElementById('btnSelectAll')?.addEventListener('click', () => {
    const visible = allCards.filter(c => c.style.display !== 'none');
    const allSelected = visible.every(c => selectedIds.has(c.dataset.id));
    if (allSelected) {
        visible.forEach(c => { selectedIds.delete(c.dataset.id); c.classList.remove('selected'); });
        if (selectedIds.size === 0) toggleSelectMode(false);
    } else {
        visible.forEach(c => { selectedIds.add(c.dataset.id); c.classList.add('selected'); });
        selectMode = true;
        document.getElementById('selectionBar').classList.add('visible');
        updateSelCount();
    }
});

document.getElementById('btnDeleteSel')?.addEventListener('click', () => {
    if (selectedIds.size === 0) return;
    const names = [...selectedIds].map(id => {
        const c = document.querySelector(`.act-card[data-id="${id}"]`);
        return c ? escapeHtml(c.dataset.libelle) : id;
    });
    document.getElementById('bulk-count').textContent = selectedIds.size;
    document.getElementById('bulk-names').innerHTML = names.map(n => `<div>• ${n}</div>`).join('');
    document.getElementById('modal-bulk-delete').classList.add('open');
});

function closeBulkModal() {
    document.getElementById('modal-bulk-delete').classList.remove('open');
}

async function executeBulkDelete() {
    closeBulkModal();
    const ids = [...selectedIds];
    for (const id of ids) {
        const card = document.querySelector(`.act-card[data-id="${id}"]`);
        if (!card) continue;
        const form = document.getElementById('form-budget-delete');
        form.action = card.dataset.urlDelete;
        document.getElementById('budget-delete-token').value = card.dataset.csrfDelete;
        const fd = new FormData(form);
        try {
            await fetch(form.action, { method: 'POST', body: fd });
        } catch(e) {}
        card.remove();
    }
    toggleSelectMode(false);
    window.location.reload();
}

function confirmDeleteOne(btn) {
    const card = btn.closest('.act-card');
    confirmDeleteOneByCard(card);
}

function confirmDeleteOneByCard(card) {
    if (!card) return;
    if (!confirm(`Supprimer le budget "${card.dataset.libelle}" et toutes ses dépenses ?`)) return;
    const form = document.getElementById('form-budget-delete');
    form.action = card.dataset.urlDelete;
    document.getElementById('budget-delete-token').value = card.dataset.csrfDelete;
    form.submit();
}

// ============================================================
// INITIALIZATION
// ============================================================
document.addEventListener('DOMContentLoaded', () => {
    refreshCards();
    populateVoyageSelect();    // Liste déroulante pour les voyages
    populateDeviseFilters();   // Chips pour les devises
    initStatutFilters();       // Chips pour les statuts
    initSearch();
    initSort();
    initResetButton();
    applyAllFilters();
});
</script>
{% endblock %}