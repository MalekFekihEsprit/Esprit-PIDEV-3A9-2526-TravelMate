{% extends 'base.html.twig' %}

{% block title %}Réservation - {{ activite.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .reservation-container {
            max-width: 600px;
            margin: 2rem auto;
            padding: 2rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 8px 32px rgba(71,48,35,0.08);
        }
        
        .reservation-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .reservation-title {
            font-family: 'Fraunces', serif;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--color-text);
            margin-bottom: 0.5rem;
        }
        
        .reservation-subtitle {
            color: var(--color-text-muted);
            font-size: 1rem;
        }
        
        .pricing-summary {
            background: linear-gradient(135deg, var(--color-primary-soft), var(--color-secondary-soft));
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(196,111,75,0.2);
        }
        
        .pricing-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
            color: var(--color-text);
        }
        
        .pricing-row:last-child {
            margin-bottom: 0;
            padding-top: 0.75rem;
            border-top: 1px solid rgba(196,111,75,0.3);
            font-weight: 600;
            font-size: 1.1rem;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--color-text-muted);
            margin-bottom: 0.5rem;
        }
        
        .form-control {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            background: var(--color-surface);
            font: inherit;
            font-size: 0.95rem;
            color: var(--color-text);
            outline: none;
            transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
        }
        
        .form-control:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(196,111,75,0.08);
        }
        
        .form-check {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            padding: 1rem;
            background: var(--color-surface-soft);
            border-radius: var(--radius-md);
            border: 1px solid var(--color-border);
            cursor: pointer;
            transition: background var(--transition-fast), border-color var(--transition-fast);
        }
        
        .form-check:hover {
            background: var(--color-hover);
            border-color: rgba(196,111,75,0.3);
        }
        
        .form-check-input {
            width: 20px;
            height: 20px;
            accent-color: var(--color-primary);
        }
        
        .form-check-label {
            font-weight: 500;
            color: var(--color-text);
            cursor: pointer;
        }
        
        .btn-reservation {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 1rem 1.5rem;
            border-radius: 999px;
            background: var(--color-primary);
            color: #fff;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
        }
        
        .btn-reservation:hover {
            background: var(--color-primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(196,111,75,0.3);
        }
        
        .activity-info {
            background: var(--color-surface-soft);
            border-radius: var(--radius-md);
            padding: 1rem;
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--color-primary);
        }
        
        .activity-info h3 {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-primary);
            margin-bottom: 0.5rem;
        }
        
        .activity-info p {
            color: var(--color-text-muted);
            font-size: 0.9rem;
            margin: 0;
        }
        
        .invalid-feedback {
            display: block;
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="reservation-container">
    <div class="reservation-header">
        <h1 class="reservation-title">Réserver votre place</h1>
        <p class="reservation-subtitle">{{ activite.nom }}</p>
    </div>

    <div class="activity-info">
        <h3>{{ activite.nom }}</h3>
        <p>{{ activite.description|slice(0, 150) }}...</p>
    </div>

    <div class="pricing-summary">
        <div class="pricing-row">
            <span>Montant total</span>
            <span>{{ montantTotal }} DT</span>
        </div>
        <div class="pricing-row">
            <span>Acompte requis (30%)</span>
            <span>{{ acompte|number_format(2, '.', ',') }} DT</span>
        </div>
        <div class="pricing-row">
            <span>À payer maintenant</span>
            <span>{{ acompte|number_format(2, ',') }} DT</span>
        </div>
    </div>

    {{ form_start(form) }}
        
        <div class="form-group">
            {{ form_label(form.nom) }}
            {{ form_widget(form.nom) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group">
            {{ form_label(form.prenom) }}
            {{ form_widget(form.prenom) }}
            {{ form_errors(form.prenom) }}
        </div>

        <div class="form-group">
            {{ form_label(form.telephone) }}
            {{ form_widget(form.telephone) }}
            {{ form_errors(form.telephone) }}
        </div>

        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group">
            {{ form_label(form.commentaire) }}
            {{ form_widget(form.commentaire) }}
            {{ form_errors(form.commentaire) }}
        </div>

        <div class="form-group">
            <label class="form-label">{{ form_label(form.methodeConfirmation) }}</label>
            {% for choice in form.methodeConfirmation %}
                <div class="form-check">
                    {{ form_widget(choice) }}
                    <label class="form-check-label" for="{{ choice.vars.id }}">
                        {% if choice.vars.value == 'email' %}
                             Par email (recevrez un QR code)
                        {% else %}
                             Par SMS (recevrez un code à 5 chiffres)
                        {% endif %}
                    </label>
                </div>
            {% endfor %}
            {{ form_errors(form.methodeConfirmation) }}
        </div>

        <button type="submit" class="btn-reservation">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Passer au paiement
        </button>

    {{ form_end(form) }}
</div>
{% endblock %}
