{% extends 'base.html.twig' %}

{% block title %}Confirmation - Réservation #{{ reservation.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .confirmation-container {
            max-width: 600px;
            margin: 2rem auto;
            padding: 2rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 8px 32px rgba(71,48,35,0.08);
        }
        
        .success-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            color: white;
            font-size: 2rem;
        }
        
        .success-title {
            font-family: 'Fraunces', serif;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--color-text);
            margin-bottom: 0.5rem;
        }
        
        .success-subtitle {
            color: var(--color-text-muted);
            font-size: 1rem;
        }
        
        .confirmation-details {
            background: var(--color-surface-soft);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 1px solid var(--color-border);
        }
        
        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--color-border);
        }
        
        .detail-row:last-child {
            border-bottom: none;
        }
        
        .detail-label {
            font-weight: 500;
            color: var(--color-text-muted);
            font-size: 0.9rem;
        }
        
        .detail-value {
            font-weight: 600;
            color: var(--color-text);
            text-align: right;
        }
        
        .method-info {
            background: linear-gradient(135deg, var(--color-primary-soft), var(--color-secondary-soft));
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(196,111,75,0.2);
        }
        
        .method-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
        
        .method-title {
            font-weight: 600;
            color: var(--color-text);
            margin-bottom: 0.5rem;
        }
        
        .method-desc {
            color: var(--color-text-muted);
            font-size: 0.9rem;
            line-height: 1.5;
        }
        
        .btn-confirm {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 1rem 1.5rem;
            border-radius: 999px;
            background: var(--color-primary);
            color: #fff;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
            text-decoration: none;
        }
        
        .btn-confirm:hover {
            background: var(--color-primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(196,111,75,0.3);
        }
        
        .qr-preview {
            text-align: center;
            margin: 1rem 0;
            padding: 1rem;
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--color-border);
        }
        
        .qr-preview img {
            max-width: 150px;
            height: auto;
        }
        
        .code-display {
            font-family: 'Courier New', monospace;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--color-primary);
            letter-spacing: 0.2em;
            background: var(--color-surface-soft);
            padding: 1rem;
            border-radius: var(--radius-md);
            text-align: center;
            margin: 1rem 0;
        }
        
        .next-steps {
            background: rgba(47,127,121,0.1);
            border: 1px solid rgba(47,127,121,0.2);
            border-radius: var(--radius-md);
            padding: 1rem;
            margin-top: 1.5rem;
        }
        
        .next-steps h4 {
            color: var(--color-secondary);
            margin-bottom: 0.5rem;
        }
        
        .next-steps ul {
            margin: 0;
            padding-left: 1.5rem;
            color: var(--color-text-muted);
            font-size: 0.9rem;
        }
        
        .next-steps li {
            margin-bottom: 0.25rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="confirmation-container">
    <div class="success-header">
        <div class="success-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h1 class="success-title">Paiement confirmé !</h1>
        <p class="success-subtitle">Votre réservation a été enregistrée avec succès</p>
    </div>

    <div class="confirmation-details">
        <div class="detail-row">
            <span class="detail-label">Numéro de réservation</span>
            <span class="detail-value">#{{ reservation.id }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Activité</span>
            <span class="detail-value">{{ reservation.activite.nom }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Nom</span>
            <span class="detail-value">{{ reservation.nomComplet }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Email</span>
            <span class="detail-value">{{ reservation.email }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Téléphone</span>
            <span class="detail-value">{{ reservation.telephone }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Montant payé</span>
            <span class="detail-value">{{ reservation.acompte|number_format(2, '.', ',') }} DT</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Date de réservation</span>
            <span class="detail-value">{{ reservation.dateReservation|date('d/m/Y H:i') }}</span>
        </div>
    </div>

    <div class="method-info">
        <div class="method-icon">
            {% if reservation.methodeConfirmation == 'email' %}
                📧
            {% else %}
                📱
            {% endif %}
        </div>
        <h3 class="method-title">
            {% if reservation.methodeConfirmation == 'email' %}
                Confirmation par Email
            {% else %}
                Confirmation par SMS
            {% endif %}
        </h3>
        <div class="method-desc">
            {% if reservation.methodeConfirmation == 'email' %}
                <p>Vous recevrez un email contenant :</p>
                <ul>
                    <li>Les détails de votre réservation</li>
                    <li>Un QR code unique à présenter le jour de l'activité</li>
                    <li>Les informations de contact de l'organisateur</li>
                </ul>
                
                <div class="qr-preview">
                        <p style="margin-bottom: 0.5rem; font-weight: 600;">Votre QR code unique :</p>
                        <a href="{{ path('app_qr_display', {id: reservation.id}) }}" target="_blank" style="display: inline-block; padding: 0.5rem 1rem; background: var(--color-primary); color: white; text-decoration: none; border-radius: var(--radius-md); font-weight: 600;">
                            Voir mon QR code
                        </a>
                        <p style="margin-top: 0.5rem; font-size: 0.85rem; color: var(--color-text-muted);">
                            Cliquez pour générer et voir votre QR code de confirmation
                        </p>
                    </div>
            {% else %}
                <p>Vous recevrez un SMS contenant :</p>
                <ul>
                    <li>Un résumé de votre réservation</li>
                    <li>Un code de confirmation à 5 chiffres</li>
                    <li>Les instructions pour le jour de l'activité</li>
                </ul>
                
                <div class="code-display">
                    {{ reservation.codeConfirmation }}
                </div>
                <p style="text-align: center; font-size: 0.85rem; color: var(--color-text-muted); margin-top: 0.5rem;">
                    Gardez ce code précieusement !
                </p>
            {% endif %}
        </div>
    </div>

    <form method="post" action="{{ path('app_reservation_confirmation', {id: reservation.id}) }}">
        <button type="submit" class="btn-confirm">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Envoyer la confirmation
        </button>
    </form>

    <div class="next-steps">
        <h4>Prochaines étapes</h4>
        <ul>
            <li>Recevez votre confirmation par {{ reservation.methodeConfirmation == 'email' ? 'email' : 'SMS' }}</li>
            <li>Présentez votre {{ reservation.methodeConfirmation == 'email' ? 'QR code' : 'code de confirmation' }} le jour de l'activité</li>
            <li>Profitez de votre aventure avec TravelMate !</li>
        </ul>
    </div>
</div>
{% endblock %}
