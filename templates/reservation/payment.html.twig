{% extends 'base.html.twig' %}

{% block title %}Paiement - Réservation #{{ reservation.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .payment-container {
            max-width: 600px;
            margin: 2rem auto;
            padding: 2rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-xl);
            box-shadow: 0 8px 32px rgba(71,48,35,0.08);
        }
        
        .payment-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .payment-title {
            font-family: 'Fraunces', serif;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--color-text);
            margin-bottom: 0.5rem;
        }
        
        .payment-subtitle {
            color: var(--color-text-muted);
            font-size: 1rem;
        }
        
        .payment-summary {
            background: linear-gradient(135deg, var(--color-primary-soft), var(--color-secondary-soft));
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(196,111,75,0.2);
        }
        
        .payment-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
            color: var(--color-text);
        }
        
        .payment-row:last-child {
            margin-bottom: 0;
            padding-top: 0.75rem;
            border-top: 1px solid rgba(196,111,75,0.3);
            font-weight: 600;
            font-size: 1.2rem;
        }
        
        .payment-methods {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        
        .payment-method {
            padding: 1.5rem;
            border: 2px solid var(--color-border);
            border-radius: var(--radius-lg);
            background: var(--color-surface);
            cursor: pointer;
            transition: all var(--transition-fast);
            position: relative;
        }
        
        .payment-method:hover {
            border-color: var(--color-primary);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(196,111,75,0.15);
        }
        
        .payment-method.selected {
            border-color: var(--color-primary);
            background: rgba(196,111,75,0.05);
        }
        
        .payment-method-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }
        
        .payment-method-icon {
            width: 48px;
            height: 48px;
            background: var(--color-surface-soft);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
        
        .payment-method-title {
            font-weight: 600;
            color: var(--color-text);
            font-size: 1.1rem;
        }
        
        .payment-method-desc {
            color: var(--color-text-muted);
            font-size: 0.9rem;
        }
        
        .payment-method-radio {
            position: absolute;
            top: 1rem;
            right: 1rem;
            width: 20px;
            height: 20px;
            accent-color: var(--color-primary);
        }
        
        .btn-pay {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 1rem 1.5rem;
            border-radius: 999px;
            background: var(--color-primary);
            color: #fff;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
        }
        
        .btn-pay:hover {
            background: var(--color-primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(196,111,75,0.3);
        }
        
        .btn-pay:disabled {
            background: var(--color-surface-soft);
            color: var(--color-text-muted);
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        
        .loading-spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 2px solid #fff;
            border-top: 2px solid transparent;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        .btn-pay.loading .loading-spinner {
            display: inline-block;
        }
        
        .reservation-info {
            background: var(--color-surface-soft);
            border-radius: var(--radius-md);
            padding: 1rem;
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--color-primary);
        }
        
        .reservation-info h3 {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-primary);
            margin-bottom: 0.5rem;
        }
        
        .reservation-info p {
            color: var(--color-text-muted);
            font-size: 0.9rem;
            margin: 0;
        }
        
        .security-notice {
            background: rgba(47,127,121,0.1);
            border: 1px solid rgba(47,127,121,0.2);
            border-radius: var(--radius-md);
            padding: 1rem;
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: var(--color-secondary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="payment-container">
    <div class="payment-header">
        <h1 class="payment-title">Finaliser votre paiement</h1>
        <p class="payment-subtitle">Réservation #{{ reservation.id }}</p>
    </div>

    <div class="reservation-info">
        <h3>{{ reservation.activite.nom }}</h3>
        <p>Réservé pour : {{ reservation.nomComplet }}</p>
        <p>Méthode de confirmation : {{ reservation.methodeConfirmation == 'email' ? '📧 Email' : '📱 SMS' }}</p>
    </div>

    <div class="payment-summary">
        <div class="payment-row">
            <span>Montant total</span>
            <span>{{ reservation.montantTotal }} DT</span>
        </div>
        <div class="payment-row">
            <span>Acompte requis (30%)</span>
            <span>{{ reservation.acompte|number_format(2, '.', ',') }} DT</span>
        </div>
        <div class="payment-row">
            <span>À payer maintenant</span>
            <span>{{ reservation.acompte|number_format(2, '.', ',') }} DT</span>
        </div>
    </div>

    <form id="payment-form">
        <div class="payment-methods">
            <div class="payment-method selected" data-method="paypal">
                <input type="radio" name="payment_method" value="paypal" class="payment-method-radio" checked>
                <div class="payment-method-header">
                    <div class="payment-method-icon">💳</div>
                    <div>
                        <div class="payment-method-title">PayPal</div>
                        <div class="payment-method-desc">Paiement sécurisé via PayPal</div>
                    </div>
                </div>
            </div>
            
            <div class="payment-method" data-method="card">
                <input type="radio" name="payment_method" value="card" class="payment-method-radio">
                <div class="payment-method-header">
                    <div class="payment-method-icon">💳</div>
                    <div>
                        <div class="payment-method-title">Carte bancaire</div>
                        <div class="payment-method-desc">Visa, Mastercard, etc.</div>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-pay" id="pay-button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 10h20M7 15h.01M17 15h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <span>Payer {{ reservation.acompte|number_format(2, '.', ',') }} DT</span>
            <div class="loading-spinner"></div>
        </button>
    </form>

    <div class="security-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Paiement 100% sécurisé. Vos informations bancaires sont protégées.</span>
    </div>
</div>

<script src="https://www.paypal.com/sdk/js?client-id={{ paypalClientId }}&currency=TND&intent=capture"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const paymentMethods = document.querySelectorAll('.payment-method');
    const payButton = document.getElementById('pay-button');
    const paymentForm = document.getElementById('payment-form');
    
    // Gestion du changement de méthode de paiement
    paymentMethods.forEach(method => {
        method.addEventListener('click', function() {
            paymentMethods.forEach(m => m.classList.remove('selected'));
            this.classList.add('selected');
            const radio = this.querySelector('.payment-method-radio');
            radio.checked = true;
        });
    });
    
    // Traitement du paiement
    paymentForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const selectedMethod = document.querySelector('input[name="payment_method"]:checked').value;
        
        if (selectedMethod === 'paypal') {
            processPayPalPayment();
        } else {
            // Simuler paiement par carte
            processCardPayment();
        }
    });
    
    function processPayPalPayment() {
        payButton.classList.add('loading');
        payButton.disabled = true;
        
        if (typeof paypal !== 'undefined') {
            paypal.Buttons({
                createOrder: function(data, actions) {
                    return actions.order.create({
                        purchase_units: [{
                            amount: {
                                value: '{{ reservation.acompte|number_format(2, '.', '') }}'
                            }
                        }]
                    });
                },
                onApprove: function(data, actions) {
                    return actions.order.capture().then(function(details) {
                        // Envoyer les données au serveur
                        fetch('{{ path("app_reservation_payment_process", {id: reservation.id}) }}', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                paymentId: details.id,
                                status: 'completed',
                                details: details
                            })
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                window.location.href = data.redirect;
                            } else {
                                alert('Erreur lors du paiement. Veuillez réessayer.');
                                payButton.classList.remove('loading');
                                payButton.disabled = false;
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            alert('Erreur technique. Veuillez réessayer.');
                            payButton.classList.remove('loading');
                            payButton.disabled = false;
                        });
                    });
                },
                onError: function(err) {
                    console.error('PayPal error:', err);
                    alert('Erreur PayPal. Veuillez réessayer.');
                    payButton.classList.remove('loading');
                    payButton.disabled = false;
                }
            }).render('body').then(function() {
                // Cacher le bouton PayPal par défaut et cliquer programmatiquement
                setTimeout(() => {
                    const paypalButton = document.querySelector('[data-testid="paypal-button"]');
                    if (paypalButton) {
                        paypalButton.click();
                    } else {
                        // Fallback pour le développement
                        simulatePayment();
                    }
                }, 1000);
            });
        } else {
            // Fallback pour le développement
            simulatePayment();
        }
    }
    
    function processCardPayment() {
        // Simuler paiement par carte
        simulatePayment();
    }
    
    function simulatePayment() {
        payButton.classList.add('loading');
        payButton.disabled = true;
        
        // Simuler un délai de traitement
        setTimeout(() => {
            fetch('{{ path("app_reservation_payment_process", {id: reservation.id}) }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    paymentId: 'SIM_' + Date.now(),
                    status: 'completed',
                    details: { method: 'simulation' }
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.href = data.redirect;
                } else {
                    alert('Erreur lors du paiement. Veuillez réessayer.');
                    payButton.classList.remove('loading');
                    payButton.disabled = false;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Erreur technique. Veuillez réessayer.');
                payButton.classList.remove('loading');
                payButton.disabled = false;
            });
        }, 2000);
    }
});
</script>
{% endblock %}
